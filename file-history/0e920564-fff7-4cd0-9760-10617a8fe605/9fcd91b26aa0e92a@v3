// ============ 工具函数 ============
function rsaEncrypt(text) {
    return crypto.publicEncrypt(
        { key: PUBLIC_KEY, padding: crypto.constants.RSA_PKCS1_PADDING },
        Buffer.from(text, 'utf8')
    ).toString('base64')
}

function post(url, data, cookies = '') {
    return new Promise((resolve, reject) => {
        const parsed = new URL(url)
        const body = JSON.stringify(data)
        const options = {
            hostname: parsed.hostname,
            port: parsed.port || 80,
            path: parsed.pathname,
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Content-Length': Buffer.byteLength(body),
                ...(cookies ? { Cookie: cookies } : {}),
            },
        }
        const req = http.request(options, res => {
            let raw = ''
            res.on('data', chunk => (raw += chunk))
            res.on('end', () => {
                const setCookies = res.headers['set-cookie'] || []
                try {
                    resolve({ body: JSON.parse(raw), setCookies, status: res.statusCode })
                } catch {
                    resolve({ body: { raw }, setCookies, status: res.statusCode })
                }
            })
        })
        req.on('error', reject)
        req.write(body)
        req.end()
    })
}

async function login(email, password) {
    const encryptedPwd = rsaEncrypt(JSON.stringify({ password, time: Math.floor(Date.now() / 1000) }))
    const res = await post(USER_API + 'sfhome/login', { email, password: encryptedPwd, sys_lang: 'zh_CN' })
    if (String(res.body.error_code) !== '0') throw new Error('登录失败: ' + JSON.stringify(res.body))
    return {
        cookies: res.setCookies.map(c => c.split(';')[0]).join('; '),
        userInfo: res.body.data.sfuser_info,
    }
}

// 并发控制
async function parallelLimit(tasks, limit) {
    const results = []
    let idx = 0
    const workers = Array(Math.min(limit, tasks.length)).fill(null).map(async () => {
        while (idx < tasks.length) {
            const i = idx++
            results[i] = await tasks[i]()
        }
    })
    await Promise.all(workers)
    return results
}

// 生成日期列表（最近 N 天，跳过周末）
function getWorkDays(days) {
    const dates = []
    const now = new Date()
    let d = new Date(now)
    while (dates.length < days) {
        d.setDate(d.getDate() - 1)
        const dow = d.getDay()
        if (dow !== 0 && dow !== 6) { // 跳过周末
            dates.push(d.toISOString().slice(0, 10))
        }
    }
    return dates
}

// 为一个用户生成 60 天的日报内容（有重复，真实感）
function generateReportsForUser(userIdx, dates) {
    const reports = []
    // 每个人偏好的模板范围不同（模拟不同岗位）
    const templateOffset = userIdx % REPORT_TEMPLATES.length
    const favoriteTemplates = [
        REPORT_TEMPLATES[templateOffset],
        REPORT_TEMPLATES[(templateOffset + 1) % REPORT_TEMPLATES.length],
        REPORT_TEMPLATES[(templateOffset + 2) % REPORT_TEMPLATES.length],
    ]

    let lastContent = ''
    let repeatCount = 0

    for (const date of dates) {
        // 10% 概率不提交（模拟真实缺交）
        if (Math.random() < 0.1) continue

        // 30% 概率和前一天内容一样（复制粘贴党）
        if (lastContent && Math.random() < 0.3 && repeatCount < 3) {
            reports.push({ date, content: lastContent })
            repeatCount++
            continue
        }

        // 选一个模板，稍作变化
        const tpl = favoriteTemplates[Math.floor(Math.random() * favoriteTemplates.length)]
        const content = tpl.replace('今日工作', `【${date}】工作内容`)
        lastContent = content
        repeatCount = 0
        reports.push({ date, content })
    }
    return reports
}

