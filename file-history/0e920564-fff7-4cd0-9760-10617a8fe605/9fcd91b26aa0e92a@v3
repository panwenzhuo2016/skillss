// ============ Phase 3: 模拟日报 ============
async function phase3CreateReports(cookies, users) {
    console.log('\n========== Phase 3: 模拟日报数据 ==========')
    console.log(`  ${users.length} 个用户 × ${REPORT_DAYS} 天（工作日）`)

    const workDays = getWorkDays(REPORT_DAYS)
    console.log(`  工作日范围: ${workDays[workDays.length - 1]} ~ ${workDays[0]}`)

    // 为每个用户生成日报
    let totalCreated = 0
    let totalFailed = 0

    // 逐用户处理（每个用户需要先登录）
    const userTasks = users.map((user, userIdx) => async () => {
        // 登录测试用户
        let userCookies
        try {
            const loginRes = await login(user.email, PASSWORD)
            userCookies = loginRes.cookies
        } catch (e) {
            // 测试用户可能没有密码，尝试用默认密码
            // 如果登录失败，跳过此用户
            if (userIdx < 3) console.log(`  [${user.nickname}] 登录失败: ${e.message}`)
            totalFailed += workDays.length
            return
        }

        // 生成并提交日报
        const reports = generateReportsForUser(userIdx, workDays)
        for (const report of reports) {
            try {
                const res = await post(USER_API + 'daily-report/new-daily-report', {
                    sfuser_id: user.id,
                    content: report.content,
                    cc_user: ['阳明'],
                    report_date: report.date,
                    is_late: 1, // 补交
                    status: 1,  // 已提交
                    hash_filter: { obj: '$this', columns: ['cc_user'] },
                    data: { nickname: user.nickname, cc: ['阳明'], superior: [] },
                    encrypt_config: {
                        res_type: 'sfuser',
                        obj: '$this',
                        non_encrypt_columns: ['cc_user', 'files', 'report_date', 'is_late', 'status', 'sys_lang', 'version_info'],
                    },
                    authorize_config: {
                        res_type: 'sfuser',
                        sfusers: ['阳明'],
                        users: [],
                        emails: [],
                        items: [user.id],
                        operations: ['response', 'send_email'],
                        expire_time: 3600 * 24 * 62,
                    },
                    sys_lang: 'zh_CN',
                    sys_site: 'CHN',
                    intact_columns: ['sfuser_id', 'content', 'cc_user', 'report_date', 'is_late', 'status',
                        'hash_filter', 'data', 'encrypt_config', 'authorize_config'],
                }, userCookies)

                if (String(res.body.error_code) === '0') {
                    totalCreated++
                } else {
                    totalFailed++
                }
            } catch {
                totalFailed++
            }
        }

        if ((userIdx + 1) % 50 === 0) {
            console.log(`  进度: ${userIdx + 1}/${users.length} 用户, 已创建 ${totalCreated} 条日报`)
        }
    })

    await parallelLimit(userTasks, CONCURRENCY)
    console.log(`Phase 3 完成: 创建 ${totalCreated} 条日报, 失败 ${totalFailed} 条`)
}

