                            </template>
                            <template v-else>
                                <div
                                    v-for="s in sessions"
                                    :key="s.id"
                                    :class="['session-item', { active: currentSessionId === s.id }]"
                                    @click="loadSession(s.id)"
                                >
                                    <i class="el-icon-chat-line-round session-icon" />
                                    <div class="session-info">
                                        <div class="session-title">{{ s.title || $t('aiChat.sessionUntitled') }}</div>
                                        <div class="session-time">{{ formatTime(s.updated_at) }}</div>
                                    </div>
                                </div>
                                <div v-if="!sessions.length" class="session-empty">{{ $t('aiChat.sessionEmpty') }}</div>
                            </template>
                        </div>
<!--                        <el-button size="mini" style="margin-top:8px;width:100%" @click="newSession">-->
<!--                            + 新建会话-->
<!--                        </el-button>-->
                    </div>
