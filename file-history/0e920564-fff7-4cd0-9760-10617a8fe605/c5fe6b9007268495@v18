<script lang="ts">
import { Vue, Component, Prop, Watch } from 'vue-property-decorator'
import { dailyReportAiApis, AiRole, AiPrompt, AiSession, AiMessage, ExtractSlotsResult } from '@/apis'
import { dailyReportApis } from '@/apis'
import AiRoleModal from './AiRoleModal.vue'
import AiSyncModal from './AiSyncModal.vue'
import AiPromptPopover from './AiPromptPopover.vue'
import { compressDailyContext } from './aiContextUtils'
import MarkdownIt from 'markdown-it'
import moment from 'moment'

const md = new MarkdownIt({ breaks: true, linkify: true })

@Component({
    name: 'AiChatPanel',
    components: { AiRoleModal, AiSyncModal, AiPromptPopover },
})
export default class extends Vue {
    // 从 OthersReports 传入的分组信息，用于同步日报（value 为该分组的花名数组）
    @Prop({ default: () => [] }) groupOptions!: { label: string; value: string[] }[]
    @Prop({ default: 'CHN' }) sysSite!: string

    panelVisible = false

    // 角色
    roles: AiRole[] = []
    currentRole: AiRole | null = null
    roleModalVisible = false
    editingRole: AiRole | null = null

    // 提示词
    prompts: AiPrompt[] = []

    // 会话 & 消息
    sessions: AiSession[] = []
    currentSessionId: number | null = null
    messages: { role: 'user' | 'assistant' | 'context'; content: string; _id?: number; _truncated?: boolean; _fullLength?: number; _fullContent?: string; _loading?: boolean }[] = []

    // loading 状态
    rolesLoading = false
    sessionsLoading = false
    messagesLoading = false

    // 聊天输入
    inputText = ''
    isStreaming = false
    reportContext = ''
    private streamAbort: AbortController | null = null

    // 意图识别状态
    private slotsConversationId = ''
    // 上一次成功提取的槽位结果，用于续查模式
    private lastSlotResult: ExtractSlotsResult | null = null

    // System Prompt 编辑
    editingSystemPrompt = ''

    renderMd(text: string): string {
        return md.render(text || '')
    }

    // gzip 压缩字符串，返回 "gz:<base64>"
    async compressContext(str: string): Promise<string> {
        if (!str) return str
        // 先去除多余空白，减少压缩前体积
        str = str.replace(/\n{3,}/g, '\n\n').trim()
        const stream = new (window as any).CompressionStream('gzip')
        const writer = stream.writable.getWriter()
        writer.write(new TextEncoder().encode(str))
        writer.close()
        const chunks: Uint8Array[] = []
        const reader = stream.readable.getReader()
        while (true) {
            const { done, value } = await reader.read()
            if (done) break
            chunks.push(value)
        }
        const merged = new Uint8Array(chunks.reduce((n, c) => n + c.length, 0))
        let offset = 0
        for (const c of chunks) { merged.set(c, offset); offset += c.length }
        let binary = ''
        for (let i = 0; i < merged.length; i++) binary += String.fromCharCode(merged[i])
        return 'gz:' + btoa(binary)
    }

    // 弹窗
    syncModalVisible = false

    @Watch('panelVisible')
    async onPanelOpen(val: boolean) {
        if (val) {
            await this.loadRoles()
            await this.loadPrompts()
            // 数据加载完后再滚一次，确保 v-if 面板 DOM 已渲染
            this.$nextTick(() => this.scrollToBottom())
        }
    }

    @Watch('currentRole')
    async onRoleChange(role: AiRole | null) {
        this.editingSystemPrompt = role?.system_prompt ?? ''
        this.sessions = []
        this.currentSessionId = null
        this.messages = []
        if (role) await this.loadSessions(true)
    }

    // ---- 角色 ----
    async loadRoles() {
        this.rolesLoading = true
        try {
            this.roles = await dailyReportAiApis.getRoleList()
            if (this.roles.length && !this.currentRole) {
                this.selectRole(this.roles[0])
            }
        } finally {
            this.rolesLoading = false
        }
    }

    selectRole(role: AiRole) {
        this.currentRole = role
    }

    openRoleModal(role: AiRole | null) {
        this.editingRole = role
        this.roleModalVisible = true
    }

    onRoleSaved(role: AiRole) {
        const idx = this.roles.findIndex(r => r.id === role.id)
        if (idx >= 0) {
            this.$set(this.roles, idx, role)
            if (this.currentRole?.id === role.id) {
                this.currentRole = role
                this.editingSystemPrompt = role.system_prompt
            }
        } else {
            this.roles.push(role)
            this.selectRole(role)
        }
    }

    async removeRole(id: number) {
        await this.$confirm(this.$t('aiChat.confirmDeleteRole') as string, this.$t('aiChat.confirmTitle') as string)
        await dailyReportAiApis.deleteRole(id)
        this.roles = this.roles.filter(r => r.id !== id)
        if (this.currentRole?.id === id) {
            this.currentRole = this.roles[0] ?? null
        }
    }

    async saveSystemPrompt() {
        if (!this.currentRole) return
        if (this.editingSystemPrompt === this.currentRole.system_prompt) return
        await dailyReportAiApis.updateRole({
            id: this.currentRole.id,
            system_prompt: this.editingSystemPrompt,
        })
        this.currentRole = { ...this.currentRole, system_prompt: this.editingSystemPrompt }
        const idx = this.roles.findIndex(r => r.id === this.currentRole!.id)
        if (idx >= 0) this.$set(this.roles, idx, this.currentRole)
    }

    // ---- 提示词 ----
    async loadPrompts() {
        this.prompts = await dailyReportAiApis.getPromptList()
    }

    insertPrompt(content: string) {
        this.inputText = this.inputText ? this.inputText + ' ' + content : content
    }

    removePrompt(id: number) {
        this.prompts = this.prompts.filter(p => p.id !== id)
    }

    // ---- 会话 ----
    async loadSessions(showLoading = false) {
        if (!this.currentRole) return
        if (showLoading) this.sessionsLoading = true
        try {
            this.sessions = await dailyReportAiApis.getSessionList(this.currentRole.id)
        } finally {
            this.sessionsLoading = false
        }
    }

    async loadSession(sessionId: number) {
        // 切换会话时中断正在进行的流式请求
        if (this.streamAbort) {
            this.streamAbort.abort()
            this.streamAbort = null
        }
        this.isStreaming = false
        this.currentSessionId = sessionId
        // 切换会话时重置意图识别状态，防止残留上一次的槽位结果
        this.slotsConversationId = ''
        this.lastSlotResult = null
        this.reportContext = ''
        this.pendingSlotMessages = []
        this.messagesLoading = true
        try {
            const msgs = await dailyReportAiApis.getSessionMessages(sessionId)
            this.messages = msgs.map(m => ({
                role: m.role,
                content: m.content,
                _id: m.id,
                _truncated: m.is_truncated || false,
                _fullLength: m.full_length || 0,
            }))
            this.$nextTick(() => {
                this.scrollToBottom()
                // markdown 渲染后高度可能变化，再滚一次
                setTimeout(() => this.scrollToBottom(), 100)
            })
        } finally {
            this.messagesLoading = false
        }
    }

    newSession() {
        this.currentSessionId = null
        this.messages = []
        this.slotsConversationId = ''
        this.lastSlotResult = null
        this.reportContext = ''
        this.pendingSlotMessages = []
    }

    // ---- 聊天 ----
    onKeydown(e: KeyboardEvent) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault()
            this.sendMessage()
        }
    }

    async sendMessage() {
        const text = this.inputText.trim()
        if (!text || !this.currentRole || this.isStreaming) return

        // 有手动同步的 reportContext 且没有过意图识别 → 直接问答
        // 否则走意图识别（首次或续查）
        if (this.reportContext && !this.lastSlotResult) {
            await this.sendAskMessage(text)
        } else {
            await this.sendExtractSlots(text)
        }
    }

    /**
     * 意图识别流程：提取槽位，槽位齐全后自动拉日报数据再调 ask
     */
    // 收集意图识别阶段待落库的消息
    private pendingSlotMessages: { role: string; content: string }[] = []

    /**
     * 将意图识别阶段的消息落库（创建或复用会话）
     */
    private async flushSlotMessages() {
        if (!this.pendingSlotMessages.length || !this.currentRole) return
        const sessionId = await dailyReportAiApis.saveMessages({
            role_id: this.currentRole.id,
            session_id: this.currentSessionId,
            messages: this.pendingSlotMessages,
        })
        if (sessionId && !this.currentSessionId) {
            this.currentSessionId = sessionId
            await this.loadSessions()
        }
        this.pendingSlotMessages = []
    }

    private async sendExtractSlots(text: string) {
        this.messages.push({ role: 'user', content: text })
        this.pendingSlotMessages.push({ role: 'user', content: text })
        this.inputText = ''
        this.$nextTick(this.scrollToBottom)

        const assistantIdx = this.messages.length
        this.messages.push({ role: 'assistant', content: '' })
        this.isStreaming = true

        try {
            // 收集可用分组名和所有成员花名
            const availableGroups = this.groupOptions.map(g => g.label)
            const availableMembers = [...new Set(this.groupOptions.flatMap(g => g.value))].filter(Boolean)
            // 续查模式：传入上次的槽位结果
            const previousContext = this.lastSlotResult ? {
                member_type: this.lastSlotResult.member_type,
                members: this.lastSlotResult.members,
                period_start: this.lastSlotResult.period_start,
                period_end: this.lastSlotResult.period_end,
            } : undefined
            const result = await dailyReportAiApis.extractSlots({
                message: text,
                conversation_id: this.slotsConversationId || undefined,
                available_groups: availableGroups,
                available_members: availableMembers,
                previous_context: previousContext,
            })

            if (!result) {
                this.messages[assistantIdx].content = this.$t('aiChat.errorMsg') as string
                this.pendingSlotMessages.push({ role: 'assistant', content: this.messages[assistantIdx].content })
                await this.flushSlotMessages()
                return
            }

            // 保存 conversation_id 用于多轮
            this.slotsConversationId = result.conversation_id

            if (!result.slots_complete) {
                // 槽位不完整，显示反问
                this.messages[assistantIdx].content = result.reply
                this.pendingSlotMessages.push({ role: 'assistant', content: result.reply })
                await this.flushSlotMessages()
                return
            }

            // 槽位完整，保存结果用于续查
            this.lastSlotResult = result
            // 回显意图识别结果
            const nicknames = this.resolveMembers(result)
            const memberLabel = result.member_type === 'group'
                ? `分组：${result.members.join('、')}`
                : `成员：${result.members.join('、')}`
            const countLabel = nicknames.length >= 10 ? `，共 ${nicknames.length} 人` : ''
            const periodLabel = `${result.period_start} ~ ${result.period_end}`
            const slotSummary = `查询对象：${memberLabel}${countLabel}\n时间范围：${periodLabel}${result.period_raw ? `（${result.period_raw}）` : ''}`
            this.messages[assistantIdx].content = slotSummary + '\n\n正在同步日报数据...'
            this.pendingSlotMessages.push({ role: 'assistant', content: slotSummary })
            this.$nextTick(this.scrollToBottom)

            if (!nicknames.length) {
                const errMsg = `未找到匹配的成员「${result.members.join('、')}」，请尝试使用花名或先手动同步数据。`
                this.messages[assistantIdx].content = errMsg
                this.pendingSlotMessages.push({ role: 'assistant', content: errMsg })
                await this.flushSlotMessages()
                return
            }

            const context = await this.fetchReportContext(nicknames, result.period_start, result.period_end)
            if (!context) {
                this.messages[assistantIdx].content = '该时间段内没有找到日报数据。'
                this.pendingSlotMessages.push({ role: 'assistant', content: '该时间段内没有找到日报数据。' })
                await this.flushSlotMessages()
                return
            }

            // 重置意图识别状态
            this.slotsConversationId = ''

            // 意图识别消息先落库（会创建 session）
            await this.flushSlotMessages()

            // 保留意图识别结果消息，走正常 ask 流程
            this.reportContext = context
            // 意图已由 extract-slots 处理，ask 只需分析同步好的日报数据
            await this.sendAskMessage('请根据以上日报数据进行分析')
        } catch (e: any) {
            this.messages[assistantIdx].content = this.$t('aiChat.errorMsg') as string
            this.pendingSlotMessages.push({ role: 'assistant', content: this.messages[assistantIdx].content })
            await this.flushSlotMessages()
        } finally {
            this.isStreaming = false
        }
    }

    /**
     * 根据槽位结果解析出 nicknames 列表
     */
    private resolveMembers(result: ExtractSlotsResult): string[] {
        if (result.member_type === 'group') {
            // 匹配 groupOptions 的 label，展开为花名列表
            const matched = this.groupOptions.filter(g =>
                result.members.some(m => g.label.includes(m) || m.includes(g.label))
            )
            return [...new Set(matched.flatMap(g => g.value))].filter(Boolean)
        }
        // individual：LLM 返回的成员名必须在花名列表中匹配到，匹配不到则丢弃
        const allMembers = this.groupOptions.flatMap(g => g.value).filter(Boolean)
        return result.members
            .map(name => allMembers.find(m => m.includes(name) || name.includes(m)))
            .filter((n): n is string => !!n)
    }

    /**
     * 根据 nicknames + 日期范围拉取日报数据，返回聚合后的文本上下文
     */
    private async fetchReportContext(nicknames: string[], startDate: string, endDate: string): Promise<string> {
        const days = moment(endDate).diff(moment(startDate), 'day') + 1
        const perPage = Math.max(200, days + 10)

        const results = await Promise.all(
            nicknames.map(nickname =>
                dailyReportApis.getOtherReportsAPI({
                    start_date: startDate,
                    end_date: endDate,
                    nickname,
                    per_page: perPage,
                    page: 1,
                    show_rest: 1,
                    sys_site: this.sysSite,
                } as any)
            )
        )

        const dateMap: Record<string, string[]> = {}
        results.forEach((res, idx) => {
            if (!res) return
            const name = nicknames[idx].replace(/\[.+]/, '')
            ;(res.reports ?? []).forEach((item: any) => {
                const date = item.date ?? ''
                if (!dateMap[date]) dateMap[date] = []
                if (item.report) {
                    dateMap[date].push(`${name}：\n${item.report.content ?? ''}`)
                } else if ([4, 5].includes(item.type_id)) {
                    dateMap[date].push(`${name}：休息日`)
                } else {
                    dateMap[date].push(`${name}：未提交`)
                }
            })
        })

        const sortedDates = Object.keys(dateMap).sort((a, b) => b.localeCompare(a))
        return sortedDates
            .map(date => `【${date}】\n${dateMap[date].join('\n\n')}`)
            .join('\n\n---\n\n')
    }

    /**
     * 正常问答流程：带 reportContext 调 askAi（SSE 流式）
     */
    private async sendAskMessage(text: string) {
        const contextToSend = this.reportContext
        if (contextToSend) {
            const contextLimit = 5000
            const isTruncated = contextToSend.length > contextLimit
            this.messages.push({
                role: 'context',
                content: isTruncated ? contextToSend.slice(0, contextLimit) : contextToSend,
                _truncated: isTruncated,
                _fullLength: contextToSend.length,
                _fullContent: isTruncated ? contextToSend : undefined,
            })
            this.reportContext = ''
        }
        this.messages.push({ role: 'user', content: text })
        this.inputText = ''
        this.$nextTick(this.scrollToBottom)

        const assistantIdx = this.messages.length
        this.messages.push({ role: 'assistant', content: '' })
        this.isStreaming = true

        this.streamAbort = new AbortController()
        try {
            const history = this.messages.slice(0, -2).filter(m => m.role !== 'context' && !!m.content).slice(-10) as { role: 'user' | 'assistant'; content: string }[]
            const processedContext = contextToSend ? compressDailyContext(contextToSend) : ''
            if (processedContext) {
                console.log('[AiChat] 压缩前上下文:\n', processedContext)
            }
            const compressedContext = processedContext ? await this.compressContext(processedContext) : ''
            const response = await dailyReportAiApis.askAi({
                role_id: this.currentRole!.id,
                session_id: this.currentSessionId,
                message: text,
                report_context: compressedContext,
                report_context_raw: contextToSend ? await this.compressContext(contextToSend) : undefined,
                history,
            }, this.streamAbort.signal)

            const reader = response.body!.getReader()
            const decoder = new TextDecoder()
            let buffer = ''

            while (true) {
                const { done, value } = await reader.read()
                if (done) break
                buffer += decoder.decode(value, { stream: true })
                const lines = buffer.split('\n')
                buffer = lines.pop() ?? ''

                for (const line of lines) {
                    if (!line.startsWith('data: ')) continue
                    try {
                        const parsed = JSON.parse(line.slice(6))
                        if (parsed.error_code !== 0) {
                            this.messages[assistantIdx].content = this.$t('aiChat.errorMsg') as string
                            break
                        }
                        const data = parsed.data
                        if (data.type === 'session_id') {
                            if (!this.currentSessionId) {
                                this.currentSessionId = Number(data.session_id)
                                await this.loadSessions()
                            }
                        } else if (data.type === 'chat' && data.content) {
                            this.messages[assistantIdx].content += data.content
                            this.$nextTick(this.scrollToBottom)
                        }
                    } catch (_) {}
                }
            }
        } catch (e: any) {
            if (e?.name !== 'AbortError') {
                this.messages[assistantIdx].content = this.$t('aiChat.errorMsg') as string
            }
        } finally {
            if (!this.messages[assistantIdx]?.content && this.streamAbort && !this.streamAbort.signal.aborted) {
                this.messages[assistantIdx].content = this.$t('aiChat.errorMsg') as string
            }
            this.streamAbort = null
            this.isStreaming = false
            // 错误消息落库：后端可能未保存（网络中断、前端超时等），前端兜底
            const finalContent = this.messages[assistantIdx]?.content
            const errorMsg = this.$t('aiChat.errorMsg') as string
            if (finalContent === errorMsg && this.currentSessionId) {
                await dailyReportAiApis.saveMessages({
                    role_id: this.currentRole!.id,
                    session_id: this.currentSessionId,
                    messages: [{ role: 'assistant', content: finalContent }],
                })
            }
            await this.loadSessions()
        }
    }

    // 加载更多 context 内容
    async loadMoreContext(m: { content: string; _id?: number; _truncated?: boolean; _fullLength?: number; _fullContent?: string; _loading?: boolean }) {
        if (!m._truncated || m._loading) return
        const chunkSize = 5000

        // 实时场景：完整内容在本地 _fullContent 中，直接截取
        if (m._fullContent) {
            const offset = m.content.length
            const nextChunk = m._fullContent.slice(offset, offset + chunkSize)
            m.content += nextChunk
            m._truncated = (offset + chunkSize) < m._fullContent.length
            if (!m._truncated) m._fullContent = undefined // 加载完毕，释放内存
            return
        }

        // 历史场景：从后端分段加载
        if (!m._id) return
        this.$set(m, '_loading', true)
        try {
            const offset = m.content.length
            const result = await dailyReportAiApis.getContextMore(m._id, offset)
            if (result) {
                m.content += result.content
                m._truncated = result.has_more
                m._fullLength = result.full_length
            }
        } finally {
            this.$set(m, '_loading', false)
        }
    }

    // 同步日报回调
    onSynced(context: string) {
        this.reportContext = context
    }

    scrollToBottom() {
        const el = this.$refs.msgList as HTMLElement
        if (el) el.scrollTop = el.scrollHeight
    }

    scrollToActiveSession() {
        this.$nextTick(() => {
            const list = this.$el.querySelector('.session-list')
            const active = this.$el.querySelector('.session-item.active')
            if (list && active) {
                (active as HTMLElement).scrollIntoView({ block: 'nearest' })
            }
        })
    }

    formatTime(str: string) {
        if (!str) return ''
        const d = new Date(str)
        const pad = (n: number) => String(n).padStart(2, '0')
        return `${d.getFullYear()}/${pad(d.getMonth() + 1)}/${pad(d.getDate())} ${pad(d.getHours())}:${pad(d.getMinutes())}`
    }
}
