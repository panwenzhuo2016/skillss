    # ===== 代码节点：解析 JSON =====
    - data:
        code: |
          import json
          import re

          def main(text: str) -> dict:
              # 兼容 LLM 输出 markdown 代码块包裹的情况
              match = re.search(r'\{[\s\S]*\}', text)
              if not match:
                  return {
                      "slots_complete": False,
                      "members": "[]",
                      "member_type": "",
                      "period_start": "",
                      "period_end": "",
                      "reply": "抱歉没理解你的意思，请告诉我你想查谁的日报，以及查哪个时间段？"
                  }

              try:
                  data = json.loads(match.group())
              except json.JSONDecodeError:
                  return {
                      "slots_complete": False,
                      "members": "[]",
                      "member_type": "",
                      "period_start": "",
                      "period_end": "",
                      "reply": "抱歉没理解你的意思，请告诉我你想查谁的日报，以及查哪个时间段？"
                  }

              return {
                  "slots_complete": bool(data.get("slots_complete", False)),
                  "members": json.dumps(data.get("members", []), ensure_ascii=False),
                  "member_type": str(data.get("member_type", "")),
                  "period_start": str(data.get("period_start", "")),
                  "period_end": str(data.get("period_end", "")),
                  "reply": str(data.get("reply", ""))
              }
        code_language: python3
        outputs:
          slots_complete:
            children: null
            type: boolean
          members:
            children: null
            type: string
          member_type:
            children: null
            type: string
          period_start:
            children: null
            type: string
          period_end:
            children: null
            type: string
          reply:
            children: null
            type: string
