<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- 清理 control_role 表中的重复记录，保留每组 (control_id, unit_id) 中 id 最小的记录 -->
    <changeSet id="006-1-cleanup-duplicate-control-roles" author="luobeilin">
        <comment>删除 collabspace_control_role 表中 (control_id, unit_id) 重复的记录，保留 id 最小的一条</comment>
        <sql>
            DELETE cr FROM collabspace_control_role cr
            INNER JOIN (
                SELECT control_id, unit_id, MIN(id) AS keep_id
                FROM collabspace_control_role
                GROUP BY control_id, unit_id
                HAVING COUNT(*) > 1
            ) dup ON cr.control_id = dup.control_id
                 AND cr.unit_id = dup.unit_id
                 AND cr.id != dup.keep_id;
        </sql>
    </changeSet>

    <!-- 添加唯一索引，防止再次产生重复 -->
    <changeSet id="006-2-add-unique-index-control-role" author="luobeilin">
        <comment>为 collabspace_control_role 表添加 (control_id, unit_id) 唯一索引</comment>
        <sql>
            CREATE UNIQUE INDEX uk_control_role_control_unit ON collabspace_control_role (control_id, unit_id);
        </sql>
    </changeSet>

</databaseChangeLog>
