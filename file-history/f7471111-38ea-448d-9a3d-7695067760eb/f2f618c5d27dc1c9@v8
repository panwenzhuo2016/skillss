// ========== 补充：editRole 冲突校验专项 ==========

async function testEditRoleConflictDetection() {
  console.log('\n⚠️ 补充. editRole 冲突校验');

  // 冲突检测仅在操作对象为成员时触发
  // 先给小组设置一个较高权限（如 editor），然后给该小组下的成员设置较低权限（reader），应返回冲突

  // 查看 listTeamRoles 找一个有成员的小组
  const teams = await GET(`/${CONFIG.spaceNodeId}/listTeamRoles?pageNo=1&pageSize=100`);
  if (!teams.data?.records?.length) {
    console.log('  ⚠️  无小组数据，跳过冲突校验');
    return;
  }

  // 找一个有 unitId（已设置权限）且 role 不为 null 的小组
  const teamWithRole = teams.data.records.find(r => r.unitId && r.role);
  if (!teamWithRole) {
    console.log('  ⚠️  无已设置权限的小组，跳过冲突校验');
    return;
  }

  console.log(`  ℹ️  冲突测试用小组: ${teamWithRole.teamName} (unitId=${teamWithRole.unitId}, role=${teamWithRole.role})`);

  if (!CONFIG.ttt2UnitId) {
    console.log('  ⚠️  ttt2 unitId 未知，跳过冲突检测');
    return;
  }

  // 给小组设置 editor（如果不是的话）
  if (teamWithRole.role !== 'editor') {
    await POST('/editRole', {
      spaceNodeId: CONFIG.spaceNodeId,
      unitId: teamWithRole.unitId,
      role: 'editor',
    });
  }

  // 给 ttt2（该小组下成员）设置 reader → 应触发冲突
  await POST('/deleteRole', { spaceNodeId: CONFIG.spaceNodeId, unitId: CONFIG.ttt2UnitId });
  await POST('/addRole', { spaceNodeId: CONFIG.spaceNodeId, unitIds: [CONFIG.ttt2UnitId], role: 'editor' });

  const conflictRes = await POST('/editRole', {
    spaceNodeId: CONFIG.spaceNodeId,
    unitId: CONFIG.ttt2UnitId,
    role: 'reader',
  });
  assert('editRole 返回 success（冲突仍执行）', conflictRes.success === true, conflictRes);
  // 冲突取决于成员是否真的属于有更高权限的小组
  console.log(`  ℹ️  hasConflict=${conflictRes.data?.hasConflict}, message=${conflictRes.data?.conflictMessage || 'null'}`);

  if (conflictRes.data?.hasConflict) {
    assert('冲突时含 conflictMessage', typeof conflictRes.data.conflictMessage === 'string');
    assert('冲突时含 conflictTeamName', typeof conflictRes.data.conflictTeamName === 'string');
    assert('冲突时含 conflictTeamRole', typeof conflictRes.data.conflictTeamRole === 'string');
  }

  // 给小组的 unitId 调用 editRole → hasConflict 应始终为 false
  const teamEditRes = await POST('/editRole', {
    spaceNodeId: CONFIG.spaceNodeId,
    unitId: String(teamWithRole.unitId),
    role: 'reader',
  });
  assert('小组 editRole hasConflict 始终为 false',
    teamEditRes.data?.hasConflict === false, teamEditRes.data?.hasConflict);

  // 还原
  await POST('/editRole', {
    spaceNodeId: CONFIG.spaceNodeId,
    unitId: String(teamWithRole.unitId),
    role: teamWithRole.role,
  });
  if (CONFIG.ttt2UnitId) {
    await POST('/deleteRole', { spaceNodeId: CONFIG.spaceNodeId, unitId: CONFIG.ttt2UnitId });
  }
  console.log('  ℹ️  已还原');
}

