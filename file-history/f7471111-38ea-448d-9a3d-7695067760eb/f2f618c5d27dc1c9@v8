async function testBatchOperations() {
  console.log('\n📦 11. 批量接口');

  if (!CONFIG.ttt2UnitId) { console.log('  ⚠️  ttt2 unitId 未知，跳过'); return; }
  const unitId = CONFIG.ttt2UnitId;

  // 准备：确保 ttt2 和 翁斯坦 都有权限
  await POST('/deleteRole', { spaceNodeId: CONFIG.spaceNodeId, unitId });
  await POST('/addRole', { spaceNodeId: CONFIG.spaceNodeId, unitIds: [unitId], role: 'reader' });

  // batchEditRole：同时修改 ttt2 为 editor
  const batchEditRes = await POST('/batchEditRole', {
    spaceNodeId: CONFIG.spaceNodeId,
    unitIds: [unitId],
    role: 'editor',
  });
  assert('batchEditRole 返回 success', batchEditRes.success === true, batchEditRes);
  assert('batchEditRole 含 hasConflict', typeof batchEditRes.data?.hasConflict === 'boolean', batchEditRes.data);

  // 验证生效
  const afterBatchEdit = await GET(`/${CONFIG.spaceNodeId}/listMemberRoles?pageNo=1&pageSize=100`);
  const ttt2After = afterBatchEdit.data?.records?.find(r => String(r.unitId) === String(unitId));
  assert('batchEditRole 后角色为 editor', ttt2After?.role === 'editor', ttt2After?.role);

  // batchDeleteRole
  const logsBefore = await GET(`/${CONFIG.spaceNodeId}/permissionLogs?pageNo=1&pageSize=1`);
  const totalBefore = logsBefore.data?.total || 0;

  const batchDelRes = await POST('/batchDeleteRole', {
    spaceNodeId: CONFIG.spaceNodeId,
    unitIds: [unitId],
  });
  assert('batchDeleteRole 返回 success', batchDelRes.success === true, batchDelRes);

  // 验证已移除
  const afterBatchDel = await GET(`/${CONFIG.spaceNodeId}/listMemberRoles?pageNo=1&pageSize=100`);
  const ttt2Deleted = afterBatchDel.data?.records?.find(r => String(r.unitId) === String(unitId));
  assert('batchDeleteRole 后成员已移除', ttt2Deleted == null, ttt2Deleted);

  // 验证日志
  const logsAfter = await GET(`/${CONFIG.spaceNodeId}/permissionLogs?pageNo=1&pageSize=1`);
  assert('batchDeleteRole 产生了日志', (logsAfter.data?.total || 0) > totalBefore);
}

// ========== 维度 12：数据重复检测 ==========

async function testDuplicateDataBug() {
  console.log('\n🐛 12. 数据重复检测');

  if (!CONFIG.ttt2UnitId) { console.log('  ⚠️  ttt2 unitId 未知，跳过'); return; }
  const unitId = CONFIG.ttt2UnitId;

  // 清理
  await POST('/deleteRole', { spaceNodeId: CONFIG.spaceNodeId, unitId });

  // 第一次 addRole
  await POST('/addRole', { spaceNodeId: CONFIG.spaceNodeId, unitIds: [unitId], role: 'reader' });

  const after1 = await GET(`/${CONFIG.spaceNodeId}/listMemberRoles?pageNo=1&pageSize=100`);
  const count1 = after1.data?.records?.filter(r => String(r.unitId) === String(unitId)).length;
  assert('第1次 addRole 后只出现1次', count1 === 1, count1);

  // 第二次 addRole（重复添加同一个 unitId，换角色）
  await POST('/addRole', { spaceNodeId: CONFIG.spaceNodeId, unitIds: [unitId], role: 'editor' });

  const after2 = await GET(`/${CONFIG.spaceNodeId}/listMemberRoles?pageNo=1&pageSize=100`);
  const count2 = after2.data?.records?.filter(r => String(r.unitId) === String(unitId)).length;
  assert('重复 addRole 后仍只出现1次（不应有重复记录）', count2 === 1, count2);

  // editRole 再改一次
  await POST('/editRole', { spaceNodeId: CONFIG.spaceNodeId, unitId, role: 'manager' });

  const after3 = await GET(`/${CONFIG.spaceNodeId}/listMemberRoles?pageNo=1&pageSize=100`);
  const count3 = after3.data?.records?.filter(r => String(r.unitId) === String(unitId)).length;
  assert('editRole 后仍只出现1次', count3 === 1, count3);

  // 验证角色值是最后一次设置的
  const final = after3.data?.records?.find(r => String(r.unitId) === String(unitId));
  assert('最终角色为 manager', final?.role === 'manager', final?.role);

  // 清理
  await POST('/deleteRole', { spaceNodeId: CONFIG.spaceNodeId, unitId });
}

