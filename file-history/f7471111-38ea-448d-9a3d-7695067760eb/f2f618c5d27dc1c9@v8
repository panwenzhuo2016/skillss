// ========== 维度 2：分页边界 ==========

async function testPaginationBoundary() {
  console.log('\n📐 2. 分页边界');

  const endpoints = [
    { name: 'listTeamRoles', path: `/${CONFIG.spaceNodeId}/listTeamRoles` },
    { name: 'listMemberRoles', path: `/${CONFIG.spaceNodeId}/listMemberRoles` },
    { name: 'permissionLogs', path: `/${CONFIG.spaceNodeId}/permissionLogs` },
  ];

  for (const ep of endpoints) {
    // pageSize=1 最小值
    const p1 = await GET(`${ep.path}?pageNo=1&pageSize=1`);
    assert(`${ep.name} pageSize=1 返回成功`, p1.success === true);
    assert(`${ep.name} pageSize=1 最多返回1条`, p1.data?.records?.length <= 1);

    // pageSize=100 最大合法值
    const p100 = await GET(`${ep.path}?pageNo=1&pageSize=100`);
    assert(`${ep.name} pageSize=100 返回成功`, p100.success === true);

    // total 与 records 一致性（total <= 100 时）
    if (p100.data?.total != null && p100.data.total <= 100) {
      assert(`${ep.name} total<=100 时 length===total`,
        p100.data.records.length === p100.data.total,
        { total: p100.data.total, length: p100.data.records.length });
    }

    // 超出最后一页
    const overPage = await GET(`${ep.path}?pageNo=9999&pageSize=20`);
    assert(`${ep.name} 超页返回空列表`, overPage.data?.records?.length === 0);
    assert(`${ep.name} 超页 total 不变`, overPage.data?.total === p100.data?.total,
      { expected: p100.data?.total, actual: overPage.data?.total });

    // 两页不重复（listTeamRoles 用 teamId，其他用 unitId 或 createdAt）
    if (p1.data?.total > 1) {
      const p2 = await GET(`${ep.path}?pageNo=2&pageSize=1`);
      assert(`${ep.name} 第2页有数据`, p2.data?.records?.length > 0);
      if (ep.name === 'listTeamRoles') {
        assert(`${ep.name} 两页 teamId 不重复`,
          p1.data.records[0].teamId !== p2.data.records[0].teamId);
      } else if (ep.name === 'listMemberRoles') {
        assert(`${ep.name} 两页 unitId 不重复`,
          p1.data.records[0].unitId !== p2.data.records[0].unitId);
      }
    }

    // 不传分页参数用默认值
    const noPage = await GET(`${ep.path}`);
    assert(`${ep.name} 不传分页参数返回成功`, noPage.success === true);
    assert(`${ep.name} 默认 records 不超过 20`, noPage.data?.records?.length <= 20);
  }
}

// ========== 维度 3：搜索边界 ==========

async function testSearchBoundary() {
  console.log('\n🔎 3.1 listTeamRoles - 搜索');

  const all = await GET(`/${CONFIG.spaceNodeId}/listTeamRoles?pageNo=1&pageSize=100`);
  if (all.data?.records?.length > 0) {
    const realName = all.data.records[0].teamName;

    // 精确匹配
    const exact = await GET(`/${CONFIG.spaceNodeId}/listTeamRoles?keyword=${encodeURIComponent(realName)}&pageNo=1&pageSize=20`);
    assert(`精确搜索"${realName}"有结果`, exact.data?.records?.length > 0);
    const allMatch = exact.data.records.every(r => r.teamName.toLowerCase().includes(realName.toLowerCase()));
    assert('搜索结果 teamName 都包含关键词', allMatch);

    // 部分匹配
    if (realName.length > 2) {
      const partial = realName.substring(0, 2);
      const partialRes = await GET(`/${CONFIG.spaceNodeId}/listTeamRoles?keyword=${encodeURIComponent(partial)}&pageNo=1&pageSize=20`);
      assert(`部分匹配"${partial}"有结果`, partialRes.data?.records?.length > 0);
    }

    // 大小写不敏感
    if (/[a-zA-Z]/.test(realName)) {
      const upper = await GET(`/${CONFIG.spaceNodeId}/listTeamRoles?keyword=${encodeURIComponent(realName.toUpperCase())}&pageNo=1&pageSize=20`);
      const lower = await GET(`/${CONFIG.spaceNodeId}/listTeamRoles?keyword=${encodeURIComponent(realName.toLowerCase())}&pageNo=1&pageSize=20`);
      assert('搜索大小写不敏感', upper.data?.total === lower.data?.total);
    }

    // 搜索 + 分页 total 一致
    const s1 = await GET(`/${CONFIG.spaceNodeId}/listTeamRoles?keyword=${encodeURIComponent(realName)}&pageNo=1&pageSize=1`);
    const s2 = await GET(`/${CONFIG.spaceNodeId}/listTeamRoles?keyword=${encodeURIComponent(realName)}&pageNo=1&pageSize=100`);
    assert('搜索不同 pageSize 下 total 一致', s1.data?.total === s2.data?.total);
  }

  // 空 keyword 等同不传
  const noKw = await GET(`/${CONFIG.spaceNodeId}/listTeamRoles?pageNo=1&pageSize=20`);
  const emptyKw = await GET(`/${CONFIG.spaceNodeId}/listTeamRoles?keyword=&pageNo=1&pageSize=20`);
  assert('空 keyword 等同不传', emptyKw.data?.total === noKw.data?.total);

  // 纯空格
  const spaceKw = await GET(`/${CONFIG.spaceNodeId}/listTeamRoles?keyword=${encodeURIComponent('   ')}&pageNo=1&pageSize=20`);
  assert('纯空格 keyword 不报错', spaceKw.success === true);

  // 不存在
  const none = await GET(`/${CONFIG.spaceNodeId}/listTeamRoles?keyword=${encodeURIComponent('不存在的xxx_zzz')}&pageNo=1&pageSize=20`);
  assert('不存在关键词返回空', none.data?.records?.length === 0);
}

