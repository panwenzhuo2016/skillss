async function testInjectionAndSpecialChars() {
  console.log('\n🛡️ 5. 注入防护 + 特殊字符');

  const specialChars = ['%', '_', '\'', '"', '\\', '<script>alert(1)</script>', '&&', '||', '\0'];
  for (const ch of specialChars) {
    // listTeamRoles
    const r1 = await GET(`/${CONFIG.spaceNodeId}/listTeamRoles?keyword=${encodeURIComponent(ch)}&pageNo=1&pageSize=20`);
    assert(`listTeamRoles 特殊字符"${ch.slice(0, 15)}"正常返回`, r1.success === true, r1);

    // permissionLogs
    const r2 = await GET(`/${CONFIG.spaceNodeId}/permissionLogs?keyword=${encodeURIComponent(ch)}&pageNo=1&pageSize=20`);
    assert(`permissionLogs 特殊字符"${ch.slice(0, 15)}"正常返回`, r2.success === true, r2);
  }

  // SQL 注入
  const injections = [
    "' OR 1=1 --",
    "1; DROP TABLE collabspace_node_permission_log;",
    "' UNION SELECT * FROM collabspace_control_role --",
    "1' AND '1'='1",
    "admin'/*",
  ];
  for (const payload of injections) {
    const r1 = await GET(`/${CONFIG.spaceNodeId}/listTeamRoles?keyword=${encodeURIComponent(payload)}&pageNo=1&pageSize=20`);
    assert(`listTeamRoles 注入"${payload.slice(0, 20)}..."正常返回`, r1.success === true, r1);

    const r2 = await GET(`/${CONFIG.spaceNodeId}/permissionLogs?keyword=${encodeURIComponent(payload)}&pageNo=1&pageSize=20`);
    assert(`permissionLogs 注入"${payload.slice(0, 20)}..."正常返回`, r2.success === true, r2);
  }

  // 超长字符串
  const longStr = 'a'.repeat(300);
  const longRes = await GET(`/${CONFIG.spaceNodeId}/listTeamRoles?keyword=${encodeURIComponent(longStr)}&pageNo=1&pageSize=20`);
  assert('超长 keyword 正常返回', longRes.success === true, longRes);
}

// ========== 维度 6：写操作验证 ==========

async function testWriteAndVerify() {
  console.log('\n⚡ 6.1 editRole - 写操作验证 + 冲突校验');

  // 先查当前成员列表
  const members = await GET(`/${CONFIG.spaceNodeId}/listMemberRoles?pageNo=1&pageSize=20`);
  if (!members.data?.records?.length) {
    console.log('  ⚠️  无成员数据，先 addRole 再测');
    await POST('/addRole', { spaceNodeId: CONFIG.spaceNodeId, unitIds: [CONFIG.ttt2UnitId], role: 'reader' });
  }

  const membersNow = await GET(`/${CONFIG.spaceNodeId}/listMemberRoles?pageNo=1&pageSize=20`);
  if (!membersNow.data?.records?.length) {
    console.log('  ⚠️  仍无成员数据，跳过');
    return;
  }

  const member = membersNow.data.records[0];
  const unitId = member.unitId;
  const originalRole = member.role;
  const newRole = originalRole === 'reader' ? 'editor' : 'reader';
  console.log(`  ℹ️  测试对象: ${member.unitName} (${unitId}), ${originalRole} → ${newRole}`);

  // 记录变更前日志数量
  const logsBefore = await GET(`/${CONFIG.spaceNodeId}/permissionLogs?pageNo=1&pageSize=1`);
  const totalBefore = logsBefore.data?.total || 0;

  // 执行 editRole
  const editRes = await POST('/editRole', {
    spaceNodeId: CONFIG.spaceNodeId,
    unitId,
    role: newRole,
  });
  assert('editRole 返回 success', editRes.success === true, editRes);
  assert('返回 hasConflict (boolean)', typeof editRes.data?.hasConflict === 'boolean', editRes.data);

  // 冲突时验证冲突字段
  if (editRes.data?.hasConflict) {
    assert('冲突时含 conflictMessage (string)', typeof editRes.data.conflictMessage === 'string');
    assert('冲突时含 conflictTeamName (string)', typeof editRes.data.conflictTeamName === 'string');
    assert('冲突时含 conflictTeamRole (string)', typeof editRes.data.conflictTeamRole === 'string');
    console.log(`  ℹ️  冲突: ${editRes.data.conflictMessage}`);
  } else {
    assert('无冲突时 conflictMessage 为 null', editRes.data?.conflictMessage == null);
  }

  // 查询验证变更生效
  const afterMembers = await GET(`/${CONFIG.spaceNodeId}/listMemberRoles?pageNo=1&pageSize=100`);
  const updated = afterMembers.data?.records?.find(r => String(r.unitId) === String(unitId));
  assert('权限已变更', updated?.role === newRole, { expected: newRole, actual: updated?.role });

  // 验证日志写入
  const logsAfter = await GET(`/${CONFIG.spaceNodeId}/permissionLogs?pageNo=1&pageSize=1`);
  assert('日志数量增加', (logsAfter.data?.total || 0) > totalBefore,
    { before: totalBefore, after: logsAfter.data?.total });

  if (logsAfter.data?.records?.length > 0) {
    const latest = logsAfter.data.records[0];
    assert('最新日志 targetName 匹配', latest.targetName === member.unitName, latest.targetName);
    assert('最新日志 operatorName 为管理员', latest.operatorName === '靖禾', latest.operatorName);
    console.log(`  ℹ️  日志: ${latest.description}`);
  }

  // 幂等性：相同操作再执行一次
  const sameRes = await POST('/editRole', { spaceNodeId: CONFIG.spaceNodeId, unitId, role: newRole });
  assert('相同操作再执行不报错', sameRes.success === true, sameRes);

  // 还原
  await POST('/editRole', { spaceNodeId: CONFIG.spaceNodeId, unitId, role: originalRole });
  console.log(`  ℹ️  已还原 ${member.unitName} 为 ${originalRole}`);
}

async function testAddAndDeleteRole() {
