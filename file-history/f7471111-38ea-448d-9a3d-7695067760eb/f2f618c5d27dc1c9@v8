// ========== 维度 4：参数校验 ==========

async function testParamValidation() {
  console.log('\n🔒 4. 参数校验');

  // 三个 GET 列表接口都测分页参数校验
  const endpoints = [
    `/${CONFIG.spaceNodeId}/listTeamRoles`,
    `/${CONFIG.spaceNodeId}/listMemberRoles`,
    `/${CONFIG.spaceNodeId}/permissionLogs`,
  ];

  for (const ep of endpoints) {
    const name = ep.split('/').pop();

    const r1 = await GET(`${ep}?pageNo=0&pageSize=20`);
    assert(`${name} pageNo=0 应返回错误`, r1.success === false, r1);

    const r2 = await GET(`${ep}?pageNo=-1&pageSize=20`);
    assert(`${name} pageNo=-1 应返回错误`, r2.success === false, r2);

    const r3 = await GET(`${ep}?pageNo=1&pageSize=0`);
    assert(`${name} pageSize=0 应返回错误`, r3.success === false, r3);

    const r4 = await GET(`${ep}?pageNo=1&pageSize=101`);
    assert(`${name} pageSize=101 应返回错误`, r4.success === false, r4);

    const r5 = await GET(`${ep}?pageNo=1&pageSize=-1`);
    assert(`${name} pageSize=-1 应返回错误`, r5.success === false, r5);
  }

  // POST editRole 缺少必填字段
  const noNodeId = await POST('/editRole', { unitId: '1', role: 'reader' });
  assert('editRole 缺少 spaceNodeId 返回错误', noNodeId.success === false);

