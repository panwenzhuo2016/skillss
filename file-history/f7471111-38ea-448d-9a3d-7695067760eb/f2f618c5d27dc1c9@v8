// ========== HTTP 工具 ==========

function parseCookies(res) {
  const cookies = {};
  const setCookieHeaders = res.headers.getSetCookie?.() || [];
  for (const header of setCookieHeaders) {
    const [kv] = header.split(';');
    const eqIdx = kv.indexOf('=');
    if (eqIdx > 0) {
      cookies[kv.substring(0, eqIdx).trim()] = kv.substring(eqIdx + 1).trim();
    }
  }
  return cookies;
}

async function rawFetch(method, url, body) {
  const headers = {
    'x-space-id': CONFIG.spaceId,
    'content-type': 'application/json',
  };
  if (cookie) headers['cookie'] = cookie;
  if (xsrfToken) headers['x-xsrf-token'] = xsrfToken;

  const opts = { method, headers, redirect: 'manual' };
  if (body) opts.body = JSON.stringify(body);
  return fetch(url, opts);
}

async function GET(path) {
  const res = await rawFetch('GET', `${CONFIG.host}/api/v1/node/role${path}`);
  // 用 text 再手动 parse，避免大整数精度丢失
  const text = await res.text();
  // 将 JSON 中超过 15 位的纯数字值转为字符串（unitId 等大整数）
  const safeText = text.replace(/:(\s*)(\d{15,})/g, ':"$2"');
  try { return JSON.parse(safeText); } catch { return JSON.parse(text); }
}

async function POST(path, body) {
  const res = await rawFetch('POST', `${CONFIG.host}/api/v1/node/role${path}`, body);
  const text = await res.text();
  const safeText = text.replace(/:(\s*)(\d{15,})/g, ':"$2"');
  try { return JSON.parse(safeText); } catch { return JSON.parse(text); }
}

// ========== 登录管理 ==========

async function login() {
  console.log(`🔑 登录 ${CONFIG.adminEmail} ...`);
  const res = await fetch(`${CONFIG.host}/api/v1/testLogin/${CONFIG.adminEmail}`, { redirect: 'manual' });
  const cookies = parseCookies(res);
  if (!cookies.SESSION) {
    console.log('❌ 登录失败：未获取到 SESSION');
    console.log('   响应状态:', res.status);
    process.exit(1);
  }
  xsrfToken = cookies['XSRF-TOKEN'] || '';
  cookie = `SESSION=${cookies.SESSION}; XSRF-TOKEN=${xsrfToken}`;
  console.log(`   ✅ 登录成功\n`);
}

let savedSessions = {};
function saveSession(name) {
  savedSessions[name] = { cookie, xsrfToken };
}
function restoreSession(name) {
  ({ cookie, xsrfToken } = savedSessions[name]);
}

async function loginAs(email) {
  const res = await fetch(`${CONFIG.host}/api/v1/testLogin/${email}`, { redirect: 'manual' });
  const cookies = parseCookies(res);
  if (!cookies.SESSION) {
    console.log(`  ⚠️  登录 ${email} 失败，跳过`);
    return false;
  }
  xsrfToken = cookies['XSRF-TOKEN'] || '';
  cookie = `SESSION=${cookies.SESSION}; XSRF-TOKEN=${xsrfToken}`;
  return true;
}

// ========== 数据发现：从 API 动态获取 unitId ==========

async function discoverUnitIds() {
  console.log('🔍 发现测试数据...');

  // 从 listMemberRoles 获取已有成员的 unitId
  const members = await GET(`/${CONFIG.spaceNodeId}/listMemberRoles?pageNo=1&pageSize=100`);
  if (members.data?.records?.length > 0) {
    for (const r of members.data.records) {
      if (r.unitName === CONFIG.wstName) {
        CONFIG.wstUnitId = String(r.unitId);
        console.log(`   翁斯坦 unitId: ${CONFIG.wstUnitId}`);
      }
      if (r.unitName === CONFIG.ttt2Name) {
        CONFIG.ttt2UnitId = String(r.unitId);
        console.log(`   ttt2 unitId: ${CONFIG.ttt2UnitId}`);
      }
    }
  }

  // 如果 ttt2 不在成员列表中（未设置权限），登录 ttt2 从 listRole 的 self 字段获取
  if (!CONFIG.ttt2UnitId) {
    saveSession('admin');
    if (await loginAs(CONFIG.normalEmail)) {
      const selfInfo = await GET(`/${CONFIG.spaceNodeId}/listRole`);
      if (selfInfo.data?.self?.unitId) {
        CONFIG.ttt2UnitId = String(selfInfo.data.self.unitId);
        console.log(`   ttt2 unitId (from self): ${CONFIG.ttt2UnitId}`);
      }
    }
    restoreSession('admin');
  }

  // 如果翁斯坦也未找到，类似处理
  if (!CONFIG.wstUnitId) {
    saveSession('admin');
    if (await loginAs(CONFIG.managerEmail)) {
      const selfInfo = await GET(`/${CONFIG.spaceNodeId}/listRole`);
      if (selfInfo.data?.self?.unitId) {
        CONFIG.wstUnitId = String(selfInfo.data.self.unitId);
        console.log(`   翁斯坦 unitId (from self): ${CONFIG.wstUnitId}`);
      }
    }
    restoreSession('admin');
  }

  if (!CONFIG.wstUnitId) {
    console.log('   ⚠️  未找到翁斯坦 unitId，部分测试将跳过');
  }
  if (!CONFIG.ttt2UnitId) {
    console.log('   ⚠️  未找到 ttt2 unitId，部分测试将跳过');
  }
  console.log('');
}

