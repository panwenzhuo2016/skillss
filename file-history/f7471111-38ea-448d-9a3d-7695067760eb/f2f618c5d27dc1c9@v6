async function testBatchEditRole() {
  console.log('\n📦 32. batchEditRole - 批量编辑');

  const ttt2UnitId = '2008117047041433601';
  const wstUnitId = '2008109689078784002';

  // 先 addRole 确保两个用户都有权限
  await POST('/addRole', {
    spaceNodeId: CONFIG.spaceNodeId,
    unitIds: [ttt2UnitId],
    role: 'reader',
  });

  // 确保翁斯坦也有权限
  const members = await GET(`/${CONFIG.spaceNodeId}/listMemberRoles?pageNo=1&pageSize=100`);
  const wst = members.data?.records?.find(r => r.unitId?.toString() === wstUnitId);
  if (!wst) {
    await POST('/addRole', {
      spaceNodeId: CONFIG.spaceNodeId,
      unitIds: [wstUnitId],
      role: 'reader',
    });
  }
  const wstOriginalRole = wst?.role || 'reader';

  // batchEditRole：同时把两个用户改为 editor
  const batchRes = await POST('/batchEditRole', {
    spaceNodeId: CONFIG.spaceNodeId,
    unitIds: [ttt2UnitId, wstUnitId],
    role: 'editor',
  });
  assert('batchEditRole 返回 success', batchRes.success === true, batchRes);
  assert('batchEditRole 含 hasConflict', typeof batchRes.data?.hasConflict === 'boolean', batchRes.data);

  // 验证两个用户都变成了 editor
  const afterMembers = await GET(`/${CONFIG.spaceNodeId}/listMemberRoles?pageNo=1&pageSize=100`);
  const ttt2After = afterMembers.data?.records?.find(r => r.unitId?.toString() === ttt2UnitId);
  const wstAfter = afterMembers.data?.records?.find(r => r.unitId?.toString() === wstUnitId);
  assert('batchEditRole 后 ttt2 为 editor', ttt2After?.role === 'editor', ttt2After?.role);
  assert('batchEditRole 后 翁斯坦 为 editor', wstAfter?.role === 'editor', wstAfter?.role);

  // 还原
  await POST('/deleteRole', { spaceNodeId: CONFIG.spaceNodeId, unitId: ttt2UnitId });
  await POST('/editRole', { spaceNodeId: CONFIG.spaceNodeId, unitId: wstUnitId, role: wstOriginalRole });
  console.log('  ℹ️  已还原');
}

