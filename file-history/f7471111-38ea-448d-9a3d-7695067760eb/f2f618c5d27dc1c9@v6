async function testPaginationBoundary() {
  console.log('\n📐 10. 分页边界值');

  // pageSize=1 最小合法值
  const res1 = await GET(`/${CONFIG.spaceNodeId}/listTeamRoles?pageNo=1&pageSize=1`);
  assert('pageSize=1 返回成功', res1.success === true, res1);
  assert('pageSize=1 最多返回1条', res1.data?.records?.length <= 1, res1.data?.records?.length);

  // pageSize=100 最大合法值
  const res2 = await GET(`/${CONFIG.spaceNodeId}/listTeamRoles?pageNo=1&pageSize=100`);
  assert('pageSize=100 返回成功', res2.success === true, res2);

  // pageSize=100 listMemberRoles
  const res3 = await GET(`/${CONFIG.spaceNodeId}/listMemberRoles?pageNo=1&pageSize=100`);
  assert('listMemberRoles pageSize=100 返回成功', res3.success === true, res3);

  // pageSize=100 permissionLogs
  const res4 = await GET(`/${CONFIG.spaceNodeId}/permissionLogs?pageNo=1&pageSize=100`);
  assert('permissionLogs pageSize=100 返回成功', res4.success === true, res4);

  // total 与实际记录数一致性：取全部数据验证
  const all = await GET(`/${CONFIG.spaceNodeId}/listTeamRoles?pageNo=1&pageSize=100`);
  if (all.data?.total <= 100) {
    assert('total <= 100 时 records.length === total', all.data.records.length === all.data.total,
      { total: all.data.total, length: all.data.records.length });
  }

  // pageNo 大于实际页数时 records 应为空但 total 不变
  if (all.data?.total > 0) {
    const lastPageNo = Math.ceil(all.data.total / 1) + 1; // 超出最后一页
    const overPage = await GET(`/${CONFIG.spaceNodeId}/listTeamRoles?pageNo=${lastPageNo}&pageSize=1`);
    assert('超出最后一页返回空列表', overPage.success && overPage.data?.records?.length === 0, overPage.data?.records?.length);
    assert('超出最后一页 total 不变', overPage.data?.total === all.data.total,
      { expected: all.data.total, actual: overPage.data?.total });
  }
}

