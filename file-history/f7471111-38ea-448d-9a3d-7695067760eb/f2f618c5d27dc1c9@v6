async function testDuplicateControlRoleBug() {
  console.log('\n🐛 34. 【BUG验证】addRole 重复调用是否产生重复记录');

  const ttt2UnitId = '2008117047041433601';

  // 先清理
  await POST('/deleteRole', { spaceNodeId: CONFIG.spaceNodeId, unitId: ttt2UnitId });

  // 第一次 addRole
  await POST('/addRole', {
    spaceNodeId: CONFIG.spaceNodeId,
    unitIds: [ttt2UnitId],
    role: 'reader',
  });

  // 查 listMemberRoles 确认 ttt2 只出现一次
  const after1 = await GET(`/${CONFIG.spaceNodeId}/listMemberRoles?pageNo=1&pageSize=100`);
  const ttt2Count1 = after1.data?.records?.filter(r => r.unitId?.toString() === ttt2UnitId).length;
  assert('第1次 addRole 后 ttt2 只出现1次', ttt2Count1 === 1, ttt2Count1);

  // 第二次 addRole（重复添加同一个 unitId）
  await POST('/addRole', {
    spaceNodeId: CONFIG.spaceNodeId,
    unitIds: [ttt2UnitId],
    role: 'editor',
  });

  // 查 listMemberRoles 确认 ttt2 仍然只出现一次
  const after2 = await GET(`/${CONFIG.spaceNodeId}/listMemberRoles?pageNo=1&pageSize=100`);
  const ttt2Count2 = after2.data?.records?.filter(r => r.unitId?.toString() === ttt2UnitId).length;
  assert('【重复 addRole】ttt2 仍只出现1次（不应有重复记录）', ttt2Count2 === 1, ttt2Count2);

  // 验证角色是否正确更新为 editor（而不是还是 reader）
  const ttt2AfterDup = after2.data?.records?.find(r => r.unitId?.toString() === ttt2UnitId);
  assert('重复 addRole 后角色更新为 editor', ttt2AfterDup?.role === 'editor', ttt2AfterDup?.role);

  // 第三次 editRole 再改一次
  await POST('/editRole', {
    spaceNodeId: CONFIG.spaceNodeId,
    unitId: ttt2UnitId,
    role: 'manager',
  });

  const after3 = await GET(`/${CONFIG.spaceNodeId}/listMemberRoles?pageNo=1&pageSize=100`);
  const ttt2Count3 = after3.data?.records?.filter(r => r.unitId?.toString() === ttt2UnitId).length;
  assert('editRole 后 ttt2 仍只出现1次', ttt2Count3 === 1, ttt2Count3);

  // 清理
  await POST('/deleteRole', { spaceNodeId: CONFIG.spaceNodeId, unitId: ttt2UnitId });
  console.log('  ℹ️  已清理');
}

