async function main() {
  console.log('🚀 文档设置权限功能优化 - 接口测试');
  console.log(`   环境: ${CONFIG.host}`);
  console.log(`   空间: ${CONFIG.spaceId}`);
  console.log(`   节点: ${CONFIG.spaceNodeId}\n`);

  try {
    await login();
    await testListTeamRoles();
    await testListTeamRolesSearch();
    await testListTeamRolesPagination();
    await testListMemberRoles();
    await testPermissionLogs();
    await testEditRoleAndLog();
    await testPermissionLogSearch();
    await testParamValidation();
    await testNoPermissionNode();
  } catch (e) {
    if (e.cause?.code === 'ECONNREFUSED') {
      console.log('\n❌ 无法连接测试环境，请检查网络');
    } else {
      console.log(`\n❌ 异常: ${e.stack || e.message}`);
    }
    process.exit(1);
  }

  console.log(`\n=============================`);
  console.log(`✅ 通过: ${passed}  ❌ 失败: ${failed}  📊 总计: ${passed + failed}`);
  console.log(`=============================`);
  process.exit(failed > 0 ? 1 : 0);
}

main();
