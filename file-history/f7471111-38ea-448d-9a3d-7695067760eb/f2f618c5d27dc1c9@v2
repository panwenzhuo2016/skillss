async function testParamValidation() {
  console.log('\n🔒 8. 参数校验');

  const res1 = await GET(`/${CONFIG.spaceNodeId}/listTeamRoles?pageNo=0&pageSize=20`);
  assert('pageNo=0 应返回错误', res1.success === false, res1);

  const res2 = await GET(`/${CONFIG.spaceNodeId}/listMemberRoles?pageNo=1&pageSize=101`);
  assert('pageSize=101 应返回错误', res2.success === false, res2);

  const res3 = await GET(`/${CONFIG.spaceNodeId}/listTeamRoles?pageNo=-1&pageSize=20`);
  assert('pageNo=-1 应返回错误', res3.success === false, res3);
}

async function testNoPermissionNode() {
  console.log('\n🚫 9. 无权限数据的节点');

  // 用一个不存在但合法的 Long 值节点ID（不超过 Long.MAX_VALUE）
  const fakeNodeId = '1';
  const res1 = await GET(`/${fakeNodeId}/listTeamRoles?pageNo=1&pageSize=20`);
  assert('不存在节点 listTeamRoles 不报500', res1.success === true || (res1.code && res1.code !== 500), res1);

  const res2 = await GET(`/${fakeNodeId}/listMemberRoles?pageNo=1&pageSize=20`);
  assert('不存在节点 listMemberRoles 不报500', res2.success === true || (res2.code && res2.code !== 500), res2);

  const res3 = await GET(`/${fakeNodeId}/permissionLogs?pageNo=1&pageSize=20`);
  assert('不存在节点 permissionLogs 返回空', res3.success && res3.data?.records?.length === 0, res3.data?.total);
}

