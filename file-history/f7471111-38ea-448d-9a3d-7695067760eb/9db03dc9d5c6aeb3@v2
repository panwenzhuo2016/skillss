#!/bin/bash
# ============================================================
# 文档设置权限功能优化 - 接口测试脚本
# 用法: bash test-api.sh
# 前置: 先在浏览器登录测试环境，从 DevTools > Network 复制 Cookie
# ============================================================

BASE_URL="http://xcollabspace-test.xtool-staging.yottastudios.com/api/v1/node/role"

# ========== 按需修改以下参数 ==========
COOKIE="SESSION=你的session值"          # 从浏览器复制
SPACE_ID="spcFKY26VSy2P"               # 空间站ID
SPACE_NODE_ID="1934538201599315970"     # 有权限设置的文档节点ID
UNIT_ID="1623148087983276034"           # 用于测试 editRole 的 unitId
# =====================================

HEADERS="-H 'x-space-id: $SPACE_ID' -H 'Cookie: $COOKIE' -H 'Content-Type: application/json'"

echo "=============================="
echo "1. 查询小组权限列表"
echo "=============================="
echo "--- 不带搜索 ---"
eval curl -s "$BASE_URL/$SPACE_NODE_ID/listTeamRoles?pageNo=1&pageSize=20" $HEADERS | python -m json.tool 2>/dev/null || eval curl -s "$BASE_URL/$SPACE_NODE_ID/listTeamRoles?pageNo=1&pageSize=20" $HEADERS
echo ""

echo "--- 带搜索 ---"
eval curl -s "$BASE_URL/$SPACE_NODE_ID/listTeamRoles?keyword=技术&pageNo=1&pageSize=20" $HEADERS | python -m json.tool 2>/dev/null || eval curl -s "$BASE_URL/$SPACE_NODE_ID/listTeamRoles?keyword=技术&pageNo=1&pageSize=20" $HEADERS
echo ""

echo "=============================="
echo "2. 查询成员权限列表"
echo "=============================="
echo "--- 不带搜索 ---"
eval curl -s "$BASE_URL/$SPACE_NODE_ID/listMemberRoles?pageNo=1&pageSize=20" $HEADERS | python -m json.tool 2>/dev/null || eval curl -s "$BASE_URL/$SPACE_NODE_ID/listMemberRoles?pageNo=1&pageSize=20" $HEADERS
echo ""

echo "--- 带搜索 ---"
eval curl -s "$BASE_URL/$SPACE_NODE_ID/listMemberRoles?keyword=张&pageNo=1&pageSize=20" $HEADERS | python -m json.tool 2>/dev/null || eval curl -s "$BASE_URL/$SPACE_NODE_ID/listMemberRoles?keyword=张&pageNo=1&pageSize=20" $HEADERS
echo ""

echo "=============================="
echo "3. 查询权限变更历史"
echo "=============================="
echo "--- 不带搜索 ---"
eval curl -s "$BASE_URL/$SPACE_NODE_ID/permissionLogs?pageNo=1&pageSize=20" $HEADERS | python -m json.tool 2>/dev/null || eval curl -s "$BASE_URL/$SPACE_NODE_ID/permissionLogs?pageNo=1&pageSize=20" $HEADERS
echo ""

echo "--- 带搜索 ---"
eval curl -s "$BASE_URL/$SPACE_NODE_ID/permissionLogs?keyword=可编辑&pageNo=1&pageSize=20" $HEADERS | python -m json.tool 2>/dev/null || eval curl -s "$BASE_URL/$SPACE_NODE_ID/permissionLogs?keyword=可编辑&pageNo=1&pageSize=20" $HEADERS
echo ""

echo "=============================="
echo "4. 编辑权限（测试冲突校验）"
echo "=============================="
eval curl -s -X POST "$BASE_URL/editRole" \
  $HEADERS \
  -d "'{ \"spaceNodeId\": \"$SPACE_NODE_ID\", \"unitId\": \"$UNIT_ID\", \"role\": \"reader\" }'" | python -m json.tool 2>/dev/null || \
eval curl -s -X POST "$BASE_URL/editRole" \
  $HEADERS \
  -d "'{ \"spaceNodeId\": \"$SPACE_NODE_ID\", \"unitId\": \"$UNIT_ID\", \"role\": \"reader\" }'"
echo ""

echo "=============================="
echo "5. 验证变更历史已记录"
echo "=============================="
eval curl -s "$BASE_URL/$SPACE_NODE_ID/permissionLogs?pageNo=1&pageSize=5" $HEADERS | python -m json.tool 2>/dev/null || eval curl -s "$BASE_URL/$SPACE_NODE_ID/permissionLogs?pageNo=1&pageSize=5" $HEADERS
echo ""

echo "=============================="
echo "测试完成"
echo "=============================="
