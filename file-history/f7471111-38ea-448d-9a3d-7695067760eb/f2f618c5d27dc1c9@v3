async function testEditRoleAndLog() {
  console.log('\n⚡ 6. editRole - 冲突校验 + 日志记录');

  // 先查当前成员列表，找一个可用的成员 unitId
  const members = await GET(`/${CONFIG.spaceNodeId}/listMemberRoles?pageNo=1&pageSize=20`);
  if (!members.data?.records?.length) {
    console.log('  ⚠️  该节点无成员权限数据，跳过 editRole 测试');
    return;
  }

  const member = members.data.records[0];
  const unitId = member.unitId;
  const originalRole = member.role;
  const newRole = originalRole === 'reader' ? 'editor' : 'reader';
  console.log(`  ℹ️  测试对象: ${member.unitName} (${unitId}), ${originalRole} -> ${newRole}`);

  // 记录变更前日志数量
  const logsBefore = await GET(`/${CONFIG.spaceNodeId}/permissionLogs?pageNo=1&pageSize=1`);
  const totalBefore = logsBefore.data?.total || 0;

  // 执行 editRole
  const editRes = await POST('/editRole', {
    spaceNodeId: CONFIG.spaceNodeId,
    unitId,
    role: newRole,
  });
  assert('editRole 返回 success', editRes.success === true, editRes);
  assert('包含 hasConflict (boolean)', typeof editRes.data?.hasConflict === 'boolean', editRes.data?.hasConflict);

  if (editRes.data?.hasConflict) {
    assert('冲突时含 conflictMessage', typeof editRes.data.conflictMessage === 'string', editRes.data.conflictMessage);
    assert('冲突时含 conflictTeamName', typeof editRes.data.conflictTeamName === 'string', editRes.data.conflictTeamName);
    assert('冲突时含 conflictTeamRole', typeof editRes.data.conflictTeamRole === 'string', editRes.data.conflictTeamRole);
    console.log(`  ℹ️  冲突: ${editRes.data.conflictMessage}`);
  }

  // 验证权限已变更
  const membersAfter = await GET(`/${CONFIG.spaceNodeId}/listMemberRoles?pageNo=1&pageSize=20`);
  const updated = membersAfter.data?.records?.find(r => r.unitId === unitId);
  assert('权限已变更', updated?.role === newRole, { expected: newRole, actual: updated?.role });

  // 验证日志写入
  const logsAfter = await GET(`/${CONFIG.spaceNodeId}/permissionLogs?pageNo=1&pageSize=1`);
  assert('日志数量增加', (logsAfter.data?.total || 0) > totalBefore, { before: totalBefore, after: logsAfter.data?.total });

  if (logsAfter.data?.records?.length > 0) {
    const latest = logsAfter.data.records[0];
    assert('最新日志 targetName 匹配', latest.targetName === member.unitName, latest.targetName);
    console.log(`  ℹ️  日志: ${latest.description}`);
  }

  // 改回原角色
  const restoreRes = await POST('/editRole', {
    spaceNodeId: CONFIG.spaceNodeId,
    unitId,
    role: originalRole,
  });
  assert('还原权限成功', restoreRes.success === true, restoreRes);
  console.log(`  ℹ️  已还原 ${member.unitName} 为 ${originalRole}`);
}

