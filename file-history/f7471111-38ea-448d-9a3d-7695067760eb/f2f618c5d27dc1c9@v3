    return;
  }

  // 用 nickName 搜索（如果有）
  const withNickName = all.data.records.find(r => r.nickName);
  if (withNickName) {
    const res = await GET(`/${CONFIG.spaceNodeId}/listMemberRoles?keyword=${encodeURIComponent(withNickName.nickName)}&pageNo=1&pageSize=20`);
