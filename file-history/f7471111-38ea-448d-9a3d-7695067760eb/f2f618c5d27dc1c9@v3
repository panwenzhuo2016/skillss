  // 部分匹配：取名字的第一个字搜索
  const firstName = all.data.records[0].unitName;
  if (firstName && firstName.length > 1) {
    const partialName = firstName.substring(0, 1);
    const partialRes = await GET(`/${CONFIG.spaceNodeId}/listMemberRoles?keyword=${encodeURIComponent(partialName)}&pageNo=1&pageSize=20`);
    assert(`部分匹配"${partialName}"有结果`, partialRes.success && partialRes.data?.records?.length > 0, partialRes.data?.total);
