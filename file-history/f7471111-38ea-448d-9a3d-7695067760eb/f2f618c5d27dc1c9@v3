    assert(`日志注入 "${payload.slice(0, 20)}..." 不报500`, res.success === true || (res.code && res.code !== 500), res);
  }
}

async function testEditRoleAllRoleValues() {
  console.log('\n🔄 22. editRole - 三种角色切换');

  const members = await GET(`/${CONFIG.spaceNodeId}/listMemberRoles?pageNo=1&pageSize=1`);
  if (!members.data?.records?.length) {
    console.log('  ⚠️  无成员数据，跳过角色切换测试');
    return;
  }

  const m = members.data.records[0];
  const originalRole = m.role;
  const roles = ['reader', 'editor', 'manager'];
  const otherRoles = roles.filter(r => r !== originalRole);

  // 依次切换到其他两种角色，再切回来
  for (const targetRole of otherRoles) {
    const res = await POST('/editRole', {
      spaceNodeId: CONFIG.spaceNodeId,
      unitId: m.unitId,
      role: targetRole,
    });
    assert(`切换到 ${targetRole} 成功`, res.success === true, res);

    // 验证生效
    const check = await GET(`/${CONFIG.spaceNodeId}/listMemberRoles?pageNo=1&pageSize=20`);
    const updated = check.data?.records?.find(r => r.unitId === m.unitId);
    assert(`验证角色变为 ${targetRole}`, updated?.role === targetRole, updated?.role);
  }

  // 还原
  const restoreRes = await POST('/editRole', {
    spaceNodeId: CONFIG.spaceNodeId,
    unitId: m.unitId,
    role: originalRole,
  });
  assert(`还原为 ${originalRole}`, restoreRes.success === true, restoreRes);
}

