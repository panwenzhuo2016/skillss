async function testSearchEdgeCases() {
  console.log('\n🔎 12. 搜索边界');

  // 空字符串 keyword 等同于不搜索
  const noKeyword = await GET(`/${CONFIG.spaceNodeId}/listTeamRoles?pageNo=1&pageSize=20`);
