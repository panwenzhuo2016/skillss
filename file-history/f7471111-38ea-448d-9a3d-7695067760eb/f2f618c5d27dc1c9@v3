  assert('permissionLogs pageSize=1 返回成功', page1.success === true, page1);
  assert('permissionLogs pageSize=1 最多1条', page1.data?.records?.length <= 1, page1.data?.records?.length);

  if (page1.data?.total > 1) {
    const page2 = await GET(`/${CONFIG.spaceNodeId}/permissionLogs?pageNo=2&pageSize=1`);
    assert('permissionLogs 第2页有数据', page2.success && page2.data?.records?.length > 0, page2.data?.records?.length);

    // 两页数据的 createdAt 或 targetName 不完全相同（不重复）
    if (page1.data.records.length > 0 && page2.data?.records?.length > 0) {
      const r1 = page1.data.records[0];
      const r2 = page2.data.records[0];
      const notSame = r1.createdAt !== r2.createdAt || r1.targetName !== r2.targetName || r1.description !== r2.description;
      assert('permissionLogs 第1页和第2页不重复', notSame,
        { page1: r1.description, page2: r2.description });
    }

    // 最后一页
    const lastPageNo = Math.ceil(page1.data.total / 5);
    const lastPage = await GET(`/${CONFIG.spaceNodeId}/permissionLogs?pageNo=${lastPageNo}&pageSize=5`);
    assert('permissionLogs 最后一页有数据', lastPage.success && lastPage.data?.records?.length > 0, lastPage.data?.records?.length);

    // 全部日志按时间倒序
    const allLogs = await GET(`/${CONFIG.spaceNodeId}/permissionLogs?pageNo=1&pageSize=100`);
    if (allLogs.data?.records?.length >= 2) {
      let sorted = true;
      for (let i = 0; i < allLogs.data.records.length - 1; i++) {
        const t1 = new Date(allLogs.data.records[i].createdAt).getTime();
        const t2 = new Date(allLogs.data.records[i + 1].createdAt).getTime();
        if (t1 < t2) { sorted = false; break; }
      }
      assert('所有日志都按时间倒序', sorted, allLogs.data.records.map(r => r.createdAt));
    }
  }
}

async function testEditRoleBoundary() {
