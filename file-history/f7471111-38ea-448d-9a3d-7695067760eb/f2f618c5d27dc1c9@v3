async function testResponseStructureConsistency() {
  console.log('\n📦 19. 响应结构一致性');

  // 所有三个列表接口都应返回 pageNum/pageSize/total/records
  const endpoints = [
    { name: 'listTeamRoles', path: `/${CONFIG.spaceNodeId}/listTeamRoles?pageNo=1&pageSize=5` },
    { name: 'listMemberRoles', path: `/${CONFIG.spaceNodeId}/listMemberRoles?pageNo=1&pageSize=5` },
    { name: 'permissionLogs', path: `/${CONFIG.spaceNodeId}/permissionLogs?pageNo=1&pageSize=5` },
  ];

  for (const ep of endpoints) {
    const res = await GET(ep.path);
    assert(`${ep.name} 含 pageNum`, typeof res.data?.pageNum === 'number', res.data?.pageNum);
    assert(`${ep.name} 含 pageSize`, typeof res.data?.pageSize === 'number', res.data?.pageSize);
    assert(`${ep.name} pageSize 与请求一致`, res.data?.pageSize === 5, res.data?.pageSize);
    assert(`${ep.name} 含 total (number)`, typeof res.data?.total === 'number', res.data?.total);
    assert(`${ep.name} 含 records (array)`, Array.isArray(res.data?.records), res.data?.records);
    assert(`${ep.name} records.length <= pageSize`, res.data?.records?.length <= 5, res.data?.records?.length);
  }
}

