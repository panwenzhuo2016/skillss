// 维度 2: 版本快照 CRUD 流程
async function testVersionSnapshotCRUD() {
  console.log('\n📋 2. 版本快照 CRUD 流程');

  if (!CONFIG.spaceNodeId) {
    console.log('  ⚠️ 无 spaceNodeId，跳过');
    return;
  }

  // 查询正常列表
  const listRes = await POST('/spaceNode/migration/version/list', {
    spaceNodeId: CONFIG.spaceNodeId,
    status: 1,
  });
  assert('查询正常快照列表 success', listRes.success === true, listRes);

  // 查询回收站列表
  const trashRes = await POST('/spaceNode/migration/version/list', {
    spaceNodeId: CONFIG.spaceNodeId,
    status: 2,
  });
  assert('查询回收站列表 success', trashRes.success === true, trashRes);

  // 如果有快照，测试 update/delete/recover 流程
  if (listRes.data && listRes.data.length > 0) {
    const snapshot = listRes.data[listRes.data.length - 1]; // 取最后一个
    const snapshotId = snapshot.id;
    const originalName = snapshot.snapshotName;

    // 更新快照名称
    const updateName = originalName + '-测试改名';
    const updateRes = await POST('/spaceNode/migration/version/update', {
      id: Number(snapshotId),
      spaceNodeId: CONFIG.spaceNodeId,
      name: updateName,
    });
    assert('version/update 返回 success', updateRes.success === true, updateRes);
    if (updateRes.success) {
      assert('更新后名称正确', updateRes.data?.snapshotName === updateName, updateRes.data);
    }

    // 验证更新生效
    const listAfterUpdate = await POST('/spaceNode/migration/version/list', {
      spaceNodeId: CONFIG.spaceNodeId,
      status: 1,
    });
    const updated = listAfterUpdate.data?.find(s => s.id === snapshotId);
    assert('更新后列表中名称已变更', updated?.snapshotName === updateName, updated?.snapshotName);

    // 还原名称
    await POST('/spaceNode/migration/version/update', {
      id: Number(snapshotId),
      spaceNodeId: CONFIG.spaceNodeId,
      name: originalName,
    });
    console.log(`  ℹ️  已还原快照名称为 "${originalName}"`);

    // 删除快照（软删除）
    const deleteRes = await POST('/spaceNode/migration/version/delete', {
      id: Number(snapshotId),
      spaceNodeId: CONFIG.spaceNodeId,
    });
    assert('version/delete 返回 success', deleteRes.success === true, deleteRes);

    // 验证删除后不在正常列表
    const listAfterDel = await POST('/spaceNode/migration/version/list', {
      spaceNodeId: CONFIG.spaceNodeId,
      status: 1,
    });
    const deletedInList = listAfterDel.data?.find(s => s.id === snapshotId);
    assert('删除后不在正常列表中', !deletedInList, deletedInList);

    // 验证出现在回收站
    const trashAfterDel = await POST('/spaceNode/migration/version/list', {
      spaceNodeId: CONFIG.spaceNodeId,
      status: 2,
    });
    const inTrash = trashAfterDel.data?.find(s => s.id === snapshotId);
    assert('删除后出现在回收站', !!inTrash, trashAfterDel.data);

    // 恢复快照
    const recoverRes = await POST('/spaceNode/migration/version/recover', {
      id: Number(snapshotId),
      spaceNodeId: CONFIG.spaceNodeId,
    });
    assert('version/recover 返回 success', recoverRes.success === true, recoverRes);

    // 验证恢复后回到正常列表
    const listAfterRecover = await POST('/spaceNode/migration/version/list', {
      spaceNodeId: CONFIG.spaceNodeId,
      status: 1,
    });
    const recovered = listAfterRecover.data?.find(s => s.id === snapshotId);
    assert('恢复后回到正常列表', !!recovered, recovered);

  } else {
    console.log('  ⚠️ 该节点无快照数据，跳过 update/delete/recover 测试');
  }
}

// 维度 3: 批量迁移任务创建与查询
async function testBatchMigration() {
  console.log('\n📋 3. 批量迁移任务创建与查询');

  if (!CONFIG.spaceNodeId || !CONFIG.spaceId2) {
    console.log('  ⚠️ 缺少测试数据，跳过');
    return;
  }

  // 创建批量迁移任务（复制模式，保留原文件）
  const createRes = await POST('/spaceNode/migration/createBatchMigrationTask', {
    items: [
      {
        sourceSpaceId: CONFIG.spaceId,
        spaceNodeIds: [CONFIG.spaceNodeId],
      }
    ],
    targetSpaceId: CONFIG.spaceId2,
    isRemained: true,
  });
  assert('createBatchMigrationTask 返回 success', createRes.success === true, createRes);

  if (createRes.success && createRes.data) {
    const batchId = createRes.data;
    assert('返回 batchId 非空', typeof batchId === 'string' && batchId.length > 0, batchId);
    assert('batchId 以 batch- 开头', batchId.startsWith('batch-'), batchId);

    // 查询批量任务进度
    // 等待一小会让任务被消费
    await new Promise(r => setTimeout(r, 2000));

    const batchInfo = await GET(`/spaceNode/migration/batch/${batchId}`);
    assert('查询批量任务返回 success', batchInfo.success === true, batchInfo);
    assert('batchId 一致', batchInfo.data?.batchId === batchId, batchInfo.data?.batchId);
    assert('tasks 是数组', Array.isArray(batchInfo.data?.tasks), batchInfo.data?.tasks);

    if (batchInfo.data?.tasks?.length > 0) {
      const subTask = batchInfo.data.tasks[0];
      assert('子任务含 taskId', typeof subTask.taskId === 'string', subTask.taskId);
      assert('子任务含 sourceSpaceId', typeof subTask.sourceSpaceId === 'string', subTask.sourceSpaceId);
      assert('子任务含 status (number)', typeof subTask.status === 'number', subTask.status);
      assert('子任务含 statusDesc', subTask.statusDesc !== undefined, subTask.statusDesc);
      assert('子任务 sourceSpaceId 正确', subTask.sourceSpaceId === CONFIG.spaceId, subTask.sourceSpaceId);

      // 查询单个子任务
      const taskInfo = await GET(`/spaceNode/migration/task/${subTask.taskId}`);
      assert('单任务查询返回 success', taskInfo.success === true, taskInfo);
      assert('单任务 taskId 正确', taskInfo.data?.taskId === subTask.taskId, taskInfo.data?.taskId);
      assert('单任务含 email', typeof taskInfo.data?.email === 'string', taskInfo.data?.email);
      assert('单任务含 targetSpaceId', taskInfo.data?.targetSpaceId === CONFIG.spaceId2, taskInfo.data?.targetSpaceId);
      assert('单任务 status 0-3', [0, 1, 2, 3].includes(taskInfo.data?.status), taskInfo.data?.status);
    }
  }
}

