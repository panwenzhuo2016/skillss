async function setupTestData() {
  console.log('📦 获取测试数据...');

  // 获取管理的空间站列表
  const spaces = await GET('/spaceNode/migration/managedSpaces');
  if (spaces.success && spaces.data && spaces.data.length > 0) {
    CONFIG.spaceId = spaces.data[0].spaceId;
    console.log(`   空间站: ${CONFIG.spaceId} (${spaces.data[0].name})`);
    if (spaces.data.length > 1) {
      CONFIG.spaceId2 = spaces.data[1].spaceId;
      console.log(`   空间站2: ${CONFIG.spaceId2} (${spaces.data[1].name})`);
    }
  } else {
    console.log(`   ⚠️ 无法获取空间站列表，使用默认值`);
  }

  // 获取空间站的文件树以找到 spaceNodeId（需要 x-space-id header）
  const treeRes = await GET('/node/spaceNodeTree');
  if (treeRes.success && treeRes.data && treeRes.data.length > 0) {
    // 找一个非文件夹节点（type != 1）
    const findFileNode = (nodes) => {
      for (const node of nodes) {
        const d = node.data || node;
        if (d.type !== 1 && d.id) return d;
        const children = node.children || d.children;
        if (children && children.length > 0) {
          const found = findFileNode(children);
          if (found) return found;
        }
      }
      return null;
    };
    const fileNode = findFileNode(treeRes.data);
    if (fileNode) {
      CONFIG.spaceNodeId = fileNode.id;
      console.log(`   文件节点: ${CONFIG.spaceNodeId} (${fileNode.name})`);
    } else {
      // 如果都是文件夹，取第一个节点
      const firstNode = treeRes.data[0]?.data || treeRes.data[0];
      if (firstNode?.id) {
        CONFIG.spaceNodeId = firstNode.id;
        console.log(`   节点(文件夹): ${CONFIG.spaceNodeId} (${firstNode.name})`);
      }
    }
  }

  // 如果没找到节点ID，从版本快照列表尝试
  if (!CONFIG.spaceNodeId) {
    console.log(`   ⚠️ 无法从树获取节点ID，将在测试中跳过需要节点ID的用例`);
  }

  console.log('');
}

