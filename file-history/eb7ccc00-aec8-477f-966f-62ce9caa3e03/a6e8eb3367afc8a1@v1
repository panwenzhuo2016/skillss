// 维度 9: 并发请求
async function testConcurrency() {
  console.log('\n🔀 9. 并发请求');

  // 并发查询 managedSpaces
  const promises = Array.from({ length: 5 }, () =>
    GET('/spaceNode/migration/managedSpaces')
  );
  const results = await Promise.all(promises);
  const allOk = results.every(r => r.success === true);
  assert('5个并发 managedSpaces 都成功', allOk);

  // 并发查询版本列表
  if (CONFIG.spaceNodeId) {
    const vPromises = Array.from({ length: 5 }, () =>
      POST('/spaceNode/migration/version/list', {
        spaceNodeId: CONFIG.spaceNodeId,
        status: 1,
      })
    );
    const vResults = await Promise.all(vPromises);
    const vAllOk = vResults.every(r => r.success === true);
    assert('5个并发 version/list 都成功', vAllOk);

    // 数据一致性
    if (vAllOk && vResults[0].data) {
      const firstCount = vResults[0].data.length;
      const allSame = vResults.every(r => r.data.length === firstCount);
      assert('并发 version/list 数据量一致', allSame,
        vResults.map(r => r.data.length));
    }
  }

  // 并发查询 batch
  const bPromises = Array.from({ length: 5 }, (_, i) =>
    GET(`/spaceNode/migration/batch/concurrent-test-${i}`)
  );
  const bResults = await Promise.all(bPromises);
  const bAllOk = bResults.every(r => r.success === true);
  assert('5个并发 batch 查询都成功', bAllOk);
}

// 维度 10: 响应结构一致性
async function testResponseStructure() {
  console.log('\n📦 10. 响应结构一致性');

  // managedSpaces 响应结构
  const spaces = await GET('/spaceNode/migration/managedSpaces');
  assert('managedSpaces 含 success', typeof spaces.success === 'boolean', spaces.success);
  assert('managedSpaces 含 data', spaces.data !== undefined, spaces.data);
  assert('managedSpaces 含 code', spaces.code !== undefined, spaces.code);

  // batch 响应结构
  const batch = await GET('/spaceNode/migration/batch/struct-test');
  assert('batch 含 success', typeof batch.success === 'boolean', batch.success);
  if (batch.success) {
    assert('batch data 含 batchId', batch.data?.batchId !== undefined, batch.data);
    assert('batch data 含 tasks', batch.data?.tasks !== undefined, batch.data);
  }

  // version/list 响应结构
  if (CONFIG.spaceNodeId) {
    const vl = await POST('/spaceNode/migration/version/list', {
      spaceNodeId: CONFIG.spaceNodeId,
      status: 1,
    });
    assert('version/list 含 success', typeof vl.success === 'boolean', vl.success);
    if (vl.success && vl.data && vl.data.length > 0) {
      const item = vl.data[0];
      const requiredFields = ['id', 'snapshotName', 'snapshotCreator', 'snapshotCreateTime', 'snapshotId'];
      for (const field of requiredFields) {
        assert(`version item 含 ${field}`, item[field] !== undefined, item[field]);
      }
    }

    // 正常列表 vs 回收站列表结构一致
    const trash = await POST('/spaceNode/migration/version/list', {
      spaceNodeId: CONFIG.spaceNodeId,
      status: 2,
    });
    assert('回收站列表也是数组', Array.isArray(trash.data), trash.data);
    if (trash.data && trash.data.length > 0) {
      const item = trash.data[0];
      assert('回收站含 snapshotDeleteUser', item.snapshotDeleteUser !== undefined, item);
      assert('回收站含 snapshotDeleteTime', item.snapshotDeleteTime !== undefined, item);
    }
  }
}

// 维度 11: 迁移任务状态枚举验证
async function testMigrationStatusEnum() {
  console.log('\n📊 11. 迁移任务状态枚举');

  // 创建一个迁移任务并检查状态值
  // status: 0=未开始, 1=处理中, 2=已完成, 3=失败
  const createRes = await POST('/spaceNode/migration/createBatchMigrationTask', {
    items: [
      {
        sourceSpaceId: CONFIG.spaceId,
        spaceNodeIds: [CONFIG.spaceNodeId || 1],
      }
    ],
    targetSpaceId: CONFIG.spaceId2 || CONFIG.spaceId,
    isRemained: true,
  });

  if (createRes.success && createRes.data) {
    const batchId = createRes.data;
    // 立即查询，任务可能还未处理
    const batchInfo = await GET(`/spaceNode/migration/batch/${batchId}`);
    if (batchInfo.data?.tasks?.length > 0) {
      const task = batchInfo.data.tasks[0];
      assert('status 在 0-3 范围内', [0, 1, 2, 3].includes(task.status), task.status);
      assert('statusDesc 非空', typeof task.statusDesc === 'string' && task.statusDesc.length > 0, task.statusDesc);

      // 等待处理完成
      await new Promise(r => setTimeout(r, 3000));
      const batchInfo2 = await GET(`/spaceNode/migration/batch/${batchId}`);
      if (batchInfo2.data?.tasks?.length > 0) {
        const task2 = batchInfo2.data.tasks[0];
        assert('等待后 status 仍在 0-3 范围', [0, 1, 2, 3].includes(task2.status), task2.status);
        if (task2.status === 3) {
          assert('失败状态含 errorMessage', task2.errorMessage != null, task2.errorMessage);
        }
      }
    }
  } else {
    console.log('  ⚠️ 创建任务失败，跳过状态枚举验证');
  }
}

// 维度 12: 版本快照列表状态过滤
async function testVersionListStatusFilter() {
  console.log('\n🔍 12. 版本快照列表状态过滤');

  if (!CONFIG.spaceNodeId) {
    console.log('  ⚠️ 无 spaceNodeId，跳过');
    return;
  }

  // status=1 (正常)
  const r1 = await POST('/spaceNode/migration/version/list', {
    spaceNodeId: CONFIG.spaceNodeId,
    status: 1,
  });
  assert('status=1 返回 success', r1.success === true, r1);

  // status=2 (回收站)
  const r2 = await POST('/spaceNode/migration/version/list', {
    spaceNodeId: CONFIG.spaceNodeId,
    status: 2,
  });
  assert('status=2 返回 success', r2.success === true, r2);

  // status=0 (无效值) - 不应报500
  const r3 = await POST('/spaceNode/migration/version/list', {
    spaceNodeId: CONFIG.spaceNodeId,
    status: 0,
  });
  assert('status=0 不报500', r3.code !== 500, r3);

  // status=999 (不存在的状态) - 不应报500
  const r4 = await POST('/spaceNode/migration/version/list', {
    spaceNodeId: CONFIG.spaceNodeId,
    status: 999,
  });
  assert('status=999 不报500', r4.code !== 500, r4);

  // 正常列表和回收站互斥
  if (r1.success && r2.success && r1.data?.length > 0 && r2.data?.length > 0) {
    const normalIds = new Set(r1.data.map(s => s.id));
    const trashIds = new Set(r2.data.map(s => s.id));
    let overlap = false;
    for (const id of normalIds) {
      if (trashIds.has(id)) { overlap = true; break; }
    }
    assert('正常列表和回收站无重叠', !overlap);
  }
}

