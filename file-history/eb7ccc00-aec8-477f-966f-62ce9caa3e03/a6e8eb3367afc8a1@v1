// 维度 5: 特殊字符与注入防护
async function testInjectionAndSpecialChars() {
  console.log('\n🛡️ 5. 注入防护 + 特殊字符');

  // taskId 含特殊字符
  const specialChars = ['%', '\'', '"', '<script>', '&&', '../', '..\\'];
  for (const ch of specialChars) {
    const res = await GET(`/spaceNode/migration/task/${encodeURIComponent(ch)}`);
    assert(`taskId="${ch}" 不报500`, res.code !== 500, res);
  }

  // batchId 含特殊字符
  for (const ch of specialChars) {
    const res = await GET(`/spaceNode/migration/batch/${encodeURIComponent(ch)}`);
    assert(`batchId="${ch}" 不报500`, res.code !== 500, res);
  }

  // SQL 注入尝试 - version/list
  const injections = [
    "' OR 1=1 --",
    "1; DROP TABLE xxx;",
    "' UNION SELECT * FROM users --",
  ];
  for (const payload of injections) {
    const res = await POST('/spaceNode/migration/version/list', {
      spaceNodeId: 1,
      status: 1,
    });
    assert(`version/list SQL注入 "${payload.slice(0, 20)}..." 不报500`, res.code !== 500, res);
  }

  // version/update - name 含特殊字符
  if (CONFIG.spaceNodeId) {
    const listRes = await POST('/spaceNode/migration/version/list', {
      spaceNodeId: CONFIG.spaceNodeId,
      status: 1,
    });
    if (listRes.data && listRes.data.length > 0) {
      const snapshot = listRes.data[0];
      const originalName = snapshot.snapshotName;
      const specialNames = ['<script>alert(1)</script>', "name' OR '1'='1", 'a'.repeat(200)];
      for (const name of specialNames) {
        const res = await POST('/spaceNode/migration/version/update', {
          id: Number(snapshot.id),
          spaceNodeId: CONFIG.spaceNodeId,
          name: name,
        });
        assert(`version/update 特殊名称 "${name.slice(0, 25)}..." 不报500`, res.code !== 500, res);
      }
      // 还原名称
      await POST('/spaceNode/migration/version/update', {
        id: Number(snapshot.id),
        spaceNodeId: CONFIG.spaceNodeId,
        name: originalName,
      });
      console.log(`  ℹ️  已还原快照名称`);
    }
  }
}

