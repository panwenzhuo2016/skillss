package com.yottastudios.ns.collabspace.workspace.service.impl;

import com.baomidou.mybatisplus.core.conditions.query.LambdaQueryWrapper;
import com.baomidou.mybatisplus.core.conditions.query.QueryWrapper;
import com.baomidou.mybatisplus.extension.service.impl.ServiceImpl;
import com.yottastudios.ns.collabspace.workspace.entity.CollabspaceVersionSnapshotEntity;
import com.yottastudios.ns.collabspace.workspace.enums.VersionSnapshotStatusEnum;
import com.yottastudios.ns.collabspace.workspace.mapper.CollabspaceVersionSnapshotMapper;
import com.yottastudios.ns.collabspace.workspace.service.IVersionSnapshotService;
import jakarta.annotation.Resource;
import lombok.extern.slf4j.Slf4j;
import org.springframework.stereotype.Service;

import java.time.LocalDateTime;
import java.util.List;

@Service
@Slf4j
public class VersionSnapshotServiceImpl extends ServiceImpl<CollabspaceVersionSnapshotMapper, CollabspaceVersionSnapshotEntity> implements IVersionSnapshotService {
    @Resource
    CollabspaceVersionSnapshotMapper collabspaceVersionSnapshotMapper;

    @Override
    public CollabspaceVersionSnapshotEntity getByName(String name, Long nodeId) {
        QueryWrapper<CollabspaceVersionSnapshotEntity> queryWrapper = new QueryWrapper<>();
        queryWrapper.lambda().eq(CollabspaceVersionSnapshotEntity::getSnapshotName, name)
                .eq(CollabspaceVersionSnapshotEntity::getNodeId, nodeId);
        List<CollabspaceVersionSnapshotEntity> list = collabspaceVersionSnapshotMapper.selectList(queryWrapper);
        return list.isEmpty() ? null : list.getFirst();
    }

    @Override
    public List<CollabspaceVersionSnapshotEntity> getByNodeId(Long spaceNodeId, Integer status) {
        QueryWrapper<CollabspaceVersionSnapshotEntity> queryWrapper = new QueryWrapper<>();
        queryWrapper.lambda().eq(CollabspaceVersionSnapshotEntity::getSnapshotStatus, status)
                .eq(CollabspaceVersionSnapshotEntity::getNodeId, spaceNodeId);
        return collabspaceVersionSnapshotMapper.selectList(queryWrapper);
    }

    @Override
    public List<CollabspaceVersionSnapshotEntity> getOverTimeSnapshotList() {
        LocalDateTime threshold = LocalDateTime.now().minusDays(30);

        return this.list(new LambdaQueryWrapper<CollabspaceVersionSnapshotEntity>()
                .eq(CollabspaceVersionSnapshotEntity::getSnapshotStatus, VersionSnapshotStatusEnum.DISABLED.getValue())
                .lt(CollabspaceVersionSnapshotEntity::getUpdatedAt, threshold)
        );
    }

    @Override
    public void disableByNodeId(Long nodeId) {
        log.info("[Collabspace][Migration][UPDATE] 禁用节点版本快照, nodeId={}", nodeId);
        this.lambdaUpdate()
                .eq(CollabspaceVersionSnapshotEntity::getNodeId, nodeId)
                .eq(CollabspaceVersionSnapshotEntity::getSnapshotStatus, VersionSnapshotStatusEnum.ENABLED.getValue())
                .set(CollabspaceVersionSnapshotEntity::getSnapshotStatus, VersionSnapshotStatusEnum.DISABLED.getValue())
                .update();
    }
}
