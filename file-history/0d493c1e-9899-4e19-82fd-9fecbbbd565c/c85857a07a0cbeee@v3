<template>
    <OaTemplateContent
        v-loading="isLoading"
        :show-back-btn="true"
        header-:title="`${$t('app.reimbursement')}`"
        :show-header="showHeader"
        :show-footer="true"
        :is-confirm-disabled="isConfirmDisabled"
        class="RMApprovalApplicationManagements"
        @cancel="cancelSubmit"
        @confirm="submitForm"
        @back="cancelSubmit"
    >
        <!-- 申请表单 -->
        <!-- v-model="applicationParams" -->
        <RMForm
            :re-edit-data="reEditData"
            :local-saved-data="selectedLocalContent"
            @changeConfirmDisabled="changeConfirmDisabled"
            @changeReimbursementType="changeApplicationType"
            @onParamsChanged="data => autoSaveContentToLocal({ data })"
            @onFilesChanged="files => autoSaveContentToLocal({ files })"
            @changeApplicationParams="e => (applicationParams = e)"
        />

        <!-- 审批流程展示 -->
        <ProcessCard :path="path" />

        <div v-if="localContent">
            <el-dialog
                :visible.sync="showLocal"
                width="400px"
                :title="`${$t('t544')}`"
                :show-close="false"
                :modal="false"
                center
            >
                <div v-if="$store.state.curSysLang !== 'en'" class="dialogText">{{$t('t_app3_2351',
                    ['上一次',localContent.title])}}</div>
                <div v-if="$store.state.curSysLang === 'en'" class="dialogText">Do you want to restore the automatically saved version from the
                    last {{localContent.title}} ?</div>
                <template #footer>
                    <el-button size="medium" @click="showLocal = false">{{$t('cancel')}}</el-button>
                    <el-button size="medium" type="primary" @click="copyLocalContent">{{$t('t486')}}</el-button>
                </template>
            </el-dialog>
        </div>
    </OaTemplateContent>
</template>

<script lang="ts">
import deepCopy from 'deep-copy'
import _ from 'lodash'
import moment from 'moment'
import { Vue, Component, Prop, Watch, Model, Emit } from 'vue-property-decorator'

import { approvalApis } from '@/apis'
import OaTemplateCItem from '@/app/PC/Common/OaCommTemplate/OaTemplateCItem.vue'
import OaTemplateContent from '@/app/PC/Common/OaCommTemplate/OaTemplateContent.vue'
import { showMessageWarning, showMessageSuccess } from '@/app/PC/Common/ShowMessage/showMessage'
import { getOaStaffMap } from '@/app/PC/StaffPage/utils/StaffMapTS'

import ProcessCard from './components/ProcessCard.vue'
import RMForm from './components/RMForm.vue'
import { applicationRequestParamsData } from './utils/ReimbursementData'

// 避免操作时改变原字典数据
const ARPData: Record<string, Record<string, any>[]> = deepCopy(applicationRequestParamsData)

@Component({
    name: 'ApplicationManagements',

    components: {
        OaTemplateContent,
        OaTemplateCItem,
        ProcessCard,
        RMForm,
    },

    beforeDestroy() {
        if (this.saveCount) {
            clearInterval(this.saveCount)
        }
    },
})
export default class extends Vue {
    @Prop({ type: Object, default: () => {} }) readonly reEditData: Record<string, any>
    @Prop({ type: Boolean, default: true }) readonly showHeader: boolean

    isLoading = false
    path = []
    // 确认提交后按钮置灰，防抖
    isConfirmDisabled = false

    applicationParams: Record<string, any> = {}

    timeCount = null // 请求审批流程的定时器
    saveCount = 0 // 暂存申请内容的定时器
    showLocal = true
    isCopying = false
    selectedLocalContent = {}
    dataToBeSaved: Record<string, any> = { files: [] }

    get localContent() {
        if (localStorage.getItem('RMSaveToLocal') && !this.reEditData) {
            return JSON.parse(localStorage.getItem('RMSaveToLocal'))
        }
        return null
    }

    @Emit('changePageType')
    changePageType(e) {
        return e
    }

    @Watch('applicationParams', { immediate: true, deep: true })
    onApplicationParamsChanged(val) {
        if (!val.process_key) {
            return
        }

        const requestParamsData = ARPData[val.process_key]
        // 必须的参数
        const requireParamsArr = requestParamsData.filter(item => item.isRequired && item.value !== 'files')
        // 在某种关联条件下必须的参数
        const relativeParamsArr = requestParamsData.filter(item => item.isRelative)

        if (this.timeCount) {
            clearTimeout(this.timeCount)
        }
        // 如果没有直接主管/部门主管，直接返回
        const info = this.$store.state.profileInfo
        if (!info.supervisor || !info.direct_supervisor) {
            showMessageWarning('您暂无直接主管/部门主管，请联系小兰维护后再进行申请')
            return
        }

        for (const item of requireParamsArr) {
            if (!val[item.value]) {
                return
            }
            if (item.type === 'Array') {
                if (JSON.stringify(val[item.value]) === '[]') {
                    return
                }
            } else if (item.type === 'Object') {
                if (JSON.stringify(val[item.value]) === '{}') {
                    return
                }
            }
        }

        for (const item of relativeParamsArr) {
            if (item.relative_fun(val[item.relative_value])) {
                if (!val[item.value]) {
                    return
                }
                if (item.type === 'Array') {
                    if (JSON.stringify(val[item.value]) === '[]') {
                        return
                    }
                } else if (item.type === 'Object') {
                    if (JSON.stringify(val[item.value]) === '{}') {
                        return
                    }
                }
            }
        }

        // 发票重复校验
        const invoiceSubmitInfo = this.isInvoiceAbleSubmit()
        if (invoiceSubmitInfo.value) {
            return
        }

        this.timeCount = window.setTimeout(async () => {
            const params: Record<string, any> = {
                process_key: val.process_key,
                context: { ...val },
                decrypt_config: {
                    obj: '$this',
                    decrypt_columns: ['all_nodes.profile'],
                },
                sfuser_id: this.$store.state.userInfo.id,
            }

            delete params.context.process_key
            delete params.context.files

            // 重新编辑增加version参数
            if (this.reEditData?.isReEdit) {
                params.version = this.reEditData.version
            }
            const res = await approvalApis.setPreflightProcessAPI(params)
            if (res) {
                this.handlerPreflight({ res })
            }
        }, 1000)
    }

    async submitForm() {
        // 如果没有直接主管/部门主管，直接返回
        const info = this.$store.state.profileInfo
        if (!info.supervisor || !info.direct_supervisor) {
            showMessageWarning('您暂无直接主管/部门主管，请联系小兰维护后再进行申请')
            this.isConfirmDisabled = false
            return
        }
        if (!this.applicationParams.process_key) {
            this.isConfirmDisabled = false
            return
        }

        const requestParamsData = ARPData[this.applicationParams.process_key]
        const requireParamsArr = requestParamsData.filter(item => item.isRequired && item.value !== 'files')
        const relativeParamsArr = requestParamsData.filter(item => item.isRelative)
        const filesParams = requestParamsData.filter(item => item.value === 'files')[0]?.fileInfo
        let relativeFiles = []
        if (filesParams) {
            relativeFiles = filesParams.filter(item => item.isRelative)
        }
        this.isConfirmDisabled = true

        // 检查信息是否填完整
        for (const item of requireParamsArr) {
            if (!this.applicationParams[item.value]) {
                showMessageWarning(`${this.$t('t566')}`)
                this.isConfirmDisabled = false
                return
            }
            if (item.type === 'Array') {
                if (JSON.stringify(this.applicationParams[item.value]) === '[]') {
                    showMessageWarning(`${this.$t('t566')}`)
                    this.isConfirmDisabled = false
                    return
                }
            } else if (item.type === 'Object') {
                if (JSON.stringify(this.applicationParams[item.value]) === '{}') {
                    showMessageWarning(`${this.$t('t566')}`)
                    this.isConfirmDisabled = false
                    return
                }
            }
        }

        for (const item of relativeParamsArr) {
            if (item.relative_fun(this.applicationParams[item.relative_value])) {
                if (!this.applicationParams[item.value]) {
                    showMessageWarning(`${this.$t('t566')}`)
                    this.isConfirmDisabled = false
                    return
                }
                if (item.type === 'Array') {
                    if (JSON.stringify(this.applicationParams[item.value]) === '[]') {
                        showMessageWarning(`${this.$t('t566')}`)
                        this.isConfirmDisabled = false
                        return
                    }
                } else if (item.type === 'Object') {
                    if (JSON.stringify(this.applicationParams[item.value]) === '{}') {
                        showMessageWarning(`${this.$t('t566')}`)
                        this.isConfirmDisabled = false
                        return
                    }
                }
            }
        }

        // 发票重复校验
        const invoiceSubmitInfo = this.isInvoiceAbleSubmit()
        if (invoiceSubmitInfo.value) {
            this.$message.error(invoiceSubmitInfo.error_msg)
            this.isConfirmDisabled = false
            return
        }

        const params: Record<string, any> = {
            sfuser_id: this.$store.state.userInfo.id,
            process_key: this.applicationParams.process_key,
            context: JSON.parse(JSON.stringify(this.applicationParams)),
        }
        const filesData = []
        if (filesParams && filesParams.length) {
            const requiredFiles = filesParams.filter(item => item.isRequired)
            for (const item of relativeFiles) {
                if (item.relative_fun(this.applicationParams[item.relative_value])) {
                    requiredFiles.push(item)
                }
            }
            if (requiredFiles.length && !this.applicationParams.files) {
                showMessageWarning(`${this.$t('t2405221294')}`)
                this.isConfirmDisabled = false
                return
            }

            if (this.applicationParams.files) {
                this.applicationParams.files
                    .map(item => ({
                        ...item,
                        allFiles: [...item.historyFiles, ...item.upFiles],
                    }))
                    .filter(item => item.allFiles.length)
                    .forEach(item => {
                        item.allFiles.forEach(file => {
                            filesData.push({
                                key: item.value,
                                value: file.uniqueName,
                                isRequired: item.isRequired,
                                name: file.name,
                            })
                        })
                    })
                const lackRequiredFiles: Record<string, any> = _.differenceWith(
                    requiredFiles,
                    filesData,
                    (a, b) => a.value === b.key
                )
                if (lackRequiredFiles.length) {
                    const lackFile = requiredFiles.filter(
                        item => item.value === lackRequiredFiles[0].value
                    )[0]
                    const warningText = lackFile.label ? `${this.$t('t2405221294')}` + ': ' + lackFile.label : `${this.$t('t2405221294')}`
                    showMessageWarning(warningText)
                    this.isConfirmDisabled = false
                    return
                }
            }
            const lackSupplementFiles: Record<string, any> = _.differenceWith(
                filesParams.filter(item => item.lackParams),
                filesData,
                (a, b) => a.value === b.key
            )
            lackSupplementFiles.forEach(file => filesData.push(file.lackParams))
        }

        delete params.context.process_key
        delete params.context.files

        if (filesParams && filesParams.length && filesData.length) {
            params.files = filesData
        }

        const params1 = { ...params }
        params1.decrypt_config = {
            obj: '$this',
            decrypt_columns: ['all_nodes.profile'],
        }

        // 重新编辑增加version参数
        if (this.reEditData?.isReEdit) {
            params1.version = this.reEditData.version
        }
        const res = await approvalApis.setPreflightProcessAPI(params1)
        if (res) {
            if (this.timeCount) {
                clearTimeout(this.timeCount)
            }
            this.handlerPreflight({ res, isSubmit: true, params })
        } else {
            showMessageWarning(`${this.$t('t568')}`)
            this.isConfirmDisabled = false
        }
    }

    // 确认按钮是否可点击
    changeConfirmDisabled(bool) {
        this.isConfirmDisabled = bool
    }
    cancelSubmit() {
        if (this.reEditData?.isReEdit) {
            // 重新编辑
            this.closeReEdit('withoutRefresh')
        } else {
            // 初次请求
            this.changePageType('TableList')
        }
        this.path = []
    }

    initPage() {
        if (this.timeCount) {
            clearTimeout(this.timeCount)
        }
        this.path = []
        this.applicationParams = {}
        this.changeConfirmDisabled(false)
    }

    // 根据报销类型变更页面
    changeApplicationType(type) {
        this.initPage()
        this.applicationParams.process_key = type
    }

    // 关闭重新编辑页面
    closeReEdit(e = undefined) {
        this.$emit('close', e)
    }

    showPath(pathArr) {
        this.path = [...pathArr]
    }

    encryptParams({ params, cc, nodes, allRelativeNicknames, execute_user }) {
        const newParams = _.cloneDeep(params)
        // 自定义抄送人去重
        let existUsers = []
        existUsers = _.flatten([...nodes.map(item => item.operator), ...cc])
        if (newParams.context.extraCCInfo) {
            const allExtraCC = newParams.context.extraCCInfo.ccNames.map(item => item.nickname)
            const extraCC = newParams.context.extraCCInfo.ccNames.filter(item =>
                _.difference(allExtraCC, existUsers).includes(item.nickname)
            )
            newParams.context.extraCCInfo = {
                ccNames: extraCC,
                cc_NCN: extraCC.filter(item => item.sfuser_id).map(item => item.sfuser_id),
                cc_CN: extraCC.filter(item => !item.sfuser_id).map(item => item.nickname),
            }
            newParams.cc_ids = [...newParams.context.extraCCInfo.cc_NCN]
            newParams.cc_nickname = [...newParams.context.extraCCInfo.cc_CN]
        }

        if (newParams.cc_nickname) {
            newParams.hash_filter = {
                obj: '$this',
                columns: ['cc_nickname'],
            }
        }

        // 额外添加的抄送人也需授权
        const extraCC = newParams.context.extraCCInfo
            ? newParams.context.extraCCInfo.ccNames.map(item => item.nickname)
            : []
        const context_non_encrypt_columns = Object.keys(newParams.context)
            .filter(item => item !== 'extraCCInfo')
            .map(item => 'context.' + item)

        newParams.encrypt_config = {
            res_type: 'sfuser',
            obj: '$this',
            non_encrypt_columns: [
                'process_key',
                'files',
                'sys_lang',
                'version_info',
                'version',
                'cc_ids',
                'cc_nickname',
                ...context_non_encrypt_columns,
            ],
        }
        newParams.authorize_config = {
            res_type: 'sfuser',
            sfusers: _.uniq(_.flatten([...cc, ...nodes.map(item => item.operator), ...extraCC, ...execute_user])),
            users: [],
            emails: [],
            items: [this.$store.state.userInfo.id],
            operations: ['response', 'send_email'],
            expire_time: 3600 * 24 * 365,
        }
        newParams.info = {
            nicknames: { cc, nodes },
            allRelativeNicknames,
        }

        return newParams
    }

    // 提交申请后刷新数据
    async refreshData() {
        // 发起成功后更新待办事项数量
        const res = await approvalApis.getRMTodoListAPI()
        if (res) {
            this.$store.commit('setRMTodoList', res)
        }
        clearInterval(this.saveCount)
        localStorage.removeItem('RMSaveToLocal')
    }

    // 发起一个新的申请流程
    async takeProcess(params) {
        this.isLoading = true

        if (this.reEditData?.isReEdit) {
            // 重新编辑
            params.request_id = Number(this.reEditData.application_request_id)
            params.context.version = this.reEditData.version
            params.encrypt_config.non_encrypt_columns.push('request_id')
            const res = await approvalApis.setReEditAPI(params)
            if (res) {
                showMessageSuccess(`${this.$t('t564')}`)
                this.closeReEdit()
                this.refreshData()
            } else {
                this.changeConfirmDisabled(false)
            }
        } else {
            // 初次请求
            const res = await approvalApis.setStartProcessAPI(params)
            if (res) {
                showMessageSuccess(`${this.$t('t562')}`)
                this.cancelSubmit()
                this.refreshData()
            } else {
                this.changeConfirmDisabled(false)
            }
        }

        this.isLoading = false
    }

    handlerPreflight({ res, isSubmit = false, params = {} }) {
        const path = []
        let cc = []
        let nodes = []
        const templateNodes = []
        let allRelativeNicknames = {}
        const { nodes_special_nicknames, profile, cc_special_nicknames } = res.all_nodes
        if (!this.reEditData?.isReEdit) {
            // 如果是首次申请,相关花名根据后端预检接口确定
            allRelativeNicknames = { ...nodes_special_nicknames, ...profile, ...cc_special_nicknames }
        } else {
            // 如果是重新编辑,相关花名取首次申请时存储的数据
            allRelativeNicknames = this.reEditData.allRelativeNicknames
        }
        nodes = res.nodes.map((item, key) => ({
            operator_type: item.operator_type,
            operator: allRelativeNicknames[item.operator_type],
            order: key,
        }))
        cc = _.difference(
            _.flatten(res.cc_types.map(item => allRelativeNicknames[item])),
            nodes.map(item => item.operator)
        )

        // 如果相邻两个审批流人员相同，流程图中保留一个
        nodes.forEach(item => {
            if (!templateNodes.length) {
                templateNodes.push({ ...item })
            } else {
                templateNodes[templateNodes.length - 1].operator !== item.operator
                    ? templateNodes.push({ ...item })
                    : ''
            }
        })
        path.push({ cc, nodes: templateNodes })
        this.showPath(path)
        if (isSubmit) {
            let execute_user = res?.dynamic_nicknames?.jira_confluence_executor ?? []
            const submitParams = this.encryptParams({ params: params, cc, nodes, allRelativeNicknames,execute_user })
            this.takeProcess(submitParams)
        }
    }

    autoSaveContentToLocal({ files, data }) {
        this.saveCount = window.setTimeout(() => {
            if (data) {
                this.dataToBeSaved = data
            } else if (files) {
                const filesData = []
                if (files) {
                    files
                        .map(item => ({
                            ...item,
                            allFiles: [...item.historyFiles, ...item.upFiles],
                        }))
                        .filter(item => item.allFiles.length)
                        .forEach(item => {
                            item.allFiles.forEach(file => {
                                filesData.push({
                                    key: item.value,
                                    value: file.uniqueName,
                                    isRequired: item.isRequired,
                                    name: file.name,
                                })
                            })
                        })
                }
                this.dataToBeSaved.files = filesData
            }

            getOaStaffMap('processes').then(OAMap => {
                const contentSaveToLocal = JSON.stringify({
                    time: moment().format('YYYY-MM-DD HH:mm'),
                    title: OAMap.getMapByName('processes').filter(
                        item => item.value === this.dataToBeSaved.process_key
                    )[0].label,
                    content: this.dataToBeSaved,
                })
                localStorage.setItem('RMSaveToLocal', contentSaveToLocal)
            })
        }, 5000)
    }
    copyLocalContent() {
        this.selectedLocalContent = JSON.parse(localStorage.getItem('RMSaveToLocal')).content
        this.showLocal = false
    }

    // 判断发票是否重复
    isInvoiceAbleSubmit() {
        let invoiceSubmitInfo = {
            value: false,
            error_msg: '',
        }
        const reimbursement_detail = this.applicationParams.reimbursement_detail

        const isRepeatWithDatabase = !!reimbursement_detail.some(item =>
            item.invoice.find(o => o.isRepeatWithDatabase)
        )
        const isRepeatWithOtherInvoice = !!reimbursement_detail.some(item =>
            item.invoice.find(o => o.isRepeatWithOtherInvoice)
        )
        const title = reimbursement_detail
            .flatMap(item => item.invoice.filter(o => o.notMatchConfig).map(o => o.title))
            .join('、')

        if (isRepeatWithDatabase) {
            invoiceSubmitInfo = {
                value: true,
                error_msg: `${this.$t('pq23060704')}`,
            }
        } else if (isRepeatWithOtherInvoice) {
            invoiceSubmitInfo = {
                value: true,
                error_msg: `${this.$t('pq23060705')}`,
            }
        } else if (title) {
            invoiceSubmitInfo = {
                value: true,
                error_msg: `${this.$t('pq23091409', { invoiceTitle: title })}`,
            }
        }
        return invoiceSubmitInfo
    }
}
</script>

