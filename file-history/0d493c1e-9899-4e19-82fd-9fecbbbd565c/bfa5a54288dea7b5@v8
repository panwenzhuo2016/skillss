    public function remark(int $stateId, int $actionId, string $remark = '')
    {
        // 备注为空，则不显示
        if (!$remark) {
            return;
        }

        $validActionIds = [Action::APPROVE, Action::REJECT]; // 当前只允许同意或者驳回添加备注，因为这个备注要渲染到流程图节点中
        if (!in_array($actionId, $validActionIds)) {
            return;
        }

        WorkflowRemark::create([
            'request_id' => $this->requestModel->id,
            'state_id' => $stateId,
            'action_id' => $actionId,
            'remark' => $remark,
        ]);
    }

    /**
     * @param array $conditions
     * @param array $stateBranches
     * @param int $currentState
     * @param int $sfuserId
     * @throws Exception
     * @return int
     */
    public function getNextState(array $conditions, array $stateBranches, int $currentState, int $sfuserId = 0): int
    {
        foreach ($conditions as $condition) {
            $data = [];
            $attrs = $condition['attrs'];
            // 从 request_data 中获取必要参数
            foreach ($attrs as $attr) {
                $data[$attr] = Arr::get($this->requestModel->data, $attr);
            }
            $data['process_key'] = $this->requestModel->process_key;

            $extraUserTypes = Arr::get($condition, Condition::EXTRA_FIXED_USER_TYPES_KEY, []);
            $extraFixedUserTypes = [];
            foreach ($extraUserTypes as $extraUserType) {
                $extraFixedUserTypes[$extraUserType] = Stakeholder::fetchSfuserIdsViaType($extraUserType, $this->requestModel->id, true);
            }
            $data[Condition::EXTRA_FIXED_USER_TYPES_KEY] = $extraFixedUserTypes;

            // 获取对应的状态索引值
            $index = call_user_func_array([Condition::class, $condition['method']], [$data]);
            $currentState = $stateBranches[$index];
        }
        return $currentState;
    }

    public function xp4(&$temp)
    {
        // xp4 是区分执行的，展示还是用原来的申请类型。
        if (!empty($temp['basic']['data']['apply_type']) && in_array($temp['basic']['data']['apply_type'], P4vAccess::P4V_APPLY_TYPES_NEW)) {
            $temp['basic']['data']['apply_type'] = $temp['basic']['data']['old_apply_type'] ?? $temp['basic']['data']['apply_type'];
        }
    }

    // 1
    public function dealFile(array $basic): array
    {
        if (!empty($basic['files'])) {
            $uniqueValues = []; // 用于跟踪已出现的value
            $filteredFiles = [];

            foreach ($basic['files'] as $file) {
                // 当前value是否已存在
                if (!isset($uniqueValues[$file['value']])) {
                    $filteredFiles[] = $file;        // 保留首次出现的条目
                    $uniqueValues[$file['value']] = true; // 标记为已存在
                }
            }
            $basic['files'] = $filteredFiles; // 覆盖原数组
        }
        if (!empty($basic['history_files'])) {
            $uniqueValues = []; // 用于跟踪已出现的value
            $filteredFiles = [];

            foreach ($basic['history_files'] as $file) {
                // 当前value是否已存在
                if (!isset($uniqueValues[$file['value']])) {
                    $filteredFiles[] = $file;        // 保留首次出现的条目
                    $uniqueValues[$file['value']] = true; // 标记为已存在
                }
            }
            $basic['history_files'] = $filteredFiles; // 覆盖原数组
        }
        return $basic;
    }

    public static function needStartCC(string $processKey): bool
    {
        return !self::notNeedStartCC($processKey);
    }
    public static function notNeedStartCC(string $processKey): bool
    {
        if ($processKey == \App\Workflows\Common\Registry::OFFICE_SUPPLIES) {
            return true;
        }
        if ($processKey == \App\Workflows\Common\Registry::CROSS_ACCESS) {
            return true;
        }
        if ($processKey == \App\Workflows\Common\Registry::IT_PERMISSION) {
            return true;
        }
        return false;
    }
