    /**
     * 添加参与者。
     *
     * @param mixed $sfuserIds
     * @param string $type
     * @param bool $cc
     * @throws UserNotFoundException
     */
    public function addStakeholders($sfuserIds, string $type = WorkflowRequestStakeholder::DIRECT_SUPERVISOR_TYPE, bool $cc = false) // 直接主管基本都要参与到环节中，因此设置为默认值
    {
        $sfuserIds = Arr::wrap($sfuserIds);
        $cc = (int)$cc;
        if ($cc) {
            // 审批人和抄送人为同一人时，取消抄送
            $noNeedCcs = WorkflowRequestStakeholder::where('request_id', $this->requestModel->id)->where('cc', 0)
                ->where('type', '<>', WorkflowRequestStakeholder::REQUESTER_TYPE)->pluck('user_id')->unique()->toArray();
            $sfuserIds = array_diff($sfuserIds, $noNeedCcs);
        }
        // 将指定用户添加到可见人列表
        foreach ($sfuserIds as $sfuserId) {
            // 引入 cachedUserIds 来避免多次无用查询
            if (!in_array($sfuserId, $this->cachedUserIds)) {
                // For multi-site, 先不检查 sfuserid 是否存在
                // $sfuser = Sfuser::find($sfuserId);
                // if (!$sfuser) {
                //     // 如果不存在，直接抛出一个异常
                //     static::$messageBag['missing_userid'] = $sfuserId;
                //     throw new UserNotFoundException(__('my_api.user_of_type_with_id_not_found', ['uType' => $type, 'uId' => $sfuserId]));
                // }
                $this->cachedUserIds[] = $sfuserId;
            }

            WorkflowRequestStakeholder::firstOrCreate(
                ['user_id' => $sfuserId, 'request_id' => $this->requestModel->id, 'type' => $type, 'cc' => $cc],
                ['user_id' => $sfuserId, 'request_id' => $this->requestModel->id, 'type' => $type, 'cc' => $cc, 'created_at' => Carbon::now(), 'updated_at' => Carbon::now()],
            );
        }
        if ($cc) {
            // 抄送未读 +1
            $ccType = in_array($this->requestModel->process_key, Registry::REIMBURSEMENT_TYPE) ? 'reimburse_cc' : 'oa_cc';
            NotifyNumberService::app()->modifyMultiple(array_unique($sfuserIds), $ccType);
        }
    }

    public function cancelStakeholders($sfuserIds, string $type = WorkflowRequestStakeholder::DIRECT_SUPERVISOR_TYPE, bool $cc = false) // 直接主管基本都要参与到环节中，因此设置为默认值
    {
        $sfuserIds = Arr::wrap($sfuserIds);
        $cc = (int)$cc;
        if ($cc) {
            // 审批人和抄送人为同一人时，取消抄送
            $noNeedCcs = WorkflowRequestStakeholder::where('request_id', $this->requestModel->id)->where('cc', 0)
                ->where('type', '<>', WorkflowRequestStakeholder::REQUESTER_TYPE)->pluck('user_id')->unique()->toArray();
            $sfuserIds = array_diff($sfuserIds, $noNeedCcs);
        }
        // 将指定用户添加到可见人列表
        foreach ($sfuserIds as $sfuserId) {
            WorkflowRequestStakeholder::where('user_id', $sfuserId)->where('request_id', $this->requestModel->id)
                ->where('type', $type)->where('cc', $cc)->delete();
        }
        if ($cc) {
            // 抄送未读 -1
            $ccType = in_array($this->requestModel->process_key, Registry::REIMBURSEMENT_TYPE) ? 'reimburse_cc' : 'oa_cc';
            NotifyNumberService::app()->modifyMultiple(array_unique($sfuserIds), $ccType, -1);
        }
    }

    /**
     * 移除参与者。
     *
     * @param mixed $sfuserIds
     * @param string $type
     */
    public function removeStakeholders($sfuserIds, string $type = WorkflowRequestStakeholder::DIRECT_SUPERVISOR_TYPE)
    {
        $sfuserIds = Arr::wrap($sfuserIds);
        // 从列表中移除指定可见人
        foreach ($sfuserIds as $sfuserId) {
            // 不存在则创建，使用 REPLACE INTO 会不会性能好点？
            $wr = WorkflowRequestStakeholder::where(
                ['user_id' => $sfuserId, 'request_id' => $this->requestModel->id, 'type' => $type],
            )->first();
            if ($wr) {
                $wr->delete();
            }
        }
    }

