    /**
     * @throws Exception
     */
    public function requestTags(): array
    {
        $request = $this->requestModel->toArray();
        $tags = [];
        switch ($request['process_key']) {
            // @noinspection all
            case Registry::SICK_LEAVE:
                // 病假时，判断是否首次，Redis 优化还没做，暂时从 DB 走
                $data = IndividualData::getData($request['user_id']); // 获取当前操作人的个人数据
                if (array_key_exists('first_sick_leave', $data) && $data['first_sick_leave']
                    && $data['first_sick_leave'] == $this->requestModel->id) {
                    // 代表是首次病假，保存进去
                    $tags[] = Tag::FIRST_SICK_LEAVE;
                }
            // no break
            case Registry::PERSONAL_LEAVE:
            case Registry::ANNUAL_LEAVE:
            case Registry::MATERNITY_INSPECTION_LEAVE:
            case Registry::ELDERLY_CARE_LEAVE: // 育儿假特殊
            case Registry::PARENTAL_LEAVE: // 育儿假特殊
            case Registry::HOME_WORKING: // 居家办公
                $totalHours = Arr::get($request['data'], 'total_hours');
                $days = $totalHours / 8;
                if ($days >= 7) {
                    $tags[] = Tag::GREATER_THAN_7_DAYS;
                } elseif ($days >= 3) {
                    $tags[] = Tag::GREATER_THAN_3_DAYS;
                }
                break;
            // 自然日
            case Registry::WEDDING_LEAVE:
            case Registry::MATERNITY_LEAVE:
            case Registry::PATERNITY_LEAVE:
            case Registry::BEREAVEMENT_LEAVE:
                $totalHours = Arr::get($request['data'], 'total_hours');
                $days = $totalHours / 24;
                if ($days >= 7) {
                    $tags[] = Tag::GREATER_THAN_7_DAYS;
                } elseif ($days >= 3) {
                    $tags[] = Tag::GREATER_THAN_3_DAYS;
                }
                break;
            // 房补-非首次
            case Registry::RENT_ALLOWANCE:
                $is_first = Arr::get($request['data'], 'first', 0);
                if (!$is_first) {
                    $tags[] = Tag::NOT_FIRST_RENT_ALLOWANCE;
                }
                break;
            // IT 标记已执行
            case Registry::OFFICE_SUPPLIES:
            case Registry::CROSS_ACCESS:
            case Registry::IT_PERMISSION:
                $markedExecuted = Arr::get($request['data'], SpecialAction::KEY_FOR_MARKED_EXECUTED, 0);
                if ($markedExecuted) {
                    $tags[] = Tag::MARKED_EXECUTED;
                } elseif ($request['current_state_id'] == State::COMPLETED) {
                    $tags[] = Tag::MARKED_NOT_EXECUTED;
                }
                break;
            // 报销标记已执行
            case Registry::OVERWORK_TAXI_REIMBURSEMENT:
            case Registry::TEST_EXPAT_REIMBURSEMENT:
            case Registry::TEAM_BUILDING_REIMBURSEMENT:
            case Registry::TRAFFIC_REIMBURSEMENT:
            case Registry::TRIP_REIMBURSEMENT:
            case Registry::ART_OUTSOURCING_REIMBURSEMENT:
            case Registry::MATERIAL_REIMBURSEMENT:
            case Registry::ADMINISTRATION_REIMBURSEMENT:
            case Registry::PERSONNEL_REIMBURSEMENT:
            case Registry::NUCLEIC_ACID_TEST_REIMBURSEMENT:
            case Registry::MARKET_BUSINESS_REIMBURSEMENT:
                if ($request['current_state_id'] == State::COMPLETED) {
                    $reimbursement = WorkflowReimbursement::where('request_id', $request['id'])->first();
                    if ($reimbursement && $reimbursement->is_executed == 1) {
                        $tags[] = Tag::MARKED_EXECUTED;
                    } else {
                        $tags[] = Tag::MARKED_NOT_EXECUTED;
                    }
                }
                break;
            // p4v 已执行
            case Registry::P4V_ACCESS:
                if ($request['current_state_id'] == State::COMPLETED) {
                    $p4vExtraN = WorkflowP4vExtra::where('request_id', $request['id'])->where('is_executed', -1)
                        ->first();
                    if ($p4vExtraN) {
                        $tags[] = Tag::MARKED_UN_EXECUTED;
                    }
                    $p4vExtraE = WorkflowP4vExtra::where('request_id', $request['id'])->where('is_executed', 1)
                        ->first();
                    $p4vExtraNE = WorkflowP4vExtra::where('request_id', $request['id'])->where('is_executed', 0)
                        ->first();
                    if ($p4vExtraE && $p4vExtraNE) {
                        $tags[] = Tag::MARKED_PARTIAL_EXECUTED;
                    }
                    if ($p4vExtraE && !$p4vExtraNE) {
                        $tags[] = Tag::MARKED_EXECUTED;
                    }
                    if (!$p4vExtraE && $p4vExtraNE) {
                        $tags[] = Tag::MARKED_NOT_EXECUTED;
                    }
                }
                break;
            case Registry::JIRA_CONFLUENCE:
            case Registry::EB:
            case Registry::YA:
            case Registry::X_JIRA_CONFLUENCE:
            case Registry::AI_TOOLS:
            case Registry::GCP:
            case Registry::ONLY_OFFICE:
                $tags = Tag::getOtherTags($request, $tags);
                break;
            default:
                break;
        }

        $convertToPersonalLeave = Arr::get($request['data'], SpecialAction::KEY_FOR_CONVERTING_TO_PERSONAL_LEAVE, false);

        if ($convertToPersonalLeave) {
            $tags[] = Tag::CONVERT_TO_PERSONAL_LEAVE;
        }

        if (!$convertToPersonalLeave && $request['need_supplements'] && !$request['has_supplements']) { // 如果是变更为事假了，这个标签就不展示了
            $tags[] = Tag::LACK_SUPPLEMENT_FILES;
        }

        return $tags;
    }

