    /**
     * 添加相关的抄送人。
     *
     * @throws UserNotFoundException
     * @throws Exception
     */
    public function cc()
    {
        // 抄送的时候，应该从 request 中获取抄送的人的 ID，因此针对脏数据，必须处理一遍，添加上 ccIds
        /**
         * @see \App\Console\Commands\Upgrade\PutCCsIntoWorkflowRequest
         */
        $data = $this->requestModel->data;
        $sfuserIds = Arr::get($data, WorkflowRequest::CCS_KEY, []);
        // 自定义抄送人
        if ($customCcs = Arr::get($data, WorkflowRequest::CUSTOM_CC_KEY, [])) {
            $sfuserIds[WorkflowRequest::CUSTOM_CC_KEY] = $customCcs;
        }
        foreach ($sfuserIds as $type => $sfuserId) {
            $this->addStakeholders($sfuserId, $type, true);
        }
    }

    public function cancelCC()
    {
        // 抄送的时候，应该从 request 中获取抄送的人的 ID，因此针对脏数据，必须处理一遍，添加上 ccIds
        /**
         * @see \App\Console\Commands\Upgrade\PutCCsIntoWorkflowRequest
         */
        $data = $this->requestModel->data;
        $sfuserIds = Arr::get($data, WorkflowRequest::CCS_KEY, []);
        // 自定义抄送人
        if ($customCcs = Arr::get($data, WorkflowRequest::CUSTOM_CC_KEY, [])) {
            $sfuserIds[WorkflowRequest::CUSTOM_CC_KEY] = $customCcs;
        }
        foreach ($sfuserIds as $type => $sfuserId) {
            $this->cancelStakeholders($sfuserId, $type, true);
        }
    }

