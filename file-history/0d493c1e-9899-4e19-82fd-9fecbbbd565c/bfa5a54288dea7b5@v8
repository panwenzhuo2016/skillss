    /**
     * 返回与请求相关的抄送者，会动态判断并获取所有 sfuser 的 ID.
     *
     * @throws Exception
     * @return array
     */
    public function getCcIds(): array
    {
        $index = 0;
        if (!empty($this->carbonCopyConditions)) {
            $data = [];
            $attrs = $this->carbonCopyConditions['attrs'];
            // 从 request_data 中获取必要参数
            foreach ($attrs as $attr) {
                $data[$attr] = Arr::get($this->requestModel->data, $attr);
            }
            $data['process_key'] = $this->requestModel->process_key;

            $extraUserTypes = Arr::get($this->carbonCopyConditions, Condition::EXTRA_FIXED_USER_TYPES_KEY, []);
            $extraFixedUserTypes = [];
            foreach ($extraUserTypes as $extraUserType) {
                $extraFixedUserTypes[$extraUserType] = Stakeholder::fetchSfuserIdViaFixedType($this->requestModel->user_id, $extraUserType, $this->requestModel->process_key);
            }
            $data[Condition::EXTRA_FIXED_USER_TYPES_KEY] = $extraFixedUserTypes;
            // 获取对应的状态索引值
            $index = call_user_func_array([CarbonCopyCondition::class, $this->carbonCopyConditions['method']], [$data]);
        }

        $ccs = $this->ccs[$index];
        $ccIds = [];
        foreach ($ccs as $type) {
            if (in_array($type, WorkflowRequestStakeholder::FIXED_MAPS)) {
                // 涉及到提交给谁时，需要以流程发起者的身份去查找
                $sfuserIds = Arr::wrap(Stakeholder::fetchSfuserIdViaFixedType($this->requestModel->user_id, $type, $this->requestModel->process_key));
            } else {
                $sfuserIds = Stakeholder::fetchSpecialSfuserId($type, $this->requestModel->user_id, $this->requestModel->data);
            }
            $ccIds = array_merge($ccIds, [$type => $sfuserIds]);
        }

        return $ccIds;
    }

