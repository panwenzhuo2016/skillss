    /**
     * 根据给定的流程 key 和用户 ID 生成一个 WorkflowRequest Model.
     *
     * @throws ReflectionException
     * @throws WorkflowException
     * @throws Throwable
     */
    public static function make(string $processKey, int $sfuserId, array $requestData = [], array $files = [], array $customCcs = []): self
    {
        // 确保 Process Key 存在
        if (!array_key_exists($processKey, (array)Registry::STATE_MAPS)) {
            throw new WorkflowException(__('my_api.process_key_not_exist', ['processKey' => $processKey]));
        }

        // 确保 sfuser 存在
        try {
            Sfuser::findOrFail($sfuserId);
        } catch (ModelNotFoundException $e) {
            throw new UserNotFoundException(__('my_api.sfuser_with_id_not_found', ['sfuserId' => $sfuserId]), $e->getCode(), $e->getPrevious());
        }

        // 检查 files 格式
        [$errNo, $needSupplementFiles, $hasSupplementFiles] = static::checkFiles($files);
        if ($errNo != 0) {
            throw new WorkflowException(__('my_api.check_files_failed', ['err' => $errNo]));
        }

        // 获取当前流程的 START 状态，每个 WorkflowRequest 都必须从 START 状态开始
        /**
         * @see RegistryTest
         */
        $stateClassName = Registry::STATE_MAPS[$processKey]['class'];
        $stateClass = new ReflectionClass($stateClassName);
        $startState = $stateClass->getConstant('START');

        $version = Helper::getWorkflowVersion($processKey);
        // static::checkInput($processKey, $sfuserId, $requestData);

        // 开始事务，生成相关的记录
        db()->beginTransaction();
        try {
            /**
             * 生成 workflow request，这里需要用到 no 和 context，查看下面引用的单元测试类。
             *
             * @see RegistryTest
             */
            $workflowRequest = WorkflowRequest::create([
                'process_key' => $processKey,
                'no' => Helper::getCurrentNo(),
                'user_id' => $sfuserId,
                'data' => $requestData,
                'files' => $files,
                'history_files' => [],
                'current_state_id' => $startState,
                'version' => $version,
                'need_supplements' => $needSupplementFiles,
                'has_supplements' => $hasSupplementFiles,
            ]);

            // 创建完成后，初始化一个当前类的实例，用于后续其他操作
            $wr = new WorkflowRequestService($workflowRequest->id, $sfuserId);

            // 将自己作为发起者添加到 Stakeholder 中
            $wr->addStakeholders($sfuserId, WorkflowRequestStakeholder::REQUESTER_TYPE);

            // 扫描 action roles 配置项，将每一个角色对应的人存入 request action 中
            foreach ($wr->actionRoles as $currentState => $actions) {
                foreach ($actions as $actionId => $operatorType) {
                    if (in_array($operatorType, WorkflowRequestStakeholder::FIXED_MAPS)) {
                        // 固定人，直接获取
                        $data = [
                            'request_id' => $workflowRequest->id,
                            // 必须以发起者的身份查找操作者，而不是当前实例的人
                            'operator_id' => Stakeholder::fetchSfuserIdViaFixedType($workflowRequest->user_id, $operatorType, $processKey),
                            'operator_type' => $operatorType,
                            'state_id' => $currentState,
                            'action_id' => $actionId,
                            'clicked' => 0,
                            'history_clicked' => 0,
                            'is_active' => 0,
                        ];
                        $wr->addRequestActioner($data);
                    } else {
                        // 找出特殊花名
                        $sfuserIds = Stakeholder::fetchSpecialSfuserId($operatorType, $workflowRequest->user_id, $requestData);
                        foreach ($sfuserIds as $operatorId) {
                            $wr->addRequestActioner([
                                'request_id' => $workflowRequest->id,
                                'operator_id' => $operatorId,
                                'operator_type' => $operatorType,
                                'state_id' => $currentState,
                                'action_id' => $actionId,
                                'clicked' => 0,
                                'history_clicked' => 0,
                                'is_active' => 0,
                            ]);
                        }
                    }
                }
            }

            // 自定义抄送人
            if (!empty($customCcs)) {
                $wr->appendData(WorkflowRequest::CUSTOM_CC_KEY, $customCcs);
            }
            // 由于流程要记住一开始的人，因此我们要在一开始就扫描出 ccIds，并存入到 data 中，这样就可以保证后续跟踪到的始终是
            // 当前流程相关的抄送者，于是我们的查找逻辑就改为先查找 action 表，命中返回，失败则查找 request 表
            $tagUsers = $wr->getTagTypes();
            $wr->appendData(WorkflowRequest::SEE_TAGS_KEY, $tagUsers);
            $ccIds = $wr->getCcIds();
            $wr->appendData(WorkflowRequest::CCS_KEY, $ccIds, true);

            // 激活 START 状态下的 Action
            $wr->activateAction($startState);

            // 自动以请求者的身份（该实例中的 sfuserModel 的 id 就是请求者的 id）执行一次同意操作，这样状态就会流转到下一个阶段
            $wr->performAction(Action::APPROVE);

            db()->commit();
        } catch (Exception $e) {
            db()->rollBack();
            throw $e;
        }

        // 触发生成的事件
        $wr->requestCreated();
        return $wr;
    }

    /**
     * 对用户输入进行检查。
     *
     * @param string $processKey
     * @param int $sfuserId
     * @param array $context
     * @throws Exception|ReflectionException|WorkflowException
     */
    public static function checkInput(string $processKey, int $sfuserId, array &$context, int $version = 0)
    {
        // @see RegistryTest
        if (!in_array($processKey, array_keys(Registry::STATE_MAPS))) {
            throw new WorkflowException(__('my_api.invalid_process_key'));
        }
        if ($processKey == Registry::HOME_WORKING) {
            throw new WorkflowException(__('my_api.no_home_work'));
        }

        // 针对某些审批，判断 Knock id 是否绑定
        if (in_array($processKey, Registry::REQUIRE_KNOCK_NOTIFICATIONS)) {
            if (Auth::belongsToCurrentSite() && empty(Auth::user()->knock_id)) {
                throw new WorkflowException(__('my_api.knock_id_not_bound'));
            }
        }

        $stateClassName = Registry::STATE_MAPS[$processKey]['class'];
        if (!$stateClassName) {
            throw new WorkflowException(__('my_api.invalid_process_key'));
        }
        $stateClass = new ReflectionClass($stateClassName);

        if ($version <= 0) {
            $version = Helper::getWorkflowVersion($processKey);
        }

        // 获取到 $stateClass 之后，检查是否存在 rules 方法
        if ($stateClass->hasMethod('rules')) {
            // 存在的话，获取出 rules，并且执行一次验证
            switch ($processKey) {
                case Registry::CROSS_ACCESS:
                    $newInstance = new $stateClassName($version, Arr::get($context, 'target_project'));
                    break;
                case Registry::SUPPLEMENT:
                    $newInstance = new $stateClassName($version, Arr::get($context, 'request_id', -1));
                    break;
                default:
                    $newInstance = new $stateClassName($version);
                    break;
            }
            $rules = $newInstance->rules();
            $messages = [];
            if ($stateClass->hasMethod('messages')) {
                $messages = $newInstance->messages();
            }
            $validator = Validator::make($context, $rules, $messages);

            // catch exception
            try {
                $validator->fails();
                $validated = $validator->validate(); // 这里出错的话会抛出异常
            } catch (ValidationException $e) {
                $messageBag = $e->validator->getMessageBag()->toArray();
                throw new WorkflowException(my_json_encode($messageBag));
            }
        }

        if (in_array($processKey, Registry::NATURAL_DAY_TYPE)) {
            $context['start_datetime'] = date('Y-m-d', strtotime($context['start_datetime']));
            $context['end_datetime'] = date('Y-m-d', strtotime($context['end_datetime']));
        }

        // 新增晚到数据列表
        if (in_array($processKey, Registry::UNNATURAL_DAY_TYPE)) {
            $startDateTime = date('Y-m-d 00:00:00', strtotime($context['start_datetime']));
            $endDateTime = date('Y-m-d 00:00:00', strtotime($context['end_datetime']));
            $lateList = WorkflowDataExtra::alias('wde')->leftJoin('workflow_requests', 'workflow_requests.id', '=', 'wde.request_id')->where('wde.process_key', Registry::LATE_WORK_OVERTIME)
                ->where('sfuser_id', $sfuserId)
                ->where('start_time', '>=', $startDateTime)
                ->where('end_time', '<=', $endDateTime)
                ->where('workflow_requests.current_state_id', State::COMPLETED)
                ->select(['request_id', 'workflow_requests.no', DB::Raw("DATE_FORMAT(start_time,'%Y-%m-%d') as 'late_date'")])->get()->toArray();
            $context['work_late_list'] = $lateList;
        }

        CheckWorkflowInput::app()->checkInput($processKey, $version, $sfuserId, $context);
    }

    /**
     * 检查上传的 files 的状态。
     *
     * @param array $files
     * @return array
     */
    public static function checkFiles(array $files): array
    {
        [$errNo, $needSupplements, $hasSupplements] = [0, count($files) > 0, false];

        if (!$needSupplements) { // 不需要补充材料，不用检查是否包含补交材料了
            return [0, $needSupplements, $hasSupplements];
        }

        $filtered = Arr::where($files, function ($file) {
            return !Arr::accessible($file) || !Arr::has($file, ['key', 'value']); // 必须包含 key 和 value
        });

        if (!empty($filtered)) { // 存在不包含 key/value attr 的，直接返回 error
            return [1, false, false];
        }

        // value 不为空的数目与 files 总数相等时表示材料已补交，这里不检查 broken link
        $hasSupplements = count(Arr::where($files, function ($file) {
            return !empty($file['value']);
        })) == count($files);

        return [$errNo, $needSupplements, $hasSupplements];
    }

    /**
     * 预检一个流程，生成流程图.
     * @param string $processKey
     * @param int $sfuserId
     * @param array $context
     * @param int $version
     * @throws ReflectionException*@throws Exception
     * @throws RequestNotFoundException
     * @throws Exception
     * @throws WorkflowException
     * @return array
     */
    public static function preflightProcess(string $processKey, int $sfuserId, array $context = [], int $version = 0): array
    {
        // 确保 Process Key 存在
        if (!array_key_exists($processKey, (array)Registry::STATE_MAPS)) {
            throw new WorkflowException(__('my_api.process_key_not_exist', ['processKey' => $processKey]));
        }

        // 确保 sfuser 存在
        try {
            Sfuser::findOrFail($sfuserId);
        } catch (ModelNotFoundException $e) {
            throw new RequestNotFoundException(__('my_api.sfuser_with_id_not_found', ['sfuserId' => $sfuserId]), $e->getCode(), $e->getPrevious());
        }

        $stateClassName = Registry::STATE_MAPS[$processKey]['class'];
        $stateClass = new ReflectionClass($stateClassName);

        $startStateId = $stateClass->getConstant('START');
        $completedStateId = $stateClass->getConstant('COMPLETED');

        $actionsReflectionProp = $stateClass->getProperty('actions');
        $conditionsReflectionProp = $stateClass->getProperty('conditions');
        $actionRolesReflectionProp = $stateClass->getProperty('actionRoles');
        $ccsReflectionProp = $stateClass->getProperty('ccs');
        $ccConditionsReflectionProp = $stateClass->getProperty('carbonCopyConditions');

        if (!$actionsReflectionProp || !$conditionsReflectionProp || !$actionRolesReflectionProp || !$ccsReflectionProp) {
            throw new WorkflowException('failed to fetch some props through Reflection');
        }

        $actionsReflectionProp->setAccessible(true);
        $conditionsReflectionProp->setAccessible(true);
        $actionRolesReflectionProp->setAccessible(true);
        $ccsReflectionProp->setAccessible(true);
        $ccConditionsReflectionProp->setAccessible(true);

        if ($version <= 0) {
            $version = Helper::getWorkflowVersion($processKey);
        }

        switch ($processKey) {
            case Registry::CROSS_ACCESS:
                $sc = new $stateClassName($version, Arr::get($context, 'target_project'));
                break;
            case Registry::SUPPLEMENT:
                $sc = new $stateClassName($version, Arr::get($context, 'request_id'));
                break;
            default:
                $sc = new $stateClassName($version);
                break;
        }
        $actions = $actionsReflectionProp->getValue($sc);
        $conditions = $conditionsReflectionProp->getValue($sc);
        $actionRoles = $actionRolesReflectionProp->getValue($sc);
        $ccs = $ccsReflectionProp->getValue($sc);
        $carbonCopyConditions = $ccConditionsReflectionProp->getValue($sc);

        // Nodes
        $nodes = [];
        $currentState = $startStateId;
        // 从 START 开始走，一直 APPROVE，遇到 COMPLETED 停止，如何避免死循环
        while ($currentState != $completedStateId) {
            $operator_type = $actionRoles[$currentState][Action::APPROVE];
            array_push($nodes, [
                'state_id' => $currentState,
                'operator_type' => $operator_type,
            ]);
            $states[] = $currentState;
            // 不存在 Approve 操作，直接 break
            if (!Arr::has($actions[$currentState], Action::APPROVE)) {
                break;
            }
            // 决定下一个 STATE
            $stateBranches = $actions[$currentState][Action::APPROVE];
            $nextState = $stateBranches[0];
            if (count($stateBranches) > 1) { // 超过 1 个分支，确定走向哪一个分支
                $current_conditions = $conditions[$currentState][Action::APPROVE];
                foreach ($current_conditions as $condition) {
                    $data = [];
                    $attrs = $condition['attrs'];
                    // 从 request_data 中获取必要参数
                    foreach ($attrs as $attr) {
                        $data[$attr] = Arr::get($context, $attr);
                    }
                    $data['process_key'] = $processKey;

                    $extraUserTypes = Arr::get($condition, Condition::EXTRA_FIXED_USER_TYPES_KEY, []);
                    $extraFixedUserTypes = [];
                    foreach ($extraUserTypes as $extraUserType) {
                        $extraFixedUserTypes[$extraUserType] = Stakeholder::fetchSfuserIdViaFixedType($sfuserId, $extraUserType, $processKey);
                    }
                    $data[Condition::EXTRA_FIXED_USER_TYPES_KEY] = $extraFixedUserTypes;

                    // 获取对应的状态索引值
                    $index = call_user_func_array([Condition::class, $condition['method']], [$data]);
                    $nextState = $stateBranches[$index];
                }
            }
            $currentState = $nextState;
        }

        // CCs
        $index = 0;
        if (!empty($carbonCopyConditions)) {
            $data = [];
            $attrs = $carbonCopyConditions['attrs'];
            // 从 request_data 中获取必要参数
            foreach ($attrs as $attr) {
                $data[$attr] = Arr::get($context, $attr);
            }
            $data['process_key'] = $processKey;

            $extraUserTypes = Arr::get($carbonCopyConditions, Condition::EXTRA_FIXED_USER_TYPES_KEY, []);
            $extraFixedUserTypes = [];
            foreach ($extraUserTypes as $extraUserType) {
                $extraFixedUserTypes[$extraUserType] = Stakeholder::fetchSfuserIdViaFixedType($sfuserId, $extraUserType, $processKey);
            }
            $data[Condition::EXTRA_FIXED_USER_TYPES_KEY] = $extraFixedUserTypes;

            // 获取对应的状态索引值
            $index = call_user_func_array([CarbonCopyCondition::class, $carbonCopyConditions['method']], [$data]);
        }

        // 当前流程中整个审批链路中涉及到的所有的人员类型
        $types = array_values(array_unique(Arr::flatten($actionRoles)));
        $alltypes = array_values(array_unique(Arr::flatten($ccs)));

        return ['nodes' => $nodes, 'cc_types' => $ccs[$index], 'context' => $context, 'types' => $types, 'all_cc_types' => $alltypes];
    }

