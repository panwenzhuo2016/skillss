    /**
     * 返回审批流中的节点。
     *
     * @throws Exception
     * @return array
     */
    public function nodes(): array
    {
        $states = [];
        $currentState = $this->startStateId;
        // 从 START 开始走，一直 APPROVE，遇到 COMPLETED 停止，如何避免死循环
        while ($currentState != $this->completedStateId) {
            $states[] = $currentState;
            // 不存在 Approve 操作，直接 break
            if (!Arr::has($this->actions[$currentState], Action::APPROVE)) {
                break;
            }
            // 决定下一个 STATE
            $stateBranches = $this->actions[$currentState][Action::APPROVE];
            $nextState = $stateBranches[0];
            if (count($stateBranches) > 1) { // 超过 1 个分支，确定走向哪一个分支
                $conditions = $this->conditions[$currentState][Action::APPROVE];
                $nextState = $this->getNextState($conditions, $stateBranches, $currentState, $this->requestModel->user_id);
            }
            $currentState = $nextState;
        }

        $res = WorkflowRequestAction::where('request_id', $this->requestModel->id)
            ->where('action_id', Action::APPROVE)
            ->whereIn('state_id', $states)
            ->get(['state_id', 'operator_id', 'operator_type', 'clicked', 'updated_at'])->toArray();

        // 来回通过、驳回的场景并不多，因此我们就直接取出所有记录，在内存中获取出最近的一条
        $remarks = WorkflowRemark::where('request_id', $this->requestModel->id)
            ->where('expired', 0)
            ->orderBy('id') // 按 ID 升序排序，后面用了 keyBy，这么做可以保证最新的记录可以顺利地取出来
            ->select(['state_id', 'action_id', 'remark'])
            ->get()->keyBy('state_id')->toArray();

        // 历史备注
        $historyRemarks = WorkflowRemark::where('request_id', $this->requestModel->id)->where('expired', 1)
            ->select(['state_id', 'action_id', 'remark', 'created_at'])->get();

        // 以 states 数组里的顺序排序
        $stateIndex = array_flip($states);
        usort($res, function ($a, $b) use ($stateIndex) {
            return $stateIndex[$a['state_id']] - $stateIndex[$b['state_id']];
        });

        $lastOperatorId = 0;
        $markDuplicated = [];
        // 如果存在备注，处理返回的流程图节点
        foreach ($res as $key => &$item) {
            if (Arr::has($remarks, $item['state_id'])) {
                $item['remarks'] = Arr::only($remarks[$item['state_id']], ['action_id', 'remark']);
                // 存在备注的时候，我们需要手工更改 clicked 状态，保证前端读取这个时间
                // 因为驳回的时候，审批通过的节点 clicked 仍然为 0
                $item['clicked'] = 1;
            }
            $stateHistoryRemark = $historyRemarks->where('state_id', $item['state_id'])->sortBy('created_at')->toArray();
            if (!empty($stateHistoryRemark)) {
                $item['history_remarks'] = array_map(function ($one) {
                    return Arr::only($one, ['action_id', 'remark', 'created_at']);
                }, array_values($stateHistoryRemark));
            }
            if ($item['operator_id'] == $lastOperatorId) {
                $markDuplicated[] = $key;
            }
            $lastOperatorId = $item['operator_id'];
            unset($item['operator_id']);
        }
        unset($item);

        // 合并 operator id 相同的节点
        $res = array_filter($res, function ($value, $key) use ($markDuplicated) {
            return !in_array($key, $markDuplicated);
        }, ARRAY_FILTER_USE_BOTH);

        return array_values($res);
    }

