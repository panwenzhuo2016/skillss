    /**
     * 创建一个流程完成后的操作。
     */
    public function requestCreated()
    {
        switch ($this->requestModel->process_key) {
            case Registry::SICK_LEAVE:
                // 病假时，判断是否首次，Redis 优化还没做，暂时从 DB 走
                $data = IndividualData::getData($this->sfuserModel->id); // 获取当前操作人的个人数据
                if (!array_key_exists('first_sick_leave', $data) || !$data['first_sick_leave']) {
                    // 代表是首次病假，保存进去
                    $data['first_sick_leave'] = $this->requestModel->id;
                    IndividualData::setData($this->sfuserModel->id, $data);
                }
                break;
        }

        if ($this->requestModel->has_supplements) {
            $paths = Arr::pluck($this->requestModel->files, 'value');
            PublicFileStorePath::whereIn('file_store_path', $paths)->update([
                'table_id' => $this->requestModel->id,
                'table_name' => 'workflow_requests',
                'type' => 'annex',
                'operator_id' => $this->requestModel->user_id,
            ]);
        }

        // 旧发票失效， 新发票入库， 记录invoice_no
        InvoiceService::app()->disableRequestInvoices($this->requestModel->id);
        if (in_array($this->requestModel->process_key, Registry::REIMBURSEMENT_TYPE)) {
            $details = Arr::get($this->requestModel->data, 'reimbursement_detail', []);
            foreach ($details as &$invoices) {
                foreach ($invoices['invoice'] as &$invoice) {
                    if (Arr::get($invoice, 'need_to_be_identified', 0)) {    // 需要识别的发票
                        if (Arr::get($invoice, 'invoice_no')) { // 有编号，是驳回/撤回后，重新发起且未重新上传的发票
                            $isIdentified = Arr::get($invoice, 'is_identified', 0);
                            if ($isIdentified && InvoiceService::app()->checkRepeatedInvoice($invoice['invoice_number'])) {
                                throw new Exception("The invoice number is repeated, its invoice_no is {$invoice['invoice_no']}");
                            }
                            Invoice::whereInvoiceNo($invoice['invoice_no'])->update(['is_on' => $isIdentified ? 1 : 0, 'is_visible' => 1]); // 是否识别看传参，在流程中必可见
                        } else {
                            $invoiceInfo = InvoiceService::app()->putInvoiceIntoLibrary($invoice['invoice_name'] ?? '', $invoice['buyerName'] ?? '', $invoice['invoice_number'] ?? '', $invoice['is_identified'], '', $this->requestModel->id, $invoice);
                            if ($invoiceInfo && $invoiceInfo['sub_code'] != Invoice::ERR_OK) {
                                $message = "invoice_name:{$invoice['invoice_name']}, invoice_number:{$invoice['invoice_number']}, request_id:{$this->requestModel->id}, err_code: {$invoiceInfo['sub_code']}, the invoice is repeated.";
                                Log::error($message);
                                throw new Exception($message);
                            }
                            $invoice['invoice_no'] = $invoiceInfo['invoice_no'];
                        }
                    }
                }
                unset($invoice);
            }
            unset($invoices);
            $newData = $this->requestModel->data;
            $newData['reimbursement_detail'] = $details;
            $this->getRequest()->update(['data' => $newData]);
        }

        // 如果是其他AI权限开通审批, 创建的时候给待执行表写入数据
        if (in_array($this->requestModel->process_key, Registry::OTHER_PERMISSION_TYPE)) {
            OtherPermissionExecute::updateOrCreate(
                ['request_id' => $this->requestModel->id],
                [
                    'request_id' => $this->requestModel->id,
                    'process_key' => $this->requestModel->process_key,
                    'is_execute' => 0,
                ]
            );
        }
        // 给当前 actioner 发送邮件
    }

    /**
     * 修改代办数目。
     */
    public function alterNotifyNum(int $currentActionId, int $currentState, int $nextState)
    {
        $service = NotifyNumberService::app();
        $issued = in_array($this->requestModel->process_key, Registry::REIMBURSEMENT_TYPE) ? 'reimburse_issued' : 'oa_issued';
        $toBeApproved = in_array($this->requestModel->process_key, Registry::REIMBURSEMENT_TYPE) ? 'reimburse_to_be_approved' : 'oa_to_be_approved';

        // 发起申请
        if ($currentState == State::START && $currentActionId == Action::APPROVE) {
            $service->modifyIndividual($this->requestModel->user_id, $issued); // 我发起的 +1
        }

        // 目前状态在审批中，且非催办
        if (!in_array($currentState, State::COMMON_TYPES) && $currentActionId != Action::URGE) {
            // 撤回或驳回
            if (in_array($currentActionId, [Action::CANCEL, Action::REJECT])) {
                $service->modifyIndividual($this->requestModel->user_id, $issued, -1); // 我发起的 -1
            }

            $requestAction = WorkflowRequestAction::where('request_id', $this->requestModel->id)->where('state_id', $currentState)
                ->where('operator_type', '<>', 'requester')->first();
            if ($requestAction != null) {
                $service->modifyIndividual($requestAction->operator_id, $toBeApproved, -1); // 待我审批 -1
            }
        }

        // 下一个状态在审批中，且非催办
        if (!in_array($nextState, State::COMMON_TYPES) && $currentActionId != Action::URGE) {
            $requestAction = WorkflowRequestAction::where('request_id', $this->requestModel->id)->where('state_id', $nextState)->where('is_active', 1)
                ->where('operator_type', '<>', 'requester')->first();
            if ($requestAction != null) {
                $service->modifyIndividual($requestAction->operator_id, $toBeApproved); // 待我审批 +1
            }
        }

        // 审批完成, 抄送在 cc 中实现
        if ($nextState == State::COMPLETED) {
            $service->modifyIndividual($this->requestModel->user_id, $issued, -1); // 我发起的 -1

            // 缺少材料
            if ($this->requestModel->need_supplements && !$this->requestModel->has_supplements) {
                $service->modifyIndividual($this->requestModel->user_id, 'oa_my_supplement'); // 待我补交材料 +1

                WorkflowRequestStakeholder::where(['request_id' => $this->requestModel->id, 'cc' => 0])
                    ->whereIn('type', [WorkflowRequestStakeholder::SSC_TYPE, WorkflowRequestStakeholder::RENT_ALLOWANCE_DIRECT_SUPERVISOR_TYPE])
                    ->pluck('user_id')->unique()->each(function ($sfuserId) use ($service) {
                        $service->modifyIndividual($sfuserId, 'oa_supplement'); // 待员工补充材料 +1
                    });
            }

            if ($this->requestModel->process_key == Registry::SUPPLEMENT) {
                // 更新个人待我补交材料
                $service->setOaMySupplement($this->requestModel->user_id);

                $linkRequest = Arr::get($this->requestModel->data, 'link_request');
                WorkflowRequestStakeholder::where(['request_id' => $linkRequest, 'cc' => 0])
                    ->whereIn('type', [WorkflowRequestStakeholder::SSC_TYPE, WorkflowRequestStakeholder::RENT_ALLOWANCE_DIRECT_SUPERVISOR_TYPE])
                    ->pluck('user_id')->unique()->each(function ($sfuserId) use ($service) {
                        $service->setOaSupplement($sfuserId); // 更新个人待员工补充材料
                    });
            }

            // 如果是其他 权限开通审批, 创建的时候 找到执行人，给我的执行加1
            if (in_array($this->requestModel->process_key, Registry::OTHER_PERMISSION_TYPE)) {
                // 找到执行人，给我的执行加1
                $idss = (new HrApprovalService())->getOtherIds($this->requestModel->process_key);
                // 对每个执行人进行操作加1
                foreach ($idss as $sfuserId) {
                    NotifyNumberService::app()->modifyIndividual($sfuserId, 'oa_execute'); // 我的执行 +1
                }
            }
        }
    }

    /**
     * 执行完毕一个动作。
     *
     * @throws Throwable|WorkflowException
     */
    public function actionPerformed(int $currentActionId, int $currentState, int $nextState)
    {
        $service = new ActionPerformedService($this->requestModel);

        // 通用的删除触发操作
        if ($currentActionId == Action::DELETE) {
            switch ($this->requestModel->process_key) {
                case Registry::BUSINESS_TRIP:
                    WorkflowDataExtra::where('request_id', $this->requestModel->id)
                        ->where('sfuser_id', $this->requestModel->user_id)
                        ->delete();
                    break;
                case Registry::SUPPLEMENT:
                    WorkflowSupplementExtra::where('request_id', $this->requestModel->id)
                        ->where('link_request', Arr::get($this->requestModel->data, 'request_id'))
                        ->delete();
                    break;
                case Registry::ONLY_OFFICE:
                case Registry::JIRA_CONFLUENCE:
                case Registry::EB:
                case Registry::YA:
                case Registry::X_JIRA_CONFLUENCE:
                case Registry::AI_TOOLS:
                case Registry::GCP:
                case Registry::MATTERMOST:
                    OtherPermissionExecute::where('request_id', $this->requestModel->id)->delete();
                    break;
                default:
                    break;
            }
        }

        // 通用的撤回和驳回的触发操作
        if ($currentActionId == Action::CANCEL || $currentActionId == Action::REJECT) {
            if (in_array($this->requestModel->process_key, Registry::REIMBURSEMENT_TYPE)) { // 报销审批流相关发票失效
                InvoiceService::app()->disableRequestInvoices($this->requestModel->id);
            }
            switch ($this->requestModel->process_key) {
                case Registry::ELDERLY_CARE_LEAVE:
                    $service->elderlyCareLeaveCancel($currentState);
                    break;
                case Registry::MEAL_ALLOWANCE:
                    MealAllowanceLog::where('sfuser_id', $this->requestModel->user_id)
                        ->where('year', Arr::get($this->requestModel->data, 'year', date('Y', strtotime('+1 month'))))
                        ->where('month', Arr::get($this->requestModel->data, 'month', date('m', strtotime('+1 month'))))
                        ->where('request_id', $this->requestModel->id)
                        ->delete();
                    break;
                case Registry::OVERWORK_TAXI_REIMBURSEMENT:
                    $dates = data_get($this->requestModel->data, 'reimbursement_detail.*.dates.*.activity_date');
                    if (empty($dates)) {
                        $dates = array_column(Arr::get($this->requestModel->data, 'reimbursement_detail'), 'activity_date');
                    }
                    ReimbursementCabDateState::cancelReimbursementCab($this->requestModel->user_id, $dates);
                    break;
                case Registry::TRIP_REIMBURSEMENT:
                    $dates = array_column(Arr::get($this->requestModel->data, 'reimbursement_detail'), 'activity_date');
                    $dates = array_unique($dates);
                    ReimbursementTripDate::where('sfuser_id', $this->requestModel->user_id)->whereIn('use_date', $dates)->delete();
                    break;
                case Registry::MAKEUP_ATTENDANCE:
                case Registry::LATE_WORK_OVERTIME:
                case Registry::LATE_UNDERGROUND:
                case Registry::OTHER_LATE_ARRIVAL:
                    WorkflowDataExtra::where('request_id', $this->requestModel->id)
                        ->where('sfuser_id', $this->requestModel->user_id)
                        ->delete();
                    break;
                case Registry::BUSINESS_TRIP:
                    $service->deleteWorkflowDetail();
                    break;
                case Registry::WORK_ON_WEEKEND:
                    // 请假撤回
                case Registry::SICK_LEAVE:
                case Registry::WEDDING_LEAVE:
                case Registry::BEREAVEMENT_LEAVE:
                case Registry::MATERNITY_LEAVE:
                case Registry::PATERNITY_LEAVE:
                case Registry::MATERNITY_INSPECTION_LEAVE:
                    $service->deleteCommonLeave();
                    break;
                case Registry::BREASTFEEDING_LEAVE:
                    $service->deleteBreastFeedingLeave();
                    break;
                case Registry::PARENTAL_LEAVE:
                    $service->deleteParentalLeave($currentState);
                    break;
                case Registry::PERSONAL_LEAVE:
                    $service->deletePersonalLeave($currentState);
                    break;
                case Registry::ANNUAL_LEAVE:
                    $service->deleteAnnualLeave($currentState);
                    break;
                // 居家办公（防疫）撤回
                case Registry::HOME_WORKING:
                    $service->deleteHomeWorking($currentState);
                    break;
                case Registry::DEDUCTION:
                    $service->deleteDeduction($currentState);
                    break;
                default:
                    break;
            }
        }

        switch ($this->requestModel->process_key.implode(':', [$currentActionId, $currentState, $nextState])) {
            // 补交材料 - 同意 - 待 SSC 审批 - 完成
            case Registry::SUPPLEMENT.implode(':', [Action::APPROVE, State::START, State::SUPPLEMENT_SUPERVISOR_PENDING]):
                $linkRequestId = Arr::get($this->requestModel->data, 'request_id', 0);
                WorkflowSupplementExtra::updateOrCreate([
                    'request_id' => $this->requestModel->id,
                    'link_request' => $linkRequestId,
                ], [
                    'request_id' => $this->requestModel->id,
                    'link_request' => $linkRequestId,
                    'link_process_key' => WorkflowRequest::findOrFail($linkRequestId)->process_key,
                ]);
                break;
            case Registry::SUPPLEMENT.implode(':', [Action::APPROVE, State::SUPPLEMENT_SUPERVISOR_PENDING, State::COMPLETED]):
                $service->supplementComplete();
                break;
            case Registry::MEAL_ALLOWANCE.implode(':', [Action::APPROVE, State::START, State::COMPLETED]):
                MealAllowanceLog::updateOrCreate([
                    'sfuser_id' => $this->requestModel->user_id,
                    'year' => Arr::get($this->requestModel->data, 'year', date('Y', strtotime('+1 month'))),
                    'month' => Arr::get($this->requestModel->data, 'month', date('m', strtotime('+1 month'))),
                ], [
                    'sfuser_id' => $this->requestModel->user_id,
                    'year' => Arr::get($this->requestModel->data, 'year', date('Y', strtotime('+1 month'))),
                    'month' => Arr::get($this->requestModel->data, 'month', date('m', strtotime('+1 month'))),
                    'request_id' => $this->requestModel->id,
                    'allowance_type' => Arr::get($this->requestModel->data, 'choice', MealAllowanceLog::CHOICE_MONEY),
                    'source' => 1,
                ]);
                break;
            case Registry::RENT_ALLOWANCE.implode(':', [Action::APPROVE, State::ADMIN_SUPERVISOR_PENDING, State::COMPLETED]):
                $service->rentAllowanceComplete();
                break;
            case Registry::OFFICE_SUPPLIES.implode(':', [Action::APPROVE, State::START, State::SUPERVISOR_PENDING]):
                $service->officeSuppliesStart();
                break;
            case Registry::CROSS_ACCESS.implode(':', [Action::APPROVE, State::START, State::SPECIAL_PROJECT_SUPERVISOR_PENDING]):
                WorkflowCrossAccess::updateOrCreate([
                    'request_id' => $this->requestModel->id,
