    /**
     * 获取流程详情的方法、注意标签、动作、特殊动作已按当前用户身份进行了过滤。
     *
     * @param mixed $read
     * @param mixed $includes
     * @throws Exception
     */
    public function detail($read = false, $includes = []): array
    {
        $basic = $this->requestModel->toArray();
        $basic = $this->dealFile($basic);
        // 1 1.26 新增，如果是自动处理发版晚到，则不显示节点记录
        $isAuto = !empty($basic['data']['remark']) && $basic['data']['remark'] === WorkflowRequestService::AUTO_REMARK;
        if ($isAuto) {
            $basic['files'] = [];
            $basic['history_files'] = [];
            $basic['info'] = [
                'allRelativeNicknames' => [
                    'requester' => 'system',
                ],
                'nicknames' => [
                    'cc' => [],
                    'nodes' => [
                        [
                            'operator_type' => 'system',
                            'operator_id' => 0,
                            'nickname' => 'system',
                        ],
                    ],
                ],
            ];
            return [
                'basic' => $basic, // 流程基本信息
                // 1
                'nodes' => [
                    ['clicked' => 1, 'operator_type' => 'system', 'state_id' => State::COMPLETED, 'operator_id' => 0,
                        'updated_at' => $basic['created_at'], ],
                ], // 流程节点记录
                'actions' => [], // 当前用户可以操作的 action
                'cc_types' => [], // ccIds
                'carbon_copied' => false,
                'tags' => [],
                'un_excuted_reason' => [],
                'special_actions' => [],
                'relative_request' => $this->relativeRequestInfo($this->requestModel->process_key),
            ];
        }

        if ($read) {
            $readCnt = WorkflowRequestStakeholder::where([
                'request_id' => $this->requestModel->id, 'user_id' => $this->sfuserModel->id, 'is_read' => 0, 'cc' => 1,
            ])->count();
            if ($readCnt) {
                $cc = in_array($this->requestModel->process_key, Registry::REIMBURSEMENT_TYPE) ? 'reimburse_cc' : 'oa_cc';
                NotifyNumberService::app()->modifyIndividual($this->sfuserModel->id, $cc, -1 * $readCnt); // 抄送未读 -1
            }

            // 一个人在一个流程中可能出现多次，因此我们并不知道精准定位到他是以什么身份进入的
            // 这里直接将当前用户针对该流程所有的记录都设置为已读
            WorkflowRequestStakeholder::where('request_id', $this->requestModel->id)
                ->where('user_id', $this->sfuserModel->id)
                ->update(['is_read' => 1]);
        }

        $ret = [];

        $tags = [];
        $specialActions = [];

        // 只有申请者和 SSC 可以看到标签
        $requesterId = $this->requestModel->user_id;

        // 已经发起的流程，对应的 SSC 的查找以流程发起时的为准，但是有可能存在 SSC 是抄送者，所以先以操作者查找，找不到再根据旧有的逻辑进行查找
        $sscId = Stakeholder::fetchSfuserIdsViaType(WorkflowRequestStakeholder::SSC_TYPE, $this->requestModel->id);
        $currUserId = $this->sfuserModel->id;
        $rentSupervisorId = -1;
        if ($this->requestModel->process_key == Registry::RENT_ALLOWANCE) {
            $rentSupervisorId = Stakeholder::fetchSfuserIdsViaType(WorkflowRequestStakeholder::RENT_ALLOWANCE_DIRECT_SUPERVISOR_TYPE, $this->requestModel->id);
        }
        $itSupervisorId = -1;
        if (in_array($this->requestModel->process_key, Registry::IT_TYPE)) {
            $type = Arr::get($this->actionRoles[State::IT_SUPERVISOR_PENDING], Action::APPROVE);
            // IT 审批第一版没有做流程控制, 如果找不到对应的主管就是第一版的, 下面会返回 null
            $itSupervisorId = Stakeholder::fetchSfuserIdsViaType($type, $this->requestModel->id, true, false);
        }
        $reimbursementPersonnel = [];
        if (in_array($this->requestModel->process_key, Registry::REIMBURSEMENT_TYPE)) {
            $types = WorkflowRequestStakeholder::REIMBURSEMENT_SUPERVISOR_TYPES;
            $types[] = WorkflowRequestStakeholder::REIMBURSEMENT_CC_TYPE;
            foreach ($types as $type) {
                $reimbursementPersonnel = array_merge(
                    $reimbursementPersonnel,
                    Stakeholder::fetchSfuserIdsViaType($type, $this->requestModel->id, false, false)
                );
            }
        }

        if ($sscId == $currUserId) {
            $requestTags = $this->requestTags();
            if (in_array(Tag::LACK_SUPPLEMENT_FILES, $requestTags)) {
                // 缺少材料，则直接追加两个特殊动作
                $specialActions = [
                    SpecialAction::CONVERT_TO_PERSONAL_LEAVE, SpecialAction::APPEND_SUPPLEMENT_FILES,
                ];
            }
            $tags = $requestTags;
        } elseif ($requesterId == $currUserId) {
            $requestTags = $this->requestTags();
            if (in_array(Tag::LACK_SUPPLEMENT_FILES, $requestTags)) {
                $specialActions = [
                    // 追加补交材料的动作
                    SpecialAction::APPEND_SUPPLEMENT_FILES,
                ];
            }
            $tags = array_values(array_intersect($requestTags, Tag::AVAILABLE_BY_REQUESTER_TYPE));
        } elseif ($currUserId == $rentSupervisorId) {
            $requestTags = $this->requestTags();
            if (in_array(Tag::LACK_SUPPLEMENT_FILES, $requestTags)) {
                // 缺少材料，则直接追加两个特殊动作
                $specialActions = [
                    SpecialAction::APPEND_SUPPLEMENT_FILES,
                ];
            }
            $tags = $requestTags;
            $specialActions[] = SpecialAction::HR_STOP_RENT_ALLOWANCE;
        } elseif (in_array($currUserId, $reimbursementPersonnel)) {
            $requestTags = $this->requestTags();
            $tags = $requestTags;
        } elseif ($currUserId == $itSupervisorId) {
            $requestTags = $this->requestTags();
            $tags = $requestTags;
        }

        // 取消执行原因
        $un_excuted_reason = [];
        if (in_array($this->requestModel->process_key, Registry::OTHER_PERMISSION_TYPE)) {
            $tags = $this->requestTags();
            $un_excuted_reason = $this->request_un_excuted_reasons();
        }

        $isLocked = $this->requestModel->is_locked;
        if ($isLocked) {
            $specialActions = array_diff($specialActions, SpecialAction::BANNED_WHEN_LOCKED_TYPE);
        }

        if (empty($includes)) {
            $basic = $this->requestModel->toArray();
            $basic = $this->dealFile($basic);
            $ret = [
                'basic' => $basic, // 流程基本信息
                'nodes' => $this->nodes(), // 流程节点记录
                'actions' => ($isLocked) ? [] : $this->validActions(), // 当前用户可以操作的 action
                'cc_types' => Arr::flatten($this->getCcTypes()), // ccIds
                'carbon_copied' => !empty($this->getCarbonCopiedIds()),
                'tags' => $tags,
                'un_excuted_reason' => $un_excuted_reason,
                'special_actions' => ($this->requestModel->current_state_id == State::COMPLETED) ? $specialActions : [],
                'relative_request' => $this->relativeRequestInfo($this->requestModel->process_key),
            ];
            if ($this->requestModel->process_key == Registry::RENT_ALLOWANCE) {
                $ret['rent_allowance_status'] = ($isLocked) ? 1 : ($this->requestModel->current_state_id == State::COMPLETED ? 2 : 3);
                Arr::has($ret, 'basic.data.first') && Arr::forget($ret, 'basic.data.first');
            } elseif ($this->requestModel->process_key == Registry::LATE_WORK_OVERTIME && !array_key_exists('relative_dates', $this->requestModel->data)) {
                $ret['is_yesterday_deploy'] = Helper::isYesterdayDeployDay(Arr::get($this->requestModel->data, 'relative_date'), $this->requestModel->user_id);
            } elseif ($this->requestModel->process_key == Registry::CROSS_ACCESS) {
                $ret['basic']['data']['current_project_name'] = Helper::getLocalProjectName($ret['basic']['data']['current_project']);
                $ret['basic']['data']['target_project_name'] = Helper::getCrossProjectName($ret['basic']['data']['target_project']);
            } elseif ($this->requestModel->process_key == Registry::P4V_ACCESS) {
                $ret['dynamic_nicknames'] = Stakeholder::specialNicknames([WorkflowRequestStakeholder::P4V_EXECUTER_TYPE], $this->requestModel->user_id, $this->requestModel->data);
            } elseif ($this->requestModel->process_key == Registry::ONLY_OFFICE) {
                $ret['dynamic_nicknames'] = Stakeholder::specialNicknames([WorkflowRequestStakeholder::ONLY_OFFICE_EXECUTOR_TYPE], $this->requestModel->user_id, $this->requestModel->data);
            } elseif ($this->requestModel->process_key == Registry::JIRA_CONFLUENCE) {
                $ret['dynamic_nicknames'] = Stakeholder::specialNicknames([WorkflowRequestStakeholder::JIRA_CONFLUENCE_EXECUTOR_TYPE], $this->requestModel->user_id, $this->requestModel->data);
            } elseif ($this->requestModel->process_key == Registry::X_JIRA_CONFLUENCE) {
                $ret['dynamic_nicknames'] = Stakeholder::specialNicknames(
                    [WorkflowRequestStakeholder::X_JIRA_CONFLUENCE_EXECUTOR_TYPE],
                    $this->requestModel->user_id,
                    $this->requestModel->data
                );
            } elseif ($this->requestModel->process_key == Registry::AI_TOOLS) {
                $ret['dynamic_nicknames'] = Stakeholder::specialNicknames([WorkflowRequestStakeholder::AI_TOOLS_EXECUTOR_TYPE], $this->requestModel->user_id, $this->requestModel->data);
            } elseif ($this->requestModel->process_key == Registry::GCP) {
                $ret['dynamic_nicknames'] = Stakeholder::specialNicknames([WorkflowRequestStakeholder::GCP_EXECUTOR_TYPE], $this->requestModel->user_id, $this->requestModel->data);
            } elseif ($this->requestModel->process_key == Registry::EB) {
                $ret['dynamic_nicknames'] = Stakeholder::specialNicknames(
                    [WorkflowRequestStakeholder::EB_EXECUTOR_TYPE],
                    $this->requestModel->user_id,
                    $this->requestModel->data
                );
            } elseif ($this->requestModel->process_key == Registry::YA) {
                $ret['dynamic_nicknames'] = Stakeholder::specialNicknames(
                    [WorkflowRequestStakeholder::YA_EXECUTOR_TYPE],
                    $this->requestModel->user_id,
                    $this->requestModel->data
                );
            } elseif ($this->requestModel->process_key == Registry::MATTERMOST) {
                $ret['dynamic_nicknames'] = Stakeholder::specialNicknames([WorkflowRequestStakeholder::MATTERMOST_EXECUTOR_TYPE], $this->requestModel->user_id, $this->requestModel->data);
            }
            // 获取详情页数据的 token 需要在控制器单独添加到 decrypt_config，这里直接 unset 掉
            Arr::has($ret, 'basic.token') && Arr::forget($ret, 'basic.token');
            Arr::has($ret, 'basic.data.'.WorkflowRequest::CCS_KEY) && Arr::forget($ret, 'basic.data.'.WorkflowRequest::CCS_KEY);
            Arr::has($ret, 'basic.data.'.WorkflowRequest::CUSTOM_CC_KEY) && Arr::forget($ret, 'basic.data.'.WorkflowRequest::CUSTOM_CC_KEY);
            Arr::has($ret, 'basic.data.'.WorkflowRequest::SEE_TAGS_KEY) && Arr::forget($ret, 'basic.data.'.WorkflowRequest::SEE_TAGS_KEY);

            return $ret;
        }

        if (in_array('basic', $includes)) {
            $ret['basic'] = $this->requestModel->toArray();
            Arr::has($ret, 'basic.token') && Arr::forget($ret, 'basic.token');
            Arr::has($ret, 'basic.data.'.WorkflowRequest::CCS_KEY) && Arr::forget($ret, 'basic.data.'.WorkflowRequest::CCS_KEY);
            Arr::has($ret, 'basic.data.'.WorkflowRequest::CUSTOM_CC_KEY) && Arr::forget($ret, 'basic.data.'.WorkflowRequest::CUSTOM_CC_KEY);
            Arr::has($ret, 'basic.data.'.WorkflowRequest::SEE_TAGS_KEY) && Arr::forget($ret, 'basic.data.'.WorkflowRequest::SEE_TAGS_KEY);
            if ($this->requestModel->process_key == Registry::CROSS_ACCESS) {
                $ret['basic']['data']['current_project_name'] = Helper::getLocalProjectName($ret['basic']['data']['current_project']);
                $ret['basic']['data']['target_project_name'] = Helper::getCrossProjectName($ret['basic']['data']['target_project']);
            } elseif ($this->requestModel->process_key == Registry::RENT_ALLOWANCE) {
                Arr::has($ret, 'basic.data.first') && Arr::forget($ret, 'basic.data.first');
            } elseif ($this->requestModel->process_key == Registry::P4V_ACCESS) {
                $ret['dynamic_nicknames'] = Stakeholder::specialNicknames([WorkflowRequestStakeholder::P4V_EXECUTER_TYPE], $this->requestModel->user_id, $this->requestModel->data);
            }
        }

        if (in_array('nodes', $includes)) {
            $ret['nodes'] = $this->nodes();
        }

        if (in_array('actions', $includes)) {
            $ret['actions'] = ($isLocked) ? [] : $this->validActions();
        }

        if (in_array('special_actions', $includes)) {
            $ret['actions'] = ($this->requestModel->current_state_id == State::COMPLETED) ? $specialActions : [];
        }

        if (in_array('tags', $includes)) {
            $ret['tags'] = $tags;
        }
        if (in_array('un_excuted_reason', $includes)) {
            $ret['un_excuted_reason'] = $un_excuted_reason;
        }

        if (in_array('cc_types', $includes)) {
            $ret['cc_types'] = Arr::flatten($this->getCcTypes());
        }

        if (in_array('carbon_copied', $includes)) {
            $ret['carbon_copied'] = !empty($this->getCarbonCopiedIds());
        }

        if (in_array('relative_request', $includes)) {
            $ret['relative_request'] = $this->relativeRequestInfo($this->requestModel->process_key);
        }

        if (in_array('rent_allowance_status', $includes) && $this->requestModel->process_key == Registry::RENT_ALLOWANCE) {
            $ret['rent_allowance_status'] = ($isLocked) ? 1 : ($this->requestModel->current_state_id == State::COMPLETED ? 2 : 3);
        }

        if (in_array('is_yesterday_deploy', $includes) && $this->requestModel->process_key == Registry::LATE_WORK_OVERTIME && !array_key_exists('relative_dates', $this->requestModel->data)) {
            $ret['is_yesterday_deploy'] = Helper::isYesterdayDeployDay(Arr::get($this->requestModel->data, 'relative_date'), $this->requestModel->user_id);
        }
        // 1
        if (Arr::has($ret, 'basic.data.clockInRecords') && !empty($ret['basic']['user_id'])
            && $ret['basic']['user_id'] === $this->sfuserModel->id) {
            unset($ret['basic']['data']['clockInRecords']);
        }

        return $ret;
    }

