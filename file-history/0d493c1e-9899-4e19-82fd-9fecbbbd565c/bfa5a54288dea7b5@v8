    public function addRequestActioner(array $attrs = [])
    {
        $sfuserId = Arr::get($attrs, 'operator_id');
        if (!in_array($sfuserId, $this->cachedUserIds)) {
            // For multi-site, 先不检查 sfuserid 是否存在
            // $sfuser = Sfuser::find($sfuserId);
            // if (!$sfuser) {
            //     // 如果不存在，直接抛出一个异常
            //     static::$messageBag['missing_userid'] = $sfuserId;
            //     throw new UserNotFoundException(__('my_api.sfuser_with_id_not_found', ['sfuserId' => $sfuserId]));
            // }
            $this->cachedUserIds[] = $sfuserId;
        } // 已经存在，表示 user 合法

        // 不存在则报错
        if (!Arr::get($attrs, 'state_id') || !Arr::get($attrs, 'action_id')) {
            throw new WorkflowException(__('my_api.wrong_parameters'));
        }

        // 这里不检查 attr 的 state 和 action 了，传入了错误的 state 和 action 也不影响 action 的执行，直接新增记录即可
        WorkflowRequestAction::updateOrInsert(
            [
                'request_id' => $this->requestModel->id,
                'operator_id' => $sfuserId,
                'state_id' => Arr::get($attrs, 'state_id'),
                'action_id' => Arr::get($attrs, 'action_id'),
            ],
            [
                'request_id' => $this->requestModel->id,
                'operator_id' => $sfuserId,
                'operator_type' => Arr::get($attrs, 'operator_type'),
                'state_id' => Arr::get($attrs, 'state_id'),
                'action_id' => Arr::get($attrs, 'action_id'),
                'clicked' => 0,
                'history_clicked' => 0,
                'created_at' => Carbon::now(),
                'updated_at' => Carbon::now(),
            ]
        );
    }

