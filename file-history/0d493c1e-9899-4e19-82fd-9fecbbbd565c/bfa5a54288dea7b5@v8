    /**
     * 以某个人的身份（实例中的 sfuserModel）执行一次特定的动作（传入的 actionId）。
     *
     * @param int $actionId
     * @param string $remark
     * @param bool $backdoor
     * @throws Throwable
     * @throws WorkflowException
     */
    public function performAction(
        int $actionId,
        string $remark = '',
        bool $backdoor = false,
        array $context = [],
        array $input = []
    ) {
        // 检查当前状态是否可以操作，如果 locked，不允许执行后续所有操作，只有 deleted 和到期锁定后，才会将请求锁住
        if ($this->requestModel->is_locked) {
            $query = AttendanceCalculateDate::where('year', (int)date('Y'))->where('month', (int)date('m'))->first();
            $outCalculateDate24 = strcmp(date('Y-m-d H:i:s'), $query->lock_approval_date.AttendanceService::$END_TIME) > 0;
            $canOperate = in_array($this->requestModel->process_key, Registry::CALCULATE_LOCK_TYPES) && !$outCalculateDate24;
            $remark = Arr::get($input, 'remark', '');
            info('[ATT] 如果 locked 在结算日24点前还可以操作: '.$canOperate.my_json_encode($this->requestModel));
            if (!$canOperate && $remark !== '系统自动审批') {
                throw new WorkflowException(__('my_api.process_is_locked'));
            }
        }
        if ($this->requestModel->process_key == Registry::RENT_ALLOWANCE && $this->requestModel->current_state_id == State::COMPLETED && $actionId == Action::CANCEL) {
            $rentAllowanceLogQuery = RentAllowanceLog::where('request_id', $this->requestModel->id)->where('sfuser_id', $this->requestModel->user_id)->first();
            if ($rentAllowanceLogQuery == null) {
                throw new WorkflowException(__('my_api.rent_allowance_log_not_found'));
            }
            if (Helper::checkAttendanceCalculateDate($rentAllowanceLogQuery->allowance_start_date, true)) {
                throw new WorkflowException(__('my_api.can_not_cancel_when_calculate'));
            }
        }

        // 检查当前人是否可以操作当前 Action
        /** @var WorkflowRequestAction $wra */
        $wra = WorkflowRequestAction::where([
            'request_id' => $this->requestModel->id,
            'state_id' => $this->requestModel->current_state_id,
            'action_id' => $actionId,
            'is_active' => 1,
        ])->when(!$backdoor, function ($query) {
            $query->where([
                'operator_id' => $this->sfuserModel->id,
            ]);
        })->first();
        if (!$wra) {
            throw new WorkflowException(sprintf('[user:%s] cannot perform given action', $this->sfuserModel->id));
        }

        // 启动事务来处理后续数据库变更
        db()->beginTransaction();
        try {
            // 更新 $wra，表示 clicked
            $wra->update(['clicked' => 1, 'history_clicked' => 1]);

            // 变更 Request 的当前状态，同时要取消激活所有当前人的处于当前状态的 Action，不再 Active
            // 因为请求已经流转到下一个阶段了，不可以再执行该阶段的任意一个操作了
            $currentState = $this->requestModel->current_state_id;
            $this->deactivateAction($this->requestModel->current_state_id);

            // 获取下一个状态
            $stateBranches = $this->actions[$currentState][$actionId];
            $nextState = $stateBranches[0];
            if (count($stateBranches) > 1) { // 超过 1 个分支，确定走向哪一个分支
                /**
                 * @see Condition
                 * @see AnnualOrPersonalLeave::$conditions
                 */

                // 所有分支的判断都必须在 [state][action] 里面声明对应的处理方法和需要读取的属性值
                // 也就是说，所有判断中用到的属性，都必须追加到 request_data 中
                $conditions = $this->conditions[$currentState][$actionId];
                $nextState = $this->getNextState($conditions, $stateBranches, $nextState, $this->requestModel->user_id);
            }

            // 如果当前动作是重新编辑，则直接将历史的备注信息标记为失效
            if ($actionId == Action::REEDIT) {
                // 标记为失效
                WorkflowRemark::where('expired', 0)
                    ->where('request_id', $this->requestModel->id)
                    ->update([
                        'expired' => 1,
                    ]);
                // 将后续所有的点击重置掉，后面会自动流转到下一个 state，并且激活下一个阶段的操作
                $this->deactivateAllAction();
                $this->requestModel->update(['completed_at' => '']);
            }

            // 审批发起时
            if ($currentState == State::START && $actionId == Action::APPROVE) {
                $this->requestModel->update(['submitted_at' => Carbon::now()]);
                if (WorkflowRequestService::needStartCC($this->requestModel->process_key)) {
                    $this->cc();
                }
            }
            if ($actionId == Action::CANCEL && WorkflowRequestService::needStartCC($this->requestModel->process_key)) {
                $exists = WorkflowRequestAction::where('request_id', $this->requestModel->id)
                    ->whereNot('operator_id', $this->sfuserModel->id)
                    ->where('clicked', 1)->exists();
                if (!$exists) {
                    $this->cancelCC();
                }
            }

            // 存在备注则直接生成一条备注记录
            if ($remark) {
                $this->remark($this->requestModel->current_state_id, $actionId, $remark);
            }

            // 确认了下一个 State 后，先更新当前 State
            $this->requestModel->current_state_id = $nextState;

            // mattermost 有个业务数据，MatterMost团队 ,存放在 $context 里
            if (!empty($context['key']) && $context['key'] === 'mattermost_access') {
                $this->appendData('mattermost_team', $context['mattermost_team']);
            }
            // eb 有个业务数据，权限 ,存放在 $context 里
            if (!empty($context['key']) && $context['key'] === 'eb_access') {
                $this->appendData('before_applicant_permission', $context['before_applicant_permission'] ?? '');
                $this->appendData('after_applicant_permission', $context['after_applicant_permission'] ?? '');
                $this->appendData('passed_permission', $context['passed_permission'] ?? []);
            }
            // eb 有个业务数据，权限 ,存放在 $context 里
            if (!empty($context['key']) && $context['key'] === 'ya_access') {
                $this->appendData('before_applicant_permission', $context['before_applicant_permission'] ?? '');
                $this->appendData('after_applicant_permission', $context['after_applicant_permission'] ?? '');
                $this->appendData('passed_permission', $context['passed_permission'] ?? []);
            }
            $this->requestModel->save();

            // 如果下个状态是一些特殊状态，需要做一些额外的操作
            switch ($nextState) {
                case $this->deletedStateId:
                    // 删除了，直接锁定
                    $this->requestModel->is_locked = 1;
                    $this->requestModel->save();
                    $this->removeAllStakeholdersExceptRequester();
                    $this->deactivateAllAction();
                    db()->commit(); // 先提交事务，再处理 actionPerformed（开启一个新的事务）
                    $this->actionPerformed($actionId, $currentState, $this->deletedStateId);
                    return;
                case $this->cancelledStateId:
                case $this->rejectedStateId:
                    // 回到撤销/驳回状态，取消激活所有的 action，保留 clicked 状态
                    $this->deactivateAllAction(false);
                    $this->unread($this->requestModel->id); // 本人取消已读，回到待办
                    break;
                case $this->completedStateId: // 完成状态发起抄送
                    $this->requestModel->update(['completed_at' => Carbon::now()]);
                    if (WorkflowRequestService::notNeedStartCC($this->requestModel->process_key)) {
                        $this->cc();
                    }
                    break;
                default:
                    break;
            }

            //  流转到下一个 State 后，激活参与者的 action
            $this->activateAction($this->requestModel->current_state_id);

            // 根据新的 state 确定下一个阶段的参与者以及 Request Actioners
            $actionRoles = $this->actionRoles[$this->requestModel->current_state_id];
            foreach ($actionRoles as $type) {
                $operatorId = Stakeholder::fetchSfuserIdsViaType($type, $this->requestModel->id);
                $this->addStakeholders($operatorId, $type);
            }

            $logMessage = ($backdoor) ? '系统自动代操作人'.$wra->operator_id.'操作 ID: '.$actionId : '操作 ID: '.$actionId;
            static::log($this->sfuserModel->id, $this->requestModel->id, $logMessage);
            db()->commit();
        } catch (Exception $e) {
            db()->rollBack();
            throw new WorkflowException($e->getMessage(), $e->getCode(), $e->getPrevious());
        }

//        // 抄送未读 -1
//        if (!empty($unreadCcs)) {
//            $ccType = in_array($this->requestModel->process_key, Registry::REIMBURSEMENT_TYPE) ? 'reimburse_cc' : 'oa_cc';
//            NotifyNumberService::app()->modifyMultiple($unreadCcs, $ccType, -1);
//        }

        // 完成了之后，立即触发事件完成的回调，在 actionPerformed 中检查，由于这部分相当于 side effect
        // 涉及到三方应用回调可能时间太长，因此不放在事务中进行处理
        $this->actionPerformed($actionId, $currentState, $nextState);

        // 修改代办数目
        $this->alterNotifyNum($actionId, $currentState, $nextState);

        if ($currentState == $nextState) {
            return;
        }

        if (!$backdoor) {
            // 如果下一个阶段的操作者是同一个人，再继续 perform 相同的 Action，再查一遍当前用户是否还有激活的操作
            /** @var WorkflowRequestAction $wra */
            $wra = WorkflowRequestAction::where([
                'request_id' => $this->requestModel->id,
                'operator_id' => $this->sfuserModel->id,
                'state_id' => $this->requestModel->current_state_id,
                'action_id' => $actionId,
                'is_active' => 1,
            ])->first();

            if ($wra) {
                // 直接继续 perform，即一直采取同一个动作，直到操作者发生变化为止
                $this->performAction($actionId, '', false, [], $input);
            }
        }

        // 现在加了个 REJECTED 的状态表示驳回，所以现在 START 都是直接自动 approve，除非以后加保存操作
        // 如果执行了指定操作后变成 START，一种是驳回，一种是重新编辑，我们需要判断操作者来区分这种情况
        if (
            // 操作人刚好是 Request 的发起者，并且执行完一次 Action 之后还是 START 状态
            // 表示是重新编辑过来的，自动提交给下一个环节
            // 之所以必须这么做，是因为需要区分审批中和已撤回两种状态
            $this->requestModel->user_id == $this->sfuserModel->id
            && $this->requestModel->current_state_id == $this->startStateId
        ) {
            $this->performAction(Action::APPROVE);
        }
    }

    /**
     * 重新编辑并且一直 APPROVE 到上次驳回或撤回的状态.
     * @return void
     */
    public function reEditAndApprove()
    {
        // 找到上次被驳回的 state_id
        $wra = WorkflowRequestAction::where('request_id', $this->requestModel->id)
            ->where('operator_type', '<>', 'requester')
            ->where('action_id', Action::REJECT)->where('clicked', 1)
            ->orderBy('updated_at')->first();
        // 如果 action 表里没有找到驳回的点击记录就是申请人主动撤回的
        if (empty($wra)) {
            $wra = WorkflowRequestAction::where('request_id', $this->requestModel->id)
                ->where('operator_type', 'requester')->where('action_id', Action::CANCEL)->where('clicked', 1)
                ->orderBy('updated_at')->first();
        }

        $endState = $wra->state_id;
        static::$cancelNotification = true;

        // 通过重新编辑发起流程
        $this->performAction(Action::REEDIT);

        // 判断一直 APPROVE 能不能走到 endState
        $reachable = false;
        for ($currentState = $this->startStateId; $currentState != State::COMPLETED;) {
            if ($currentState == $endState) {
                $reachable = true;
                break;
            }
            // 获取下一个状态
            if (!array_key_exists(Action::APPROVE, $this->actions[$currentState])) {
                break;
            }
            $stateBranches = $this->actions[$currentState][Action::APPROVE];
            $nextState = $stateBranches[0];
            if (count($stateBranches) > 1) {
                $conditions = $this->conditions[$currentState][Action::APPROVE];
                $nextState = $this->getNextState($conditions, $stateBranches, $currentState, $this->requestModel->user_id);
            }
            $currentState = $nextState;
        }

        while ($reachable) {
            $currentState = $this->requestModel->current_state_id;
            if ($endState == $currentState) {
                break;
            }
            // 一直 APPROVE 到 endState
            $this->performAction(Action::APPROVE, '', true);
        }

        static::$cancelNotification = false;
    }

