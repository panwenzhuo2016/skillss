    /**
     * 根据给定的 request id 和当前用户 id (当前登录用户的 ID) 生成一个操作实例。
     *
     * @throws ReflectionException
     * @throws WorkflowException
     * @throws RequestNotFoundException|UserNotFoundException
     */
    public function __construct(int $requestId, int $sfuserId)
    {
        // 确保当前请求实例和人都存在，不存在则会抛出一个 ModelNotFoundException
        try {
            $this->requestModel = WorkflowRequest::findOrFail($requestId);
        } catch (ModelNotFoundException $e) {
            throw new RequestNotFoundException(__('my_api.workflow_request_with_id_not_found', ['requestId' => $requestId]), $e->getCode(), $e->getPrevious());
        }

        try {
            $this->sfuserModel = Sfuser::findOrFail($sfuserId);
        } catch (ModelNotFoundException $e) {
            // 说明登陆人不在此地区
            $this->sfuserModel = new Sfuser(['id' => Auth::id()]);
            // info(__('my_api.sfuser_with_id_not_found', ['sfuserId' => $sfuserId, 'error_code' => $e->getCode(), 'error' => $e->getPrevious()]));
        }

        // 获取请求关联的 Process Key
        $processKey = $this->requestModel->process_key ?? '';
        if (!array_key_exists($processKey, (array)Registry::STATE_MAPS)) {
            throw new WorkflowException(__('my_api.process_key_not_exist', ['processKey' => $processKey]));
        }

        // 通过反射获取到 actions 和 conditions
        $stateClassName = Registry::STATE_MAPS[$processKey]['class'];
        $stateClass = new ReflectionClass($stateClassName);

        // Props
        $actionsReflectionProp = $stateClass->getProperty('actions');
        $conditionsReflectionProp = $stateClass->getProperty('conditions');
        $actionRolesReflectionProp = $stateClass->getProperty('actionRoles');
        $ccsReflectionProp = $stateClass->getProperty('ccs');
        $ccConditionsReflectionProp = $stateClass->getProperty('carbonCopyConditions');

        if (!$actionsReflectionProp || !$conditionsReflectionProp || !$actionRolesReflectionProp || !$ccsReflectionProp) {
            throw new WorkflowException('failed to fetch some props through Reflection');
        }

        $actionsReflectionProp->setAccessible(true);
        $conditionsReflectionProp->setAccessible(true);
        $actionRolesReflectionProp->setAccessible(true);
        $ccsReflectionProp->setAccessible(true);
        $ccConditionsReflectionProp->setAccessible(true);

        /*
         * @see https://www.php.net/manual/en/reflectionproperty.getvalue.php
         * 从 8.0 起，getValue 可以为空，7.3 版本并不支持
         */
        switch ($this->requestModel->process_key) {
            case Registry::CROSS_ACCESS:
                $sc = new $stateClassName($this->requestModel->version, Arr::get($this->requestModel->data, 'target_project'));
                break;
            case Registry::SUPPLEMENT:
                $sc = new $stateClassName($this->requestModel->version, Arr::get($this->requestModel->data, 'request_id', -1));
                break;
            default:
                $sc = new $stateClassName($this->requestModel->version);
                break;
        }
        $this->actions = $actionsReflectionProp->getValue($sc);
        $this->conditions = $conditionsReflectionProp->getValue($sc);
        $this->actionRoles = $actionRolesReflectionProp->getValue($sc);
        $this->ccs = $ccsReflectionProp->getValue($sc);
        $this->carbonCopyConditions = $ccConditionsReflectionProp->getValue($sc);

        // 设置常量
        $this->startStateId = $stateClass->getConstant('START');
        $this->cancelledStateId = $stateClass->getConstant('CANCELLED');
        $this->deletedStateId = $stateClass->getConstant('DELETED');
        $this->completedStateId = $stateClass->getConstant('COMPLETED');
        $this->rejectedStateId = $stateClass->getConstant('REJECTED');
    }

