            case Registry::MATERNITY_LEAVE.implode(':', [Action::APPROVE, State::DIRECT_SUPERVISOR_PENDING, State::COMPLETED]):
            case Registry::MATERNITY_LEAVE.implode(':', [Action::APPROVE, State::CEO_PENDING, State::COMPLETED]):
            case Registry::PATERNITY_LEAVE.implode(':', [Action::APPROVE, State::DIRECT_SUPERVISOR_PENDING, State::COMPLETED]):
            case Registry::PATERNITY_LEAVE.implode(':', [Action::APPROVE, State::CEO_PENDING, State::COMPLETED]):
            case Registry::MATERNITY_INSPECTION_LEAVE.implode(':', [Action::APPROVE, State::DIRECT_SUPERVISOR_PENDING, State::COMPLETED]):
            case Registry::MATERNITY_INSPECTION_LEAVE.implode(':', [Action::APPROVE, State::CEO_PENDING, State::COMPLETED]):
            case Registry::BREASTFEEDING_LEAVE.implode(':', [Action::APPROVE, State::DIRECT_SUPERVISOR_PENDING, State::COMPLETED]):
                // 审批通过 - 晚到
            case Registry::LATE_UNDERGROUND.implode(':', [Action::APPROVE, State::DIRECT_SUPERVISOR_PENDING, State::COMPLETED]):
            case Registry::OTHER_LATE_ARRIVAL.implode(':', [Action::APPROVE, State::SSC_PENDING, State::COMPLETED]):
                // 审批通过 - 其他
            case Registry::BUSINESS_TRIP.implode(':', [Action::APPROVE, State::ADMIN_SUPERVISOR_PENDING, State::COMPLETED]): // 版本一的流程
            case Registry::BUSINESS_TRIP.implode(':', [Action::APPROVE, State::DIRECT_SUPERVISOR_PENDING, State::COMPLETED]): // 版本二的流程
            case Registry::BUSINESS_TRIP.implode(':', [Action::APPROVE, State::CEO_PENDING, State::COMPLETED]): // 版本二的流程
            case Registry::WORK_ON_WEEKEND.implode(':', [Action::APPROVE, State::DIRECT_SUPERVISOR_PENDING, State::COMPLETED]):
                WorkflowAttendance::app()->updateAttendanceUnusual($this->requestModel->user_id, $this->requestModel->id, $this->requestModel->process_key);
                break;
            // 审批通过 - 加班晚到
            case Registry::LATE_WORK_OVERTIME.implode(':', [Action::APPROVE, State::DIRECT_SUPERVISOR_PENDING, State::COMPLETED]):
            case Registry::LATE_WORK_OVERTIME.implode(':', [Action::APPROVE, State::SUPERVISOR_PENDING, State::COMPLETED]):
                WorkflowAttendance::app()->updateAttendanceUnusual($this->requestModel->user_id, $this->requestModel->id, $this->requestModel->process_key);
                LateWorkOvertimeData::pushLateWorkOvertimeData($this->requestModel->user_id, $this->requestModel->id);
                break;
            case Registry::MAKEUP_ATTENDANCE.implode(':', [Action::APPROVE, State::DIRECT_SUPERVISOR_PENDING, State::COMPLETED]):
                $service->makeupAttendanceComplete();
                break;
            case Registry::MATTERMOST.implode(':', [Action::APPROVE, State::TEAM_DEPT_PENDING, State::COMPLETED]):
                info('审批通过后，自动执行Mattermost权限开通动作 '.$this->requestModel->id);
                CreateTeamMemberFromWorkflow::dispatch($this->requestModel->id);
                OtherPermissionExecute::where('request_id', $this->requestModel->id)->update(['is_execute' => 1]);
                break;
            case Registry::EB.implode(':', [Action::APPROVE, State::EB_EXECUTOR_PENDING, State::COMPLETED]):
                info('审批通过后，自动执行EB权限开通动作 '.$this->requestModel->id);
                CreateEbFromWorkflow::dispatch($this->requestModel->id);
                break;
            case Registry::YA.implode(':', [Action::APPROVE, State::YA_EXECUTOR_PENDING, State::COMPLETED]):
                info('审批通过后，由杨手动添加权限 '.$this->requestModel->id);
//                CreateEbFromWorkflow::dispatch($this->requestModel->id);
                break;
            case Registry::DEDUCTION.implode(':', [Action::APPROVE, State::START, State::DIRECT_SUPERVISOR_PENDING]):
                $service->deductionStart();
                break;
            case Registry::DEDUCTION.implode(':', [Action::APPROVE, State::DIRECT_SUPERVISOR_PENDING, State::COMPLETED]):
                $service->deductionComplete();
                break;
            default:
                break;
        }

        if (static::$cancelNotification) {
            // 取消发送的话，直接返回
            return;
        }

        // 给当前 actioner 发送 knock 提醒
        if (!app()->environment(['unit_test', 'testing'])) {
            $requestId = $this->requestModel->id;
            register_shutdown_function(function () use ($requestId, $currentActionId, $currentState, $nextState) {
                dispatch_sync(new SendWorkflowNotification($requestId, $currentActionId, $currentState, $nextState));
            });
        }
    }

