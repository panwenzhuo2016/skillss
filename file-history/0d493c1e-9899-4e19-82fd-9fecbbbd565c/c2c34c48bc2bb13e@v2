<!--
借款审批表单填写页面
当为创建时候，调用接口为：预检---开启流程---授权
当为重新编辑时候，调用接口为：预检---reEdit
-->
<template>
    <OaTemplateContent
        :show-header="true"
        :show-back-btn="!isReEdit"
        :header-title="isReEdit ? '重新编辑' : '借款'"
        :show-footer="true"
        :show-save-btn="true"
        class="OaTemplateContentBox"
        @back="cancelEditLoanForm"
        @cancel="cancelEditLoanForm"
        @save="saveEditLoanForm"
        @confirm="confirmEditLoanForm"
    >
        <OaTemplateCItem :show-footer="false" :title="`${$t('t341')}`" class="OaTemplateCItem">
            <LoanBaseForm
                ref="$loanBaseForm"
                v-model="loanApprovalDetail"
                :disabled-department="disabledDepartment"
            />
        </OaTemplateCItem>
        <OaTemplateCItem :show-footer="false" :title="`${$t('t372')}`" class="OaTemplateCItem">
            <ApprovalFlowPreview :path="processPath" />
        </OaTemplateCItem>
    </OaTemplateContent>
</template>

<script lang="ts">
import { Vue, Component, Prop, Ref, Watch } from 'vue-property-decorator'

import {
    getPersonalInfoAPI,
    preflightLoanProcessAPI,
    startLoanProcessAPI,
    authorizeRequestTokenAPI,
    reEditLoanAPI,
} from '@/apis/StaffPage/OCLoan/index'
import type { IApprovalLoanFormData, IBasicInfo } from '@/apis/StaffPage/OCLoan/types'
import ApprovalFlowPreview from '@/app/PC/Common/ApprovalFlow/ApprovalFlowPreview.vue'
import type { IPreviewFlowData } from '@/app/PC/Common/ApprovalFlow/types'
import OaTemplateCItem from '@/app/PC/Common/OaCommTemplate/OaTemplateCItem.vue'
import OaTemplateContent from '@/app/PC/Common/OaCommTemplate/OaTemplateContent.vue'
import LoanBaseForm from '@/app/PC/StaffPage/OCSystem/components/Loan/details/LoanBaseForm.vue'

import type { PageType } from '../Navigator/OCNavigatorCenter.vue'
import i18n from "@/i18n";
@Component({
    name: 'AddOCInitiatedLoanPage',
    components: {
        OaTemplateContent,
        OaTemplateCItem,
        LoanBaseForm,
        ApprovalFlowPreview,
    },
})
export default class extends Vue {
    @Prop({
        type: Function,
        required: false,
    })
    pageChange: (pageType: Partial<PageType>) => void
    @Prop({
        type: Object,
        required: false,
        default: () => ({}),
    })
    readonly reEditData: IBasicInfo
    @Prop({
        type: Boolean,
        required: false,
        default: false,
    })
    readonly isReEdit: boolean
    @Prop({
        type: Boolean,
        required: false,
        default: false,
    })
    disabledDepartment: boolean
    @Ref('$loanBaseForm') $loanBaseForm: LoanBaseForm
    loanApprovalDetail: Partial<IApprovalLoanFormData> = {}
    processPath = []
    @Watch('loanApprovalDetail', { deep: true, immediate: true }) loanApprovalDetailWatch(
        newVal: Partial<IApprovalLoanFormData>
    ) {
        // 只要表单必填项填写完成就发送预检请求
        if (newVal.departmentId && newVal.loanAmount && newVal.reverseDate && newVal.loanRemark) {
            this.preflightLoanProcess()
        }
    }
    mounted() {
        if (this.isReEdit) {
            this.loanApprovalDetail = {
                departmentId: this.reEditData.departmentId,
                loanAmount: Number(this.reEditData.loanAmount),
                reverseDate: this.reEditData.reverseDate,
                loanRemark: this.reEditData.loanRemark,
                appendix: this.reEditData.files,
                extraCC: this.reEditData.extraCC,
            }
        }
        getPersonalInfoAPI().then(({ socialSecurityCompany, accessibleDepartments }) => {
            this.loanApprovalDetail = {
                ...this.loanApprovalDetail,
                socialSecurityCompany,
                accessibleDepartments,
            }
        })
    }
    formatInitNodes(res) {
        const mapArr = [...res.specialNicknames, ...res.types]
        let initNodes = []
        // 如果是首次申请,相关花名根据后端预检接口确定
        initNodes = (res?.nodes ?? []).map((item, key) => {
            if (item.operator_type === 'requester') {
                return {
                    operator_type: item.operator_type,
                    operator: [this.$store.state.userInfo.nickname],
                    order: key,
                }
            }
            return {
                operator_type: item.operator_type,
                operator: (mapArr ?? []).find(o => o.operator_type === item.operator_type)?.nicknames,
                order: key,
            }
        })
        return initNodes
    }
    getReEditRequestInfoNodes(
        initNodes: Array<any> = [],
        specialNicknames: Array<any> = [],
        types: Array<any> = []
    ) {
        const mapArr = [...specialNicknames, ...types]
        const infoNodes = []
        for (let i = 0; i < initNodes.length; i++) {
            const item = initNodes[i]
            if (
                [
                    'requester',
                    'first_supervisor',
                    'second_supervisor',
                    'third_supervisor',
                    'financial_supervisor',
                    'ceo',
                    'financial_handle',
                    'financial_payment',
                    'administrative_submitter',
                ].includes(item.operator_type)
            ) {
                infoNodes.push({
                    operator_type: item.operator_type,
                    operator: mapArr.find(e => e.operator_type === item.operator_type).nicknames,
                })
            }
        }
        return infoNodes
    }
    showPath(initNodes: Array<any>, specialNicknames: Array<any>) {
        const processPath: IPreviewFlowData = []
        const curExtraCC = this.loanApprovalDetail.extraCC ? this.loanApprovalDetail.extraCC : []
        for (let i = 0; i < initNodes.length; i++) {
            const curNode = initNodes[i]
            let node: IPreviewFlowData[number]
            if (i === initNodes.length - 1 && curNode.operator_type === 'requester') {
                continue
            }
            // 两个相同处理人的结点合并
            // if (i >= 1 && curNode.operator === initNodes[i - 1].operator) {
            //     continue
            // }
            const operatorArr = curNode.operator
            const operator = operatorArr?.[0]
            const nickNames = specialNicknames.find(
                sn => sn.operator_type === curNode.operator_type
            )?.nicknames
            if (curNode.operator_type === 'requester') {
                node = {
                    title: `${this.$t('t373')}`,
                    subContent: operator,
                    circleText: operator,
                    isShowRightContent: true,
                }
            }
            if (
                ['first_supervisor', 'second_supervisor', 'third_supervisor'].includes(curNode.operator_type)
            ) {
                node = {
                    title: `${this.$t('t504')}`,
                    subContent: operator,
                    circleText: operator,
                    isShowRightContent: true,
                }
            }
            if (curNode.operator_type === 'financial_supervisor') {
                node = {
                    title: `${this.$t('ocsystemapi_loan_loan_dictionary_438')}`,
                    circleText: `${this.$t('StaffOCSeal.finance')}`,
                    isShowRightContent: true,
                    // subContent: operatorArr?.join('、'),
                    crossAxis: {
                        nextPre: `${this.$t('t580')}`,
                        next: operatorArr,
                    },
                }
            }
            if (curNode.operator_type === 'ceo') {
                node = {
                    title: 'CEO',
                    subContent: operator,
                    circleText: operator,
                    isShowRightContent: true,
                    crossAxis: {
                        nextPre: `${this.$t('t500')}`,
                        next: curExtraCC,
                    },
                }
            }
            if (curNode.operator_type === 'financial_handle') {
                node = {
                    title: `${this.$t('Receiver')}`,
                    circleText: `${this.$t('Receiver')}`,
                    isShowRightContent: true,
                    crossAxis: {
                        nextPre: `${this.$t('Receive')}`,
                        next: nickNames,
                    },
                }
            }
            if (curNode.operator_type === 'financial_payment') {
                node = {
                    title: `${this.$t('executor')}`,
                    circleText: `${this.$t('executor')}`,
                    isShowRightContent: true,
                    crossAxis: {
                        nextPre: `${this.$t('execute')}`,
                        next: nickNames,
                    },
                }
            }
            processPath.push(node)
        }
        return processPath
    }
    handlerPreflight(res) {
        let nodes = []
        const initNodes = this.formatInitNodes(res)
        nodes = res.nodes.map((item, key) => ({
            operator_type: item.operator_type,
            operator: initNodes.find(o => o.operator_type === item.operator_type)?.operator,
            order: key,
        }))
        const path = this.showPath(nodes, res.specialNicknames)
        this.processPath = path
    }
    preflightLoanProcess(): Promise<{
        success: boolean
        initNodes: Array<any>
        specialNicknames: Array<any>
        types: Array<any>
    }> {
        return new Promise((resolve, reject) => {
            preflightLoanProcessAPI({
                nickName: this.$store.state.userInfo.nickname,
                sfUserId: this.$store.state.userInfo.id,
                departmentId: this.loanApprovalDetail.departmentId,
                loanAmount: this.loanApprovalDetail.loanAmount,
                reverseDate: this.loanApprovalDetail.reverseDate,
                loanRemark: this.loanApprovalDetail.loanRemark ?? '',
                extraCC: this.loanApprovalDetail.extraCC ?? [],
                appendix: this.loanApprovalDetail.appendix ?? [],
            }).then(
                data => {
                    this.handlerPreflight(data)
                    const initNodes = this.formatInitNodes(data)
                    resolve({
                        success: true,
                        initNodes,
                        specialNicknames: data.specialNicknames,
                        types: data.types,
                    })
                },
                () => {
                    reject({
                        success: false,
                        initNodes: [],
                        specialNicknames: [],
                    })
                }
            )
        })
    }
    startLoanProcess(
        startType: 'save' | 'start',
        initNodes: Array<any>
    ): Promise<{ success: boolean; requestId: number }> {
        return new Promise((resolve, reject) => {
            startLoanProcessAPI({
                type: startType,
                context: {
                    nickName: this.$store.state.userInfo.nickname,
                    sfUserId: this.$store.state.userInfo.id,
                    departmentId: this.loanApprovalDetail.departmentId,
                    loanAmount: this.loanApprovalDetail.loanAmount,
                    reverseDate: this.loanApprovalDetail.reverseDate,
                    loanRemark: this.loanApprovalDetail.loanRemark ?? '',
                    extraCC: this.loanApprovalDetail.extraCC ?? [],
                    appendix: this.loanApprovalDetail.appendix ?? [],
                },
                initNodes: initNodes,
            }).then(
                data => {
                    const { requestId, success } = data
                    if (success) {
                        resolve({
                            success: true,
                            requestId,
                        })
                    } else {
                        reject({
                            success: false,
                            requestId,
                        })
                    }
                },
                err => {
                    console.error(err)
                    reject({
                        success: false,
                        requestId: 0,
                    })
                }
            )
        })
    }
    reEditLoan(
        startType: 'save' | 'start',
        requestId: number,
        nodesInfo: Array<any>
    ): Promise<{ success: boolean }> {
        return new Promise((resolve, reject) => {
            reEditLoanAPI({
                type: startType,
                requestId,
                contextInfo: {
                    nickName: this.$store.state.userInfo.nickname,
                    departmentId: this.loanApprovalDetail.departmentId,
                    loanAmount: this.loanApprovalDetail.loanAmount,
                    reverseDate: this.loanApprovalDetail.reverseDate,
                    loanRemark: this.loanApprovalDetail.loanRemark ?? '',
                    extraCC: this.loanApprovalDetail.extraCC ?? [],
                    appendix: this.loanApprovalDetail.appendix ?? [],
                },
                nodesInfo,
            }).then(
                data => {
                    const success = data
                    if (success) {
                        resolve({
                            success: true,
                        })
                    } else {
                        reject({
                            success: false,
                        })
                    }
                },
                err => {
                    console.error(err)
                    reject({
                        success: false,
                    })
                }
            )
        })
    }
    authorizeRequestToken(requestId, specialNicknames): Promise<{ success: boolean }> {
        return new Promise((resolve, reject) => {
            authorizeRequestTokenAPI({
                requestId,
                sfUsers: specialNicknames,
            }).then(
                success => {
                    if (success) {
                        resolve({ success: true })
                    } else {
                        console.log(`${this.$t('t2405221735')}`)
                        reject({ success: false })
                    }
                },
                err => {
                    console.error(err)
                    reject({ success: false })
                }
            )
        })
    }
    saveEditLoanForm() {
        this.$loanBaseForm
            .validateForm()
            .then(valid => {
                if (valid) {
                    this.$confirm(i18n.t('561'), i18n.t('t544'))
                        .then(async () => {
                            const loading = this.$loading({})
                            // 人事部/行政部发起时，自动将艾莎加入抄送列表
                            const HR_ADMIN_DEPT_IDS = [2, 15]
                            const AISHA_NICKNAME = '艾莎'
                            const userDeptId = this.$store.state.userInfo.department_id
                            const userNickname = this.$store.state.userInfo.nickname
                            if (HR_ADMIN_DEPT_IDS.includes(userDeptId) && userNickname !== AISHA_NICKNAME) {
                                if (!this.loanApprovalDetail.extraCC) {
                                    this.loanApprovalDetail.extraCC = []
                                }
                                if (!this.loanApprovalDetail.extraCC.includes(AISHA_NICKNAME)) {
                                    this.loanApprovalDetail.extraCC.push(AISHA_NICKNAME)
                                }
                            }
                            try {
                                // 如果不是重新编辑，是新创建的
                                if (!this.isReEdit) {
                                    const { initNodes, specialNicknames, types } =
                                        await this.preflightLoanProcess()
                                    const { requestId } = await this.startLoanProcess('save', initNodes)
                                    const spNames = new Set()
                                    specialNicknames.forEach(el => {
                                        if (el.nicknames) {
                                            el.nicknames.forEach(ni => {
                                                spNames.add(ni)
                                            })
                                        }
                                    })
                                    types.forEach(el => {
                                        if (el.nicknames) {
                                            el.nicknames.forEach(ni => {
                                                spNames.add(ni)
                                            })
                                        }
                                    })
                                    await this.authorizeRequestToken(requestId, [
                                        ...Array.from(spNames),
                                        ...(this.loanApprovalDetail.extraCC ?? []),
                                    ])
                                } else {
                                    // 如果是重新编辑，先预检再执行编辑操作
                                    const { initNodes, specialNicknames, types } =
                                        await this.preflightLoanProcess()
                                    const nodesInfo = this.getReEditRequestInfoNodes(
                                        initNodes,
                                        specialNicknames,
                                        types
                                    )
                                    await this.reEditLoan('save', this.reEditData.id, nodesInfo)
                                }
                                this.cancelEditLoanForm()
                                this.$message.success(`${this.$t('operationSuccessful')}`)
                            } catch (err) {
                                console.error(err)
                                this.$message.error(`${this.$t('t240522765')}`)
                            } finally {
                                loading.close()
                            }
                        })
                        .catch(() => null)
                }
            })
            .catch(err => {
                console.error(err)
            })
    }
    confirmEditLoanForm() {
        this.$loanBaseForm
            .validateForm()
            .then(async valid => {
                if (valid) {
                    const loading = this.$loading({})
                    try {
                        if (!this.isReEdit) {
                            const { initNodes, specialNicknames, types } = await this.preflightLoanProcess()
                            const { requestId } = await this.startLoanProcess('start', initNodes)
                            const spNames = new Set()
                            specialNicknames.forEach(el => {
                                if (el.nicknames) {
                                    el.nicknames.forEach(ni => {
                                        spNames.add(ni)
                                    })
                                }
                            })
                            types.forEach(el => {
                                if (el.nicknames) {
                                    el.nicknames.forEach(ni => {
                                        spNames.add(ni)
                                    })
                                }
                            })
                            await this.authorizeRequestToken(requestId, [
                                ...Array.from(spNames),
                                ...(this.loanApprovalDetail.extraCC ?? []),
                            ])
                        } else {
                            const { initNodes, specialNicknames, types } = await this.preflightLoanProcess()
                            const nodesInfo = this.getReEditRequestInfoNodes(
                                initNodes,
                                specialNicknames,
                                types
                            )
                            await this.reEditLoan('start', this.reEditData.id, nodesInfo)
                        }
                        this.cancelEditLoanForm()
                        this.$message.success(`${this.$t('operationSuccessful')}`)
                    } catch (err) {
                        console.error(err)
                        this.$message.error(`${this.$t('t240522765')}`)
                    } finally {
                        loading.close()
                    }
                }
            })
            .catch(err => {
                console.error(err)
            })
    }
    cancelEditLoanForm() {
        this.loanApprovalDetail = {}
        this.$loanBaseForm.resetForm()
        if (this.isReEdit) {
            this.$emit('closeDrawer')
        } else {
            this.pageChange({
                mainType: 'Table',
            })
        }
    }
}
</script>
