    /**
     * 待办事项.（数目统计）.
     *
     * @param Request $request
     * @return JsonResponse
     */
    public function todoList(Request $request): JsonResponse
    {
        $sfuserId = $request->input('sfuser_info.id');
        $disableCache = $request->input('disable_cache', false);

        $issuedButNotCompleted = 0; // 我发起的（待审批）的数目
        $issuedStrikeBalancePending = 0; // 我发起的（已付款，待冲账）
        $issuedButRejected = 0; // 我发起的（已付款，已驳回）
        $toBeApprovedByMe = 0; // 待我审批数目
        $cc2Me = 0; // 抄送我的并且未读的数目

        if ($disableCache) {    // 不走缓存
            $issuedButNotCompleted = (new StakeholderQueryBuilder('oc'))->filterByRequesterIds($sfuserId)->approving()->asRequester()->unlocked()->count();
            $issuedStrikeBalancePending = (new StakeholderQueryBuilder('oc'))->filterByRequesterIds($sfuserId)->stateIn(State::STRIKE_BALANCE_PENDING)->asRequester()->unlocked()->count();
            $issuedButRejected = (new StakeholderQueryBuilder('oc'))->filterByRequesterIds($sfuserId)->stateIn(State::REJECTED)->asRequester()->unlocked()->count();
            $toBeApprovedByMe = (new ActionerQueryBuilder('oc'))->filterByUserId($sfuserId)->toBeApprovedByMe()->unlocked()->count();
            $cc2Me = (new StakeholderQueryBuilder('oc'))->filterByUserId($sfuserId)->asCCer()->unread()->count();
        } else {                        // 走缓存
            $data = NotifyNumberService::app()->getIndividual($sfuserId);
            $issuedButNotCompleted = $data['oc_issued'] ?? 0;
            $issuedStrikeBalancePending = $data['oc_issued_strike_balance_pending'] ?? 0;
            $issuedButRejected = $data['oc_issued_rejected'] ?? 0;
            $toBeApprovedByMe = $data['oc_to_be_approved'] ?? 0;
            $cc2Me = $data['oc_cc'] ?? 0;
        }

        // 查询个人数据
        $userData = OcUserData::firstOrCreate(['sfuser_id' => $sfuserId], [
            'sfuser_id' => $sfuserId, 'to_be_approved_by_me' => 0, 'cc_to_me' => 0,
        ]);

        // 更新个人数据
        $update = [];
        if (!$userData->to_be_approved_by_me && $toBeApprovedByMe) {
            $update['to_be_approved_by_me'] = 1;
        }
        if (!$userData->cc_to_me && $cc2Me) {
            $update['cc_to_me'] = 1;
        }
        if (!empty($update)) {
            $userData->update($update);
        }

        // 如果从来没有过就不返回（待我审批、抄送给我）
        $ret = [
            'countingIssuedButNotCompleted' => $issuedButNotCompleted,
            'countingIssuedButRejected' => $issuedButRejected,
            'countingIssuedStrikeBalancePending' => $issuedStrikeBalancePending,
        ];
        if ($userData->to_be_approved_by_me) {
            $ret['countingToBeApprovedByMe'] = $toBeApprovedByMe;
        }
        if ($userData->cc_to_me) {
            $ret['countingCc2Me'] = $cc2Me;
        }
        $ret = ApprovalManagementController::dealLessThan0($ret);
        return $this->responseJsonSuccess($ret);
    }

