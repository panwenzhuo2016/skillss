    /**
     * 获取请求列表.
     *
     * @param string $connection
     * @param string $type
     * @param array $input
     * @return JsonResponse
     */
    public function getRequests(string $connection, string $type, array $input): JsonResponse
    {
        $input = Arr::only($input, [
            'sfuser_info', 'per_page', 'no', 'approval_statuses', 'lack_supplements', 'nickname_hash_filter', 'lock_status', 'receive_money_company_hash_filter',
            'pay_company', 'apply_reason', 'priority', 'invoice_type', 'pay_date_start', 'pay_date_end', 'actual_money',
            'launch_date_start', 'launch_date_end', 'submitted_before', 'submitted_after', 'current_approver_nickname', 'next_replace_filter',
        ]) + ['per_page' => 50];

        $sfuserId = $input['sfuser_info']['id'];

        $sq = new PaymentStakeholderQueryBuilder($connection);
        $aq = new ActionerQueryBuilder($connection);

        switch ($type) {
            case 'issued':
                $sq->asRequester()->notCCer()->filterByUserId($sfuserId);
                break;
            case 'approving':
                $sq->filterByUserId($sfuserId)->notCCer()->notRequester();
                $aq->toBeApprovedByMe()->filterByUserId($sfuserId);
                break;
            case 'resolved':
                $sq->filterByUserId($sfuserId)->notCCer()->notRequester();
                $aq->resolved()->filterByUserId($sfuserId);
                break;
            case 'cc':
                $sq->asCCer()->filterByUserId($sfuserId);
                break;
            case 'approvingOrResolved':
                $sq->filterByUserId($sfuserId)->notCCer()->notRequester();
                break;
            default:
                throw new WorkflowException('Invalid type given');
        }

        $queryBuilder = $sq->orderBy('requests.created_at', 'desc');

        // 按申请人进行过滤
        if (Arr::has($input, 'nickname_hash_filter')) {
            $userIds = OcUser::whereIn('nickname_hash', $input['nickname_hash_filter'])->pluck('sfuser_id')->toArray();
            $queryBuilder->filterByRequesterIds($userIds);
        }

        // 按编号筛选
        if ($no = Arr::get($input, 'no')) {
            $queryBuilder->filterByNo($no);
        }

        // 按关键字搜索筛选
        if (($nextReplaceFilterIds = Arr::get($input, 'next_replace_filter')) !== null) {
            $queryBuilder->filterByRequestIds($nextReplaceFilterIds);
        }

        // 按审批状态筛选
        $approvalStatuses = Arr::wrap(Arr::get($input, 'approval_statuses', []));
        if ($approvalStatuses) {
            $queryBuilder->stateIn($approvalStatuses);
        }

        // 按当前审批人花名筛选
        if ($currentApprover = Arr::get($input, 'current_approver_nickname')) {
            if ($currentApproverId = Arr::get(Stakeholder::getApproverNickname2Id('oc'), $currentApprover, -1)) {
                $queryBuilder->filterByCurrentApproverId($currentApproverId);
            }
        }

        $lackSupplements = Arr::get($input, 'lack_supplements', -1);
        if ($lackSupplements != -1) {
            /** lack_supplements: 1 缺少材料，2 材料齐全 */
            $lack = $lackSupplements == 1; // 不搜时，不传该参数，因此不用判断是否为 2 了
            $queryBuilder->filterByLackSupplements($lack);
        }

        $processKey = Arr::wrap(Arr::get($input, 'process_key', []));
        if ($processKey) {
            $queryBuilder->filterByProcessKey($processKey);
        }

        $lockStatus = Arr::get($input, 'lock_status', -1);
        if ($lockStatus == 0) {
            $queryBuilder->unlocked();
        } elseif ($lockStatus == 1) {
            $queryBuilder->locked();
        }

        // 按最新发起申请的时间搜索
        $queryBuilder->submittedBefore(Arr::get($input, 'submitted_before', ''))->submittedAfter(Arr::get($input, 'submitted_after', ''));

        // 按照收款公司查找
        if ($receiveMoneyCompany = Arr::get($input, 'receive_money_company_hash_filter', [])) {
            $queryBuilder->filterByReceiveCompany($receiveMoneyCompany);
        }

        // 按照付款公司查询
        if ($payCompany = Arr::get($input, 'pay_company')) {
            $queryBuilder->filterByPayCompany($payCompany);
        }

        // 按照请款原因查询
        if ($applyReason = Arr::get($input, 'apply_reason')) {
            $queryBuilder->filterByApplyReason($applyReason);
        }

        // 按照优先级查询
        if ($priority = Arr::get($input, 'priority')) {
            $queryBuilder->filterByPriority($priority);
        }

        // 按照发票类型查询
        if ($invoiceType = Arr::get($input, 'invoice_type')) {
            $queryBuilder->filterByInvoiceType($invoiceType);
        }

        // 按照付款金额筛选
        if ($requestMoney = Arr::get($input, 'actual_money')) {
            $queryBuilder->filterByActualMoney($requestMoney);
        }

        // 按照实际付款时间搜索
        $queryBuilder->payDateAfter(Arr::get($input, 'pay_date_start', ''))
            ->payDateBefore(Arr::get($input, 'pay_date_end', ''));

        // 按照发起时间搜索
        $queryBuilder->launchDateAfter(Arr::get($input, 'launch_date_start', ''))
            ->launchDateBefore(Arr::get($input, 'launch_date_end', ''));

        $requests = [];
        switch ($type) {
            case 'issued':
            case 'cc':
                /** @phpstan-ignore-next-line */
                $columns = '`requests`.`id`, `requests`.`user_id`, `is_locked`, `version`, `request_stakeholders`.`type`, `is_read`, `requests`.`submitted_at`, `requests`.`created_at`,
                    `process_key`, `no`, `current_state_id`, `need_supplements`, `has_supplements`, `info`, `token`, `data`->"$.detailed_reason" as detailed_reason,
                    `receive_money_company`, `pay_company`, `apply_reason`, `total_money`, `actual_money`, `currency`, `invoice_type`, `pay_date`, `pay_type`, `data`->"$.printed" as printed ';
                $requests = $queryBuilder->queryBuilder()->selectRaw($columns)->paginate($input['per_page'])->toArray();
                break;
            case 'approving':
            case 'resolved':
                $columns = '`requests`.`user_id`, `requests`.`id`, `requests`.`is_locked`, `requests`.`version`, GROUP_CONCAT(`request_stakeholders`.`type` SEPARATOR ",") as type,
                    `is_read`, `requests`.`submitted_at`, `requests`.`created_at`, `process_key`, `no`, `current_state_id`, `need_supplements`, `has_supplements`, `info`, `token`,
                    `receive_money_company`, `pay_company`, `apply_reason`, `total_money`, `actual_money`, `currency`, `invoice_type`, `pay_date`, `pay_type`,
                    `data`->"$.detailed_reason" as detailed_reason, `data`->"$.printed" as printed ';
                $idsQuery = $aq->queryBuilder()->groupBy('requests.id')->select('requests.id');
                $requests = $queryBuilder->queryBuilder()->whereIn('requests.id', $idsQuery)->selectRaw($columns)
                    ->groupBy('requests.id') // 保证申请记录唯一
                    ->paginate($input['per_page'])->toArray();
                break;
            case 'approvingOrResolved':
                $columns = '`requests`.`user_id`, `requests`.`id`, `requests`.`is_locked`, `requests`.`version`, GROUP_CONCAT(`request_stakeholders`.`type` SEPARATOR ",") as type,
                    `is_read`, `requests`.`submitted_at`, `requests`.`created_at`, `process_key`, `no`, `current_state_id`, `need_supplements`, `has_supplements`, `info`, `token`,
                    `receive_money_company`, `pay_company`, `apply_reason`, `total_money`, `actual_money`, `currency`, `invoice_type`, `pay_date`, `pay_type`,
                    `data`->"$.detailed_reason" as detailed_reason, `data`->"$.printed" as printed ';
                $resolved = (clone $queryBuilder->queryBuilder())->whereIn(
                    'requests.id',
                    (new ActionerQueryBuilder($connection))->resolved()->filterByUserId($sfuserId)->queryBuilder()->select('requests.id')
                )
                    ->selectRaw($columns.', 2 as status')->groupBy('requests.id');
                $requests = $queryBuilder->queryBuilder()->whereIn(
                    'requests.id',
                    (new ActionerQueryBuilder($connection))->toBeApprovedByMe()->filterByUserId($sfuserId)->queryBuilder()->select('requests.id')
                )
                    ->selectRaw($columns.', 1 as status')->groupBy('requests.id')
                    ->union($resolved)->orderBy('status')->orderBy('created_at', 'desc')
                    ->paginate($input['per_page'])->toArray();
                break;
        }

        $items = $requests['data'];

        // 因为 QueryBuilder 走的是 DB 而不是 Model，因此需要手动 cast
        foreach ($items as &$item) {
            $item = CommonRequest::normalizeWorkflowRequest($item);
        }
        unset($item);

        $itemIds = Arr::pluck($items, 'id');
        $actions = Action::validActions($connection, $sfuserId, $itemIds);
        $operatorTypes = Action::currentToBeApprovedOperatorTypes($connection, $itemIds);

        foreach ($items as &$item) {
            $types = explode(',', $item['type']);
            $item['type'] = array_pop($types);
            // 不返回 data 和 files
            $item['actions'] = ($item['is_locked']) ? [] : Arr::get($actions, $item['id'], []);
            // 只有审批中的才有审批人
            $item['curr_operator_type'] = in_array($item['current_state_id'], State::COMMON_TYPES) ? 0 : Arr::get($operatorTypes, $item['id'], []);
        }
        unset($item);

        // 已冲账金额
        $needStrikeBalance = StrikeBalanceDetail::whereIn('request_id', array_column($items, 'id'))->where('is_closed', 0)->groupBy('request_id')
            ->selectRaw('request_id, SUM(strike_balance_money) as sum')->pluck('sum', 'request_id')->toArray();

        $tokens = [];
        foreach ($items as &$item) {
            $item['info'] = is_string($item['info']) ? my_json_decode($item['info']) : $item['info'];
            if (!empty($item['token'])) {
                $tokens[] = $item['token'];
            }
            unset($item['token']);

            $processKey = $item['process_key'];
            $stateClassName = Registry::PROCESS_MAPS[$processKey]['class'];
            /** @phpstan-ignore-next-line */
            $stateClass = new $stateClassName($item['version']);
            $specialActions = Arr::get($stateClass->specialActions, $item['current_state_id'].'.'.$item['type'], []);
            if ($item['is_locked']) {
                $specialActions = array_diff($specialActions, SpecialAction::BANNED_WHEN_LOCKED_TYPE);
            }

            $item['special_actions'] = $specialActions;

            // 未冲账金额
            $strikeBalance = Arr::get($needStrikeBalance, $item['id'], 0);
            if ($item['pay_type'] == AdvanceChargeDetail::TELEGRAPHIC && $item['current_state_id'] === State::COMPLETED) {
                $item['need_strike_balance'] = '0.00';
            } else {
                $item['need_strike_balance'] = bcsub($item['actual_money'], $strikeBalance, 2);
            }
        }
        unset($item);

        $res = [
            'current_page' => $requests['current_page'],
            'per_page' => $requests['per_page'],
            'total' => $requests['total'],
            'requests' => $items,
        ];

        if ($type != 'issued' && count($tokens)) { // 不是我发起的，并且存在 token，则通过 Token 解密。
            $res['decrypt_config'] = [
                'tokens' => $tokens,
            ];
        }

        return $this->responseJsonSuccess($res);
    }

