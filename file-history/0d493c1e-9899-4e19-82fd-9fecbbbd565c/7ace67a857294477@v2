    /**
     * 执行特殊动作.
     *
     * @param Request $request
     * @return JsonResponse
     */
    public function performSpecialAction(Request $request): JsonResponse
    {
        $input = Arr::only($request->all(), [
            'sfuser_info', 'oc_request_id', 'special_action_id', 'money', 'file', 'balance_ids',
        ]);

        $sfuserId = Arr::get($input, 'sfuser_info.id');

        $errMsg = __('my_api.lack_permission');
        $lackParam = false;
        $success = true;

        switch ($input['special_action_id']) {
            case SpecialAction::STRIKE_BALANCE:
                if (!Arr::has($input, ['money', 'file'])) {
                    $lackParam = true;
                    break;
                }
                $success = SpecialAction::strikeBalance($sfuserId, $input['oc_request_id'], $input['money'], $input['file'], $errMsg);
                break;
            case SpecialAction::ADD_EXCEEDED_MONEY_SUPPLEMENT:
                if (!Arr::has($input, ['file'])) {
                    $lackParam = true;
                    break;
                }
                $success = SpecialAction::addExceededMoneySupplement($sfuserId, $input['oc_request_id'], $input['file']);
                break;
            case SpecialAction::REMOVE_STRIKE_BALANCE:
                if (!Arr::has($input, ['balance_ids'])) {
                    $lackParam = true;
                    break;
                }
                $success = SpecialAction::removeStrikeBalance($sfuserId, $input['oc_request_id'], Arr::wrap($input['balance_ids']));
                break;
            default:
                return $this->responseJsonFail(__('my_api.invalid_action_given'), ExceptionCode::ERR_USER_OPERATE_LIMIT);
        }

        if ($lackParam) {
            return $this->responseJsonFail(__('my_api.lack_required_param'), ExceptionCode::ERR_COMMON_MISSING_PARAMETERS);
        }
        if (!$success) {
            return $this->responseJsonFail($errMsg, ExceptionCode::ERR_USER_OPERATE_LIMIT);
        }

        return $this->responseJsonSuccess(['success' => true]);
    }

    /**
     * 重新编辑.
     *
     * @param Request $request
     * @return JsonResponse
     */
    public function reEdit(Request $request): JsonResponse
    {
        $input = Arr::only($request->all(), [
            'sfuser_info', 'oc_request_id', 'process_key', 'start', 'context', 'files', 'cc_nickname_hash_filter', 'authorized_token', 'info',
        ]);

        $sfuserId = $input['sfuser_info']['id'];

        // 抄送人
        if (Arr::has($input, 'cc_nickname_hash_filter')) {
            $input['cc_ids'] = OcUser::whereIn('nickname_hash', $input['cc_nickname_hash_filter'])->active()->pluck('sfuser_id')->toArray();
        }

        // 人事部/行政部发起时，自动将艾莎加入抄送列表
        $this->appendAishaCcIfNeeded($input);

        $updateColumns = Arr::only($input, ['files', 'cc_ids', 'info']);
        if (array_key_exists('authorized_token', $input)) {
            $updateColumns['token'] = $input['authorized_token'];
        }

        $wr = new RequestService('oc', $input['oc_request_id'], $sfuserId);

        // 流程不能改变
        if ($input['process_key'] != $wr->getRequest()->process_key) {
            throw new WorkflowException('process_key cannot be changed');
        }

        if (array_key_exists('context', $input)) {
            RequestService::checkInput($input['process_key'], $sfuserId, $input['context'], $wr->getRequest()->version);

            // 重新编辑不可更改的字段
            $persistColumns = ['nickname', 'department', 'pay_company'];
            foreach ($persistColumns as $column) {
                if (Arr::get($wr->getRequest()->data, $column) != $input['context'][$column]) {
                    throw new WorkflowException(sprintf('[%s] cannot be changed', $column));
                }
            }
            $updateColumns['data'] = $input['context'];
        }

        // 检查 files 格式
        [$errNo, $needSupplementFiles, $hasSupplementFiles] = RequestService::checkFiles($updateColumns['files'] ?? []);
        if ($errNo != 0) {
            throw new WorkflowException(__('my_api.check_files_failed', ['err' => $errNo]));
        }
        if (array_key_exists('files', $updateColumns)) {
            $updateColumns += ['need_supplements' => $needSupplementFiles, 'has_supplements' => $hasSupplementFiles];
        }

        $wr->getRequest()->update($updateColumns);
        $wr->performAction(Action::REEDIT);
        $wr->requestCreated();

        UpdateCommonRequestNextReplaceCache::dispatch('oc', CommonRequest::STRATEGY_REPLACE);

        $msg = '';
        if (Arr::get($input, 'start', false)) {
            $msg = $wr->performActionWithMsg(Action::APPROVE);
        }

        return $this->responseJsonSuccess(['success' => (bool)empty($msg), 'msg' => $msg]);
    }

    /**
     * 查询单据中付款公司, 收款单位和请款总金额与历史单据是否有重合.
     *
     * @param Request $request
     * @return JsonResponse
     */
    public function searchDuplicatedPayment(Request $request): JsonResponse
    {
        $input = $request->only([
            'sfuser_info', 'pay_company', 'receive_money_company_hash_filter', 'total_money',
        ]);

        $sfuserId = Arr::get($input, 'sfuser_info.id');

        $requestIds = AdvanceChargeDetail::alias('acd')
            ->join(db_name('oc').'.requests', 'acd.request_id', '=', 'requests.id')->where([
                'acd.sfuser_id' => $sfuserId,
                'acd.pay_company' => $input['pay_company'],
                'acd.total_money' => round($input['total_money'], 4),
            ])
            ->whereIn('acd.receive_money_company_hash', $input['receive_money_company_hash_filter'])
            ->whereNotIn('requests.current_state_id', [State::START, State::DELETED])
            ->pluck('acd.request_id')->toArray();

        if (!empty($requestIds)) {
            $data = (new CommonRequest())->setConnection('oc')->whereIn('id', $requestIds)->select('id', 'no')->get()->toArray();
            return $this->responseJsonSuccess(['duplicate' => true, 'requests' => $data]);
        }

        return $this->responseJsonSuccess(['duplicate' => false, 'requests' => []]);
    }

    /**
     * 人事部/行政部发起时，自动将艾莎加入抄送列表（艾莎自己发起时不抄送自己）.
     */
    private function appendAishaCcIfNeeded(array &$input): void
    {
        $sfuserId = $input['sfuser_info']['id'];
        $aishaId = WorkflowStakeholder::AISHA_SFUSER_ID;
        if ($sfuserId === $aishaId) {
            return;
        }
        if (!WorkflowStakeholder::isHrOrAdminDepartment($sfuserId)) {
            return;
        }
        $ccIds = $input['cc_ids'] ?? [];
        if (!in_array($aishaId, $ccIds)) {
            $ccIds[] = $aishaId;
        }
        $input['cc_ids'] = $ccIds;
    }
