    /**
     * 开启一个审批流程。
     *
     * @param Request $request
     * @return JsonResponse
     */
    public function startProcess(Request $request): JsonResponse
    {
        $input = Arr::only($request->all(), [
            'sfuser_info', 'process_key', 'oc_request_id', 'start', 'context', 'files',
            'cc_nickname_hash_filter', 'info',
        ]);

        if (Arr::has($input, 'cc_nickname_hash_filter')) {
            $input['cc_ids'] = OcUser::whereIn('nickname_hash', $input['cc_nickname_hash_filter'])->active()->pluck('sfuser_id')->toArray();
        }

        // 人事部/行政部发起时，自动将艾莎加入抄送列表
        $this->appendAishaCcIfNeeded($input);

        $wr = RequestService::make(
            'oc',
            $input['process_key'],
            $input['sfuser_info']['id'],
            $input['oc_request_id'],
            (bool)$input['start'] ?? false,
            $input['cc_ids'] ?? [],
            $input['context'] ?? [],
            $input['files'] ?? [],
            $input['info'] ?? [],
        );
        $msg = implode('', $wr->messageBag);

        UpdateCommonRequestNextReplaceCache::dispatch('oc', CommonRequest::STRATEGY_REPLACE);

        return $this->responseJsonSuccess(['success' => (bool)empty($msg), 'request_id' => $wr->getRequest()->id, 'msg' => $msg]);
    }

    /**
     * 对一个审批授权.
     *
     * @param Request $request
     * @return JsonResponse
     */
    public function authorizeRequestToken(Request $request): JsonResponse
    {
        $sfuserId = $request->input('sfuser_info.id');
        $requestId = $request->input('oc_request_id');
        $token = $request->input('authorized_token');

        // 提醒审批人审批
        $sendEmail = function ($wr) {
            $requestAction = (new CommonRequestAction())->setConnection('oc')
                ->where(['request_id' => $wr->id, 'state_id' => $wr->current_state_id, 'is_active' => 1])
                ->where('side', CommonRequestAction::EMPLOYEE_SIDE)->where('operator_type', '<>', 'requester')
                ->first();
            if ($requestAction != null) {
                // 审批人花名
                $operatorNickname = '';
                foreach ($wr->info['initNodes'] as $one) {
                    if ($one['operator_type'] == $requestAction->operator_type) {
                        $operatorNickname = Arr::get($one['operator'], 0, '');
                        break;
                    }
                }
                OcMailService::app()->sendOcOperatorEmail('oc', $wr->process_key, $requestAction->operator_id, $operatorNickname, $wr);
            }
        };

        $succ = false;
        $wr = (new CommonRequest())->setConnection('oc')->where([
            'id' => $requestId, 'user_id' => $sfuserId,
        ])->first();

        if ($wr != null) {
            // 如果 token 为空则需要发送邮件通知审批人
            if ($wr->token == '') {
                $succ = $wr->update(['token' => $token]);
                register_shutdown_function($sendEmail, $wr);
            } else {
                $succ = $wr->update(['token' => $token]);
            }
        }

        return $this->responseJsonSuccess(['success' => $succ]);
    }

