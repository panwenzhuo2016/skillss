    /**
     * 一键已读.
     *
     * @param Request $request
     * @return JsonResponse
     */
    public function readAllCCRequests(Request $request)
    {
        $input = Arr::only($request->all(), [
            'sfuser_info', 'per_page', 'no', 'approval_statuses', 'lack_supplements', 'nickname_hash_filter',
            'receive_money_company_hash_filter', 'pay_company', 'apply_reason', 'invoice_type',
            'pay_date_start', 'pay_date_end', 'next_replace_filter',
        ]);

        $sfuserId = $input['sfuser_info']['id'];

        $queryBuilder = (new PaymentStakeholderQueryBuilder('oc'))->asCCer()->filterByUserId($sfuserId);

        // 按申请人进行过滤
        if (Arr::has($input, 'nickname_hash_filter')) {
            $userIds = OcUser::whereIn('nickname_hash', $input['nickname_hash_filter'])->pluck('sfuser_id')->toArray();
            $queryBuilder->filterByRequesterIds($userIds);
        }

        // 按编号筛选
        if ($no = Arr::get($input, 'no')) {
            $queryBuilder->filterByNo($no);
        }

        // 按关键字搜索筛选
        if (($nextReplaceFilterIds = Arr::get($input, 'next_replace_filter')) !== null) {
            $queryBuilder->filterByRequestIds($nextReplaceFilterIds);
        }

        // 按审批状态筛选
        $approvalStatuses = Arr::wrap(Arr::get($input, 'approval_statuses', []));
        if ($approvalStatuses) {
            $queryBuilder->stateIn($approvalStatuses);
        }

        $lackSupplements = Arr::get($input, 'lack_supplements', -1);
        if ($lackSupplements != -1) {
            /** lack_supplements: 1 缺少材料，2 材料齐全 */
            $lack = $lackSupplements == 1; // 不搜时，不传该参数，因此不用判断是否为 2 了
            $queryBuilder->filterByLackSupplements($lack);
        }

        $processKey = Arr::get($input, 'process_key', []);
        if ($processKey) {
            $queryBuilder->filterByProcessKey($processKey);
        }

        // 按照收款公司查找
        if ($receiveMoneyCompany = Arr::get($input, 'receive_money_company_hash_filter', [])) {
            $queryBuilder->filterByReceiveCompany($receiveMoneyCompany);
        }

        // 按照付款公司查询
        if ($payCompany = Arr::get($input, 'pay_company')) {
            $queryBuilder->filterByPayCompany($payCompany);
        }

        // 按照请款原因查询
        if ($applyReason = Arr::get($input, 'apply_reason')) {
            $queryBuilder->filterByApplyReason($applyReason);
        }

        // 按照发票类型查询
        if ($invoiceType = Arr::get($input, 'invoice_type')) {
            $queryBuilder->filterByInvoiceType($invoiceType);
        }

        // 按照实际付款时间搜索
        $queryBuilder->payDateAfter(Arr::get($input, 'pay_date_start', ''))
            ->payDateBefore(Arr::get($input, 'pay_date_end', ''));

        $cnt = $queryBuilder->queryBuilder()->update(['is_read' => 1]);

        // 更新付款抄送未读
        NotifyNumberService::app()->modifyIndividual($sfuserId, 'oc_cc', -1 * $cnt);

        return $this->responseJsonSuccess(['count' => $cnt]);
    }

    /**
     * 我发起的一键导出.
     *
     * @param Request $request
     * @return JsonResponse
     */
    public function exportIssuedRequests(Request $request)
    {
        $input = Arr::only($request->all(), [
            'sfuser_info', 'per_page', 'no', 'approval_statuses', 'lack_supplements', 'lock_status', 'receive_money_company_hash_filter',
            'pay_company', 'apply_reason', 'invoice_type', 'pay_date_start', 'pay_date_end', 'launch_date_start', 'launch_date_end',
            'next_replace_filter',
        ]) + ['per_page' => 50];

        $sfuserId = $input['sfuser_info']['id'];

        $queryBuilder = (new OcQueryBuilder())->filterByRequestUsers($sfuserId);

        // 按编号筛选
        if ($no = Arr::get($input, 'no')) {
            $queryBuilder->filterByNo($no);
        }

        // 按关键字搜索筛选
        if (($nextReplaceFilterIds = Arr::get($input, 'next_replace_filter')) !== null) {
            $queryBuilder->filterByRequestIds($nextReplaceFilterIds);
        }

        // 按审批状态筛选
        $approvalStatuses = Arr::wrap(Arr::get($input, 'approval_statuses', []));
        if ($approvalStatuses) {
            $queryBuilder->stateIn($approvalStatuses);
        }

        $lackSupplements = Arr::get($input, 'lack_supplements', -1);
        if ($lackSupplements != -1) {
            /** lack_supplements: 1 缺少材料，2 材料齐全 */
            $lack = $lackSupplements == 1; // 不搜时，不传该参数，因此不用判断是否为 2 了
            $queryBuilder->filterByLackSupplements($lack);
        }

        $processKey = Arr::get($input, 'process_key', []);
        if ($processKey) {
            $queryBuilder->filterByProcessKey($processKey);
        }

        $lockStatus = Arr::get($input, 'lock_status', -1);
        if ($lockStatus == 0) {
            $queryBuilder->unlocked();
        } elseif ($lockStatus == 1) {
            $queryBuilder->locked();
        }

        // 按照收款公司查找
        if ($receiveMoneyCompany = Arr::get($input, 'receive_money_company_hash_filter', [])) {
            $queryBuilder->filterByReceiveCompany($receiveMoneyCompany);
        }

        // 按照付款公司查询
        if ($payCompany = Arr::get($input, 'pay_company')) {
            $queryBuilder->filterByPayCompany($payCompany);
        }

        // 按照请款原因查询
        if ($applyReason = Arr::get($input, 'apply_reason')) {
            $queryBuilder->filterByApplyReason($applyReason);
        }

        // 按照发票类型查询
        if ($invoiceType = Arr::get($input, 'invoice_type')) {
            $queryBuilder->filterByInvoiceType($invoiceType);
        }

        // 按照实际付款时间搜索
        $queryBuilder->payDateAfter(Arr::get($input, 'pay_date_start', ''))
            ->payDateBefore(Arr::get($input, 'pay_date_end', ''));

        // 按照发起时间搜索
        $queryBuilder->launchDateAfter(Arr::get($input, 'launch_date_start', ''))
            ->launchDateBefore(Arr::get($input, 'launch_date_end', ''));

        $requests = $queryBuilder->queryBuilder()->selectRaw(
            '`requests`.`id`, `user_id`, `process_key`, `no`, `current_state_id`, `is_locked`, `requests`.`created_at`, `data`,
            `actual_money`, `pay_date`, `complete_date`'
        )->paginate($input['per_page'])->toArray();

        foreach ($requests['data'] as &$one) {
            $one = (array)$one;
            $one['data'] = my_json_decode($one['data']);
            $one['actual_money'] = number_format($one['actual_money'], 2, '.', '');
        }
        unset($one);

        $res = [
            'current_page' => $requests['current_page'],
            'per_page' => $requests['per_page'],
            'total' => $requests['total'],
            'requests' => $requests['data'],
        ];

        return $this->responseJsonSuccess($res);
    }

    /**
     * 获取审批详情.
     *
     * @param Request $request
     * @return JsonResponse
     */
    public function request(Request $request)
    {
        $sfuserId = $request->input('sfuser_info.id');
        $requestId = $request->input('oc_request_id');

        // 在 OA 端，只有可见，才能查看详情
        $wrs = (new CommonRequestStakeholder())->setConnection('oc')
            ->where('request_id', $requestId)->where('user_id', $sfuserId)
            ->first();
        if (!$wrs) {
            throw new WorkflowException(__('my_api.workflow_request_not_found'), ExceptionCode::ERR_RESOURCE_MISSING);
        }

        $wr = new RequestService('oc', $requestId, $sfuserId);

        $detail = $wr->detail(true);

        if (Arr::has($detail, 'basic') && $detail['basic']['process_key'] == Registry::PAYMENT) {
            $requestId = $detail['basic']['id'];
            $chargeDetail = AdvanceChargeDetail::where('request_id', $requestId)->first();

            // 大写付款金额
            $detail['basic']['data']['actual_money'] = ($chargeDetail == null) ? '' : $chargeDetail->actual_money;
            $detail['basic']['data']['uppercase_actual_money'] = Helper::num2rmb($detail['basic']['data']['actual_money']);
            $detail['basic']['data']['uppercase_actual_money_eng'] = Helper::num2eng($detail['basic']['data']['actual_money']);
            // 冲账详情
            $detail['basic']['strike_balance_detail'] = StrikeBalanceDetail::where(['request_id' => $requestId, 'is_closed' => 0])->get()->toArray();
            // 付款时间
            $detail['basic']['pay_date'] = ($chargeDetail == null) ? '' : $chargeDetail->pay_date;
            // 审批通过时间
            $detail['basic']['approval_date'] = ($chargeDetail == null) ? '' : $chargeDetail->approval_date;
            // 审批完成时间
            $detail['basic']['complete_date'] = ($chargeDetail == null) ? '' : $chargeDetail->complete_date;
            // 优先级 兼容历史数据
            $detail['basic']['data']['priority'] = ($chargeDetail == null) ? Arr::get($detail, 'basic.data.priority', 1) : $chargeDetail->priority;

            // 作为申请人
            if ($sfuserId == $wr->getRequest()->user_id) {
                // 付款凭证
                $detail['basic']['pay_proof'] = empty($chargeDetail->pay_proof) ? [] : $chargeDetail->pay_proof;
            }

            // 超额请款审批单据, 员工端只有财务主管和 CEO 可以看到
            $operatorIds = (new CommonRequestAction())->setConnection('oc')->where('request_id', $requestId)
                ->whereIn('operator_type', [CommonSpecialStakeholder::FINANCIAL_TYPE, CommonSpecialStakeholder::CEO_TYPE])
                ->pluck('operator_id')->unique()->toArray();
            if (in_array($sfuserId, $operatorIds) && $chargeDetail != null) {
                $detail['basic']['is_excess'] = $chargeDetail->is_excess;
                $detail['basic']['excess_file'] = empty($chargeDetail->excess_file) ? [] : $chargeDetail->excess_file;
            }

            // 作废详情
            if ($detail['basic']['is_locked']) {
                $lockDetail = (new CommonRequestLockDetail())->setConnection('oc')->where('request_id', $requestId)->first();
                $detail['basic']['lock_detail'] = ($lockDetail == null) ? [] : $lockDetail->toArray();
            }

            // 管理端审批人花名
            $types = [CommonSpecialStakeholder::FINANCIAL_HANDEL_TYPE, CommonSpecialStakeholder::FINANCIAL_PAYMENT_TYPE];
            $stateClass = $wr->getStateClass();
            foreach ($types as $operatorType) {
                $specialSfusers = $stateClass->fetchSpecialSfuser('oc', $operatorType, $detail['basic']['data']);
                $detail['special_nicknames'][] = [
                    'operator_type' => $operatorType,
                    'nicknames' => $specialSfusers['nicknames'],
                ];
            }

            // 留言
            $detail['message_forum'] = OcMessageForum::where('request_id', $requestId)->orderBy('id', 'DESC')->get()->toArray();

            Arr::forget($detail, 'basic.data.supplier_info.supplier_company_hash');
        }

        $res = ['detail' => $detail];

        // 有 Token，并且不是本人的话，不需要通过 Token 解密
        if ($wr->getRequest()->token && $sfuserId != $wr->getRequest()->user_id) {
            $res['decrypt_config'] = [
                'tokens' => Arr::wrap($wr->getRequest()->token),
            ];
        }

        return $this->responseJsonSuccess($res);
    }

    /**
     * 付款留言增删改.
     *
     * @param Request $request
     * @return JsonResponse
     */
    public function editMessageForum(Request $request): JsonResponse
    {
        $input = Arr::only($request->all(), [
            'sfuser_info', 'oc_request_id', 'operation_type', 'oc_message_id', 'data',
        ]);
        $sfuserId = $input['sfuser_info']['id'];

        $exists = (new CommonRequest())->setConnection('oc')->where(['id' => $input['oc_request_id'], 'user_id' => $sfuserId])->exists();
        if (!$exists) {
            return $this->responseJsonFail(__('my_api.lack_permission'));
        }

        switch ($input['operation_type']) {
            case 'add':
                $ret = OcMessageForum::create(['request_id' => $input['oc_request_id'], 'sfuser_id' => $sfuserId, 'data' => $input['data']]);
                if ($ret) {
                    $paths = array_column(Arr::get($input, 'data.files', []), 'value');
                    if (empty($paths)) {
                        break;
                    }
                    $files = array_map(fn ($path) => [
                        'table_name' => 'oc_message_forums',
                        'table_id' => $ret->id,
                        'file_store_path' => $path,
                        'type' => 'annex',
                        'disk' => 'oc',
                        'operator_id' => $sfuserId,
                        'is_closed' => 0,
                    ], $paths);
                    (new CommonFileStorePath())->setConnection('oc')->insert($files);
                }
                break;
            case 'modify':
                $ret = OcMessageForum::where(['id' => $input['oc_message_id'], 'sfuser_id' => $sfuserId])->update(['data' => $input['data']]);
                if ($ret) {
                    $paths = array_column(Arr::get($input, 'data.files', []), 'value');
                    (new CommonFileStorePath())->setConnection('oc')
                        ->where(['table_name' => 'oc_message_forums', 'table_id' => $input['oc_message_id']])
                        ->whereNotIn('file_store_path', $paths)
                        ->update(['is_closed' => 1]);
                    foreach ($paths as $path) {
                        (new CommonFileStorePath())->setConnection('oc')
                            ->updateOrCreate([
                                'table_name' => 'oc_message_forums',
                                'table_id' => $input['oc_message_id'],
                                'file_store_path' => $path,
                            ], [
                                'table_name' => 'oc_message_forums',
                                'table_id' => $input['oc_message_id'],
                                'file_store_path' => $path,
                                'type' => 'annex',
                                'disk' => 'oc',
                                'operator_id' => $sfuserId,
                                'is_closed' => 0,
                            ]);
                    }
                }
                break;
            case 'delete':
                $ret = OcMessageForum::where(['id' => $input['oc_message_id'], 'sfuser_id' => $sfuserId])->delete();
                if ($ret) {
                    (new CommonFileStorePath())->setConnection('oc')
                        ->where(['table_name' => 'oc_message_forums', 'table_id' => $input['oc_message_id']])
                        ->delete();
                }
                break;
            default:
                break;
        }

        return $this->responseJsonSuccess(['success' => !empty($ret)]);
    }

