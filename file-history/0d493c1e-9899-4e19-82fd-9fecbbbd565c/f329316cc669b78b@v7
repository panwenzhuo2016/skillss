    public function nicknameExists(Request $request): JsonResponse
    {
        $sfuserId = $request->input('sfuser_info.id');
        $nicknameHash = $request->input('nickname_hash_filter');

        if (empty($sfuserId) || empty($nicknameHash)) {
            return $this->responseJsonSuccess(['exist' => false, 'sfuser_id' => 0]);
        }

        /** @var Sfuser $u */
        $u = Sfuser::whereIn('nickname_hash', $nicknameHash)->where('is_closed', 0)->first();
        $sfuserId = $u->id ?? 0;
        if (SiteService::app()->is(SiteService::CHN)) {
