    public function crossAccessFitName(Request $request): JsonResponse
    {
        $type = $request->input('type');
        $name = $request->input('name');

        $data = [];
        if (!empty($name)) {
            $projectNames = CrossAccess::SPECIAL_PROJECT_MAPS;
            if ($type == 'current') {
                $projectNames = array_merge($projectNames, CrossAccess::LOCAL_PROJECT_MAPS);
            } elseif ($type == 'target') {
                $projectNames = array_merge($projectNames, CrossAccess::CROSS_PROJECT_MAPS);
            }
            array_walk($projectNames, function ($value, $key) use ($name, &$data) {
                if (stripos($key, $name) !== false) {
                    $data[] = ['name' => $key, 'value' => $value];
                }
            });
        }

        return $this->responseJsonSuccess($data);
    }

    public function todoList(Request $request): JsonResponse
    {
        $sfuserId = Arr::get($request->all(), 'sfuser_info.id');
        $disableCache = $request->input('disable_cache', false);

        $data = IndividualData::getData($sfuserId);

        // 都已经获得了总数，有必要过滤吗
        $counts = $disableCache ? Record::count($sfuserId) : Record::getFromCache($sfuserId);

        $todoMenus = Arr::get($data, 'todo_menus', []);
        $currTodoMenus = array_keys(array_filter($counts, function ($value, $key) {
            if ($key == Record::ISSUED_BUT_NOT_COMPLETED || $key == Record::FILE_SUPPLEMENT_AS_REQUESTER) {
                return true;
            }
            return $value > 0;
        }, ARRAY_FILTER_USE_BOTH)); // 本次合法的菜单条目

        // 与历史菜单项合并
        $totalTodoMenus = array_unique(array_merge($currTodoMenus, $todoMenus));
        if (count($todoMenus) != count($totalTodoMenus)) {
            // 数目不等，则更新 IndividualData，因为只可能增加，不可能减少
            $data['todo_menus'] = $totalTodoMenus;
            IndividualData::setData($sfuserId, $data);
        }

        $ret = [];
        foreach ($totalTodoMenus as $key) {
            $ret[$key] = $counts[$key];
        }

        // 有没有我的执行
        $types = WorkflowSpecialStakeholder::alias('wss')
            ->whereIn('type', WorkflowRequestStakeholder::OTHER_TYPES)
            ->whereJsonContains('ids', $sfuserId)->pluck('wss.type')->toArray();
        if (!empty($types)) {
            $typeToKeyMap = [
                WorkflowRequestStakeholder::ONLY_OFFICE_EXECUTOR_TYPE => Registry::ONLY_OFFICE,
                WorkflowRequestStakeholder::JIRA_CONFLUENCE_EXECUTOR_TYPE => Registry::JIRA_CONFLUENCE,
                WorkflowRequestStakeholder::EB_EXECUTOR_TYPE => Registry::EB,
                WorkflowRequestStakeholder::YA_EXECUTOR_TYPE => Registry::YA,
                WorkflowRequestStakeholder::X_JIRA_CONFLUENCE_EXECUTOR_TYPE => Registry::X_JIRA_CONFLUENCE,
                WorkflowRequestStakeholder::AI_TOOLS_EXECUTOR_TYPE => Registry::AI_TOOLS,
                WorkflowRequestStakeholder::GCP_EXECUTOR_TYPE => Registry::GCP,
                WorkflowRequestStakeholder::MATTERMOST_EXECUTOR_TYPE => Registry::MATTERMOST,
            ];

            $process_keys = array_values(array_intersect_key($typeToKeyMap, array_flip($types)));

            $exists = OtherPermissionExecute::alias('op')
                ->whereIn('op.process_key', $process_keys)
                ->exists();

            if ($exists) {
                $execute_to_me = DB::table('workflow_requests')
                    ->leftJoin('other_permission_execute', 'other_permission_execute.request_id', '=', 'workflow_requests.id')
                    ->where('workflow_requests.current_state_id', '=', State::COMPLETED)
                    ->whereIn('other_permission_execute.process_key', $process_keys)
                    ->where('other_permission_execute.is_execute', 0)
                    ->count();
                $ret['execute_to_me'] = $execute_to_me;
            }
        }
        $ret = ApprovalManagementController::dealLessThan0($ret);
        return $this->responseJsonSuccess(['todos' => $ret]);
    }

    public function reimbursementTodo(Request $request): JsonResponse
    {
        $sfuserId = Arr::get($request->all(), 'sfuser_info.id');
        $disableCache = $request->input('disable_cache', false);

        $data = IndividualData::getData($sfuserId);

        // 都已经获得了总数，有必要过滤吗
        $counts = $disableCache ? Record::count($sfuserId, Record::REIMBURSEMENT_TYPES) : Record::getFromCache($sfuserId, Record::REIMBURSEMENT_TYPES);

        $todoMenus = Arr::get($data, 'reimbursement_todo', []);
        $currTodoMenus = array_keys(array_filter($counts, function ($value, $key) {
            return $key == Record::REIMBURSE_ISSUED_BUT_NOT_COMPLETED || $value > 0;
        }, ARRAY_FILTER_USE_BOTH)); // 本次合法的菜单条目

        // 与历史菜单项合并
        $totalTodoMenus = array_unique(array_merge($currTodoMenus, $todoMenus));
        if (count($todoMenus) != count($totalTodoMenus)) {
            // 数目不等，则更新 IndividualData，因为只可能增加，不可能减少
            $data['reimbursement_todo'] = $totalTodoMenus;
            IndividualData::setData($sfuserId, $data);
        }

        $ret = Arr::only($counts, $totalTodoMenus);
        $ret = ApprovalManagementController::dealLessThan0($ret);
        return $this->responseJsonSuccess(['todos' => $ret]);
    }

