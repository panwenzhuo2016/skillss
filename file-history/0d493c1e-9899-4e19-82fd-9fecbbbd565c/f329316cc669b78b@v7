    public static function dealLessThan0(array $ret): array
    {
        foreach ($ret as $k => $v) {
            if ($v < 0) {
                info('小于0了，看下是为什么，todoList: less than 0, set to 0, key: '.$k.', value: '.$v);
                $ret[$k] = 0;
            }
        }
        return $ret;
    }

    protected function getRequests(Request $request, string $type)
    {
        $input = Arr::only($request->all(), [
            'sfuser_info', 'per_page', 'no', 'approval_statuses', 'status_type', 'lack_supplements', 'nickname_hash_filter', 'process_key', 'process_keys',
            'lock_status', 'include_expired', 'submitted_before', 'submitted_after',
        ]) + ['per_page' => 50];
        $sfuserId = $input['sfuser_info']['id'];

        $sfuserIdsForFiltering = [];
        $nicknameHashFilter = Arr::get($input, 'nickname_hash_filter');
        if ($nicknameHashFilter) {
            $sfuserIdsForFiltering = Sfuser::filterIfExists([
                ['sfusers.nickname_hash', 'IN', 'nickname_hash_filter'],
            ], $input)
                ->select('id')
                ->get()
                ->toArray();
        }

        // 传递了花名，但是查出来的 ids 为 0，则直接返回空集合
        if ($nicknameHashFilter && !$sfuserIdsForFiltering) {
            $res = [
                'current_page' => 1,
                'per_page' => $input['per_page'] ?? 50,
                'total' => 0,
                'requests' => [],
            ];
            return $this->responseJsonSuccess($res);
        }

        $queryBuilder = new StakeholderQueryBuilder();
        $qb = new ActionerQueryBuilder();

        switch ($type) {
            case 'issued':
                $queryBuilder = $queryBuilder->asRequester()->notCCer()->filterByUserId($sfuserId);
                break;
            case 'approving':
                $queryBuilder = $qb->toBeApprovedByMe()->filterByUserId($sfuserId);
                break;
            case 'resolved':
                $queryBuilder = $qb->resolved()->filterByUserId($sfuserId);
                break;
            case 'cc':
                $queryBuilder = $queryBuilder->asCCer()->filterByUserId($sfuserId);
                break;
            default:
                throw new InternalException('invalid type given');
        }

        $queryBuilder->orderBy('workflow_requests.created_at', 'desc');

        // 按申请人进行过滤
        if ($sfuserIdsForFiltering) {
            $queryBuilder->filterByRequesterIds($sfuserIdsForFiltering);
        }

        // 按编号筛选
        if ($no = Arr::get($input, 'no')) {
            $queryBuilder->filterByNo($no);
        }

        $excludeExpired = !Arr::get($input, 'include_expired', false);
        if ($excludeExpired) {
            $resolveUser = $type == 'resolved' || $type == 'approving';
            $expiredOperate = false;
            $startTime = '';
            $endTime = '';
            if ($resolveUser) {
                $service = new AttendanceService();
                $lock_approval_date = $service->getLockApprovalDate();
                $expiredOperate = $service->expiredOperate($lock_approval_date);
                $startTime = date('Y-m-d', strtotime("{$lock_approval_date} first day of last month")).' 00:00:00';
                $endTime = $lock_approval_date.AttendanceService::$END_TIME;
            }
            if ($expiredOperate) {
                $queryBuilder->excludeExpiredOperate($startTime, $endTime);
            } else {
                $queryBuilder->excludeExpired();
            }
        }

        // 待我审批列表始终不展示「超过审批期限」的考勤申请：start_datetime < 上月1号（上上个月及更早）
        // 与前端「该申请已超过审批期限,无法审批」一致。必须单独按 start_datetime 过滤，否则 is_expired=0 的也会出现（如 12 月请假在 2 月仍可见）
        if ($type == 'approving') {
            $service = new AttendanceService();
            $lock_approval_date = $service->getLockApprovalDate();
            $lastMonthFirstDay = date('Y-m-d', strtotime("{$lock_approval_date} first day of last month")).' 00:00:00';
            $queryBuilder->excludeAttendanceBeforeLastMonthFirstDay($lastMonthFirstDay);
        }

        // 按最新发起申请的时间搜索
        $queryBuilder->submittedBefore(Arr::get($input, 'submitted_before', ''))->submittedAfter(Arr::get($input, 'submitted_after', ''));

        // 按审批状态筛选
        $approvalStatuses = Arr::wrap(Arr::get($input, 'approval_statuses', []));
        if ($approvalStatuses) {
            $queryBuilder->stateIn($approvalStatuses);
        }
        $statusType = Arr::get($input, 'status_type', -1);
        switch ($statusType) {
            case 1: // 非报销
                $queryBuilder->excludeProcessKeys(Registry::REIMBURSEMENT_TYPE);
                break;
            case 2: // 仅报销
                $queryBuilder->filterByProcessKeys(Registry::REIMBURSEMENT_TYPE);
                break;
            default: break;
        }

        $lackSupplements = Arr::get($input, 'lack_supplements', -1);
        if ($lackSupplements != -1) {
            /** lack_supplements: 1 缺少材料，2 材料齐全 */
            $lack = $lackSupplements == 1; // 不搜时，不传该参数，因此不用判断是否为 2 了
            $queryBuilder->filterByLackSupplements($lack);
        }

        $processKey = Arr::get($input, 'process_key', '');
        if ($processKey) {
            $queryBuilder->filterByProcessKey($processKey);
        }

        $processKeys = Arr::get($input, 'process_keys', []);
        if ($processKeys) {
            if (in_array(Registry::JIRA_CONFLUENCE, $processKeys)) {
                $processKeys[] = Registry::X_JIRA_CONFLUENCE;
            }
            $queryBuilder->filterByProcessKeys($processKeys);
        }

        $lockStatus = Arr::get($input, 'lock_status', -1);
        if ($lockStatus == 0) {
            $queryBuilder->unlocked();
        } elseif ($lockStatus == 1) {
            $queryBuilder->locked();
        }

        $requests = [];
        switch ($type) {
            case 'issued':
            case 'cc':
                /** @phpstan-ignore-next-line */
                $requests = $queryBuilder->queryBuilder()->selectRaw(
                    '`workflow_requests`.`user_id`, `workflow_requests`.`id`, `workflow_requests`.`is_locked`, `workflow_request_stakeholders`.`type`, `is_read`, `workflow_requests`.`submitted_at`, `workflow_requests`.`created_at`, `process_key`, `no`, `current_state_id`, `need_supplements`, `has_supplements`, `info`, `token`'
                )->paginate($input['per_page'])->toArray();
                break;
            case 'approving':
            case 'resolved':
                // 之前的方式是有问题的，还是走子查询然后 groupBy 比较靠谱
                $sq = new StakeholderQueryBuilder();
                $idsQuery = $queryBuilder->orderBy('workflow_requests.created_at', 'desc')
                    ->queryBuilder()
                    ->groupBy('request_id')
                    ->select('request_id');
                $requests = $sq->filterByUserId($sfuserId)->notCCer()
                    ->notRequester() // 待我审批和我已审批需要过滤掉申请者
                    // 在这里还要再排序一次
                    ->orderBy('workflow_requests.created_at', 'desc')
                    ->queryBuilder()
                    ->whereIn('workflow_requests.id', $idsQuery)
                    ->selectRaw(
                        '`workflow_requests`.`user_id`, `workflow_requests`.`id`, `workflow_requests`.`is_locked`, GROUP_CONCAT(`workflow_request_stakeholders`.`type` SEPARATOR \',\') as type,
                        `is_read`, `workflow_requests`.`submitted_at`, `workflow_requests`.`created_at`, `process_key`, `no`, `current_state_id`, `need_supplements`, `has_supplements`, `info`, `token`'
                    )
                    ->groupBy('workflow_requests.id') // 保证申请记录唯一
                    ->paginate($input['per_page'])->toArray();
        }

        $items = $requests['data'];

        // 因为 QueryBuilder 走的是 DB 而不是 Model，因此需要手动 cast
        foreach ($items as &$item) {
            $item = WorkflowRequest::normalizeWorkflowRequest($item);
        }
        unset($item);

        $itemIds = Arr::pluck($items, 'id');
        $actions = Action::validActions($sfuserId, $itemIds);
        $operatorTypes = Action::currentToBeApprovedOperatorTypes($itemIds);

        // 报销总金额
        if ($statusType == 2) {
            $reimbursements = WorkflowReimbursement::whereIn('request_id', $itemIds)->pluck('total_money', 'request_id')->toArray();
        }
        $service = new AttendanceService();
        $lock_approval_date = $service->getLockApprovalDate();
        $outCalculateDate24 = strcmp(date('Y-m-d H:i:s'), $lock_approval_date.AttendanceService::$END_TIME) > 0;
        foreach ($items as &$item) {
            $types = explode(',', $item['type']);
            $item['type'] = array_pop($types);
            // 不返回 data 和 files
            $canOperate = $type == 'approving' && in_array($item['process_key'], Registry::CALCULATE_LOCK_TYPES) && !$outCalculateDate24;
            $item['actions'] = ($item['is_locked'] && !$canOperate) ? [] : $actions[$item['id']];
            if (!in_array($item['current_state_id'], State::COMMON_TYPES)) {
                if (!isset($operatorTypes[$item['id']])) {
                    throw new WorkflowException('当前审批状态异常，请重新发起申请或联系管理员!');
                }
            }
            // 只有审批中的才有审批人
            $item['curr_operator_type'] = in_array($item['current_state_id'], State::COMMON_TYPES) ? 0 : $operatorTypes[$item['id']];
        }
        unset($item);

        // 取出所有 type 为 ssc/IT 或房补审批人的 request id
        $needTagRequestIds = collect($items)->filter(function ($item) {
            $types = [
                WorkflowRequestStakeholder::SSC_TYPE,
                WorkflowRequestStakeholder::RENT_ALLOWANCE_DIRECT_SUPERVISOR_TYPE,
                WorkflowRequestStakeholder::REIMBURSEMENT_CC_TYPE,
            ];
            $types = array_merge($types, WorkflowRequestStakeholder::IT_DIRECT_SUPERVISOR_TYPES);
            $types = array_merge($types, WorkflowRequestStakeholder::REIMBURSEMENT_SUPERVISOR_TYPES);
            return in_array($item['type'], $types); // 取出当前可见人为 ssc/IT 或房补审批人身份的
        })->pluck('id')->toArray();

        $needPartialTagRequestIds = collect($items)->filter(function ($item) {
            return $item['type'] == WorkflowRequestStakeholder::REQUESTER_TYPE; // 取出当前可见人为申请者身份的
        })->pluck('id')->toArray();

        $tags = Tag::tags($needTagRequestIds); // SSC 针对缺少材料的标签可以执行补交材料和变更事假的两个特殊动作
        $partialTags = Tag::tags($needPartialTagRequestIds); // 申请者针对缺少材料的标签可以执行补交材料的特殊操作

        $tokens = [];
        foreach ($items as &$item) {
            $item['info'] = is_string($item['info']) ? my_json_decode($item['info']) : $item['info'];
            $item['token'] && $tokens[] = $item['token'];
            unset($item['token']);
            $itemTags = [];
            $specialActions = [];
            if ($item['type'] == WorkflowRequestStakeholder::SSC_TYPE) {
                $itemTags = Arr::get($tags, $item['id'], []); // SSC 视角的标签，即使是发起者，也以 SSC 视角去看
                if (in_array(Tag::LACK_SUPPLEMENT_FILES, $itemTags)) {
                    // 缺少材料，则直接追加两个特殊动作
                    if (in_array($item['process_key'], Helper::getProcessesByCategory('请假'))) {
                        $specialActions = [
                            SpecialAction::CONVERT_TO_PERSONAL_LEAVE, SpecialAction::APPEND_SUPPLEMENT_FILES,
                        ];
                    }
                }
            } elseif ($item['type'] == WorkflowRequestStakeholder::RENT_ALLOWANCE_DIRECT_SUPERVISOR_TYPE) {
                if ($item['process_key'] == Registry::RENT_ALLOWANCE) {
                    $itemTags = Arr::get($tags, $item['id'], []);
                    if (in_array(Tag::LACK_SUPPLEMENT_FILES, $itemTags)) {
                        $specialActions = [
                            SpecialAction::APPEND_SUPPLEMENT_FILES,
                        ];
                    }
                    $specialActions[] = SpecialAction::HR_STOP_RENT_ALLOWANCE;
                }
            } elseif (in_array($item['type'], WorkflowRequestStakeholder::IT_DIRECT_SUPERVISOR_TYPES)) {
                if (in_array($item['process_key'], Registry::IT_TYPE)) {
                    $itemTags = Arr::get($tags, $item['id'], []);
                }
            } elseif ($item['type'] == WorkflowRequestStakeholder::REIMBURSEMENT_CC_TYPE
                || in_array($item['type'], WorkflowRequestStakeholder::REIMBURSEMENT_SUPERVISOR_TYPES)
            ) {
                if (in_array($item['process_key'], Registry::REIMBURSEMENT_TYPE)) {
                    $itemTags = Arr::get($tags, $item['id'], []);
                }
            } elseif ($item['type'] == WorkflowRequestStakeholder::REQUESTER_TYPE) {
                // 非 SSC 身份，并且是请求发起者，标记一下身份
                $itemTags = Arr::get($partialTags, $item['id'], []);
                // 请求者不应看到除变更材料和缺少材料之外的标签
                // 请求者能看到的标签
                $itemTags = array_intersect($itemTags, Tag::AVAILABLE_BY_REQUESTER_TYPE);
                if (in_array(Tag::LACK_SUPPLEMENT_FILES, $itemTags)) {
                    $specialActions = [
                        // 追加补交材料的动作
                        SpecialAction::APPEND_SUPPLEMENT_FILES,
                    ];
                }
            }

            if ($item['is_locked']) {
                $specialActions = array_diff($specialActions, SpecialAction::BANNED_WHEN_LOCKED_TYPE);
            }

            $item['tags'] = array_values($itemTags);
            $item['un_excuted_reason'] = Tag::get_un_excuted_reasons($item, []);
            $item['special_actions'] = ($item['current_state_id'] == State::COMPLETED) ? $specialActions : [];
            if ($item['process_key'] == Registry::RENT_ALLOWANCE) {
                $item['rent_allowance_status'] = ($item['is_locked']) ? 1 : ($item['current_state_id'] == State::COMPLETED ? 2 : 3);
            } elseif (in_array($item['process_key'], Registry::REIMBURSEMENT_TYPE) && !empty($reimbursements)) {
                $item['total_money'] = $reimbursements[$item['id']] ?? null;
            }
            // 对外展示还是jira_access，
            $item['process_key'] = Registry::toJira($item['process_key']);
        }
        unset($item);

        $res = [
            'current_page' => $requests['current_page'],
            'per_page' => $requests['per_page'],
            'total' => $requests['total'],
            'requests' => $items,
        ];

        if ($type != 'issued' && count($tokens)) { // 不是我发起的，并且存在 token，则通过 Token 解密。
            $res['decrypt_config'] = [
                'tokens' => $tokens,
            ];
        }

        return $this->responseJsonSuccess($res);
    }
