     *
     * @throws Throwable
     * @see SpecialAction
     */
    public function performSpecialAction(Request $request): JsonResponse
    {
        // 补交材料可能会涉及到授权操作
        $input = Arr::only($request->all(), [
            'sfuser_info', 'request_id', 'special_action_id', 'files', 'authorized_token', 'info', 'pay_end_date', 'allowance_end_date',
        ]);
        $sfuserId = Arr::get($input, 'sfuser_info.id');
        $requestId = Arr::get($input, 'request_id');
        $files = Arr::get($input, 'files', []);
        $payEndDate = Arr::get($input, 'pay_end_date', '');
        $allowanceEndDate = Arr::get($input, 'allowance_end_date', date('Y-m-d'));
        $token = Arr::get($input, 'authorized_token', '');
        $info = Arr::get($input, 'info', []);

        // 检出 WorkflowRequest 实例
        /** @var WorkflowRequest $requestModel */
        $requestModel = WorkflowRequest::findOrFail($requestId);

        $errMsg = __('my_api.lack_permission');
        $specialActionId = Arr::get($input, 'special_action_id');
        switch ($specialActionId) {
            // 补交材料的操作
            case SpecialAction::APPEND_SUPPLEMENT_FILES:
                $res = SpecialAction::appendSupplementFiles($errMsg, $sfuserId, $requestModel, $files, $payEndDate, $token, $info);
                break;
            case SpecialAction::CONVERT_TO_PERSONAL_LEAVE:
                $res = SpecialAction::covertToPersonalLeave($sfuserId, $requestModel);
                break;
            case SpecialAction::HR_STOP_RENT_ALLOWANCE:
                $res = SpecialAction::hrStopRentAllowance($errMsg, $sfuserId, $requestModel, $allowanceEndDate);
                break;
            default:
                return $this->responseJsonFail(__('my_api.invalid_action_given'), ExceptionCode::ERR_USER_OPERATE_LIMIT);
        }

        if (!$res) {
            return $this->responseJsonFail($errMsg, ExceptionCode::ERR_USER_OPERATE_LIMIT);
        }

        return $this->responseJsonSuccess(['success' => true]);
    }

    /**
     * 重新编辑.
     * @param Request $request
     * @throws \App\Workflows\Exceptions\WorkflowException
     * @throws \ReflectionException
     * @throws Throwable
     * @throws \App\Workflows\Exceptions\RequestNotFoundException
     * @throws \App\Workflows\Exceptions\UserNotFoundException
     * @return JsonResponse
     */
    public function reEdit(Request $request): JsonResponse
    {
        $input = Arr::only($request->all(), [
            'request_id', 'sfuser_info', 'process_key', 'context', 'files', 'authorized_token', 'info', 'cc_nickname_hash_filter', 'cc_ids', 'member',
        ]);

        $query = WorkflowRequest::findOrFail($input['request_id']);
        $version = 0;
        $oldTotalMoney = 0;
        if ($query->process_key == $input['process_key']) {
            $version = $query->version;
            if (in_array($input['process_key'], Registry::REIMBURSEMENT_TYPE)) {
                $oldTotalMoney = Arr::get($query->data, 'total_money');
            }
        }

        if ($input['process_key'] == Registry::MATTERMOST) {
            $input['context']['is_mattermost'] = true;
            $input['context']['member'] = $input['member'] ?? [];
        }
        $sfuserId = $input['sfuser_info']['id'];
        $processKey = $input['process_key'];
        $startTime = Arr::get($input, 'context.start_datetime', '');
        $endTime = Arr::get($input, 'context.end_datetime', '');

        $lockKey = "workflow:check:{$sfuserId}:{$processKey}:".md5($startTime.$endTime);
        $lock = Cache::lock($lockKey, 10); // 默认使用默认缓存驱动，如果是 Redis 即可
        // 尝试获取锁，最多等待5秒
        if (!$lock->block(5)) {
            info("{$lockKey} is locked by other process.");
            throw new WorkflowException(__('my_api.system_busy_please_retry'));
        }

        // 重新编辑，不 checkStakeholders 了，反正参与者都已经在发起时保存起来了，就按照旧的流程走
        WorkflowRequestService::checkInput($input['process_key'], $input['sfuser_info']['id'], $input['context'], $version);

        // 自定义抄送人
        $customCcs = Arr::get($input, 'cc_ids', []);
        if (!empty($input['cc_nickname_hash_filter'])) {
            $tmpIds = Sfuser::active()->whereIn('nickname_hash', $input['cc_nickname_hash_filter'])->pluck('id')->toArray();
            $customCcs = array_values(array_unique(array_merge($customCcs, $tmpIds)));
        }
        if (!empty($customCcs)) {
            $input['context'][WorkflowRequest::CUSTOM_CC_KEY] = $customCcs;
        }

        try {
            $new = $this->service->isChangeProcessKey($input['sfuser_info']['id'], $input['request_id'], $input['process_key'], $input['context'], (array)Arr::get($input, 'files'));
        } catch (\Exception $e) {
            return $this->responseJsonFail($e->getMessage(), $e->getCode());
        }
        if ($new) {
            $wr = WorkflowRequestService::make($input['process_key'], $input['sfuser_info']['id'], $input['context'], (array)Arr::get($input, 'files'), $customCcs);
        } else {
            $wr = new WorkflowRequestService($input['request_id'], $input['sfuser_info']['id']);

            if (in_array($input['process_key'], Registry::REIMBURSEMENT_TYPE) && abs($input['context']['total_money'] - $oldTotalMoney) < 1e-4) {
                $wr->reEditAndApprove();
            } else {
                $wr->performAction(Action::REEDIT);
            }
        }
        $wr->requestCreated();
        // 更新 token
        $wr->getRequest()->update([
            'token' => $input['authorized_token'] ?? '',
            'info' => $input['info'] ?? [],
        ]);
        optional($lock)->release();
        return $this->responseJsonSuccess(['success' => true]);
    }

