    /**
     * 获取能申请差旅费报销的日期
     * 出差日期检验筛选.
     *
     * @param Request $request
     * @return JsonResponse
     */
    public function getCouldTripReimbursementDates(Request $request): JsonResponse
    {
        $sfuserId = $request->input('sfuser_info.id');

        $startDate = date('Y-m-d', strtotime('-1 year'));
        $tripDates = WorkflowDataExtra::where('sfuser_id', $sfuserId)->where('process_key', Registry::BUSINESS_TRIP)
            ->where('end_time', '>=', $startDate.' 00:00:00')->select('request_id', 'start_time', 'end_time')->get()->toArray();

        $requestIds = array_unique(array_column($tripDates, 'request_id'));
        $requestIds = WorkflowRequest::whereIn('id', $requestIds)->where('current_state_id', State::COMPLETED)
            ->pluck('id')->toArray();

        $allDates = [];
        foreach ($tripDates as $one) {
            if (!in_array($one['request_id'], $requestIds)) {
                continue;
            }
            $allDates = array_merge($allDates, Helper::getBetweenDates($one['start_time'], $one['end_time'], Registry::BUSINESS_TRIP));
        }
        $allDates = array_filter(array_unique($allDates), function ($date) use ($startDate) {
            return $date >= $startDate && $date <= date('Y-m-d');
        });

        $appliesDates = ReimbursementTripDate::where('sfuser_id', $sfuserId)->where('use_date', '>=', $startDate)
            ->pluck('use_date')->toArray();
        $filteredDates = array_values(array_diff($allDates, $appliesDates));

        return $this->responseJsonSuccess(['dates' => $filteredDates]);
    }

    /**
     * @apiName【报销记录】获取流程列表获取报销单需要的额外信息
     * @param Request $request
     * @return JsonResponse
     */
    public function reimbursementFormExtra(Request $request): JsonResponse
    {
        $sfuserId = $request->input('sfuser_info.id');
        $requestId = $request->input('request_id');

        $stakeholders = WorkflowRequestStakeholder::where('request_id', $requestId)->pluck('user_id')->toArray();
        if (!in_array($sfuserId, $stakeholders)) {
            return $this->responseJsonFail(__('my_api.sfuser_not_stakeholder_of_request', ['sfuserId' => $sfuserId, 'requestId' => $requestId]), ExceptionCode::ERR_USER_OPERATE_LIMIT);
        }

        $request = WorkflowRequest::findOrFail($requestId);
        $workflowRequest = new WorkflowRequestService($requestId, $sfuserId);
        // 合并相同的报销类型
        $data = collect($request->data['reimbursement_detail'])->groupBy('reimbursement_type')->map(function ($group) {
            return [
                'reimbursement_type' => $group->first()['reimbursement_type'],
                'reimbursement_money' => $group->sum('reimbursement_money'),
            ];
        })->toArray();

        $feeTypes = [];
        $substituteMap = Reimbursement::SUBSTITUTE_TICKET_MAP;
        // 合并替票
        foreach ($data as $key => $value) {
            $mapKey = $key;
            if (array_key_exists($key, $substituteMap)) {
                $mapKey = $substituteMap[$key];
            }
            if (array_key_exists($mapKey, $feeTypes)) {
                $feeTypes[$mapKey]['reimbursement_money'] += $value['reimbursement_money'];
            } else {
                $feeTypes[$mapKey] = [
                    'reimbursement_type' => $mapKey,
                    'reimbursement_money' => $value['reimbursement_money'],
                ];
            }
        }

        $res = [
            'nickname' => Sfuser::findOrFail($request->user_id)->nickname,
            'request_id' => $requestId,
            'no' => $request->no,
            'process_key' => $request->process_key,
            'data' => $request->data,
            'invoice_num' => count(data_get($request->data, 'reimbursement_detail.*.invoice.*')),
            'total_money' => $request->data['total_money'],
            'rmb_total_money' => Helper::num2rmb($request->data['total_money']),
            'fee_types' => array_values($feeTypes),
            'nodes' => $workflowRequest->nodes(),
            'info' => $request->info,
        ];

        // 有 Token，并且不是本人的话，不需要通过 Token 解密
        if ($request->token && $sfuserId != $request->user_id) {
            $res['decrypt_config'] = [
                'tokens' => Arr::wrap($request->token),
            ];
        }

        return $this->responseJsonSuccess($res);
    }

