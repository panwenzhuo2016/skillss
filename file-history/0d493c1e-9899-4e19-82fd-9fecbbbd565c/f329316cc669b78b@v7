    /**
     * 开启一个审批流程。
     *
     * @param Request $request
     * @throws \App\Workflows\Exceptions\WorkflowException
     * @throws \ReflectionException
     * @throws Throwable
     * @return JsonResponse
     */
    public function startProcess(Request $request): JsonResponse
    {
        $input = Arr::only($request->all(), [
            'sfuser_info', 'process_key', 'context', 'files', 'authorized_token', 'info', 'cc_nickname_hash_filter', 'cc_ids', 'member',
        ]);

        $sfuserId = $input['sfuser_info']['id'];
        $processKey = $input['process_key'];
        $startTime = Arr::get($input, 'context.start_datetime', '');
        $endTime = Arr::get($input, 'context.end_datetime', '');

        $lockKey = "workflow:check:{$sfuserId}:{$processKey}:".md5($startTime.$endTime);
        $lock = Cache::lock($lockKey, 10); // 默认使用默认缓存驱动，如果是 Redis 即可
        // 尝试获取锁，最多等待5秒
        if (!$lock->block(5)) {
            info("{$lockKey} is locked by other process.");
            throw new WorkflowException(__('my_api.system_busy_please_retry'));
        }

        WorkflowRequestService::checkInput($input['process_key'], $sfuserId, $input['context']);

        if ($input['process_key'] == Registry::MATTERMOST) {
            $input['context']['is_mattermost'] = true;
            $input['context']['member'] = $input['member'] ?? [];
        }

        Stakeholder::checkStakeholders($input, $sfuserId);

        // 自定义抄送人
        $customCcs = Arr::get($input, 'cc_ids', []);
        if (!empty($input['cc_nickname_hash_filter'])) {
            $tmpIds = Sfuser::active()->whereIn('nickname_hash', $input['cc_nickname_hash_filter'])->pluck('id')->toArray();
            $customCcs = array_values(array_unique(array_merge($customCcs, $tmpIds)));
        }

        // 自动抛出异常，不用 catch，返回给客户端
        $wr = WorkflowRequestService::make($input['process_key'], $input['sfuser_info']['id'], $input['context'], (array)Arr::get($input, 'files', []), $customCcs);

        // 请求实例生成完后，更新 token
        $wr->getRequest()->update([
            'token' => $input['authorized_token'] ?? '',
            'info' => $input['info'] ?? [],
        ]);
        // 无论成功还是失败，都要释放锁
        optional($lock)->release();
        return $this->responseJsonSuccess(['success' => true]);
    }

    /**
     * 查询关联加班晚到和返回请假总时长.
     * @param Request $request
     * @return JsonResponse
     */
    public function leaveProcessPreflight(Request $request): JsonResponse
    {
        $sfuserId = $request->input('sfuser_info.id');
        $processKey = $request->input('process_key');
        $startDateTime = $request->input('start_datetime');
        $endDateTime = $request->input('end_datetime');

        $data = [];

        // 育儿假特殊, 按非自然日处理
        if ($processKey == Registry::PARENTAL_LEAVE) {
            $data['total_hours'] = Helper::getCommonLeaveHours($processKey, $startDateTime, $endDateTime, $sfuserId);
        }
        // 陪护假特殊, 按非自然日处理（工作日计算）
        elseif ($processKey == Registry::ELDERLY_CARE_LEAVE) {
            $data['total_hours'] = Helper::getCommonLeaveHours($processKey, $startDateTime, $endDateTime, $sfuserId);
        }
        // 自然日类型
        elseif (in_array($processKey, Registry::NATURAL_DAY_TYPE)) {
            $data['total_hours'] = Helper::getCommonLeaveHours($processKey, $startDateTime, $endDateTime);
        }
        // 非自然日类型
        elseif (in_array($processKey, Registry::UNNATURAL_DAY_TYPE)) {
            $data['total_hours'] = Helper::getCommonLeaveHours($processKey, $startDateTime, $endDateTime, $sfuserId);

            $startDateTime = date('Y-m-d 00:00:00', strtotime($startDateTime));
            $endDateTime = date('Y-m-d 00:00:00', strtotime($endDateTime));
            $lateList = WorkflowDataExtra::alias('wde')->leftJoin('workflow_requests', 'workflow_requests.id', '=', 'wde.request_id')
                ->where('wde.process_key', Registry::LATE_WORK_OVERTIME)
                ->where('sfuser_id', $sfuserId)
                ->where('start_time', '>=', $startDateTime)
                ->where('end_time', '<=', $endDateTime)
                ->where('workflow_requests.current_state_id', State::COMPLETED)
                ->selectRaw("request_id, workflow_requests.no, DATE_FORMAT(start_time,'%Y-%m-%d') as late_date")
                ->get()->toArray();
            $data['work_late_list'] = $lateList;
        }

        return $this->responseJsonSuccess($data);
    }

    /**
     * 对一个流程进行预检，对参数进行必要的检查，生成流程图 nodes, cc_ids.
     *
     * @param Request $request
     * @return JsonResponse
     */
    public function preflightProcess(Request $request): JsonResponse
    {
        $input = Arr::only($request->all(), [
            'sfuser_info', 'process_key', 'context', 'version', 'files',
        ]);

        $version = $input['version'] ?? 0;
        WorkflowRequestService::checkInput($input['process_key'], $input['sfuser_info']['id'], $input['context'], $version);

        $data = WorkflowRequestService::preflightProcess($input['process_key'], $input['sfuser_info']['id'], $input['context'], $version);

        // 先把当前人的固定的几个花名取出来
        /** @var Sfuser $sfuser */
        $sfuser = Sfuser::where('id', $input['sfuser_info']['id'])->select([
            'nickname', 'direct_supervisor_nickname', 'supervisor_nickname', 'ssc_nickname', 'department_id',
        ])->first();

        // 将本次跟踪到的人的花名放在 all_nodes 中返回
        $data['all_nodes'] = [
            'profile' => [],
            'nodes_special_nicknames' => [],
            'cc_special_nicknames' => [],
        ];

        // 前端需要将 profile 里面的 key 翻译为对应的 type
        $profile = $sfuser->toArray();

        // 仅报销类型：人事部/行政部的部门主管花名覆盖为小兰
        if (in_array($input['process_key'], Registry::REIMBURSEMENT_TYPE)
            && in_array($sfuser->department_id, Stakeholder::HR_ADMIN_DEPARTMENT_IDS)) {
            $profile['supervisor_nickname'] = Stakeholder::XIAOLAN_NICKNAME;
            info('[lbl][审批人覆盖][Workflow][OVERRIDE] preflight-报销-人事部/行政部部门主管花名覆盖为小兰, sfuserId='.$input['sfuser_info']['id'].', processKey='.$input['process_key']);
        }
        $maps = [
            WorkflowRequestStakeholder::REQUESTER_TYPE => 'nickname',
            WorkflowRequestStakeholder::DIRECT_SUPERVISOR_TYPE => 'direct_supervisor_nickname',
            WorkflowRequestStakeholder::SUPERVISOR_TYPE => 'supervisor_nickname',
            WorkflowRequestStakeholder::SSC_TYPE => 'ssc_nickname',
        ];

        // 如果该审批中包含申请者、直接主管、部门主管、部门 SSC、直接取出当前人的这些花名
        // 以确保流程的流转或者花名的显式始终以发起时的为准
        $allTypes = $data['types'];
        $data['all_nodes']['nodes_types'] = $data['types'];
        foreach ($allTypes as $k => $type) {
            if (in_array($type, WorkflowRequestStakeholder::FIXED_MAPS)) {
                $data['all_nodes']['profile'][$type] = Arr::get($profile, $maps[$type]);
                unset($allTypes[$k]);
            }
        }
        $ccTypes = $data['all_cc_types'];
        foreach ($ccTypes as $k => $ccType) {
            if (in_array($ccType, WorkflowRequestStakeholder::FIXED_MAPS)) {
                $data['all_nodes']['profile'][$ccType] = Arr::get($profile, $maps[$ccType]);
                unset($ccTypes[$k]);
            }
        }

        // 剩下的就是特殊花名了
        $specialNicknames = [];
        if ($allTypes) {
            $specialNicknames = Stakeholder::specialNicknames($allTypes, $input['sfuser_info']['id'], $input['context']); // 然后取出当前预检包含的特殊审批的人的花名
            foreach ($specialNicknames as $type => $specialNickname) {
                $specialNicknames[$type] = Arr::first($specialNickname); // 操作节点中的人默认只取第一个，取多了也不管用
            }
        }
        $data['all_nodes']['nodes_special_nicknames'] = $specialNicknames;

        // 获取的 cc_types，不用取第一个，直接返回一个数组即可
        $specialNicknames = [];
        if ($ccTypes) {
            $specialNicknames = Stakeholder::specialNicknames($ccTypes, $input['sfuser_info']['id'], $input['context']);
        }
        $data['all_nodes']['cc_special_nicknames'] = $specialNicknames;

        $processKeyToExecutorTypeMap = [
            Registry::P4V_ACCESS => WorkflowRequestStakeholder::P4V_EXECUTER_TYPE,
            Registry::ONLY_OFFICE => WorkflowRequestStakeholder::ONLY_OFFICE_EXECUTOR_TYPE,
            Registry::JIRA_CONFLUENCE => WorkflowRequestStakeholder::JIRA_CONFLUENCE_EXECUTOR_TYPE,
            Registry::EB => WorkflowRequestStakeholder::EB_EXECUTOR_TYPE,
            Registry::YA => WorkflowRequestStakeholder::YA_EXECUTOR_TYPE,
            Registry::X_JIRA_CONFLUENCE => WorkflowRequestStakeholder::X_JIRA_CONFLUENCE_EXECUTOR_TYPE,
            Registry::AI_TOOLS => WorkflowRequestStakeholder::AI_TOOLS_EXECUTOR_TYPE,
            Registry::GCP => WorkflowRequestStakeholder::GCP_EXECUTOR_TYPE,
            Registry::MATTERMOST => WorkflowRequestStakeholder::MATTERMOST_EXECUTOR_TYPE,
        ];

        foreach ($processKeyToExecutorTypeMap as $processKey => $executorType) {
            if ($input['process_key'] == Registry::JIRA_CONFLUENCE) {
                $dynamicNicknames1 = Stakeholder::specialNicknames(
                    [WorkflowRequestStakeholder::JIRA_CONFLUENCE_EXECUTOR_TYPE],
                    $input['sfuser_info']['id'],
                    $input['context']
                );
                $dynamicNicknames2 = Stakeholder::specialNicknames(
                    [WorkflowRequestStakeholder::X_JIRA_CONFLUENCE_EXECUTOR_TYPE],
                    $input['sfuser_info']['id'],
                    $input['context']
                );
                if (!isset($dynamicNicknames1['jira_confluence_executor'])) {
                    throw new WorkflowException('请联系管理员配置【Jira/Confluence执行人】后再操作');
                }
                if (!isset($dynamicNicknames2['jira_confluence_executor'])) {
                    throw new WorkflowException('请联系管理员配置【X项目Jira/Confluence执行人】后再操作');
                }
                $mergedNicknames = array_merge(
                    $dynamicNicknames1['jira_confluence_executor'],
                    $dynamicNicknames2['jira_confluence_executor']
                );
                $uniqueNicknames = array_unique($mergedNicknames);
                $data['dynamic_nicknames'] = [
                    'jira_confluence_executor' => array_values($uniqueNicknames),
                ];
                break;
            }
            if ($input['process_key'] == $processKey) {
                $data['dynamic_nicknames'] = Stakeholder::specialNicknames([$executorType], $input['sfuser_info']['id'], $input['context']);
                break;
            }
        }

        Arr::forget($data, 'types');
        Arr::forget($data, 'all_cc_types');

        return $this->responseJsonSuccess($data);
    }

