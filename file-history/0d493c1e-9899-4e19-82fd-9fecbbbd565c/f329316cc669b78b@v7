    public function readAllCCRequests(Request $request)
    {
        $input = Arr::only($request->all(), [
            'sfuser_info', 'per_page', 'no', 'approval_statuses', 'lack_supplements', 'nickname_hash_filter', 'process_key', 'process_keys', 'status_type',
        ]);
        $sfuserId = $input['sfuser_info']['id'];
        $sfuserIdsForFiltering = [];
        $nicknameHashFilter = Arr::get($input, 'nickname_hash_filter');
        if ($nicknameHashFilter) {
            $sfuserIdsForFiltering = Sfuser::filterIfExists([
                ['sfusers.nickname_hash', 'IN', 'nickname_hash_filter'],
            ], $input)
                ->select('id')
                ->get()
                ->toArray();
        }
        $queryBuilder = new StakeholderQueryBuilder();
        $queryBuilder = $queryBuilder->asCCer()->filterByUserId($sfuserId);

        // 按申请人进行过滤
        if ($sfuserIdsForFiltering) {
            $queryBuilder->filterByRequesterIds($sfuserIdsForFiltering);
        }

        // 按编号筛选
        if ($no = Arr::get($input, 'no')) {
            $queryBuilder->filterByNo($no);
        }

        // 按审批状态筛选
        $approvalStatuses = Arr::wrap(Arr::get($input, 'approval_statuses', []));
        if ($approvalStatuses) {
            $queryBuilder->stateIn($approvalStatuses);
        }
        $statusType = Arr::get($input, 'status_type', -1);
        switch ($statusType) {
            case 1: // 非报销
                $queryBuilder->excludeProcessKeys(Registry::REIMBURSEMENT_TYPE);
                break;
            case 2: // 仅报销
                $queryBuilder->filterByProcessKeys(Registry::REIMBURSEMENT_TYPE);
                break;
            default: break;
        }

        $lackSupplements = Arr::get($input, 'lack_supplements', -1);
        if ($lackSupplements != -1) {
            /** lack_supplements: 1 缺少材料，2 材料齐全 */
            $lack = $lackSupplements == 1; // 不搜时，不传该参数，因此不用判断是否为 2 了
            $queryBuilder->filterByLackSupplements($lack);
        }

        $processKey = Arr::get($input, 'process_key', '');
        if ($processKey) {
            $queryBuilder->filterByProcessKey($processKey);
        }

        $processKeys = Arr::get($input, 'process_keys', []);
        if ($processKeys) {
            $queryBuilder->filterByProcessKeys($processKeys);
        }

        $int = $queryBuilder->queryBuilder()->update(['is_read' => 1]);

        // 更新 OA 抄送未读
        $ccType = match ($statusType) {
            1 => 'oa_cc',
            2 => 'reimburse_cc',
            default => '',
        };
        if ($ccType) {
            NotifyNumberService::app()->modifyIndividual($sfuserId, $ccType, -1 * $int);
        } else {
            NotifyNumberService::app()->setOaCc($sfuserId);
        }

        return $this->responseJsonSuccess(['count' => $int]);
    }

    public function request(Request $request)
    {
        $input = Arr::only($request->all(), [
            'sfuser_info', 'request_id',
        ]);

        $sfuserId = $input['sfuser_info']['id'];
        $workflowRequest = new WorkflowRequestService($input['request_id'], $sfuserId);

        // fix: 在 OA 端，只有可见，才能查看详情
        $wrs = WorkflowRequestStakeholder::where('request_id', $input['request_id'])
            ->where('user_id', $sfuserId)
            ->first();
        $hasExecute = false;

        $basic = $workflowRequest->getRequest()->toArray();
        $isAuto = !empty($basic['data']['remark']) && $basic['data']['remark'] === WorkflowRequestService::AUTO_REMARK;
        if (!$wrs && !$isAuto) {
            // 4种权限执行的人可以看
            // 有没有我的执行
            // TODO: 优化一下下面这段代码
            $types = WorkflowSpecialStakeholder::alias('wss')
                ->whereIn('type', WorkflowRequestStakeholder::OTHER_TYPES)
                ->whereJsonContains('ids', $sfuserId)->pluck('wss.type')->toArray();
            if (!empty($types)) {
                if (in_array(WorkflowRequestStakeholder::ONLY_OFFICE_EXECUTOR_TYPE, $types)) {
                    $hasExecute = $workflowRequest->getRequest()->process_key == Registry::ONLY_OFFICE;
                }
                if (in_array(WorkflowRequestStakeholder::JIRA_CONFLUENCE_EXECUTOR_TYPE, $types)) {
                    $hasExecute = $workflowRequest->getRequest()->process_key == Registry::JIRA_CONFLUENCE || $hasExecute;
                }
                if (in_array(WorkflowRequestStakeholder::EB_EXECUTOR_TYPE, $types)) {
                    $hasExecute = $workflowRequest->getRequest()->process_key == Registry::EB || $hasExecute;
                }
                if (in_array(WorkflowRequestStakeholder::YA_EXECUTOR_TYPE, $types)) {
                    $hasExecute = $workflowRequest->getRequest()->process_key == Registry::YA || $hasExecute;
                }
                if (in_array(WorkflowRequestStakeholder::X_JIRA_CONFLUENCE_EXECUTOR_TYPE, $types)) {
                    $hasExecute = $workflowRequest->getRequest()->process_key == Registry::X_JIRA_CONFLUENCE || $hasExecute;
                }
                if (in_array(WorkflowRequestStakeholder::AI_TOOLS_EXECUTOR_TYPE, $types)) {
                    $hasExecute = $workflowRequest->getRequest()->process_key == Registry::AI_TOOLS || $hasExecute;
                }
                if (in_array(WorkflowRequestStakeholder::GCP_EXECUTOR_TYPE, $types)) {
                    $hasExecute = $workflowRequest->getRequest()->process_key == Registry::GCP || $hasExecute;
                }
                if (in_array(WorkflowRequestStakeholder::MATTERMOST_EXECUTOR_TYPE, $types)) {
                    $hasExecute = $workflowRequest->getRequest()->process_key == Registry::MATTERMOST || $hasExecute;
                }
                if ($hasExecute) {
                    // 有权限看
                } else {
                    return $this->responseJsonFail(__('my_api.workflow_request_not_found'), ExceptionCode::ERR_RESOURCE_MISSING);
                }
            } else {
                return $this->responseJsonFail(__('my_api.workflow_request_not_found'), ExceptionCode::ERR_RESOURCE_MISSING);
            }
        }

        $detail = $workflowRequest->detail(true);
        // 对外展示还是jira_access，
        $detail['basic']['process_key'] = Registry::toJira($detail['basic']['process_key']);

        if ($hasExecute) {
            // 有执行人权限的人，查详情解密不用token
        } else {
            // 有 Token，并且不是本人的话，不需要通过 Token 解密
            if ($workflowRequest->getRequest()->token && $sfuserId != $workflowRequest->getRequest()->user_id) {
                $detail['decrypt_config'] = [
                    'tokens' => Arr::wrap($workflowRequest->getRequest()->token),
                ];
            }
            $detail['site_key'] = config('my_project.site_key');
        }
        $workflowRequest->xp4($detail);
        return $this->responseJsonSuccess($detail);
    }

