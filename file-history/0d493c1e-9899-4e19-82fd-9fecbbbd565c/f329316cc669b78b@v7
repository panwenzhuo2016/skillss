    /**
     * @apiName 【审批中心】获取流程列表
     *
     * @return JsonResponse
     */
    public function getProcesses(): JsonResponse
    {
        /** @noinspection all */
        $processes = Registry::PROCESS_MAPS;
        $data = [];
        array_walk($processes, function ($value, $key) use (&$data) {
            $data[] = [
                'key' => $key,
                'name' => $value['context']['name'],
                'category' => $value['context']['category'],
                'menu' => $value['context']['menu'],
            ];
        });
        return $this->responseJsonSuccess(['processes' => $data]);
    }

