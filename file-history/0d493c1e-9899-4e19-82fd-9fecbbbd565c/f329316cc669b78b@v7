    public function doPerformAction(int $actionId, array $input, array $context): JsonResponse
    {
        if ($actionId == Action::DELETE) {
            return $this->responseJsonFail(__('my_api.invalid_action_given'), ExceptionCode::ERR_USER_OPERATE_LIMIT);
        }

        $remark = Arr::get($input, 'remark', '');
        $sfuserId = $input['sfuser_info']['id'];
        $workflowRequest = new WorkflowRequestService($input['request_id'], $sfuserId);

        // 特殊逻辑，如果是jira 并且是 x项目，把流程改掉，因为这是流程发起时未知的。此时流程已完结，只是改下process_key，以后面区分执行人用。
        if ($actionId == Action::APPROVE && $sfuserId == self::XY_SFUSER_ID
            && $workflowRequest->getRequest()->process_key == Registry::JIRA_CONFLUENCE) {
            $project_id = Arr::get($input, 'project_id', 2);
            if ($project_id == 1) {
                $workflowRequest->getRequest()->update(['process_key' => Registry::X_JIRA_CONFLUENCE]);
                OtherPermissionExecute::updateOrCreate(
                    ['request_id' => $workflowRequest->getRequest()->id],
                    [
                        'process_key' => Registry::X_JIRA_CONFLUENCE,
                    ]
                );
            }
        }

        // 特殊逻辑，如果是p4v 并且是 x项目，执行人改成x_p4 流程不变
        $requestBase = $workflowRequest->getRequest();
        if ($actionId == Action::APPROVE && $sfuserId == self::XY_SFUSER_ID
            && $requestBase->process_key == Registry::P4V_ACCESS) {
            $project_id = Arr::get($input, 'project_id', 2);
            if ($project_id == 1) {
                info('p4v申请，变更执行人'.json_encode($requestBase));
                $workflowRequest->appendData('project_id', $project_id);
                $workflowRequest->appendData('old_apply_type', $requestBase->data['apply_type']);
                $workflowRequest->appendData('apply_type', P4vAccess::X_P4);
                WorkflowP4vExtra::updateOrCreate([
                    'request_id' => $requestBase->id,
                ], [
                    'apply_type' => P4vAccess::X_P4,
                ]);
            }
        }
        if ($actionId == Action::APPROVE && $sfuserId == self::DY_SFUSER_ID
            && $requestBase->process_key == Registry::P4V_ACCESS) {
            $project_id = Arr::get($input, 'project_id', 2);
            if ($project_id == 3) {
                info('p4v申请，变更执行人3'.json_encode($requestBase));
                $workflowRequest->appendData('project_id', $project_id);
                $workflowRequest->appendData('old_apply_type', $requestBase->data['apply_type']);
                $workflowRequest->appendData('apply_type', P4vAccess::DN_P4);
                $workflowRequest->appendData('apply_type_w', P4vAccess::DW_P4);
                $ww = WorkflowP4vExtra::updateOrCreate([
                    'request_id' => $requestBase->id,
                ], [
                    'apply_type' => P4vAccess::DN_P4,
                ]);
                WorkflowP4vExtra::updateOrCreate([
                    'request_id' => $requestBase->id,
                    'apply_type' => P4vAccess::DW_P4,
                ], [
                    'apply_type' => P4vAccess::DW_P4,
                    'sfuser_id' => $ww->sfuser_id,
                    'target_department' => $ww->target_department,
                ]);
            }
        }
        if ($actionId == Action::APPROVE && $sfuserId == self::HY_SFUSER_ID
            && $requestBase->process_key == Registry::P4V_ACCESS) {
            $project_id = Arr::get($input, 'project_id', 2);
            if ($project_id == 4) {
                info('p4v申请，变更执行人4'.json_encode($requestBase));
                $workflowRequest->appendData('project_id', $project_id);
                $workflowRequest->appendData('old_apply_type', $requestBase->data['apply_type']);
                $workflowRequest->appendData('apply_type', P4vAccess::H_P4);
                WorkflowP4vExtra::updateOrCreate([
                    'request_id' => $requestBase->id,
                ], [
                    'apply_type' => P4vAccess::H_P4,
                ]);
            }
        }
        if ($actionId == Action::APPROVE
            && $requestBase->process_key == Registry::P4V_ACCESS) {
            $project_id = Arr::get($input, 'project_id', 2);
            if ($project_id == 2) {
                info('p4v申请，变更执行人2'.json_encode($requestBase));
                $workflowRequest->appendData('project_id', $project_id);
                $workflowRequest->appendData('old_apply_type', $requestBase->data['apply_type']);
                $workflowRequest->appendData('apply_type', P4vAccess::N_P4);
                WorkflowP4vExtra::updateOrCreate([
                    'request_id' => $requestBase->id,
                ], [
                    'apply_type' => P4vAccess::N_P4,
                ]);
            }
        }

        // 增加eb校验
        if ($actionId == Action::APPROVE && $requestBase->process_key == Registry::EB) {
            $con = $context;
            if (!empty($con) && !empty($con['after_applicant_permission'])) {
                if (empty($con['passed_permission'])) {
                    throw new WorkflowException('请选择游戏语言:功能角色!');
                }
                foreach ($con['passed_permission'] as $v) {
                    if (empty($v['game_langs'])) {
                        throw new WorkflowException('请选择游戏语言!');
                    }
                    if (empty($v['roles'])) {
                        throw new WorkflowException('请选择功能角色!');
                    }
                }
            }
        }

        // 增加ya校验
        if ($actionId == Action::APPROVE && $requestBase->process_key == Registry::YA) {
            $con = $context;
            if (!empty($con) && !empty($con['after_applicant_permission'])) {
                if (empty($con['passed_permission'])) {
                    throw new WorkflowException('请选择游戏语言:功能角色!');
                }
                foreach ($con['passed_permission'] as $v) {
                    if (empty($v['game_langs'])) {
                        throw new WorkflowException('请选择游戏语言!');
                    }
                    if (empty($v['roles'])) {
                        throw new WorkflowException('请选择功能角色!');
                    }
                }
            }
        }

        $workflowRequest->performAction($input['action_id'], $remark, false, $context, $input);

        return $this->responseJsonSuccess(['success' => true]);
    }
