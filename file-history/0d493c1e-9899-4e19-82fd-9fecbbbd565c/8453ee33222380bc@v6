            $nicknames = $record['nicknames'];
            $config = $record['special_config'];
            if ($config) {
                if ($type == WorkflowRequestStakeholder::P4V_SUPERVISOR_TYPE) {
                    if (!array_key_exists('target_department', $context)) {
                        continue;
