        CCEdit,
        AddFormDetail,
    },
    created() {
        getStrikeBalanceMapAPI().then(() => {
            this.editOptions.typeOptions = StrikeBalanceMap.getOptions('loanTypeMap')
            this.editOptions.departmentBranchOptions = StrikeBalanceMap.getOptions(
                'strikeBalanceDepartmentBranchMap'
            )
        })
        // 关联借款申请可选择项
        getableLoanRequestsAPI().then(res => {
            this.editOptions.relativeOptions = res.data
        })
    },
})
export default class extends Vue {
    @Prop({ type: Array, default: () => [] }) reEditData: Record<string, any>
    @Prop({ type: Number, default: 0 }) reEditItem
    @Prop({ type: Object, default: () => ({}) }) localSavedData: Record<string, any>
    // 关联借款
    @Prop({ type: Object, default: () => ({}) }) relativeItem
    @Prop({ type: Boolean, default: false }) visible
    @Watch('reEditItem', { deep: true, immediate: true })
    changeReEditItem(val) {
        if (val) {
            this.$nextTick(() => {
                this.getReEditDetail(val)
            })
        }
    }
    // 借款入口发起冲账
    @Watch('relativeData', { deep: true, immediate: true })
    changeRelativeItem(val) {
        if (val.relativeNo) {
            this.editData.relativeNo = val.relativeNo
            this.editData.department = val.department
            this.editData.loanAmount = val.loanAmount
            this.editData.total_loan_money = val.loanAmount
            this.showLoanAmount = handlerMoneyNO(val.loanAmount)
        }
    }

    get relativeData() {
        return this.relativeItem.relativeNo ? this.relativeItem : {}
    }
    @Watch('editData', { deep: true, immediate: true })
    changeConfirmDisable(val) {
        // 限制保存按钮
        if (this.loanDetailFlag) {
            if (val.relativeNo !== '' && val.type !== '' && val.group !== 0 && val.remark !== '') {
                // 类型为团建费
                if (
                    val.type === 'team_building_reversal' &&
                    val.tm_extra_info.department_or_project_group !== '' &&
                    val.tm_extra_info?.selectedSeasons?.length !== 0 &&
                    val.tm_extra_info?.team_building_season?.every(
                        item => item.number != '' && item.participants != ''
                    )
                ) {
                    // 大于
                    if (
                        this.editData.totalMoney > _.toNumber(this.editData.total_loan_money) &&
                        !this.isReEdit
                    ) {
                        this.preInitiateAble = true
                        this.saveDisabled = true
                        // 小于等于
                    } else if (!(this.editData.totalMoney > _.toNumber(this.editData.total_loan_money))) {
                        this.preInitiateAble = true
                        if (this.path.length) {
                            this.saveDisabled = false
                        }
                        if (
                            !this.oneTipsFlag &&
                            this.editData.totalMoney < _.toNumber(this.editData.total_loan_money)
                        ) {
                            this.$message.warning('冲账总金额=借款总金额时才能提交冲账申请，可以先保存为草稿')
                            this.oneTipsFlag = true
                        }
                    } else {
                        this.saveDisabled = true
                    }
                } else if (this.editData.totalMoney < _.toNumber(this.editData.total_loan_money)) {
                    this.preInitiateAble = true
                    if (this.path.length) {
                        this.saveDisabled = false
                    }
                    if (!this.oneTipsFlag) {
                        this.$message.warning('冲账总金额=借款总金额时才能提交冲账申请，可以先保存为草稿')
                        this.oneTipsFlag = true
                    }
                } else if (this.editData.totalMoney == _.toNumber(this.editData.total_loan_money)) {
                    this.preInitiateAble = true
                    if (this.path.length) {
                        this.saveDisabled = false
                    }
                } else if (this.editData.totalMoney > _.toNumber(this.editData.total_loan_money)) {
                    this.preInitiateAble = true
                    this.saveDisabled = true
                    if (!this.tipsFlag) {
                        this.$message.warning(`${this.$t('t2405221754')}`)
                    }
                    this.tipsFlag = true
                } else {
                    this.saveDisabled = true
                }
            } else {
                this.saveDisabled = true
            }
        } else {
            this.saveDisabled = true
        }
        const num = this.editData.tm_extra_info?.team_building_season?.reduce(
            (sum, cur) => sum + _.toNumber(cur.number),
            0
        )
        // 限制提交按钮
        if (this.loanDetailFlag) {
            if (val.relativeNo !== '' && val.type !== '' && val.group !== 0 && val.remark !== '') {
                // 团建费
                {
                    if (
                        val.type === 'team_building_reversal' &&
                        val.tm_extra_info.department_or_project_group !== '' &&
                        val.tm_extra_info?.selectedSeasons?.length !== 0 &&
                        val.tm_extra_info?.team_building_season?.every(
                            item => item.number != '' && item.participants != ''
                        )
                    ) {
                        if (num * 300 > this.removeReturnLoan || num * 300 == this.removeReturnLoan) {
                            this.preInitiateAble = true
                            if (
                                this.path.length &&
                                this.editData.totalMoney === _.toNumber(this.editData.total_loan_money)
                            ) {
                                this.confirmDisable = false
                            } else {
                                this.confirmDisable = true
                            }
                        } else {
                            // this.$message.warning(`${this.$t('t2405221755')}`)
                            this.confirmDisable = true
                        }
                    } else {
                        this.confirmDisable = true
                    }
                    if (val.type !== 'team_building_reversal') {
                        this.preInitiateAble = true
                        if (
                            this.path.length &&
                            this.editData.totalMoney === _.toNumber(this.editData.total_loan_money)
                        ) {
                            this.confirmDisable = false
                        }
                    }
                }
            } else {
                this.confirmDisable = true
            }
        } else {
            this.confirmDisable = true
        }
        if (val.type === 'team_building_reversal' && num * 300 < this.removeReturnLoan) {
            if (!this.teamBuildingTips) {
                this.$message.warning('冲账总金额不能超过团建最大金额')
                this.teamBuildingTips = true
            }
        }
    }

    @Watch('editData.type', { deep: true, immediate: true })
    editDataTypeChange(val) {
        this.oneTipsFlag = false
        this.tipsFlag = false
        this.saveDisabled = true
        this.confirmDisable = true
    }

    @Watch('preInitiateAble', { deep: true, immediate: true })
    preInitiateAbleChange(val) {
        if (val && this.path.length === 0 && !this.isReEdit && !this.preInitiateFlag) {
            this.preInitiate()
            this.preInitiateFlag = true
        }
    }

    @Watch('saveDisabled', { deep: true, immediate: true })
    saveDisableChange(val) {
        if (
            !val &&
            this.path.length === 0 &&
            !this.isReEdit &&
            !this.preInitiateFlag &&
            this.preInitiateAble
        ) {
            this.preInitiate()
            this.preInitiateFlag = true
        }
    }

    viewParam = {
        // 预览文件的参数
        show: false,
        loading: false,
        index: 0, // 当前预览文件的序号
        list: [],
    }

    // 选择data
    editOptions = {
        relativeOptions: [],
        typeOptions: [],
        shareOptions: [],
        departmentBranchOptions: [],
    }
    preInitiateAble = false

    // 添加数据
    editData = {
        // 关联借款申请
        relativeNo: '',
        // 发起人部门
        department: '',
        // 借款总金额
        loanAmount: '',
        // 冲账类型
        type: '',
        // 费用分摊主体
        shareSubject: 0,
