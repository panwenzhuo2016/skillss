            this.editData.branch = 0
            this.shareSubInputAvailable = true
        } else {
            if (!this.isReEdit) {
                this.editData.shareSubject = 0
            }
            this.shareSubInputAvailable = false
        }
        const processKeyLabel = StrikeBalanceMap.getByValue('loanTypeMapMap', this.editData.type)?.label
        if (processKeyLabel != undefined) {
            this.chargeDetail = StrikeBalanceMap.getOptions(processKeyLabel)
        }
    }

    onload({ key, fileList }) {
        console.log(key, fileList, 'list')
        this.editData.otherFiles = fileList
    }

    changeLoanInfo(val) {
        console.log('====================================')
        console.log(val, 'val')
        console.log('====================================')
    }

    async preInitiate() {
        try {
            const param = this.getParam()
            if (param.tm_extra_info.team_building_season) {
                param.tm_extra_info.team_building_season.map(item => {
                    if (typeof item.participants == 'string') {
                        item.participants.split('、')
                    }
                })
            }
            const res = await preInitiateDataAPI(param)
            this.path = res.nodes
            this.submitter = res.submitter
            if (this.path.length) {
                if (!(this.editData.totalMoney > _.toNumber(this.editData.total_loan_money))) {
                    this.saveDisabled = false
                }
                if (this.editData.totalMoney == _.toNumber(this.editData.total_loan_money)) {
                    this.confirmDisable = false
                }
            }
        } catch (e) {
            console.log(e, 'e')

            this.$message.error(e.error_msg)
        }
    }

    reduceFiles() {
        if (this.historyFile.length) {
            this.historyFile.map(item => {
                this.editData.otherFiles.push({
                    hasError: false,
                    isDone: true,
                    pieceDone: 1,
                    pieceTotal: 1,
                    name: item.key,
                    uniqueName: item.value,
                })
            })
        }
        // 文件去重
        const obj = {}
        console.log(this.editData.otherFiles)

        this.files = this.editData.otherFiles.reduce((prev, cur) => {
            obj[cur.uniqueName] ? '' : (obj[cur.uniqueName] = true && prev.push(cur))
            return prev
        }, [])
        console.log(this.files, 'hhhhh')
    }

    getParam() {
        // 参加团建人员改为数组
        try {
            console.log(this.editData)
            if (this.isReEdit) {
                this.reduceFiles()
            }

            // this.editData.ccEdit = this.editData.ccEdit.length ? this.editData.ccEdit.map(item => item.nickname) : []
            // if (this.historyExtraCC.length) {
            //     this.editData.ccEdit = this.editData.ccEdit.length ? [...this.editData.ccEdit, ...this.historyExtraCC] : [...this.historyExtraCC]
            // }

            const param = {
                nickName: store.state.userInfo.nickname,
                sfuserId: store.state.userInfo.id,
                group: this.editData.group,
                branch: this.editData.branch,
                totalMoney: this.editData.totalMoney,
                remark: this.editData.remark,
                type: this.editData.type,
                relatedNo: this.editData.relativeNo,
                appendix: this.isReEdit
                    ? this.files?.map(item => ({
                          value: item.value ? item.value : item.uniqueName,
                          key: item.name,
                      }))
                    : this.editData.otherFiles?.map(item => ({
                          value: item.value ? item.value : item.uniqueName,
                          key: item.name,
                      })),

                detail: this.editData.detail.map(item => ({
                    fare_type: StrikeBalanceMap.getByValue('fareMap', item.loan_type).label,
                    money: item.money,
                    detail_remark: item.remark,
                    activity_date:
                        this.editData.type === 'team_building_reversal' ? item.teamDate : item.travel_date,
                    invoice: item.invoice.map(i => ({
                        key: i.file_name ? i.file_name : i.key,
                        title: i.title,
                        value: i.url ? i.url : i.value,
                        file_name: i.file_name,
                        url: i.url,
                        need_to_be_identified: i.need_to_be_identified,
                        is_identified: i.is_identified,
                        invoice_name: i.invoice_name,
                        buyerName: i.buyerName,
                        invoice_number: i.invoice_number,
                        invoiceDate: i.invoiceDate,
                        invoice_no: i.invoice_no,
                        isRepeatWithDatabase: i.isRepeatWithDatabase,
                        isRepeatWithOtherInvoice: i.isRepeatWithOtherInvoice,
                        notMatchConfig: i.notMatchConfig,
                    })),
                })),

                tm_extra_info: {
                    department_or_project_group:
                        this.editData.type === 'team_building_reversal'
                            ? this.editData.tm_extra_info.department_or_project_group
                            : undefined,
                    selectedSeasons:
                        this.editData.type === 'team_building_reversal'
                            ? this.editData.tm_extra_info?.selectedSeasons
                            : undefined,
                    team_building_season:
                        this.editData.type === 'team_building_reversal'
                            ? this.editData.tm_extra_info?.team_building_season.map(i => ({
                                  number: _.toNumber(i.number),
                                  participants:
                                      typeof i.participants == 'string'
                                          ? i.participants.split('、')
                                          : i.participants,
                                  // participants: i.participants,
                                  season: _.toNumber(i.season),
                                  timeInfo: i.timeInfo,
                                  year: _.toNumber(i.year),
                              }))
                            : undefined,
                },
                extraCC: this.editData.ccEdit,
                info: {
                    initNodes:
                        this.path.length === 0
                            ? undefined
                            : this.path.map(item => ({
                                  operator_type: item.operatorType,
                                  operator: item.nickNames,
                              })),
                },
            }
            return param
        } catch (e) {
            console.log(e, 'getParam e')
        }
    }

    deleteHistoryFiles(index, item) {
        // 有url属性是历史附件，没有是新上传附件
        if (item.hasOwnProperty('url')) {
            this.historyFile.splice(index, 1)
        }
    }

    ww(data) {
        this.loan_detail = data
        this.loan_detail.map(item => {
            item.money = _.toNumber(item.loan_money)
        })
        this.editData.detail = this.loan_detail
        this.editData.totalMoney = _.sumBy(data, function (i) {
            return _.toNumber(i.loan_money)
        })
        this.editData.totalMoneySp = handlerMoneyNO(
            _.sumBy(data, function (i) {
                return _.toNumber(i.loan_money)
            })
        )
        // 如果有退回借款，团建费冲账，校验团建费最大金额是否小于冲账总金额 - 退回借款
        const refundOfLoan = `${this.$t('t2405221756')}`
        this.removeReturnLoan = _.sumBy(data, function (i) {
            if (i.loan_type != refundOfLoan) {
                return _.toNumber(i.loan_money)
            }
        })

        if (this.editData.type == 'team_building_reversal') {
            this.loanDetailFlag =
                this.loan_detail.every(item => item.loan_type !== '' && item.invoice.length !== 0) &&
                this.editData.totalMoney !== 0
        } else if (this.editData.type == 'trip_reversal') {
            this.loanDetailFlag =
                this.loan_detail.every(
                    item => item.loan_type !== '' && item.invoice.length !== 0 && item.travel_date !== ''
                ) && this.editData.totalMoney !== 0
        } else {
            this.loanDetailFlag =
                this.loan_detail.every(item => item.loan_type !== '' && item.invoice.length !== 0) &&
                this.editData.totalMoney !== 0
        }
        console.log(this.editData.detail, 'detail')
    }

    // 获取费用分摊主体的branch&group
    handleShareSubjects() {
        const node = this.$refs.shareSubject.getCheckedNodes()[0]
        if (node.parent == null) {
            this.editData.group = node.value
            this.editData.branch = 0
            this.editData.shareSubject = node.data.value
        } else {
            this.editData.branch = node.value
            this.editData.group = node.parent.value
            this.editData.shareSubject = node.data.value
        }
    }

    // 获取部门和借款金额
    handleRelativeNo(data) {
        this.editData.relativeNo = data.no
        this.editData.department = data.department
        this.editData.loanAmount = data.total_money
        this.editData.total_loan_money = data.total_money
        this.showLoanAmount = handlerMoneyNO(this.editData.loanAmount)
    }

    // 保存为草稿
    async save() {
        if (!this.path.length) {
            return
        }
        const loading = this.$loading({})
        try {
            const param = this.getParam()
            // 人事部/行政部发起时，自动将艾莎加入抄送列表
            const HR_ADMIN_DEPT_IDS = [2, 15]
            const AISHA_NICKNAME = '艾莎'
            const userDeptId = store.state.userInfo.department_id
            const userNickname = store.state.userInfo.nickname
            if (HR_ADMIN_DEPT_IDS.includes(userDeptId) && userNickname !== AISHA_NICKNAME) {
                if (!param.extraCC) {
                    param.extraCC = []
                }
                if (!param.extraCC.includes(AISHA_NICKNAME)) {
                    param.extraCC.push(AISHA_NICKNAME)
                }
            }
            console.log('====================================')
            console.log(param, 'param')
            console.log('====================================')
            const result = await getLoanRequestDetailAPI(this.editData.relativeNo)
            let loanUser = []
            let user = []
            const sfusers = this.path.map(item => item.nickNames)
            sfusers.map(item => (user = user.concat(item)))
            this.loanSubmitter = result.specialNickNames.flat()
            result.nodes.map(item => (loanUser = loanUser.concat(item)))
            this.loanExtraCC = result.loanExtraCC
            const res = this.isReEdit
                ? await reEditAPI(param, this.reEditItem, false, [
                      ...new Set(
                          user
                              .concat(loanUser)
                              .concat(param.extraCC)
                              .concat(this.submitter)
                              .concat(this.loanSubmitter)
                              .concat(this.loanExtraCC)
                      ),
                  ])
                : await startInitiateDataAPI(param, 0)
            if (!this.isReEdit) {
                const authorizeParam = {
                    id: res.requestId,
                    sfusers: [
                        ...new Set(
                            user
                                .concat(loanUser)
                                .concat(param.extraCC)
                                .concat(this.submitter)
                                .concat(this.loanSubmitter)
                                .concat(this.loanExtraCC)
                        ),
                    ],
                }
                await authorizeAPI(authorizeParam)
            }
            this.$message.success(`${this.$t('t2405221496')}`)
            this.cancel()
            this.back()
        } catch (e) {
            this.$message.error(e.error_msg)
        } finally {
            loading.close()
        }
    }

    async confirm() {
        if (!this.path.length) {
            return
        }
        const loading = this.$loading({})
        try {
            const param = this.getParam()
            // 人事部/行政部发起时，自动将艾莎加入抄送列表
            const HR_ADMIN_DEPT_IDS = [2, 15]
            const AISHA_NICKNAME = '艾莎'
            const userDeptId = store.state.userInfo.department_id
            const userNickname = store.state.userInfo.nickname
            if (HR_ADMIN_DEPT_IDS.includes(userDeptId) && userNickname !== AISHA_NICKNAME) {
                if (!param.extraCC) {
                    param.extraCC = []
                }
                if (!param.extraCC.includes(AISHA_NICKNAME)) {
                    param.extraCC.push(AISHA_NICKNAME)
                }
            }
            console.log(param, 'ggggg')
            // 授权人范围：冲账审批流节点中花名 + 抄送人 +冲账行政提交人（specialNickNames） + 借款审批流中节点花名 + 借款详情specialNicknames + 借款抄送人
            // loanUser: 借款审批流节点花名； submitter: 冲账的specialNickName； loanSubmitter: 借款specialNickName； user：冲账审批流节点花名； loanExtraCC: 借款抄送人
            const result = await getLoanRequestDetailAPI(this.editData.relativeNo)
            let loanUser = []
            result.nodes.map(item => (loanUser = loanUser.concat(item)))
            const sfusers = this.path.map(item => item.nickNames)
            let user = []
            sfusers.map(item => (user = user.concat(item)))
            this.loanSubmitter = result.specialNickNames.flat()
            this.loanExtraCC = result.loanExtraCC
            // 确认（start为1，为0是保存为草稿，）
            const res = this.isReEdit
                ? await reEditAPI(param, this.reEditItem, true, [
                      ...new Set(
                          user
                              .concat(loanUser)
                              .concat(param.extraCC)
                              .concat(this.submitter)
                              .concat(this.loanSubmitter)
                              .concat(this.loanExtraCC)
                      ),
                  ])
                : await startInitiateDataAPI(param, 1)
            const authorizeParam = {
                id: res.requestId,
                sfusers: [
                    ...new Set(
                        user
                            .concat(loanUser)
                            .concat(param.extraCC)
                            .concat(this.submitter)
                            .concat(this.loanSubmitter)
                            .concat(this.loanExtraCC)
                    ),
                ],
            }
            if (!this.isReEdit) {
                await authorizeAPI(authorizeParam)
            }
            const loanAuthorizeParam = {
                id: result.id,
                sfusers: [
                    ...new Set(
                        user
                            .concat(loanUser)
                            .concat(param.extraCC)
                            .concat(this.submitter)
                            .concat(this.loanExtraCC)
                            .concat(this.loanSubmitter)
                    ),
                ],
            }
            await loanAuthorizeAPI(loanAuthorizeParam)
            this.$message.success(`${this.$t('t2405221757')}`)
            this.cancel()
            this.back()
        } catch (e) {
            console.log('====================================')
            console.log(e, 'e')
            console.log('====================================')
            this.$message.error(e.error_msg)
        } finally {
            loading.close()
            this.$emit('search')
        }
    }

    async getReEditDetail(id) {
        // const loading = this.$loading({})
        try {
            this.loading = true
            const res = await getRequestDetailAPI({ id: id })
            this.isReEdit = true
            this.editData = {
                relativeNo: res.basic.data.relatedNo,
                department: res.basic.data.department,
                loanAmount: res.basic.data.totalLoanMoney,
                total_loan_money: res.basic.data.total_loan_money,
                totalMoneySp: res.basic.data.totalMoneySp,
                type: res.basic.data.type,
                shareSubject: res.basic.data.branch ? res.basic.data.branch : res.basic.data.group,
                branch: res.basic.data.branch,
                group: res.basic.data.group,
                remark: res.basic.data.remark,
                otherFiles: res.basic.appendix,
                detail: res.basic.data.detail,
                tm_extra_info: {},
                totalMoney: _.toNumber(res.basic.data.totalMoney),
                ccEdit: [],
            }
            this.showLoanAmount = res.basic.data.totalLoanMoney
            this.reEditType = res.basic.data.type
            if (res.basic.data.type === 'team_building_reversal') {
                this.editData.tm_extra_info = res.basic.data.team_building_season
            }

            this.historyFile = res.basic?.appendix.map(item => ({
                key: item.key,
                isRequired: false,
                url: item.url,
                value: item.value,
            }))
            this.editData.otherFiles = []
            this.editData.ccEdit = res.basic.data.ccExtra ? res.basic.data.ccExtra : []
            // this.paramsInfo.extraCCInfo.ccNames = JSON.parse(JSON.stringify(this.paramsInfo.extraCCInfo.ccNames))
            this.reEditDetailData = JSON.parse(JSON.stringify(res.basic.data.detail)).map((item, index) => ({
                ...item,
                dataIndex: index + 1,
            }))
            this.path = res.basic.info.initNodes.map(item => ({
                operatorType: item.operator_type,
                operatorTypeLabel: StrikeBalanceMap.getByValue('operatorLabelMap', item.operator_type).label,
                nickNames: item.operator,
            }))
            this.typeEditAble = res.basic.data.state !== 1
            this.submitter = res.basic.specialNickName.flat()
        } catch (e) {
            console.log(e)

            this.$message.error(e.error_msg)
        } finally {
            this.loading = false
        }
    }

    // 编辑抄送人
    editCC() {
        this.showEditCC = true
        if (this.editData.ccEdit && this.editData.ccEdit.length) {
            this.temporaryCC = [...this.editData.ccEdit]
        }
    }

    // 删除抄送人
    deleteCC(item) {
        this.temporaryCC = _.difference(this.temporaryCC, [item])
    }
    async querySearchCC(queryString, cb) {
        if (!queryString || !queryString.safeTrim()) {
            cb([])
            return
        }

        const qString = _.capitalize(queryString.safeTrim())

        const res = await nicknameExistsAPI(qString)
        this.ccSearchResult = []

        if (res) {
            this.ccSearchResult.push({ value: qString })
        }

        cb(this.ccSearchResult)
    }

    handleSelectCC() {
        this.$refs.ccAutoComplete.suggestions = []

        if (!this.ccNickName) {
            this.$message.warning(`${this.$t('t520')}`)
            return
        }
        if (!this.ccSearchResult.length) {
            this.$message.warning(`${this.$t('t567')}`)
            return
        }

        this.addTemporaryCC()
    }
    addTemporaryCC() {
        if (this.ccSearchResult[0] && !this.temporaryCC.includes(this.ccSearchResult[0].value)) {
            this.temporaryCC = _.difference(
                [...this.temporaryCC, this.ccSearchResult[0].value],
                [this.$store.state.userInfo.nickname]
            )
        }
        this.ccSearchResult = []
        this.ccNickName = ''
    }

    cancelCCEdit() {
        this.showEditCC = false
        this.ccSearchResult = []
        this.ccNickName = ''
        this.temporaryCC = []
    }
    confirmCCEdit() {
        this.editData.ccEdit = [...this.temporaryCC]
        this.cancelCCEdit()
    }

    open() {
        this.openText = true
    }
    close() {
        this.openText = false
    }

    back() {
        this.cancel()

        this.oneTipsFlag = false
        this.tipsFlag = false
        this.$emit('update:visible', false)
        this.$emit('update:reEditItem', 0)
        this.$emit('search')
        this.preInitiateFlag = false
    }

    cancel() {
        this.preInitiateAble = false
        this.preInitiateFlag = false
        this.oneTipsFlag = false
        this.tipsFlag = false
        this.teamBuildingTips = false
        this.typeEditAble = false
        this.$emit('update:visible', false)
        this.$emit('update:reEditItem', 0)
        this.$emit('search')
        // 关联借款申请可选择项
        getableLoanRequestsAPI().then(res => {
            this.editOptions.relativeOptions = res.data
        })
        this.submitter = []
        this.loanSubmitter = []
        this.preInitiateFlag = false
        this.historyFile = []
        this.isReEdit = false
        this.editData = {
            // 关联借款申请
            relativeNo: '',
            // 发起人部门
            department: '',
            // 借款总金额
            loanAmount: '',
            // 冲账类型
            type: '',
            // 费用分摊主体
            shareSubject: 0,
            // 冲账总金额
            totalMoney: 0,
            totalMoneySp: '',
            // 备注
            remark: '',
            // 其他附件
            otherFiles: [],
            group: 0,
            branch: 0,
            detail: [],
            tm_extra_info: {},
            // 自定义抄送人
            ccEdit: [],
            total_loan_money: '',
        }
        this.showLoanAmount = ''
        this.loan_detail = []
        this.path = []
        this.tm_extra_info = {}
        this.paramsInfo = {
            extraCCInfo: {
                ccNames: [],
            },
        }
        this.historyExtraCC = []
        this.saveDisabled = false
        this.confirmDisable = false
        this.commonFileData = [
            {
                value: 'file',
                label: '',
                isRequired: false,
                historyFiles: [],
                upFiles: [],
            },
        ]
    }
}
</script>

