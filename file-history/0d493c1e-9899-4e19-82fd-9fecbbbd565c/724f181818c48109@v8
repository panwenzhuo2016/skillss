    /**
     * @apiName 【冲账申请员工端】 获取审批详情.
     *
     * @param Request $request
     * @return JsonResponse
     */
    public function request(Request $request)
    {
        $sfuserId = $request->input('sfuser_info.id');
        $requestId = $request->input('reversal_request_id', 0);
        $no = $request->input('no', '');

        if (empty($requestId) && $no) {
            $requestId = (new CommonRequest())->setReversalTable()->whereNo($no)->first()->id;
        }

        if (!$requestId) {
            throw new WorkflowException(__('my_api.workflow_request_not_found'), ExceptionCode::ERR_RESOURCE_MISSING);
        }

        // 在 OA 端，只有可见，才能查看详情
        $wrs = (new CommonRequestStakeholder())->setReversalTable()
            ->where('request_id', $requestId)->first();
        if (!$wrs) {
            throw new WorkflowException(__('my_api.workflow_request_not_found'), ExceptionCode::ERR_RESOURCE_MISSING);
        }

        $wr = new RequestService(Registry::REVERSAL, $requestId, $sfuserId);

        $detail = $wr->detail(true);

        if (Arr::has($detail, 'basic') && $detail['basic']['process_key'] == Registry::REVERSAL) {
            $requestId = $detail['basic']['id'];
            $reversalDetail = (new CommonRequestDetail())->setReversalTable()->where('request_id', $requestId)->first();

            // 大写金额
            $detail['basic']['data']['uppercase_total_money'] = Helper::num2rmb($detail['basic']['data']['total_money']);
            $detail['basic']['data']['uppercase_total_loan_money'] = Helper::num2rmb($reversalDetail->total_loan_money);
            // 部门中文
            $detail['basic']['data']['department_name'] = Arr::get(CommonConst::LOAN_REVERSAL_DEPARTMENT_LIST[$detail['basic']['data']['department'] - 1], 'label');
            // 社保所属公司
            $socialInsuranceCompanyIndex = Sfuser::whereId($detail['basic']['sfuser_id'])->first()->social_insurance_company - 1;
            $detail['basic']['data']['social_insurance_company'] = Arr::get(CommonConst::SOCIAL_INSURANCE_COMPANY_LIST, "{$socialInsuranceCompanyIndex}.label", '');
            // 审批通过时间
            $detail['basic']['approval_date'] = $reversalDetail->approval_date ?? '';
            // 审批完成时间
            $detail['basic']['complete_date'] = $reversalDetail->complete_date ?? '';

            // 作为审批人
            $approvers = $wr->getApproverIds();

            // 附件
            $paths = array_column($detail['basic']['files'], 'value');

            // 作废详情
            if ($detail['basic']['is_locked']) {
                $lockDetail = (new CommonRequestLockDetail())->setReversalTable()->where('request_id', $requestId)->first();
                $detail['basic']['lock_detail'] = ($lockDetail == null) ? [] : $lockDetail->toArray();
            }

            // 管理端审批人花名(去除行政提交)
            $types = CommonSpecialStakeholder::MANAGEMENT_SIDE_AUTHORIZE_TYPES[Registry::REVERSAL];
            $stateClass = $wr->getStateClass();
            foreach ($types as $operatorType) {
                $specialSfusers = $stateClass->fetchSpecialSfuser(Registry::REVERSAL, $operatorType, $detail['basic']['data']);
                $detail['special_nicknames'][] = [
                    'operator_type' => $operatorType,
                    'nicknames' => $specialSfusers['nicknames'],
                ];
            }
        }

        $res = ['detail' => $detail];

        // 有 Token，并且不是本人的话，不需要通过 Token 解密
        if ($wr->getRequest()->token && $sfuserId != $wr->getRequest()->sfuser_id) {
            $res['decrypt_config'] = [
                'tokens' => Arr::wrap($wr->getRequest()->token),
            ];
        }

        return $this->responseJsonSuccess($res);
    }

