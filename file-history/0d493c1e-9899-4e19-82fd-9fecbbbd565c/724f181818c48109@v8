    /**
     * 获取可冲账的借款申请.
     *
     * @param Request $request
     * @return JsonResponse
     */
    public function getUsableLoanRequests(Request $request): JsonResponse
    {
        $sfuserInfo = $request->only(['sfuser_info']);
        $sfuserId = Arr::get($sfuserInfo, 'sfuser_info.id');
        $validReversalRequestIds = (new CommonRequest())->setReversalTable()->whereIsLocked(0)->whereNot('current_state_id', ReversalState::DELETED)->pluck('id')->toArray();
        $usedLoanRequestNos = (new CommonRequestDetail())->setReversalTable()->whereIn('request_id', $validReversalRequestIds)->pluck('related_loan_request_no')->toArray();
        $loanRequests = CommonRequest::whereSfuserId($sfuserId)
            ->whereCurrentStateId(CommonState::REVERSAL_PENDING)
            ->whereNotIn('no', $usedLoanRequestNos)
            ->select(['no', 'data'])
            ->get()->toArray();
        foreach ($loanRequests as &$loanRequest) {
            $loanRequest['department'] = CommonConst::LOAN_REVERSAL_DEPARTMENT_LIST[$loanRequest['data']['department'] - 1]['label'];
            $loanRequest['total_money'] = $loanRequest['data']['total_money'];
            unset($loanRequest['data']);
        }
        unset($loanRequest);
        return $this->responseJsonSuccess([
            'loan_requests' => $loanRequests,
        ]);
    }

    /**
     * @apiName 【冲账申请员工端】 开启一个审批流程。
     *
     * @param Request $request
     * @return JsonResponse
     */
    public function startProcess(Request $request): JsonResponse
    {
        $input = Arr::only($request->all(), [
            'sfuser_info', 'reversal_request_id', 'start', 'context', 'files',
            'cc_nickname_hash_filter', 'info',
        ]);
        $input['process_key'] = Registry::REVERSAL;

        if (Arr::has($input, 'cc_nickname_hash_filter')) {
            $input['cc_ids'] = SfuserHash2IdMapService::app()->getSfuserIdsViaNicknameHashes($input['cc_nickname_hash_filter']);
        }

        $loanRequestId = CommonRequest::whereNo(Arr::get($input, 'context.related_loan_request_no'))->first()->id;
        if (empty($loanRequestId)) {
            Log::error('Undefined loan request no: '.Arr::get($input, 'context.related_loan_request_no'));
        }
        $loanRequestDetail = CommonRequestDetail::whereRequestId($loanRequestId)->first();
        $input['context']['department'] = $loanRequestDetail->department;
        $input['context']['total_loan_money'] = $loanRequestDetail->total_money;
        $input['context']['total_money'] = ReversalService::app()->countReversalTotalMoney($input['context']['allocation_details']);

        // 限制冲账金额
        if ($input['start']) {  // 相等
            if (abs((float)($input['context']['total_money']) - (float)($input['context']['total_loan_money'])) >= 1e-4) {
                return $this->responseJsonFail(__('my_api.reversal_amount_not_match'), UserException::ERR_USER_OPERATE_LIMIT);
            }
        } else {    // 小于等于
            if ((float)($input['context']['total_money']) - (float)($input['context']['total_loan_money']) >= 1e-4) {
                return $this->responseJsonFail(__('my_api.reversal_amount_is_large'), UserException::ERR_USER_OPERATE_LIMIT);
            }
        }

        $wr = RequestService::make(
            $input['process_key'],
            $input['sfuser_info']['id'],
            $input['reversal_request_id'],
            (bool)$input['start'] ?? false,
            $input['cc_ids'] ?? [],
            $input['context'] ?? [],
            $input['files'] ?? [],
            $input['info'] ?? [],
        );
        $msg = implode('', $wr->messageBag);

        return $this->responseJsonSuccess(['success' => (bool)empty($msg), 'request_id' => $wr->getRequest()->id, 'msg' => $msg]);
    }

