    /**
     * @apiName 【冲账申请员工端】 重新编辑.
     *
     * @param Request $request
     * @return JsonResponse
     */
    public function reEdit(Request $request): JsonResponse
    {
        $input = Arr::only($request->all(), [
            'sfuser_info', 'reversal_request_id', 'start', 'context', 'files', 'cc_nickname_hash_filter', 'authorized_token', 'info',
        ]);
        $input['process_key'] = Registry::REVERSAL;
        $sfuserId = $input['sfuser_info']['id'];

        // 抄送人
        if (Arr::has($input, 'cc_nickname_hash_filter')) {
            $input['cc_ids'] = SfuserHash2IdMapService::app()->getSfuserIdsViaNicknameHashes($input['cc_nickname_hash_filter']);
        }

        $updateColumns = Arr::only($input, ['files', 'cc_ids', 'info']);
        if (array_key_exists('authorized_token', $input)) {
            $updateColumns['token'] = $input['authorized_token'];
        }

        $wr = new RequestService(Registry::REVERSAL, $input['reversal_request_id'], $sfuserId);
        $loanRequestId = CommonRequest::where('no', Arr::get($wr->getRequest()->data, 'related_loan_request_no'))->first()->id;
        $loanRequestDetail = CommonRequestDetail::whereRequestId($loanRequestId)->first();
        $input['context']['department'] = $loanRequestDetail->department;
        $input['context']['total_loan_money'] = $loanRequestDetail->total_money;
        $beforeTotalMoney = (new CommonRequestDetail())->setReversalTable()->whereRequestId($input['reversal_request_id'])->first()->before_total_money;
        $input['context']['total_money'] = ReversalService::app()->countReversalTotalMoney($input['context']['allocation_details']);
        // 限制冲账金额 小于等于
        if ((float)($input['context']['total_money']) > (float)($input['context']['total_loan_money'])) {
            return $this->responseJsonFail(__('my_api.reversal_amount_is_large'));
        }

        if (array_key_exists('context', $input)) {
            RequestService::checkInput($input['process_key'], $sfuserId, $input['context'], $wr->getRequest()->version, $wr->getRequest()->id);

            // 重新编辑不可更改的字段
            $persistColumns = ['nickname', 'related_loan_request_no'];
            foreach ($persistColumns as $column) {
                if (Arr::get($wr->getRequest()->data, $column) != $input['context'][$column]) {
                    throw new WorkflowException(sprintf('[%s] cannot be changed', $column));
                }
            }
            $updateColumns['data'] = $input['context'];
        }

        // 检查 files 格式
        [$errNo, $needSupplementFiles, $hasSupplementFiles] = RequestService::checkFiles($updateColumns['files'] ?? []);
        if ($errNo != 0) {
            throw new WorkflowException(__('my_api.check_files_failed', ['err' => $errNo]));
        }

        $wr->getRequest()->update($updateColumns);

        // 重新编辑，更改状态与数据
        $wr->performAction(Action::REEDIT);

        $msg = '';
        // start = 1  在re-edit接口，流程往下走
        if (Arr::get($input, 'start', false)) { // 非首轮
            if ($wr->getRequest()->round != 1 && abs((float)$input['context']['total_money'] - (float)($input['context']['total_loan_money'])) < 1e-4) {    //  金额相等，流程自动重走
                $wr->goOnToApprove();           // 首轮
            } elseif ($wr->getRequest()->round == 1 && abs((float)$input['context']['total_money'] - (float)($input['context']['total_loan_money'])) < 1e-4) {  // 非首轮发起时的草稿，金额不等，报错
                $msg = $wr->performActionWithMsg(Action::APPROVE);
            } else { // 金额不等 报错
                return $this->responseJsonFail(__('my_api.reversal_amount_not_match'));
            }
        }
        $wr->requestFilesCreated();

        return $this->responseJsonSuccess(['success' => true, 'msg' => $msg]);
    }

    /**
     * 获取能申请差旅费报销的日期
     * 出差日期检验筛选.
     *
     * @param Request $request
     * @return JsonResponse
     */
    public function getCouldReversalTripDates(Request $request): JsonResponse
    {
        $sfuserId = $request->input('sfuser_info.id');

        $startDate = date('Y-m-d', strtotime('-1 year'));
        $tripDates = WorkflowDataExtra::where('sfuser_id', $sfuserId)->where('process_key', WFRegistry::BUSINESS_TRIP)
            ->where('end_time', '>=', $startDate.' 00:00:00')->select('request_id', 'start_time', 'end_time')->get()->toArray();

        $requestIds = array_unique(array_column($tripDates, 'request_id'));
        $requestIds = WorkflowRequest::whereIn('id', $requestIds)->where('current_state_id', WFState::COMPLETED)
            ->pluck('id')->toArray();

        $allDates = [];
        foreach ($tripDates as $one) {
            if (!in_array($one['request_id'], $requestIds)) {
                continue;
            }
            $allDates = array_merge($allDates, Helper::getBetweenDates($one['start_time'], $one['end_time'], WFRegistry::BUSINESS_TRIP));
        }
        $allDates = array_filter(array_unique($allDates), function ($date) use ($startDate) {
            return $date >= $startDate && $date <= date('Y-m-d');
        });

        $appliesDates = ReversalTripDate::where('sfuser_id', $sfuserId)->where('use_date', '>=', $startDate)
            ->pluck('use_date')->toArray();
        $filteredDates = array_values(array_diff($allDates, $appliesDates));
        return $this->responseJsonSuccess(['dates' => $filteredDates]);
    }

    /**
     * 获取花名是否存在(非中国站点给id)。
     */
    public function nicknameExists(Request $request): JsonResponse
    {
        $sfuserId = $request->input('sfuser_info.id');
        $nicknameHash = $request->input('nickname_hash_filter');

        if (empty($sfuserId) || empty($nicknameHash)) {
            return $this->responseJsonSuccess(['exist' => false, 'sfuser_id' => 0]);
        }

        $u = Sfuser::whereIn('nickname_hash', $nicknameHash)->where('is_closed', 0)->first();
        $sfuserId = $u->id ?? 0;
        if (SiteService::app()->is(SiteService::CHN)) {
            $sfuserId = 0;
        }

        return $this->responseJsonSuccess(['exist' => !($u == null), 'sfuser_id' => $sfuserId]);
    }

