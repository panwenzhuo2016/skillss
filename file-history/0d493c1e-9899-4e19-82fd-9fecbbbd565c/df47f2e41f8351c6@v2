     */
    public function readAllCCRequests(Request $request)
    {
        $input = Arr::only($request->all(), [
            'sfuser_info', 'per_page', 'no', 'approval_statuses', 'lack_supplements', 'nickname_hash_filter',
            'department', 'pay_company', 'stamp_type', 'priority', 'complete_date_start', 'complete_date_end',
            'next_replace_filter',
        ]);

        $sfuserId = $input['sfuser_info']['id'];

        $queryBuilder = (new StampStakeholderQueryBuilder('stamp'))->asCCer()->filterByUserId($sfuserId);

        // 按申请人进行过滤
        if (Arr::has($input, 'nickname_hash_filter')) {
            $userIds = StampUser::whereIn('nickname_hash', $input['nickname_hash_filter'])->pluck('sfuser_id')->toArray();
            $queryBuilder->filterByRequesterIds($userIds);
        }

        // 按编号筛选
        if ($no = Arr::get($input, 'no')) {
            $queryBuilder->filterByNo($no);
        }

        // 按关键字搜索筛选
        if (($nextReplaceFilterIds = Arr::get($input, 'next_replace_filter')) !== null) {
            $queryBuilder->filterByRequestIds($nextReplaceFilterIds);
        }

        // 按审批状态筛选
        $approvalStatuses = Arr::wrap(Arr::get($input, 'approval_statuses', []));
        if ($approvalStatuses) {
            $queryBuilder->stateIn($approvalStatuses);
        }

        $lackSupplements = Arr::get($input, 'lack_supplements', -1);
        if ($lackSupplements != -1) {
            /** lack_supplements: 1 缺少材料，2 材料齐全 */
            $lack = $lackSupplements == 1; // 不搜时，不传该参数，因此不用判断是否为 2 了
            $queryBuilder->filterByLackSupplements($lack);
        }

        $processKey = Arr::get($input, 'process_key', []);
        if ($processKey) {
            $queryBuilder->filterByProcessKey($processKey);
        }

        // 按照部门查找
        if ($department = Arr::get($input, 'department')) {
            $queryBuilder->filterByDepartment($department);
        }

        // 按照盖章公司查询
        if ($payCompany = Arr::get($input, 'pay_company')) {
            $queryBuilder->filterByPayCompany($payCompany);
        }

        // 按照盖章类型查询
        if ($stampType = Arr::get($input, 'stamp_type')) {
            $queryBuilder->filterByStampType($stampType);
        }

        // 按照优先级查询
        $priority = Arr::get($input, 'priority');
        if ($priority != null) {
            $queryBuilder->filterByPriority($priority);
        }

        // 按照盖章完成日期搜索
        $queryBuilder->completeDateAfter(Arr::get($input, 'complete_date_start', ''))
            ->completeDateBefore(Arr::get($input, 'complete_date_end', ''));

        $cnt = $queryBuilder->queryBuilder()->update(['is_read' => 1]);

        // 更新盖章抄送未读
        NotifyNumberService::app()->modifyIndividual($sfuserId, 'stamp_cc', -1 * $cnt);

        return $this->responseJsonSuccess(['count' => $cnt]);
    }

    /**
     * 获取审批详情.
     *
     * @param Request $request
     * @return JsonResponse
     */
    public function request(Request $request)
    {
        $sfuserId = $request->input('sfuser_info.id');
        $requestId = $request->input('st_request_id');

        // 在 OA 端，只有可见，才能查看详情
        $wrs = (new CommonRequestStakeholder())->setConnection('stamp')
            ->where('request_id', $requestId)->where('user_id', $sfuserId)
            ->first();
        if (!$wrs) {
            throw new WorkflowException(__('my_api.workflow_request_not_found'), ExceptionCode::ERR_RESOURCE_MISSING);
        }

        $wr = new RequestService('stamp', $requestId, $sfuserId);

        $detail = $wr->detail(true);

        if (Arr::has($detail, 'basic') && $detail['basic']['process_key'] == Registry::STAMP) {
            $requestId = $detail['basic']['id'];
            $stampDetail = StampDetail::where('request_id', $requestId)->first();

            // 审批通过时间
            $detail['basic']['approval_date'] = $stampDetail->approval_date ?? '';
            // 审批完成时间
            $detail['basic']['complete_date'] = $stampDetail->complete_date ?? '';

            // 作为申请人
            if ($sfuserId == $wr->getRequest()->user_id) {
                // 已执行附件
                $detail['basic']['execute_file'] = $stampDetail->execute_file ?? [];
                // 添加修改盖章存档附件的特殊动作
                if ($wr->getRequest()->current_state_id == State::COMPLETED) {
                    $detail['special_actions'][] = SpecialAction::EDIT_STAMP_ARCHIVE_ATTACHMENT;
                }
            }

            // 作为审批人
            $approvers = $wr->getApproverIds();
            $legalId = Arr::get($approvers, CommonSpecialStakeholder::LEGAL_TYPE);
            $legalNotApprover = ($sfuserId === $legalId) && (array_count_values($approvers)[$sfuserId] <= 1); // 是法务且非审批人

            // 附件
            $paths = array_column($detail['basic']['files'], 'value');

            // 存档附件，仅法务不可见
            if (!$legalNotApprover) {
                $detail['basic']['archive_attachment'] = $stampDetail->archive_attachment ?? [];
                $paths = array_merge($paths, array_column($detail['basic']['archive_attachment'], 'value'));
            }

            // 盖章相关字段对法务隐藏，增加仅法务可见字段
            if ($detail['basic']['data']['is_contract'] && $sfuserId != $wr->getRequest()->user_id) {
                if ($sfuserId === $legalId) {
                    if ($legalNotApprover) {
                        $paths = array_diff($paths, array_column($detail['basic']['data']['contract'] ?? [], 'value'));
                        Arr::forget($detail['basic']['data'], ['contract', 'reason']);
                    }
                } else {
                    $paths = array_diff($paths, array_column($detail['basic']['data']['legal_contract'] ?? [], 'value'));
                    Arr::forget($detail['basic']['data'], ['legal_contract', 'remark_to_legal']);
                }
            }

            // 附件下载记录
            if (in_array($sfuserId, $approvers)) {
                $filePaths = (new CommonFileStorePath())->setConnection('stamp')->whereIn('file_store_path', $paths)->pluck('file_store_path', 'id')->toArray();
                $detail['download_record'] = StampFileDownloadRecord::whereIn('file_path_id', array_keys($filePaths))
                    ->orderBy('created_at', 'DESC')->select('*')->get()->toArray();
                foreach ($detail['download_record'] as &$one) {
                    $pathId = $one['file_path_id'];
                    $one['value'] = $filePaths[$pathId] ?? '';
                }
                unset($one);
            }

            // 作废详情
            if ($detail['basic']['is_locked']) {
                $lockDetail = (new CommonRequestLockDetail())->setConnection('stamp')->where('request_id', $requestId)->first();
                $detail['basic']['lock_detail'] = ($lockDetail == null) ? [] : $lockDetail->toArray();
            }

            // 管理端审批人花名
            $types = [CommonSpecialStakeholder::STAMP_HANDEL_TYPE, CommonSpecialStakeholder::STAMP_EXECUTE_TYPE];
            $stateClass = $wr->getStateClass();
            foreach ($types as $operatorType) {
                $specialSfusers = $stateClass->fetchSpecialSfuser('stamp', $operatorType, $detail['basic']['data']);
                $detail['special_nicknames'][] = [
                    'operator_type' => $operatorType,
                    'nicknames' => $specialSfusers['nicknames'],
                ];
            }
        }

        $res = ['detail' => $detail];

        // 有 Token，并且不是本人的话，不需要通过 Token 解密
        if ($wr->getRequest()->token && $sfuserId != $wr->getRequest()->user_id) {
            $res['decrypt_config'] = [
                'tokens' => Arr::wrap($wr->getRequest()->token),
            ];
        }

        return $this->responseJsonSuccess($res);
    }

    /**
     * 执行动作.
     *
     * @param Request $request
     * @return JsonResponse
     */
    public function performAction(Request $request): JsonResponse
    {
        $input = Arr::only($request->all(), ['sfuser_info', 'st_request_id', 'action_id', 'remark']);
        $sfuserId = $input['sfuser_info']['id'];

        if ($input['action_id'] == Action::DELETE) {
            return $this->responseJsonFail(__('my_api.invalid_action_given'), ExceptionCode::ERR_USER_OPERATE_LIMIT);
        }

        $request = new RequestService('stamp', $input['st_request_id'], $sfuserId);
        $msg = $request->performActionWithMsg($input['action_id'], $input['remark'] ?? '');

        return $this->responseJsonSuccess(['success' => (bool)empty($msg), 'msg' => $msg]);
    }

    /**
     * 执行特殊动作.
     *
     * @param Request $request
     * @return JsonResponse
     */
    public function performSpecialAction(Request $request): JsonResponse
    {
        $input = Arr::only($request->all(), [
            'sfuser_info', 'st_request_id', 'special_action_id', 'contract', 'files', 'archive_attachment',
        ]);

        $sfuserId = Arr::get($input, 'sfuser_info.id');

        $errMsg = __('my_api.lack_permission');
        $lackParam = false;
        $success = true;

        switch ($input['special_action_id']) {
            case SpecialAction::EDIT_STAMP_SUPPLEMENT:
                if (!Arr::has($input, ['contract', 'files'])) {
                    $lackParam = true;
                    break;
                }
                $success = SpecialAction::editStampSupplement($sfuserId, $input['st_request_id'], $input['contract'], $input['files']);
                break;
            case SpecialAction::EDIT_STAMP_ARCHIVE_ATTACHMENT:
                if (!Arr::has($input, ['archive_attachment'])) {
                    $lackParam = true;
                    break;
                }
                $success = SpecialAction::editStampArchiveAttachment($sfuserId, $input['st_request_id'], $input['archive_attachment']);
                break;
            default:
                return $this->responseJsonFail(__('my_api.invalid_action_given'), ExceptionCode::ERR_USER_OPERATE_LIMIT);
        }

        if ($lackParam) {
            return $this->responseJsonFail(__('my_api.lack_required_param'), ExceptionCode::ERR_COMMON_MISSING_PARAMETERS);
        }
        if (!$success) {
            return $this->responseJsonFail($errMsg, ExceptionCode::ERR_USER_OPERATE_LIMIT);
        }

        return $this->responseJsonSuccess(['success' => true]);
    }

    /**
     * 重新编辑.
     *
     * @param Request $request
     * @return JsonResponse
     */
    public function reEdit(Request $request): JsonResponse
    {
        $input = Arr::only($request->all(), [
            'sfuser_info', 'st_request_id', 'process_key', 'start', 'context', 'files', 'cc_nickname_hash_filter', 'authorized_token', 'info',
        ]);

        $sfuserId = $input['sfuser_info']['id'];

        // 抄送人
        if (Arr::has($input, 'cc_nickname_hash_filter')) {
            $input['cc_ids'] = StampUser::whereIn('nickname_hash', $input['cc_nickname_hash_filter'])->active()->pluck('sfuser_id')->toArray();
        }

        // 人事部/行政部发起时，自动将艾莎加入抄送列表
        $this->appendAishaCcIfNeeded($input);

        $updateColumns = Arr::only($input, ['files', 'cc_ids', 'info']);
        if (array_key_exists('authorized_token', $input)) {
            $updateColumns['token'] = $input['authorized_token'];
        }

        $wr = new RequestService('stamp', $input['st_request_id'], $sfuserId);

        // 流程不能改变
        if ($input['process_key'] != $wr->getRequest()->process_key) {
            throw new WorkflowException('process_key cannot be changed');
        }

        if (array_key_exists('context', $input)) {
            RequestService::checkInput($input['process_key'], $sfuserId, $input['context'], $wr->getRequest()->version);

            // 重新编辑不可更改的字段
            $persistColumns = ['nickname', 'department', 'pay_company', 'stamp_type'];
            foreach ($persistColumns as $column) {
                if (Arr::get($wr->getRequest()->data, $column) != $input['context'][$column]) {
                    throw new WorkflowException(sprintf('[%s] cannot be changed', $column));
                }
            }
            $updateColumns['data'] = $input['context'];
        }

        // 检查 files 格式
        [$errNo, $needSupplementFiles, $hasSupplementFiles] = RequestService::checkFiles($updateColumns['files'] ?? []);
        if ($errNo != 0) {
            throw new WorkflowException(__('my_api.check_files_failed', ['err' => $errNo]));
        }
        if (array_key_exists('files', $updateColumns)) {
            $updateColumns += ['need_supplements' => $needSupplementFiles, 'has_supplements' => $hasSupplementFiles];
        }

        $wr->getRequest()->update($updateColumns);
        $wr->performAction(Action::REEDIT);
        $wr->requestCreated();

        UpdateCommonRequestNextReplaceCache::dispatch('stamp', CommonRequest::STRATEGY_REPLACE);
        UpdateStampRequestCache::dispatchSync(CommonRequest::STRATEGY_REPLACE);

        $msg = '';
        if (Arr::get($input, 'start', false)) {
            $msg = $wr->performActionWithMsg(Action::APPROVE);
        }

        return $this->responseJsonSuccess(['success' => (bool)empty($msg), 'msg' => $msg]);
    }

    /**
     * 人事部/行政部发起时，自动将艾莎加入抄送列表（艾莎自己发起时不抄送自己）.
     */
    private function appendAishaCcIfNeeded(array &$input): void
    {
        $sfuserId = $input['sfuser_info']['id'];
        $aishaId = WorkflowStakeholder::AISHA_SFUSER_ID;
        if ($sfuserId === $aishaId) {
            return;
        }
        if (!WorkflowStakeholder::isHrOrAdminDepartment($sfuserId)) {
            return;
        }
        $ccIds = $input['cc_ids'] ?? [];
        if (!in_array($aishaId, $ccIds)) {
            $ccIds[] = $aishaId;
        }
        $input['cc_ids'] = $ccIds;
    }
