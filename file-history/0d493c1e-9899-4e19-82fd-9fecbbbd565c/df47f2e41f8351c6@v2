    /**
     * 代办事项.
     *
     * @param Request $request
     * @return JsonResponse
     */
    public function todoList(Request $request): JsonResponse
    {
        $sfuserId = $request->input('sfuser_info.id');
        $disableCache = $request->input('disable_cache', false);

        $issuedButNotCompleted = 0; // 我发起的（待审批）的数目
        $toBeApprovedByMe = 0; // 待我审批数目
        $cc2Me = 0; // 抄送我的并且未读的数目

        if ($disableCache) {
            $issuedButNotCompleted = (new StakeholderQueryBuilder('stamp'))->filterByRequesterIds($sfuserId)->approving()->asRequester()->unlocked()->count();
            $issuedButRejected = (new StakeholderQueryBuilder('stamp'))->filterByRequesterIds($sfuserId)->stateIn(State::REJECTED)->asRequester()->unlocked()->count();
            $toBeApprovedByMe = (new ActionerQueryBuilder('stamp'))->filterByUserId($sfuserId)->toBeApprovedByMe()->unlocked()->count();
            $cc2Me = (new StakeholderQueryBuilder('stamp'))->filterByUserId($sfuserId)->asCCer()->unread()->count();
        } else {
            $data = NotifyNumberService::app()->getIndividual($sfuserId);
            $issuedButNotCompleted = $data['stamp_issued'] ?? 0;
            $issuedButRejected = $data['stamp_issued_rejected'] ?? 0;
            $toBeApprovedByMe = $data['stamp_to_be_approved'] ?? 0;
            $cc2Me = $data['stamp_cc'] ?? 0;
        }

        // 查询个人数据
        $userData = StampUserData::firstOrCreate(['sfuser_id' => $sfuserId], [
            'sfuser_id' => $sfuserId, 'to_be_approved_by_me' => 0, 'cc_to_me' => 0,
        ]);

        // 更新个人数据
        $update = [];
        if (!$userData->to_be_approved_by_me && $toBeApprovedByMe) {
            $update['to_be_approved_by_me'] = 1;
        }
        if (!$userData->cc_to_me && $cc2Me) {
            $update['cc_to_me'] = 1;
        }
        if (!empty($update)) {
            $userData->update($update);
        }

        // 如果从来没有过就不返回
        $ret = [
            'countingIssuedButNotCompleted' => $issuedButNotCompleted,
            'countingIssuedButRejected' => $issuedButRejected,
        ];
        if ($userData->to_be_approved_by_me) {
            $ret['countingToBeApprovedByMe'] = $toBeApprovedByMe;
        }
        if ($userData->cc_to_me) {
            $ret['countingCc2Me'] = $cc2Me;
        }
        $ret = ApprovalManagementController::dealLessThan0($ret);
        return $this->responseJsonSuccess($ret);
    }

