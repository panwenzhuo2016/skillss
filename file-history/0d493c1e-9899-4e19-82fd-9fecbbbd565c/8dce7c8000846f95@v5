    /**
     * @apiName 【借款申请员工端】 获取审批详情.[单个审批].
     *
     * @param Request $request
     * @return JsonResponse
     */
    public function request(Request $request)
    {
        $sfuserId = $request->input('sfuser_info.id');
        $requestId = $request->input('loan_request_id', 0);
        $no = $request->input('no', '');

        // 在 OA 端，只有可见，才能查看详情
        if (empty($requestId) && $no) {
            $requestId = CommonRequest::whereNo($no)->first()->id;
        }

        if (!$requestId) {
            throw new WorkflowException(__('my_api.workflow_request_not_found'), ExceptionCode::ERR_RESOURCE_MISSING);
        }

        $wrs = (new CommonRequestStakeholder())
            ->where('request_id', $requestId)
            ->first();

        if (!$wrs) {
            throw new WorkflowException(__('my_api.workflow_request_not_found'), ExceptionCode::ERR_RESOURCE_MISSING);
        }

        $wr = new RequestService(Registry::LOAN, $requestId, $sfuserId);

        $detail = $wr->detail(true);

        if (Arr::has($detail, 'basic') && $detail['basic']['process_key'] == Registry::LOAN) {
            $requestId = $detail['basic']['id'];
            $requestDetail = CommonRequestDetail::whereRequestId($requestId)->first();

            // 大写借款金额
            $detail['basic']['data']['total_money'] = ($requestDetail == null) ? '' : $requestDetail->total_money;  // 借款金额
            $detail['basic']['data']['uppercase_total_money'] = Helper::num2rmb($detail['basic']['data']['total_money']);
            // $detail['basic']['data']['uppercase_total_money_eng'] = Helper::num2eng($detail['basic']['data']['uppercase_total_money']);
            // 部门中文
            $detail['basic']['data']['department_name'] = Arr::get(CommonConst::LOAN_REVERSAL_DEPARTMENT_LIST[$detail['basic']['data']['department'] - 1], 'label');
            // 社保所属公司
            $socialInsuranceCompanyValue = Sfuser::whereId($detail['basic']['sfuser_id'])->first()->social_insurance_company - 1;
            $detail['basic']['data']['social_insurance_company'] = Arr::get(CommonConst::SOCIAL_INSURANCE_COMPANY_LIST, "{$socialInsuranceCompanyValue}.label", '');
            // 计划冲账时间
            $detail['basic']['plan_reversal_date'] = ($requestDetail == null) ? '' : $requestDetail->plan_reversal_date;
            // 审批通过时间
            $detail['basic']['approval_date'] = ($requestDetail == null) ? '' : $requestDetail->approval_date;
            // 审批完成时间
            $detail['basic']['complete_date'] = ($requestDetail == null) ? '' : $requestDetail->complete_date;
            // 付款凭证 TODO: 是否限制可见范围？
            $detail['basic']['pay_proof'] = ($requestDetail == null) ? [] : $requestDetail->pay_proof;
            $detail['basic']['related_reversal_request_no'] = ($requestDetail == null) ? '' : $requestDetail->related_reversal_request_no;

            // 作废详情
            if ($detail['basic']['is_locked']) {
                $lockDetail = (new CommonRequestLockDetail())->where('request_id', $requestId)->first();
                $detail['basic']['lock_detail'] = ($lockDetail == null) ? [] : $lockDetail->toArray();
            }

            // 管理端审批人花名
            $types = CommonSpecialStakeholder::MANAGEMENT_SIDE_AUTHORIZE_TYPES[Registry::LOAN];
            $stateClass = $wr->getStateClass();
            foreach ($types as $operatorType) {
                $specialSfusers = $stateClass->fetchSpecialSfuser(Registry::LOAN, $operatorType, $detail['basic']['data']);
                $detail['special_nicknames'][] = [
                    'operator_type' => $operatorType,
                    'nicknames' => $specialSfusers['nicknames'],
                ];
            }
        }
        $res = ['detail' => $detail];

        // 有 Token，并且不是本人的话，需要通过 Token 解密
        if ($wr->getRequest()->token && $sfuserId != $wr->getRequest()->sfuser_id) {
            $res['decrypt_config'] = [
                'tokens' => Arr::wrap($wr->getRequest()->token),
            ];
        }

        return $this->responseJsonSuccess($res);
    }

    /**
     * @apiName 【借款申请员工端】 执行动作.
     *
     * @param Request $request
     * @return JsonResponse
     */
    public function performAction(Request $request): JsonResponse
    {
        $input = Arr::only($request->all(), ['sfuser_info', 'loan_request_id', 'action_id', 'remark']);
        $sfuserId = $input['sfuser_info']['id'];

        if ($input['action_id'] == Action::DELETE) {
            return $this->responseJsonFail(__('my_api.invalid_action_given'), ExceptionCode::ERR_USER_OPERATE_LIMIT);
        }

        $request = new RequestService(Registry::LOAN, $input['loan_request_id'], $sfuserId);

        $msg = $request->performActionWithMsg($input['action_id'], $input['remark'] ?? '');

        return $this->responseJsonSuccess(['success' => (bool)empty($msg), 'msg' => $msg]);
    }

    /**
     * @apiName 【借款申请员工端】 执行特殊动作.
     *
     * @param Request $request
     * @return JsonResponse
     */
    public function performSpecialAction(Request $request): JsonResponse
    {
        $input = Arr::only($request->all(), [
            'sfuser_info', 'loan_request_id', 'special_action_id', 'money', 'file',
        ]);

        $sfuserId = Arr::get($input, 'sfuser_info.id');

        $errMsg = __('my_api.lack_permission');
        $lackParam = false;
        $success = true;

        // TODO:
        switch ($input['special_action_id']) {
            default:
                break;
        }

        if ($lackParam) {
            return $this->responseJsonFail(__('my_api.lack_required_param'), ExceptionCode::ERR_COMMON_MISSING_PARAMETERS);
        }
        if (!$success) {
            return $this->responseJsonFail($errMsg, ExceptionCode::ERR_USER_OPERATE_LIMIT);
        }

        return $this->responseJsonSuccess(['success' => true]);
    }

    /**
     * @apiName 【借款申请员工端】 重新编辑.
     *
     * @param Request $request
     * @return JsonResponse
     */
    public function reEdit(Request $request): JsonResponse
    {
        $input = Arr::only($request->all(), [
            'sfuser_info', 'loan_request_id', 'start', 'context', 'files', 'cc_nickname_hash_filter', 'authorized_token', 'info',
        ]);
        $input['process_key'] = Registry::LOAN;
        $sfuserId = $input['sfuser_info']['id'];

        // 抄送人
        if (Arr::has($input, 'cc_nickname_hash_filter')) {
            $input['cc_ids'] = SfuserHash2IdMapService::app()->getSfuserIdsViaNicknameHashes($input['cc_nickname_hash_filter']);
        }


        $updateColumns = Arr::only($input, ['files', 'cc_ids', 'info']);
        if (array_key_exists('authorized_token', $input)) {
            $updateColumns['token'] = $input['authorized_token'];
        }
        // 旧借款金额
        $beforeTotalMoney = CommonRequestDetail::whereRequestId($input['loan_request_id'])->first()->before_total_money;

        $wr = new RequestService(Registry::LOAN, $input['loan_request_id'], $sfuserId);

        // 流程不能改变
        // if ($input['process_key'] != $wr->getRequest()->process_key) {
        //     throw new WorkflowException('process_key cannot be changed');
        // }

        if (array_key_exists('context', $input)) {
            RequestService::checkInput($input['process_key'], $sfuserId, $input['context'], $wr->getRequest()->version);

            // 重新编辑不可更改的字段
            $persistColumns = ['nickname'];    // 'related_reversal_request_no'
            if (CommonRequestLog::whereRequestId($input['loan_request_id'])->whereIn('action_id', [Action::CANCEL, Action::REJECT])->exists()) {
                $persistColumns[] = 'department';
            }
            foreach ($persistColumns as $column) {
                if (Arr::get($wr->getRequest()->data, $column) != $input['context'][$column]) {
                    throw new WorkflowException(sprintf('[%s] cannot be changed', $column));
                }
            }
            $updateColumns['data'] = $input['context'];
        }

        // 检查 files 格式
        [$errNo, $needSupplementFiles, $hasSupplementFiles] = RequestService::checkFiles($updateColumns['files'] ?? []);
        if ($errNo != 0) {
            throw new WorkflowException(__('my_api.check_files_failed', ['err' => $errNo]));
        }

        $wr->getRequest()->update($updateColumns);

        // 重新编辑，更改状态与数据
        $wr->performAction(Action::REEDIT);

        $msg = '';
        // start = 1  在re-edit接口，流程往下走
        if (Arr::get($input, 'start', false)) {
            if ($wr->getRequest()->round != 1 && abs($input['context']['total_money'] - $beforeTotalMoney) < 1e-4) {    //  金额相等，流程自动重走
                $wr->goOnToApprove();
            } else {
                $msg = $wr->performActionWithMsg(Action::APPROVE);
            }
        }
        $wr->requestFilesCreated();

        return $this->responseJsonSuccess(['success' => (bool)empty($msg), 'msg' => $msg]);
    }

    public function getPersonalInfo(Request $request)
    {
        $sfuserId = Arr::get($request->input(), 'sfuser_info.id');
        $socialInsuranceCompany = Sfuser::whereId($sfuserId)->first()->social_insurance_company;
        $companyName = CommonConst::SOCIAL_INSURANCE_COMPANY_LIST[$socialInsuranceCompany - 1]['label'];
        $accessibleDepartments = CommonUser::whereSfuserId($sfuserId)->first()->departments;
        $res = [
            'social_insurance_company_name' => $companyName,
            'accessible_departments' => $accessibleDepartments,
        ];
        return $this->responseJsonSuccess(['success' => true, 'data' => $res]);
    }

