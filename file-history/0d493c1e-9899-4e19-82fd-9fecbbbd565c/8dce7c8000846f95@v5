    /**
     * @apiName 【借款申请员工端】 获取请求列表. [开发使用,没提供对外接口.] [这个文件下都是员工端用的].
     *
     * @param string $type
     * @param array $input
     * @return JsonResponse
     */
    public function getRequests(string $type, array $input): JsonResponse
    {
        $processKey = Registry::LOAN;
        $input = Arr::only($input, [
            'sfuser_info', 'per_page', 'no', 'nickname_hash_filter', 'department', 'social_insurance_company',
            'plan_reversal_date_start', 'plan_reversal_date_end', 'approval_statuses', 'lock_status',
        ]) + ['per_page' => 50];

        $sfuserId = $input['sfuser_info']['id'];

        $sq = new LoanStakeholderQueryBuilder();
        $aq = new ActionerQueryBuilder($processKey);

        switch ($type) {
            case 'issued':          // 我发起的
                $sq->filterByUserId($sfuserId)->asRequester()->notCCer();
                break;
            case 'approving':       // 待我审批
                $sq->filterByUserId($sfuserId)->notCCer()->notRequester();
                $aq->toBeApproved()->filterByUserId($sfuserId);
                break;
            // case 'resolved':        // 我已审批
            //     $sq->filterByUserId($sfuserId)->notCCer()->notRequester();
            //     $aq->resolved()->filterByUserId($sfuserId);
            //     break;
            case 'otherApproving':  // 他人审批
                $sq->filterByUserId($sfuserId)->notCCer()->notRequester();
                $aq->toBeApproved()->filterByNotUserId($sfuserId);
                break;
            case 'cc':              // 抄送我的
                $sq->filterByUserId($sfuserId)->asCCer();
                break;
            case 'approvingOrResolved': // 我的审批
                $sq->filterByUserId($sfuserId)->notCCer()->notRequester();
                break;
            default:
                throw new WorkflowException('Invalid type given');
        }

        // 预排序
        $queryBuilder = $sq->orderBy('plan_reversal_date', 'asc');

        // 按申请人筛选
        if (Arr::has($input, 'nickname_hash_filter')) {
            $userIds = CommonUser::whereIn('nickname_hash', $input['nickname_hash_filter'])->pluck('sfuser_id')->toArray();
            $queryBuilder->filterByRequesterIds($userIds);
        }

        // 按编号筛选
        if ($no = Arr::get($input, 'no')) {
            $queryBuilder->filterByNo($no);
        }

        // 按审批状态筛选
        if (!in_array($type, ['approving', 'otherApproving']) && $approvalStatuses = Arr::get($input, 'approval_statuses')) {
            $queryBuilder->stateIn($approvalStatuses);
        }

        // 按锁住状态筛选(作废)
        $lockStatus = Arr::get($input, 'lock_status', -1);
        if ($lockStatus != -1) {
            $queryBuilder->lockStatus($lockStatus);
        }

        // 按照社保所属公司查找
        if ($socialInsuranceCompany = Arr::get($input, 'social_insurance_company')) {
            $queryBuilder->filterBySocialInsuranceCompany($socialInsuranceCompany);
        }

        // 按照部门搜索
        if ($departments = Arr::get($input, 'department')) {
            $queryBuilder->filterByDepartment($departments);
        }

        // 按照计划冲账时间搜索
        $queryBuilder->planReversalDateAfter(Arr::get($input, 'plan_reversal_date_start', ''))
            ->planReversalDateBefore(Arr::get($input, 'plan_reversal_date_end', ''));

        $requests = [];

        $columns = '`loan_requests`.`id`, `loan_requests`.`sfuser_id`, `is_locked`, `version`, `is_read`, `submitted_at`,
                    `process_key`, `no`,  `current_state_id`, `info`, `token`, `department`, `total_money`, `nickname`,
                    `plan_reversal_date`, `remark`, `type`, `related_reversal_request_no`';

        $columnsGroup = '`loan_requests`.`id`, `loan_requests`.`sfuser_id`, `is_locked`, `version`, `is_read`, `submitted_at`,
                        `process_key`, `no`, `current_state_id`, `info`, `token`, `department`, `total_money`, `nickname`,
                        `plan_reversal_date`, `remark`, GROUP_CONCAT(`type` SEPARATOR ",") as type, `related_reversal_request_no`';

        switch ($type) {
            case 'issued':  // 我发起的
            case 'cc':  // 抄送我的
                $requests = $queryBuilder->queryBuilder()->selectRaw($columns)->paginate($input['per_page'])->toArray();
                break;
            case 'approving':       // 待我审批
            // case 'resolved':        // 我已审批
            case 'otherApproving':  // 他人审批
                $selectedRequestIds = $aq->queryBuilder()->groupBy('loan_requests.id')->pluck('loan_requests.id')->toArray();
                $approvalStatuses = Arr::get($input, 'approval_statuses', []);
                if ($approvalStatuses && $selectedRequestIds) {
                    $queryBuilder->filterByStatesOrRequestIds($approvalStatuses, $selectedRequestIds);
                } elseif ($selectedRequestIds) {
                    $queryBuilder->filterByRequestIds($selectedRequestIds);
                } elseif ($approvalStatuses) {
                    $queryBuilder->stateIn($approvalStatuses);
                } else {
                    $requests = [
                        'per_page' => $input['per_page'] ?? 50,
                        'current_page' => 1,
                        'total' => 0,
                        'data' => [],
                    ];
                    break;
                }
                $requests = $queryBuilder->queryBuilder()
                    ->selectRaw($columnsGroup)
                    ->groupBy('loan_requests.id')   // 保证申请记录唯一
                    ->paginate($input['per_page'])
                    ->toArray();
                break;
            case 'approvingOrResolved': // 我的审批
                $resolved = (clone $queryBuilder->queryBuilder())->whereIn(
                    'loan_requests.id',
                    (new ActionerQueryBuilder($processKey))->resolved()->filterByUserId($sfuserId)->queryBuilder()->select('loan_requests.id')
                )
                    ->selectRaw($columnsGroup.', 2 as status')
                    ->groupBy('loan_requests.id');
                $requests = $queryBuilder->queryBuilder()->whereIn(
                    'loan_requests.id',
                    (new ActionerQueryBuilder($processKey))->toBeApproved()->filterByUserId($sfuserId)->queryBuilder()->select('loan_requests.id')
                )
                    ->selectRaw($columnsGroup.', 1 as status')
                    ->groupBy('loan_requests.id')
                    ->union($resolved)->orderBy('status')->orderBy('plan_reversal_date', 'asc') // 按status正序排，即待我审批在前
                    ->paginate($input['per_page'])->toArray();
                break;
        }

        $sfuserIds = array_values(array_unique(array_column($requests['data'], 'sfuser_id')));
        $socialInsuranceCompanyValues = Sfuser::whereIn('id', $sfuserIds)->pluck('social_insurance_company', 'id')->toArray();

        $items = $requests['data'];
        $itemIds = Arr::pluck($items, 'id');
        $actions = Action::validActions($processKey, $sfuserId, $itemIds);
        $operatorTypes = Action::currentToBeApprovedOperatorTypes($processKey, $itemIds);

        foreach ($items as &$item) {
            $item = CommonRequest::normalizeWorkflowRequest($item); // 手动cast
            $types = explode(',', $item['type']);
            $item['type'] = array_pop($types);
            // 不返回 data 和 files
            $item['actions'] = ($item['is_locked']) ? [] : Arr::get($actions, $item['id'], []);
            // 只有审批中的才有审批人
            $item['curr_operator_type'] = in_array($item['current_state_id'], CommonState::COMMON_TYPES) ? 0 : Arr::get($operatorTypes, $item['id'], []);
        }
        unset($item);

        $tokens = [];
        foreach ($items as &$item) {
            $item['info'] = is_string($item['info']) ? my_json_decode($item['info']) : $item['info'];
            if (!empty($item['token'])) {
                $tokens[] = $item['token'];
            }
            unset($item['token']);

            $processKey = $item['process_key'];
            $stateClassName = Registry::PROCESS_MAPS[$processKey];
            /** @phpstan-ignore-next-line */
            $stateClass = new $stateClassName($item['version']);
            $specialActions = Arr::get($stateClass->specialActions, $item['current_state_id'].'.'.$item['type'], []);

            $item['special_actions'] = $specialActions;
            $item['department_name'] = Arr::get(CommonConst::LOAN_REVERSAL_DEPARTMENT_LIST[$item['department'] - 1], 'label');
            $socialInsuranceCompanyIndex = $socialInsuranceCompanyValues[$item['sfuser_id']] - 1;
            $item['social_insurance_company'] = Arr::get(CommonConst::SOCIAL_INSURANCE_COMPANY_LIST, "{$socialInsuranceCompanyIndex}.label", '');
        }
        unset($item);

        $res = [
            'current_page' => $requests['current_page'],
            'per_page' => $requests['per_page'],
            'total' => $requests['total'],
            'requests' => $items,
        ];

        if ($type != 'issued' && count($tokens)) { // 不是我发起的，并且存在 token，则通过 Token 解密。
            $res['decrypt_config'] = [
                'tokens' => $tokens,
            ];
        }

        return $this->responseJsonSuccess($res);
    }

