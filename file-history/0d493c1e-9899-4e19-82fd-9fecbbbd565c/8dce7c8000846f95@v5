    /**
     * @apiName 【借款申请员工端】 检查用户花名是否在借款名单.
     *
     * @param Request $request
     * @return JsonResponse
     */
    public function userExists(Request $request): JsonResponse
    {
        $input = $request->only(['sfuser_info', 'nickname_hash_filter']);
        $exists = false;
        $sfuser = Sfuser::whereIn('nickname_hash', $input['nickname_hash_filter'])->first();
        if ($sfuser) {
            $exists = LoanUserList::userExists($sfuser->id)
                || OverseaWhiteList::whereItemType(OverseaWhiteList::ITEM_TYPE_LOAN_AND_REVERSAL)->whereSfuserId($sfuser->id)->whereIsClosed(0)->exists();
        }
        return $this->responseJsonSuccess(['exists' => $exists]);
    }

    /**
     * @apiName 【借款申请员工端】 待办事项.（数目统计）.
     *
     * @param Request $request
     * @return JsonResponse
     */
    public function todoList(Request $request): JsonResponse
    {
        $sfuserId = $request->input('sfuser_info.id');
        $disableCache = $request->input('disable_cache', false);

        $issuedButNotCompleted = 0; // 我发起的（待审批、待冲账）的数目
        $toBeApprovedByMe = 0; // 待我审批数目
        $myApproval = 0; // 我的审批数目
        $cc2Me = 0; // 抄送我的并且未读的数目

        if ($disableCache) {    // 不走缓存
            $issuedButNotCompleted = (new StakeholderQueryBuilder(Registry::LOAN))->filterByRequesterIds($sfuserId)->notInTodoList()->asRequester()->unlocked()->count();
            $toBeApprovedByMe = (new ActionerQueryBuilder(Registry::LOAN))->filterByUserId($sfuserId)->toBeApproved()->actionStateNotIn(CommonState::REVERSAL_PENDING)->unlocked()->count();
            $cc2Me = (new StakeholderQueryBuilder(Registry::LOAN))->filterByUserId($sfuserId)->asCCer()->unread()->count();
        } else {                // 走缓存（默认）
            $data = NotifyNumberService::app()->getIndividual($sfuserId);
            $issuedButNotCompleted = $data['loan_issued'] ?? 0;
            $toBeApprovedByMe = $data['loan_to_be_approved'] ?? 0;
            $cc2Me = $data['loan_cc'] ?? 0;
        }

        // 查询个人数据
        $userData = CommonUserData::firstOrCreate(['sfuser_id' => $sfuserId], [
            'sfuser_id' => $sfuserId, 'to_be_approved_by_me' => 0, 'cc_to_me' => 0,
        ]);

        // 更新个人数据
        $update = [];
        if (!$userData->to_be_approved_by_me && $toBeApprovedByMe) {
            $update['to_be_approved_by_me'] = 1;
        }
        if (!$userData->cc_to_me && $cc2Me) {
            $update['cc_to_me'] = 1;
        }
        if (!empty($update)) {
            $userData->update($update);
        }

        // 如果从来没有过就不返回（待我审批、抄送给我）
        $ret = [
            'countingIssuedButNotCompleted' => $issuedButNotCompleted,
        ];
        if ($userData->to_be_approved_by_me) {
            $ret['countingToBeApprovedByMe'] = $toBeApprovedByMe;
        }
        if ($userData->cc_to_me) {
            $ret['countingCc2Me'] = $cc2Me;
        }
        $ret = ApprovalManagementController::dealLessThan0($ret);
        return $this->responseJsonSuccess($ret);
    }

