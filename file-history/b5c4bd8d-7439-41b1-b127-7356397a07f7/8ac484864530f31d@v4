// ---- 维度 9：并发请求 ----
async function testConcurrency() {
  console.log('\n🔀 9. 并发请求');

  const promises = Array.from({ length: 5 }, (_, i) =>
    GET(`/space/changeRecord/page?pageNum=${i + 1}&pageSize=5`, { 'X-Space-Id': CONFIG.spaceId })
  );
  const results = await Promise.all(promises);
  const allOk = results.every(r => r.success === true);
  assert('5个并发请求都成功', allOk);

  // 验证 total 一致
  const totals = results.map(r => r.data?.total);
  const allSameTotal = totals.every(t => t === totals[0]);
  assert('并发请求 total 一致', allSameTotal, totals);
}

// ---- 维度 10：响应结构一致性 ----
async function testResponseStructure() {
  console.log('\n📦 10. 响应结构一致性');

  const endpoints = [
    { name: '驾驶舱', path: `/space/changeRecord/page?pageNum=1&pageSize=5`, headers: { 'X-Space-Id': CONFIG.spaceId } },
    { name: '产品后台', path: `/management/space/changeRecord/page?spaceId=${CONFIG.spaceId}&pageNum=1&pageSize=5`, headers: {} },
  ];

  for (const ep of endpoints) {
    const res = await GET(ep.path, ep.headers);
    assert(`${ep.name} 含 pageNum`, typeof res.data?.pageNum === 'number', res.data?.pageNum);
    assert(`${ep.name} 含 pageSize`, typeof res.data?.pageSize === 'number', res.data?.pageSize);
    assert(`${ep.name} pageSize 与请求一致`, res.data?.pageSize === 5, res.data?.pageSize);
    assert(`${ep.name} 含 total`, typeof res.data?.total === 'number', res.data?.total);
    assert(`${ep.name} 含 records`, Array.isArray(res.data?.records), res.data?.records);
    assert(`${ep.name} records.length <= pageSize`, (res.data?.records?.length || 0) <= 5);
  }

  // 两个接口返回的数据应一致（同一个 spaceId、同一个 type）
  const cockpit = await GET(`/space/changeRecord/page?type=1&pageNum=1&pageSize=100`, { 'X-Space-Id': CONFIG.spaceId });
  const mgmt = await GET(`/management/space/changeRecord/page?spaceId=${CONFIG.spaceId}&type=1&pageNum=1&pageSize=100`);
  assert('两接口 type=1 total 一致',
    cockpit.data?.total === mgmt.data?.total,
    `cockpit=${cockpit.data?.total}, mgmt=${mgmt.data?.total}`);
}

// ---- 维度 11：排序验证 ----
async function testSortOrder() {
  console.log('\n📅 11. 排序验证（按时间倒序）');

  const res = await GET(`/space/changeRecord/page?pageNum=1&pageSize=50`, { 'X-Space-Id': CONFIG.spaceId });
  if (res.data?.records?.length > 1) {
    let isDesc = true;
    for (let i = 1; i < res.data.records.length; i++) {
      if (res.data.records[i].createdAt > res.data.records[i - 1].createdAt) {
        isDesc = false;
        break;
      }
    }
    assert('记录按 createdAt 倒序排列', isDesc);
  } else {
    console.log('  ⚠️  记录不足2条，排序验证跳过');
  }
}

// ---- 维度 12：description 内容验证 ----
async function testDescriptionContent() {
  console.log('\n📝 12. description 内容验证');

  const res = await GET(`/space/changeRecord/page?pageNum=1&pageSize=100`, { 'X-Space-Id': CONFIG.spaceId });
  if (res.data?.records?.length > 0) {
    for (const record of res.data.records.slice(0, 10)) {
      // description 非空
      assert(`记录 ${record.id} description 非空`, record.description?.length > 0, record.description);

      // description 包含操作人和被操作人名字
      assert(`记录 ${record.id} description 含操作人`,
        record.description?.includes(record.operatorName),
        `desc="${record.description}", operator="${record.operatorName}"`);
      assert(`记录 ${record.id} description 含被操作人`,
        record.description?.includes(record.targetUserName),
        `desc="${record.description}", target="${record.targetUserName}"`);

      // type=1 子管理员变更 description 应包含角色名
      if (record.type === 1) {
        const hasRole = record.description.includes('成员管理员')
          || record.description.includes('文件管理员')
          || record.description.includes('未知权限');
        assert(`子管理员记录 ${record.id} 含角色名`, hasRole, record.description);
      }

      // type=2 成员变更 description 应包含"空间站"
      if (record.type === 2) {
        assert(`成员记录 ${record.id} 含"空间站"`,
          record.description.includes('空间站'), record.description);
      }
    }
  } else {
    console.log('  ⚠️  变更记录为空，跳过');
  }
}

