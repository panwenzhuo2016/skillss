// ---- 维度 2：分页边界 ----
async function testPagination() {
  console.log('\n📐 2. 分页边界');

  // pageSize=1
  const p1 = await GET(`/space/changeRecord/page?pageNum=1&pageSize=1`, { 'X-Space-Id': CONFIG.spaceId });
  assert('pageSize=1 返回 success', p1.success === true, p1);
  assert('pageSize=1 最多返回1条', (p1.data?.records?.length || 0) <= 1);

  // pageSize=100
  const p100 = await GET(`/space/changeRecord/page?pageNum=1&pageSize=100`, { 'X-Space-Id': CONFIG.spaceId });
  assert('pageSize=100 返回 success', p100.success === true);

  // total 与 records 一致性
  if (p100.data?.total <= 100 && p100.data?.total > 0) {
    assert('total <= 100 时 length === total',
      p100.data.records.length === p100.data.total,
      `length=${p100.data.records.length}, total=${p100.data.total}`);
  }

  // 超出最后一页
  const overPage = await GET(`/space/changeRecord/page?pageNum=9999&pageSize=25`, { 'X-Space-Id': CONFIG.spaceId });
  assert('超页返回 success', overPage.success === true);
  assert('超页返回空列表', (overPage.data?.records?.length || 0) === 0);
  assert('超页 total 不变', overPage.data?.total === p100.data?.total,
    `overPage.total=${overPage.data?.total}, expected=${p100.data?.total}`);

  // 两页不重复
  if (p1.data?.total > 1) {
    const p2 = await GET(`/space/changeRecord/page?pageNum=2&pageSize=1`, { 'X-Space-Id': CONFIG.spaceId });
    assert('第2页有数据', (p2.data?.records?.length || 0) > 0);
    if (p1.data?.records?.[0] && p2.data?.records?.[0]) {
      assert('两页 ID 不重复', p1.data.records[0].id !== p2.data.records[0].id);
    }
  }

  // 不传分页参数用默认值
  const noPage = await GET(`/space/changeRecord/page`, { 'X-Space-Id': CONFIG.spaceId });
  assert('不传分页参数用默认值', noPage.success === true);
  assert('默认 pageSize=25', noPage.data?.pageSize === 25, noPage.data?.pageSize);
}

// ---- 维度 3：type 参数过滤 ----
async function testTypeFilter() {
  console.log('\n🔎 3. type 参数过滤');

  const all = await GET(`/space/changeRecord/page?pageNum=1&pageSize=100`, { 'X-Space-Id': CONFIG.spaceId });
  const t1 = await GET(`/space/changeRecord/page?type=1&pageNum=1&pageSize=100`, { 'X-Space-Id': CONFIG.spaceId });
  const t2 = await GET(`/space/changeRecord/page?type=2&pageNum=1&pageSize=100`, { 'X-Space-Id': CONFIG.spaceId });

  assert('type=1 total + type=2 total = 全部 total',
    (t1.data?.total || 0) + (t2.data?.total || 0) === (all.data?.total || 0),
    `t1=${t1.data?.total}, t2=${t2.data?.total}, all=${all.data?.total}`);

  // type=1 的结果中不应出现 type=2 的记录
  if (t1.data?.records?.length > 0) {
    const allType1 = t1.data.records.every(r => r.type === 1);
    assert('type=1 结果中只有 type=1 记录', allType1);
  }
  if (t2.data?.records?.length > 0) {
    const allType2 = t2.data.records.every(r => r.type === 2);
    assert('type=2 结果中只有 type=2 记录', allType2);
  }

  // 非法 type 值
  const t99 = await GET(`/space/changeRecord/page?type=99&pageNum=1&pageSize=25`, { 'X-Space-Id': CONFIG.spaceId });
  assert('type=99 返回 success（空结果）', t99.success === true, t99);
  assert('type=99 返回空列表', (t99.data?.records?.length || 0) === 0 || t99.data?.total === 0);
}

// ---- 维度 4：参数校验 ----
async function testParamValidation() {
  console.log('\n🔒 4. 参数校验');

  // 驾驶舱接口
  // 注：MyBatis-Plus Page 会自动校正非法页码（如 0→1），@Min(1) 在 GET POJO 绑定时不触发，
  // 这是项目全局行为而非本接口 bug
  const r1 = await GET(`/space/changeRecord/page?pageNum=0&pageSize=25`, { 'X-Space-Id': CONFIG.spaceId });
  assert('驾驶舱 pageNum=0 不报500', r1.code !== 500, r1);

