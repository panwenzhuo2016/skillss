// ========== HTTP 工具 ==========

function parseCookies(res) {
  const cookies = {};
  const setCookieHeaders = res.headers.getSetCookie?.() || [];
  for (const header of setCookieHeaders) {
    const [kv] = header.split(';');
    const eqIdx = kv.indexOf('=');
    if (eqIdx > 0) {
      cookies[kv.substring(0, eqIdx).trim()] = kv.substring(eqIdx + 1).trim();
    }
  }
  return cookies;
}

async function rawFetch(method, url, headers = {}, body) {
  const opts = { method, headers: { ...headers }, redirect: 'manual' };
  if (cookie) opts.headers['cookie'] = cookie;
  if (xsrfToken) opts.headers['x-xsrf-token'] = xsrfToken;
  if (body) {
    opts.headers['content-type'] = 'application/json';
    opts.body = JSON.stringify(body);
  }
  return fetch(url, opts);
}

async function GET(path, extraHeaders = {}) {
  const res = await rawFetch('GET', `${CONFIG.host}/api/v1${path}`, extraHeaders);
  return res.json();
}

async function POST(path, body, extraHeaders = {}) {
  const res = await rawFetch('POST', `${CONFIG.host}/api/v1${path}`, extraHeaders, body);
  return res.json();
}

async function rawGET(path, extraHeaders = {}) {
  return rawFetch('GET', `${CONFIG.host}/api/v1${path}`, extraHeaders);
}

// apitable API（通过 nginx 反代 /apitable/api/v1/...）
async function APITABLE_GET(path, extraHeaders = {}) {
  const res = await rawFetch('GET', `${CONFIG.host}/apitable/api/v1${path}`, extraHeaders);
  return res.json();
}

async function APITABLE_POST(path, body, extraHeaders = {}) {
  const res = await rawFetch('POST', `${CONFIG.host}/apitable/api/v1${path}`, extraHeaders, body);
  return res.json();
}

async function APITABLE_DELETE(path, extraHeaders = {}) {
  const res = await rawFetch('DELETE', `${CONFIG.host}/apitable/api/v1${path}`, extraHeaders);
  return res.json();
}

// ========== 登录管理 ==========

async function login(email) {
  const res = await fetch(`${CONFIG.host}/api/v1/testLogin/${encodeURIComponent(email)}`,
    { redirect: 'manual' });
  const cookies = parseCookies(res);
  // 收集所有 cookie
  const allCookies = (res.headers.getSetCookie?.() || [])
    .map(h => h.split(';')[0]).join('; ');
  if (cookies.JWT || cookies.SESSION || allCookies) {
    cookie = allCookies || (cookies.JWT ? `JWT=${cookies.JWT}` : `SESSION=${cookies.SESSION}`);
    xsrfToken = cookies['XSRF-TOKEN'] || '';
    return true;
  }
  return false;
}

let savedSessions = {};
function saveSession(name) {
  savedSessions[name] = { cookie, xsrfToken };
}
function restoreSession(name) {
  ({ cookie, xsrfToken } = savedSessions[name]);
}

