// ---- 维度 1：正常流程 ----
async function testBasicFlow() {
  console.log('📋 1. 基本流程 — 驾驶舱接口');

  // type=1 子管理员变更
  const r1 = await GET(`/space/changeRecord/page?type=1&pageNum=1&pageSize=25`, { 'X-Space-Id': CONFIG.spaceId });
  assert('type=1 返回 success', r1.success === true, r1);
  assert('type=1 data 不为 null', r1.data != null, r1.data);
  assert('type=1 包含 pageNum', typeof r1.data?.pageNum === 'number', r1.data?.pageNum);
  assert('type=1 包含 pageSize', typeof r1.data?.pageSize === 'number', r1.data?.pageSize);
  assert('type=1 包含 total', typeof r1.data?.total === 'number', r1.data?.total);
  assert('type=1 包含 records 数组', Array.isArray(r1.data?.records), r1.data?.records);

  // type=2 成员变更
  const r2 = await GET(`/space/changeRecord/page?type=2&pageNum=1&pageSize=25`, { 'X-Space-Id': CONFIG.spaceId });
  assert('type=2 返回 success', r2.success === true, r2);
  assert('type=2 包含 records 数组', Array.isArray(r2.data?.records), r2.data?.records);

  // 不传 type 查全部
  const r3 = await GET(`/space/changeRecord/page?pageNum=1&pageSize=25`, { 'X-Space-Id': CONFIG.spaceId });
  assert('不传 type 返回 success', r3.success === true, r3);
  assert('不传 type total >= type1+type2', r3.data?.total >= (r1.data?.total || 0), r3.data?.total);

  // 验证 records 字段结构
  if (r3.data?.records?.length > 0) {
    const first = r3.data.records[0];
    assert('记录含 id (string)', typeof first.id === 'string', first.id);
    assert('记录含 type (number)', typeof first.type === 'number', first.type);
    assert('记录含 action (string)', typeof first.action === 'string', first.action);
    assert('action 值为 ADD 或 REMOVE', ['ADD', 'REMOVE'].includes(first.action), first.action);
    assert('记录含 operatorName (string)', typeof first.operatorName === 'string', first.operatorName);
    assert('记录含 targetUserName (string)', typeof first.targetUserName === 'string', first.targetUserName);
    assert('记录含 description (string)', typeof first.description === 'string', first.description);
    assert('记录含 createdAt (string)', typeof first.createdAt === 'string', first.createdAt);
    assert('createdAt 格式正确 yyyy-MM-dd HH:mm:ss',
      /^\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}$/.test(first.createdAt), first.createdAt);
  } else {
    console.log('  ⚠️  变更记录为空，字段结构验证跳过（表中暂无数据）');
  }
}

