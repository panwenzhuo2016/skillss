// ---- 维度 9：并发请求 ----
async function testConcurrency() {
  console.log('\n🔀 9. 并发请求');

  const promises = Array.from({ length: 5 }, (_, i) =>
    GET(`/space/changeRecord/page?pageNum=${i + 1}&pageSize=5`, { 'X-Space-Id': CONFIG.spaceId })
  );
  const results = await Promise.all(promises);
  const allOk = results.every(r => r.success === true);
  assert('5个并发请求都成功', allOk);

  // 验证 total 一致
  const totals = results.map(r => r.data?.total);
  const allSameTotal = totals.every(t => t === totals[0]);
  assert('并发请求 total 一致', allSameTotal, totals);
}

