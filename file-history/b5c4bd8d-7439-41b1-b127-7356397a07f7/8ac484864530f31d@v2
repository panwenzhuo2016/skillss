  assert('驾驶舱 pageNum=-1 不报500', r2.code !== 500, r2);

  const r3 = await GET(`/space/changeRecord/page?pageNum=1&pageSize=0`, { 'X-Space-Id': CONFIG.spaceId });
  assert('驾驶舱 pageSize=0 返回错误或校正', r3.success === false || r3.data?.pageSize > 0, r3);

  const r4 = await GET(`/space/changeRecord/page?pageNum=1&pageSize=-1`, { 'X-Space-Id': CONFIG.spaceId });
  assert('驾驶舱 pageSize=-1 不报500', r4.code !== 500, r4);

  // 产品后台接口
  const r5 = await GET(`/management/space/changeRecord/page?spaceId=${CONFIG.spaceId}&pageNum=0&pageSize=25`);
  assert('后台 pageNum=0 不报500', r5.code !== 500, r5);

  const r6 = await GET(`/management/space/changeRecord/page?spaceId=${CONFIG.spaceId}&pageNum=1&pageSize=0`);
  assert('后台 pageSize=0 返回错误或校正', r6.success === false || r6.data?.pageSize > 0, r6);
}

// ---- 维度 5：特殊字符与注入防护 ----
async function testInjection() {
  console.log('\n🛡️ 5. 注入防护 + 特殊字符');

  // spaceId 注入尝试
  const injections = [
    "' OR 1=1 --",
    "1; DROP TABLE collabspace_space_change_record;",
    "' UNION SELECT * FROM collabspace_space --",
    "<script>alert(1)</script>",
  ];
  for (const payload of injections) {
    const res = await GET(`/space/changeRecord/page?pageNum=1&pageSize=25`, { 'X-Space-Id': payload });
    assert(`spaceId 注入 "${payload.slice(0, 30)}" 不报500`,
      res.code !== 500, res);
  }

  // 产品后台 spaceId 注入
  for (const payload of injections) {
    const res = await GET(`/management/space/changeRecord/page?spaceId=${encodeURIComponent(payload)}&pageNum=1&pageSize=25`);
    assert(`后台 spaceId 注入 "${payload.slice(0, 30)}" 不报500`,
      res.code !== 500, res);
  }

  // type 参数非数字（Spring 类型转换失败返回 400 或 500 取决于全局异常配置）
  const rStr = await GET(`/space/changeRecord/page?type=abc&pageNum=1&pageSize=25`, { 'X-Space-Id': CONFIG.spaceId });
  assert('type=abc 返回错误', rStr.success === false, rStr);
}

