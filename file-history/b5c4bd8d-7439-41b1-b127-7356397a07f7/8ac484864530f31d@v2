// ---- 维度 12：description 内容验证 ----
async function testDescriptionContent() {
  console.log('\n📝 12. description 内容验证');

  const res = await GET(`/space/changeRecord/page?pageNum=1&pageSize=100`, { 'X-Space-Id': CONFIG.spaceId });
  if (res.data?.records?.length > 0) {
    for (const record of res.data.records.slice(0, 10)) {
      // description 非空
      assert(`记录 ${record.id} description 非空`, record.description?.length > 0, record.description);

      // description 包含操作人和被操作人名字
      assert(`记录 ${record.id} description 含操作人`,
        record.description?.includes(record.operatorName),
        `desc="${record.description}", operator="${record.operatorName}"`);
      assert(`记录 ${record.id} description 含被操作人`,
        record.description?.includes(record.targetUserName),
        `desc="${record.description}", target="${record.targetUserName}"`);

      // type=1 子管理员变更 description 应包含角色名
      if (record.type === 1) {
        const hasRole = record.description.includes('成员管理员')
          || record.description.includes('文件管理员')
          || record.description.includes('未知权限');
        assert(`子管理员记录 ${record.id} 含角色名`, hasRole, record.description);
      }

      // type=2 成员变更 description 应包含"空间站"
      if (record.type === 2) {
        assert(`成员记录 ${record.id} 含"空间站"`,
          record.description.includes('空间站'), record.description);
      }
    }
  } else {
    console.log('  ⚠️  变更记录为空，跳过');
  }
}

